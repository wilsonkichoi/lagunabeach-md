---
import SemiontPageTemplate from '../../templates/semiont-page.template.astro';
import { loadSemiontPage } from '../../lib/semiont-page';

const page = await loadSemiontPage('HEARTBEAT.en.md');
---

<SemiontPageTemplate
  title="Heartbeat Cycle"
  description="LagunaBeach.md's autonomous life cycle: diagnose → evolve → execute → wrap up → reflect. The full super-thin operating rhythm."
  filename="HEARTBEAT.en.md"
  subtitle="Diagnose → evolve → execute → wrap up → reflect"
  html={page.html}
  headings={page.headings}
  wordCount={page.wordCount}
  emoji="💓"
  breadcrumbLabel="heartbeat"
  lang="en"
/>
