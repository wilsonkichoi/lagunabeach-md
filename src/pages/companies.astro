      >
        <table>
          <thead>
            <tr>
              <th>#</th>
              <th>企業</th>
              <th>產業</th>
              <th>市值（億 TWD）</th>
              <th>營收（億 TWD）</th>
              <th>員工數</th>
              <th>成立</th>
            </tr>
          </thead>
          <tbody>
            {
              companies.map((c, i) => (
                <tr>
                  <td>{i + 1}</td>
                  <td>
                    <strong>{c.name}</strong>
                  </td>
                  <td>
                    <span
                      class="inline-block whitespace-nowrap rounded-[10px] px-2 py-[0.15rem] text-[0.75rem] font-medium"
                      style={`background: ${sectorColors[c.sector] || '#888'}20; color: ${sectorColors[c.sector] || '#888'}; border: 1px solid ${sectorColors[c.sector] || '#888'}40`}
                    >
                      {c.sector}
                    </span>
                  </td>
                  <td>{c.marketCap.toLocaleString()}</td>
                  <td>{c.revenue.toLocaleString()}</td>
                  <td>{c.employees.toLocaleString()}</td>
                  <td>{c.founded}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </div>

    <div class="mt-12">
      <h2 class="mb-4">🔍 關鍵洞察</h2>
      <div
        class="grid grid-cols-[repeat(auto-fit,minmax(220px,1fr))] gap-4 max-[768px]:grid-cols-2"
      >
        <div
          class="rounded-xl border border-[#eee] bg-[#f8f9fa] p-6 text-center"
