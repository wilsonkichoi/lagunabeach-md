      </div>
    </div>

    <div
      id="bubble-chart"
      class="relative mb-8 min-h-[600px] w-full overflow-hidden rounded-xl border border-[#eee] bg-[#fafafa] max-[768px]:min-h-[400px] [&_svg]:block"
    >
    </div>

    <div class="mt-8">
      <h2 class="mb-4">📋 完整排名</h2>
      <div
