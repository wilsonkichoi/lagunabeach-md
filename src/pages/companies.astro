          <div class="mt-[0.3rem] font-semibold">前 50 大佔台股總市值</div>
          <div class="mt-[0.3rem] text-[0.8rem] text-[#888]">
            台灣股市高度集中於大型企業
          </div>
        </div>
        <div
          class="rounded-xl border border-[#eee] bg-[#f8f9fa] p-6 text-center"
        >
          <div class="text-[2rem] font-extrabold text-[#2563eb]">12 家</div>
          <div class="mt-[0.3rem] font-semibold">半導體相關企業入榜</div>
          <div class="mt-[0.3rem] text-[0.8rem] text-[#888]">
            印證「矽盾」之名——半導體是台灣的國防
          </div>
        </div>
        <div
          class="rounded-xl border border-[#eee] bg-[#f8f9fa] p-6 text-center"
        >
          <div class="text-[2rem] font-extrabold text-[#2563eb]">9 家</div>
          <div class="mt-[0.3rem] font-semibold">金融業入榜前 50</div>
          <div class="mt-[0.3rem] text-[0.8rem] text-[#888]">
            金控整併後，金融業成為穩定力量
          </div>
        </div>
      </div>
    </div>

    <div
      class="mt-12 rounded-xl border border-[#eee] bg-[#f8f9fa] p-6 text-[0.9rem] leading-[1.7] [&_a]:text-[#2563eb] [&_h2]:mb-2"
    >
      <h2>📝 說明</h2>
      <p>
        本圖表收錄台灣市值前 50
        大企業（含少數未上市重要企業如長春石化、奇美實業）， 市值與營收為 2025
        年度近似值，僅供趨勢參考，不構成投資建議。 完整即時數據請查閱
        <a href="https://www.twse.com.tw/" target="_blank" rel="noopener"
          >臺灣證券交易所</a
        >。
      </p>
      <p>
        📖 延伸閱讀：
        <a href="/economy/經濟奇蹟">台灣經濟奇蹟</a> ｜
        <a href="/economy/新創生態系">新創生態系</a> ｜
        <a href="/economy/台灣金融科技發展">金融科技發展</a>
      </p>
    </div>
  </main>

  <script define:vars={{ companies, sectorColors }}>
    const data = companies;
    const colors = sectorColors;

    const script = document.createElement('script');
    script.src = 'https://d3js.org/d3.v7.min.js';
    script.onload = () => initBubbleChart(data, colors);
    document.head.appendChild(script);

    function initBubbleChart(data, colors) {
      const container = document.getElementById('bubble-chart');
      const width = container.clientWidth;
      const height = Math.max(600, window.innerHeight * 0.6);

      let currentMode = 'marketCap';
      let currentSector = 'all';

      const svg = d3
        .select('#bubble-chart')
        .append('svg')
        .attr('width', width)
        .attr('height', height)
        .attr('viewBox', `0 0 ${width} ${height}`);

      const tooltip = d3
        .select('#bubble-chart')
        .append('div')
        // Tailwind utility string — the D3-created tooltip is
        // styled directly here instead of via a :global() rule
        .attr(
          'class',
          'pointer-events-none absolute z-[100] max-w-[280px] rounded-lg bg-black/85 px-3 py-[10px] text-[0.85rem] leading-[1.5] text-white',
        )
        .style('opacity', 0);

      function getValue(d) {
        return d[currentMode] || 0;
      }

      function getRadius(d) {
        const val = getValue(d);
        const maxVal = d3.max(data, getValue);
        const minR = 18;
        const maxR = Math.min(width, height) * 0.18;
        return minR + (maxR - minR) * Math.sqrt(val / maxVal);
      }

      const simulation = d3
        .forceSimulation(data)
        .force('center', d3.forceCenter(width / 2, height / 2))
        .force('charge', d3.forceManyBody().strength(5))
        .force(
          'collision',
          d3
            .forceCollide()
            .radius((d) => getRadius(d) + 2)
            .strength(0.8),
        )
        .force('x', d3.forceX(width / 2).strength(0.05))
        .force('y', d3.forceY(height / 2).strength(0.05));

      const nodes = svg
        .selectAll('g.node')
        .data(data)
        .join('g')
        .attr('class', 'node')
        .call(
          d3
            .drag()
            .on('start', (e, d) => {
              if (!e.active) simulation.alphaTarget(0.3).restart();
              d.fx = d.x;
              d.fy = d.y;
            })
            .on('drag', (e, d) => {
              d.fx = e.x;
              d.fy = e.y;
            })
            .on('end', (e, d) => {
              if (!e.active) simulation.alphaTarget(0);
              d.fx = null;
              d.fy = null;
            }),
        );

      const circles = nodes
        .append('circle')
        .attr('r', (d) => getRadius(d))
        .attr('fill', (d) => colors[d.sector] || '#888')
        .attr('fill-opacity', 0.8)
        .attr('stroke', (d) => colors[d.sector] || '#888')
        .attr('stroke-width', 2)
        .attr('stroke-opacity', 0.3)
        .style('cursor', 'grab');

      const labels = nodes
        .append('text')
        .attr('text-anchor', 'middle')
        .attr('dominant-baseline', 'central')
        .attr('fill', '#fff')
        .attr('font-weight', '600')
        .attr('pointer-events', 'none')
        .each(function (d) {
          const r = getRadius(d);
          const el = d3.select(this);
          const shortName = d.name.split(' ')[0];
          if (r > 50) {
            el.append('tspan')
              .attr('x', 0)
              .attr('dy', '-0.4em')
              .attr('font-size', `${Math.min(14, r / 4)}px`)
              .text(shortName);
            el.append('tspan')
              .attr('x', 0)
              .attr('dy', '1.3em')
              .attr('font-size', `${Math.min(11, r / 5)}px`)
              .attr('fill-opacity', 0.8)
              .text(d.marketCap.toLocaleString() + ' 億');
          } else if (r > 28) {
            el.attr('font-size', `${Math.min(11, r / 3.5)}px`).text(shortName);
          } else {
            el.attr('font-size', '9px').text(shortName.slice(0, 2));
          }
        });

      nodes
        .on('mouseover', (e, d) => {
          const modeLabel = {
            marketCap: '市值',
            revenue: '營收',
            employees: '員工數',
          };
          tooltip.transition().duration(200).style('opacity', 1);
          tooltip
            .html(
              `
            <strong>${d.name}</strong><br/>
            <span style="color:${colors[d.sector] || '#888'}">● ${d.sector}</span><br/>
            市值：${d.marketCap.toLocaleString()} 億 TWD<br/>
            營收：${d.revenue.toLocaleString()} 億 TWD<br/>
            員工：${d.employees.toLocaleString()} 人<br/>
            成立：${d.founded} 年
          `,
            )
            .style('left', e.pageX + 15 + 'px')
            .style('top', e.pageY - 10 + 'px');
          d3.select(e.currentTarget)
            .select('circle')
            .attr('fill-opacity', 1)
            .attr('stroke-width', 3);
        })
        .on('mouseout', (e) => {
          tooltip.transition().duration(300).style('opacity', 0);
          d3.select(e.currentTarget)
            .select('circle')
            .attr('fill-opacity', 0.8)
            .attr('stroke-width', 2);
        });

      simulation.on('tick', () => {
        nodes.attr('transform', (d) => {
          d.x = Math.max(getRadius(d), Math.min(width - getRadius(d), d.x));
          d.y = Math.max(getRadius(d), Math.min(height - getRadius(d), d.y));
          return `translate(${d.x},${d.y})`;
        });
      });

      // Toggle size mode
      document.querySelectorAll('.toggle-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          document
            .querySelectorAll('.toggle-btn')
            .forEach((b) => b.classList.remove('active'));
          btn.classList.add('active');
          currentMode = btn.dataset.mode;
          updateBubbles();
        });
      });

      // Sector filter
      document.querySelectorAll('.sector-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          document
            .querySelectorAll('.sector-btn')
            .forEach((b) => b.classList.remove('active'));
          btn.classList.add('active');
          currentSector = btn.dataset.sector;
          updateBubbles();
        });
      });

      function updateBubbles() {
        circles
          .transition()
          .duration(600)
          .attr('r', (d) => {
            if (currentSector !== 'all' && d.sector !== currentSector) return 0;
            return getRadius(d);
          })
          .attr('fill-opacity', (d) => {
            if (currentSector !== 'all' && d.sector !== currentSector) return 0;
            return 0.8;
          });

        labels
          .transition()
          .duration(600)
          .attr('fill-opacity', (d) => {
            if (currentSector !== 'all' && d.sector !== currentSector) return 0;
            return 1;
          });

        simulation
          .force(
            'collision',
            d3
              .forceCollide()
              .radius((d) => {
                if (currentSector !== 'all' && d.sector !== currentSector)
                  return 0;
                return getRadius(d) + 2;
              })
              .strength(0.8),
          )
          .alpha(0.6)
          .restart();
      }
    }
  </script>
</Layout>
