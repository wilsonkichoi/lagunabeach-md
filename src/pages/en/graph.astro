---
import Layout from '../../layouts/Layout.astro';
import { readdir, readFile } from 'fs/promises';
import { resolve, join } from 'path';

const categories = [
  'history',
  'art-galleries',
  'nature-marine-life',
  'food',
  'beaches',
  'trails',
  'events-festivals',
  'neighborhoods',
];

const categoryColors: Record<string, string> = {
  history: '#e74c3c',
  'art-galleries': '#e91e63',
  'nature-marine-life': '#27ae60',
  food: '#f39c12',
  beaches: '#3498db',
  trails: '#8bc34a',
  'events-festivals': '#9b59b6',
  neighborhoods: '#607d8b',
};

const categoryNames: Record<string, string> = {
  history: '📜 History',
  'art-galleries': '🎨 Art & Galleries',
  'nature-marine-life': '🌊 Nature & Marine Life',
  food: '🍽️ Food',
  beaches: '🏖️ Beaches',
  trails: '🥾 Trails',
  'events-festivals': '🎭 Events & Festivals',
  neighborhoods: '🏘️ Neighborhoods',
};

// Build nodes and edges
const nodes: any[] = [];
const edges: any[] = [];
const tagMap: Record<string, string[]> = {};

let allZhArticles: any[] = [];
let allEnArticles: any[] = [];
{
  try {
    for (const cat of categories) {
      const catDir = resolve('src/content/zh-TW', cat);
      try {
        const files = await readdir(catDir);
        for (const file of files) {
          if (file.endsWith('.md') && !file.startsWith('_')) {
            const slug = file.replace(/\.md$/, '');
            const content = await readFile(join(catDir, file), 'utf-8');
            const titleMatch = content.match(/^title:\s*["']?(.+?)["']?\s*$/m);
            const tagsMatch = content.match(/^tags:\s*\[(.+?)\]/m);
            const title = titleMatch ? titleMatch[1] : slug;
            const tags = tagsMatch
              ? tagsMatch[1]
                  .split(',')
                  .map((t) => t.trim().replace(/["']/g, ''))
              : [];
            allZhArticles.push({ id: `${cat}/${slug}`, data: { title, tags } });
          }
        }
      } catch {}
    }
  } catch {}
}
{
  try {
    for (const cat of categories) {
      const catDir = resolve('src/content/en', cat);
      try {
        const files = await readdir(catDir);
        for (const file of files) {
          if (file.endsWith('.md') && !file.startsWith('_')) {
            const slug = file.replace(/\.md$/, '');
            const content = await readFile(join(catDir, file), 'utf-8');
            const titleMatch = content.match(/^title:\s*["']?(.+?)["']?\s*$/m);
            const title = titleMatch ? titleMatch[1] : slug;
            allEnArticles.push({
              id: `${cat}/${slug}`,
              data: { title, tags: [] },
            });
          }
        }
      } catch {}
    }
  } catch {}
}

// Center node
nodes.push({
  id: 'lagunabeach',
  label: '🌊 LagunaBeach.md',
  group: 'center',
  size: 30,
});

// SSOT concept node
nodes.push({
  id: 'ssot',
  label: '📐 SSOT\n(Single Source of Truth)',
  group: 'meta',
  color: '#8b5cf6',
  size: 16,
});
edges.push({ source: 'lagunabeach', target: 'ssot' });

// Special nodes
nodes.push({
  id: 'about',
  label: '📖 About',
  group: 'special',
  color: '#6366f1',
  size: 14,
  url: '/en/about',
});
nodes.push({
  id: 'contribute',
  label: '✋ Contribute',
  group: 'special',
  color: '#22c55e',
  size: 14,
  url: '/en/contribute',
});
nodes.push({
  id: 'quotes',
  label: '✨ Community\nQuotes',
  group: 'special',
  color: '#f59e0b',
  size: 12,
  url: '/en/about',
});
nodes.push({
  id: 'editorial',
  label: '📋 Editorial\nGuidelines',
  group: 'meta',
  color: '#8b5cf6',
  size: 10,
});
nodes.push({
  id: 'llms',
  label: '🤖 AI-Friendly\n(llms.txt)',
  group: 'meta',
  color: '#8b5cf6',
  size: 10,
});
edges.push({ source: 'lagunabeach', target: 'about' });
edges.push({ source: 'lagunabeach', target: 'contribute' });
edges.push({ source: 'about', target: 'quotes' });
edges.push({ source: 'ssot', target: 'editorial' });
edges.push({ source: 'ssot', target: 'llms' });
// SSOT connects to all categories
for (const cat of categories) {
  edges.push({ source: 'ssot', target: cat });
}

for (const cat of categories) {
  // Category node
  nodes.push({
    id: cat,
    label: categoryNames[cat] || cat,
    group: cat,
    color: categoryColors[cat],
    size: 20,
    url: `/en/${cat}`,
  });
  edges.push({ source: 'lagunabeach', target: cat });

  // Chinese article nodes
  const catArticles = allZhArticles.filter((a) => {
    const parts = a.id.split('/');
    return parts[0] === cat && !parts[parts.length - 1].startsWith('_');
  });
  for (const article of catArticles) {
    const slug = article.id.split('/').slice(1).join('/').replace(/\.md$/, '');
    const nodeId = `${cat}/${slug}`;
    nodes.push({
      id: nodeId,
      label: article.data.title,
      group: cat,
      color: categoryColors[cat],
      size: 10,
      url: `/${cat}/${encodeURIComponent(slug)}`,
    });
    edges.push({ source: cat, target: nodeId });

    // Build tag connections
    if (article.data.tags) {
      for (const tag of article.data.tags) {
        if (!tagMap[tag]) tagMap[tag] = [];
        tagMap[tag].push(nodeId);
      }
    }
  }

  // English article nodes
  const enCatArticles = allEnArticles.filter((a) => {
    const parts = a.id.split('/');
    return parts[0] === cat && !parts[parts.length - 1].startsWith('_');
  });
  for (const article of enCatArticles) {
    const slug = article.id.split('/').slice(1).join('/').replace(/\.md$/, '');
    const nodeId = `en/${cat}/${slug}`;
    nodes.push({
      id: nodeId,
      label: `🌐 ${article.data.title}`,
      group: cat,
      color: categoryColors[cat],
      size: 8,
      url: `/en/${cat}/${slug}`,
    });
    edges.push({ source: cat, target: nodeId });
  }
}

// Cross-category edges via shared tags
for (const [tag, articleIds] of Object.entries(tagMap)) {
  if (articleIds.length >= 2) {
    for (let i = 0; i < articleIds.length - 1; i++) {
      for (let j = i + 1; j < articleIds.length; j++) {
        const catA = articleIds[i].split('/')[0];
        const catB = articleIds[j].split('/')[0];
        if (catA !== catB) {
          edges.push({ source: articleIds[i], target: articleIds[j] });
        }
      }
    }
  }
}

// Parse Hub wikilinks to create Hub→article edges
const categoryMapping: Record<string, string> = {
  history: 'History',
  'art-galleries': 'Art & Galleries',
  'nature-marine-life': 'Nature & Marine Life',
  food: 'Food',
  beaches: 'Beaches',
  trails: 'Trails',
  'events-festivals': 'Events & Festivals',
  neighborhoods: 'Neighborhoods',
};
const nodeIds = new Set(nodes.map((n) => n.id));

for (const [cat, folder] of Object.entries(categoryMapping)) {
  try {
    const hubDir = resolve(process.cwd(), 'knowledge', folder);
    const files = await readdir(hubDir);
    const hubFile = files.find((f) => f.startsWith('_') && f.includes('Hub'));
    if (hubFile) {
      const content = await readFile(join(hubDir, hubFile), 'utf-8');
      const wikilinks =
        content.match(/\[\[([^\]|]+?)(?:\|[^\]]+?)?\]\]/g) || [];
      for (const wl of wikilinks) {
        const target = wl
          .replace(/\[\[/, '')
          .replace(/\]\]/, '')
          .split('|')[0]
          .trim();
        const matchNode = nodes.find(
          (n) =>
            n.label === target ||
            n.label === `🌐 ${target}` ||
            n.id === `${cat}/${target}` ||
            n.id === `${cat}/${encodeURIComponent(target)}`,
        );
        if (matchNode && matchNode.id !== cat) {
          const exists = edges.some(
            (e) =>
              (e.source === cat && e.target === matchNode.id) ||
              (e.source === matchNode.id && e.target === cat),
          );
          if (!exists) {
            edges.push({ source: cat, target: matchNode.id });
          }
        }
        if (!matchNode) {
          for (const [otherCat] of Object.entries(categoryMapping)) {
            if (otherCat === cat) continue;
            const crossNode = nodes.find(
              (n) => n.label === target && n.group === otherCat,
            );
            if (crossNode) {
              edges.push({ source: cat, target: crossNode.id });
              break;
            }
          }
        }
      }
    }
  } catch {}
}

const graphData = JSON.stringify({ nodes, edges });
---

<!--
  Phase 6 page migration #7: en/graph.astro
  ─────────────────────────────────────────
  Mirrors graph.astro (zh-TW) except: simpler header layout (no
  max-[768px]: wrap), an extra ← Home link, no .graph-header p
  max-width. Same `.graph-page` hook kept for global.css base rule.
-->
<Layout
  title="🕸️ Knowledge Graph — LagunaBeach.md"
  description="All knowledge nodes and connections on LagunaBeach.md"
  lang="en"
>
  <main class="graph-page flex h-screen flex-col">
    <div class="flex items-center gap-8 bg-[#1a1a2e] px-8 py-4 text-white">
      <h1 class="m-0 whitespace-nowrap text-[1.3rem]">🕸️ Knowledge Graph</h1>
      <p class="m-0 text-[0.9rem] opacity-70">
        All knowledge nodes and connections on LagunaBeach.md
      </p>
      <div class="ml-auto flex items-center gap-2">
        <input
          id="graph-search"
          type="text"
          placeholder="🔍 Search nodes..."
          autocomplete="off"
          class="w-[200px] rounded-md border border-white/30 bg-white/10 px-[0.8rem] py-[0.4rem] text-[0.9rem] text-white outline-none transition-colors duration-200 placeholder:text-white/50 focus:border-[#3b82f6] focus:bg-white/15"
        />
        <span
          id="search-count"
          class="whitespace-nowrap text-[0.8rem] text-white/70"></span>
      </div>
      <a href="/en" class="text-[0.9rem] text-[#3b82f6] no-underline"
        >&larr; Home</a
      >
    </div>
    <div id="graph-container" class="flex-1 overflow-hidden bg-[#fafafa]"></div>
    <div
      id="tooltip"
      class="pointer-events-none absolute z-[100] hidden rounded-md bg-[rgba(26,26,46,0.9)] px-[0.8rem] py-[0.4rem] text-[0.85rem] text-white"
    >
    </div>
  </main>
</Layout>

<script define:vars={{ graphData }}>
  const data = JSON.parse(graphData);

  const script = document.createElement('script');
  script.src = 'https://d3js.org/d3.v7.min.js';
  script.onload = () => initGraph(data);
  document.head.appendChild(script);

  function initGraph(data) {
    const container = document.getElementById('graph-container');
    const width = container.clientWidth;
    const height = container.clientHeight;

    const svg = d3
      .select('#graph-container')
      .append('svg')
      .attr('width', width)
      .attr('height', height);

    const g = svg.append('g');

    svg.call(
      d3.zoom().on('zoom', (event) => {
        g.attr('transform', event.transform);
      }),
    );

    // ── Hover neighbour map (id → Set of directly-connected ids), built from
    // raw edge ids before forceLink mutates source/target into node objects. ──
    const neighbours = new Map();
    const addAdj = (a, b) => {
      if (!neighbours.has(a)) neighbours.set(a, new Set());
      neighbours.get(a).add(b);
    };
    for (const e of data.edges) {
      const s = typeof e.source === 'object' ? e.source.id : e.source;
      const t = typeof e.target === 'object' ? e.target.id : e.target;
      if (s != null && t != null) {
        addAdj(s, t);
        addAdj(t, s);
      }
    }

    const simulation = d3
      .forceSimulation(data.nodes)
      .alphaDecay(0.045)
      .force(
        'link',
        d3
          .forceLink(data.edges)
          .id((d) => d.id)
          .distance((d) => {
            if (d.source.id === 'lagunabeach') return 150;
            return 80;
          }),
      )
      .force('charge', d3.forceManyBody().strength(-400))
      .force('center', d3.forceCenter(width / 2, height / 2))
      .force(
        'collision',
        d3.forceCollide().radius((d) => d.size + 5),
      );

    const link = g
      .append('g')
      .selectAll('line')
      .data(data.edges)
      .join('line')
      .attr('stroke', '#ddd')
      .attr('stroke-width', 1)
      .attr('stroke-opacity', 0.6);

    const node = g
      .append('g')
      .selectAll('circle')
      .data(data.nodes)
      .join('circle')
      .attr('r', (d) => d.size)
      .attr(
        'fill',
        (d) => d.color || (d.group === 'center' ? '#1a1a2e' : '#ccc'),
      )
      .attr('stroke', '#fff')
      .attr('stroke-width', 2)
      .attr('cursor', 'pointer')
      .call(
        d3
          .drag()
          .on('start', (event, d) => {
            if (!event.active) simulation.alphaTarget(0.3).restart();
            d.fx = d.x;
            d.fy = d.y;
          })
          .on('drag', (event, d) => {
            d.fx = event.x;
            d.fy = event.y;
          })
          .on('end', (event, d) => {
            if (!event.active) simulation.alphaTarget(0);
            d.fx = null;
            d.fy = null;
          }),
      );

    const label = g
      .append('g')
      .selectAll('text')
      .data(data.nodes)
      .join('text')
      .text((d) =>
        typeof d.label === 'string'
          ? d.label.split(/[：:]/)[0].trim()
          : d.label,
      )
      .attr('font-size', (d) => {
        if (d.group === 'center') return '16px';
        if (d.size >= 15) return '13px';
        return '10px';
      })
      .attr('font-weight', (d) => (d.size > 15 ? 'bold' : 'normal'))
      .attr('text-anchor', 'middle')
      .attr('dy', (d) => d.size + 14)
      .attr('fill', '#333')
      .attr('stroke', 'rgba(255,255,255,0.92)')
      .attr('stroke-width', 3)
      .attr('paint-order', 'stroke')
      .attr('stroke-linejoin', 'round')
      .attr('pointer-events', 'none');

    node.on('click', (event, d) => {
      if (d.url) window.location.href = d.url;
    });

    const tooltip = document.getElementById('tooltip');
    const endId = (v) => (typeof v === 'object' ? v.id : v);
    function resetFocus() {
      link.attr('stroke', '#ddd');
      // Restore the active search state if one is set, else full opacity.
      if (searchInput && searchInput.value.trim()) {
        searchInput.dispatchEvent(new Event('input'));
        return;
      }
      node.attr('opacity', 1).attr('stroke', '#fff').attr('stroke-width', 2);
      label.attr('opacity', 1);
      link.attr('stroke-opacity', 0.6);
    }
    node
      .on('mouseover', (event, d) => {
        tooltip.textContent = d.label;
        tooltip.style.display = 'block';
        tooltip.style.left = event.pageX + 10 + 'px';
        tooltip.style.top = event.pageY - 10 + 'px';
        // Focus: hovered node + its neighbours stay opaque; fade the rest and
        // highlight the connecting links.
        const keep = new Set([d.id, ...(neighbours.get(d.id) || [])]);
        node.attr('opacity', (n) => (keep.has(n.id) ? 1 : 0.1));
        label.attr('opacity', (n) => (keep.has(n.id) ? 1 : 0.08));
        link
          .attr('stroke-opacity', (l) =>
            endId(l.source) === d.id || endId(l.target) === d.id ? 0.85 : 0.02,
          )
          .attr('stroke', (l) =>
            endId(l.source) === d.id || endId(l.target) === d.id
              ? '#2563eb'
              : '#ddd',
          );
        d3.select(event.target)
          .attr('stroke', '#3b82f6')
          .attr('stroke-width', 3);
      })
      .on('mouseout', () => {
        tooltip.style.display = 'none';
        resetFocus();
      });

    simulation.on('tick', () => {
      link
        .attr('x1', (d) => d.source.x)
        .attr('y1', (d) => d.source.y)
        .attr('x2', (d) => d.target.x)
        .attr('y2', (d) => d.target.y);
      node.attr('cx', (d) => d.x).attr('cy', (d) => d.y);
      label.attr('x', (d) => d.x).attr('y', (d) => d.y);
    });

    // Search / filter
    const searchInput = document.getElementById('graph-search');
    const searchCount = document.getElementById('search-count');
    searchInput.addEventListener('input', () => {
      const query = searchInput.value.trim().toLowerCase();
      if (!query) {
        node.attr('opacity', 1);
        label.attr('opacity', 1);
        link.attr('stroke-opacity', 0.6);
        searchCount.textContent = '';
        return;
      }
      const matched = new Set();
      data.nodes.forEach((n) => {
        if (
          n.label.toLowerCase().includes(query) ||
          n.id.toLowerCase().includes(query)
        ) {
          matched.add(n.id);
        }
      });
      searchCount.textContent = matched.size + ' results';
      node.attr('opacity', (d) => (matched.has(d.id) ? 1 : 0.08));
      label.attr('opacity', (d) => (matched.has(d.id) ? 1 : 0.08));
      link.attr('stroke-opacity', (d) => {
        const sid = typeof d.source === 'object' ? d.source.id : d.source;
        const tid = typeof d.target === 'object' ? d.target.id : d.target;
        return matched.has(sid) && matched.has(tid) ? 0.6 : 0.03;
      });
    });
  }
</script>
