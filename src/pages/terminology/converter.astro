---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
import { readdir, readFile } from 'fs/promises';
import { resolve, join } from 'path';
import { parse as parseYaml } from 'yaml';
import { createRequire } from 'module';

// ── Build-time: s2t + t2s converters for both directions ──────────────────────
// to.tw is character-variant only (TWVariants — 裡/裏 etc.), not phrase-aware,
// so 「视频」→「視頻」 (chars only). Phrase substitution would silently
// replace 「视频」→「影片」 directly, killing detection — so we deliberately
// stick to to.tw (not to.twp).
let s2tConverter: ((text: string) => string) | null = null;
let t2sConverter: ((text: string) => string) | null = null;
try {
  const require = createRequire(import.meta.url);
  const OpenCC = require('opencc-js');
  s2tConverter = OpenCC.Converter({ from: 'cn', to: 'tw' });
  t2sConverter = OpenCC.Converter({ from: 'tw', to: 'cn' });
} catch {
  console.warn(
    '[converter.astro] opencc-js not available, china values may not match simplified input',
  );
}

function toTraditional(text: string): string {
  if (!s2tConverter) return text;
  try {
    return s2tConverter(text);
  } catch {
    return text;
  }
}

function toSimplified(text: string): string {
  if (!t2sConverter) return text;
  try {
    return t2sConverter(text);
  } catch {
    return text;
  }
}

/**
 * Extract the primary source term from a china value that may contain
 * slash-separated variants or parenthetical annotations.
 * This mirrors the logic in scripts/tools/terminology-clean.py.
 */
function cleanChinaSource(raw: string): string {
  if (!raw || raw.startsWith('N/A') || raw.startsWith('（無')) return raw;
  let s = raw;
  // Remove parenthetical annotations like （簡）（中國）（舊）etc.
  s = s.replace(/（[^）]*）/g, '');
  s = s.replace(/\([^)]*\)/g, '');
  // Take first variant if slash-separated
  if (s.includes('/')) {
    s = s.split('/')[0];
  }
  return s.trim();
}

// ── Build-time: generate conversion rules from YAML files ─────────────────────
interface TermEntry {
  id: string;
  category?: string;
  subcategory?: string;
  fork_type?: string;
  display: {
    taiwan: string;
    china?: string;
    hongkong?: string;
  };
  notes?: string;
  sources?: string[];
}

interface ConversionRule {
  source: string;
  target: string;
  forkType: string;
  category: string;
  id: string;
}

const termDir = resolve(process.cwd(), 'data/terminology');
const files = await readdir(termDir);
const rules: ConversionRule[] = [];
// Track seen sources to avoid duplicates
const seenSources = new Set<string>();

for (const file of files) {
  if (!file.endsWith('.yaml') || file.startsWith('_')) continue;
  const raw = await readFile(join(termDir, file), 'utf-8');
  try {
    const d = parseYaml(raw) as TermEntry;
    // Support both display.{china,taiwan} and top-level {china,taiwan} formats
    const chinaVal = d?.display?.china || (d as any)?.china;
    const taiwanVal = d?.display?.taiwan || (d as any)?.taiwan;
    if (d && chinaVal && taiwanVal && chinaVal !== taiwanVal) {
      const forkType = d.fork_type || (d as any)?.type || '';
      const category = d.category || '';
      const id = d.id || file.replace('.yaml', '');
      const target = taiwanVal;
      const chinaRaw = chinaVal;

      // Step 1: Clean the raw china value (strip annotations, take first slash variant)
      const chinaCleaned = cleanChinaSource(chinaRaw);

      // Skip if value is N/A, （無直接對應）, or cleaned result equals taiwan
      if (!chinaCleaned || chinaCleaned === target) continue;
      if (chinaCleaned.startsWith('N/A') || chinaCleaned.startsWith('（無'))
        continue;

      // Step 2: Normalize to traditional + derive simplified form so we
      // detect both regardless of input shape and regardless of whether
      // the frontend OpenCC has finished loading.
      // YAML files are stored in traditional Chinese, so chinaCleaned ===
      // chinaTraditional in practice — we cannot rely on cleaned !== trad
      // to gate the simp rule. Instead actively generate simp via t2s.
      const chinaTraditional = toTraditional(chinaCleaned);
      const chinaSimplified = toSimplified(chinaTraditional);

      // Add rule for the traditional form (primary matching source)
      if (!seenSources.has(chinaTraditional) && chinaTraditional !== target) {
        rules.push({
          source: chinaTraditional,
          target,
          forkType,
          category,
          id,
        });
        seenSources.add(chinaTraditional);
      }

      // Add simplified-form fallback rule. Critical for when frontend OpenCC
      // hasn't loaded yet (CDN slow / mobile / strict CSP) — without this,
      // simplified input can never match the traditional yaml source.
      if (
        chinaSimplified !== chinaTraditional &&
        !seenSources.has(chinaSimplified) &&
        chinaSimplified !== target
      ) {
        rules.push({
          source: chinaSimplified,
          target,
          forkType,
          category,
          id: id + '_simp',
        });
        seenSources.add(chinaSimplified);
      }

      // Also keep the original cleaned form if it differs from both
      // (handles yaml entries that already mix forms)
      if (
        chinaCleaned !== chinaTraditional &&
        chinaCleaned !== chinaSimplified &&
        !seenSources.has(chinaCleaned) &&
        chinaCleaned !== target
      ) {
        rules.push({
          source: chinaCleaned,
          target,
          forkType,
          category,
          id: id + '_orig',
        });
        seenSources.add(chinaCleaned);
      }
    }
  } catch {
    // skip malformed
  }
}

// Sort by source length descending (longer matches first to avoid partial replacement)
rules.sort((a, b) => b.source.length - a.source.length);

// ── Reverse direction (TW → CN) ruleset ────────────────────────────────────
// Swap source/target. Note: 一個台灣用語可能對應多個中國變體（slash），
// 反向時用 cleaned china value（已取 first variant）作為 target，避免使用者
// 看到「滑鼠 → 鼠標 / 滑鼠標」這類混亂。OpenCC frontend 反向用 tw → cn
// 所以這裡的 source 用 traditional taiwan term（已是繁體），target 也保留繁體
// （讀者習慣，且 OpenCC 在 frontend 會把整段中國用語版本套 t2s 轉簡體 if needed）
const reverseRules: ConversionRule[] = [];
const seenReverseSources = new Set<string>();
// 防 yaml data bug：若某個 taiwan term 字串等於另一條 rule 的 china term
// （暗示 yaml 的 display.taiwan / display.china 欄位被顛倒寫，例如
// 軟件.yaml: taiwan='軟件' china='解除安裝' 是顛倒的），跳過。
// 這在 forward rules 不會 surface（因為長度排序 + used array），
// 但 reverse rules 會把錯誤直接暴露給使用者。
const forwardSources = new Set(rules.map((r) => r.source));
for (const r of rules) {
  // Skip the simplified-fallback rules (id ends with _simp) — they have
  // simplified source which would generate dup entries in reverse mode
  if (r.id.endsWith('_simp')) continue;
  if (!r.target || !r.source) continue;
  if (seenReverseSources.has(r.target)) continue; // avoid TW→CN dup
  // 跳過 yaml field-swap bug 條目（target 跟某 forward rule 的 source 衝突）
  if (forwardSources.has(r.target)) continue;
  reverseRules.push({
    source: r.target, // TW term
    target: r.source, // CN term (traditional form)
    forkType: r.forkType,
    category: r.category,
    id: r.id,
  });
  seenReverseSources.add(r.target);
}
reverseRules.sort((a, b) => b.source.length - a.source.length);

const rulesJSON = JSON.stringify(rules);
const reverseRulesJSON = JSON.stringify(reverseRules);
---

<Layout
  title="台灣用語轉換器：中國用語一鍵轉台灣說法"
  description={`免費線上台灣用語轉換工具。「視頻」→「影片」、「軟件」→「軟體」、「打車」→「叫計程車」——${rules.length} 條轉換規則涵蓋科技、生活、醫療、校園等分類，附台灣化指數分析。同步處理字形、詞彙、語感的完整對應。`}
>
  <!-- Preload OpenCC for faster mobile loading -->
  <link
    rel="modulepreload"
    href="https://cdn.jsdelivr.net/npm/opencc-js@1/dist/esm/cn2t.js"
  />
  <!--
    Phase 6 partial migration — terminology/converter.astro
    ───────────────────────────────────────────────────────
    Wrappers, header, body, editor grid, action bar, analysis box
    moved to inline Tailwind. Kept in scoped <style>:
    - :global(mark.source-word / replaced-word / sample-mark)
      because marks are rendered via innerHTML by the JS converter
    - .change-list / .change-item / .change-source etc.
      because the analysis rows are created in JS and styled via
      classList, not directly in astro markup
    - .conv-faq details/summary ::before pseudo + ::-webkit-details-marker
      override because Tailwind can't express pseudo-element detail
      markers
    - .opencc-ready / .opencc-failed state classes (JS-toggled)
  -->
  <div class="flex flex-col bg-[#f8f8f8]">
    <!-- ── Header（共用 PageHero 元件） ─────────────────────────── -->
    <PageHero
      bgVariant="solid"
      bgColor="#1a1a2e"
      bgTone="dark"
      titleVariant="inherit"
      titleSize="md"
      containerWidth="wide"
      padding="default"
    >
      <Fragment slot="title">
        台灣用語轉換器
        <span
          class="mt-[0.2em] block font-[var(--font-ui,system-ui,sans-serif)] text-[0.45em] font-normal tracking-[0.04em] opacity-[0.65]"
          >Taiwan Terminology Converter</span
        >
      </Fragment>
      <Fragment slot="subtitle">
        <span id="header-tagline"
          >把中國用語轉換為台灣用語：字形、詞彙、語感的完整對應。</span
        >
      </Fragment>

      <!-- 方向 toggle + 規則數 + 導航按鈕 — 全部進 default slot -->
      <div class="mt-6 flex flex-col items-center gap-4">
        <div
          id="direction-toggle"
          class="inline-flex items-stretch overflow-hidden rounded-lg border border-white/25 text-[0.85rem]"
          role="tablist"
          aria-label="轉換方向"
        >
          <button
            data-dir="cn2tw"
            class="dir-btn cursor-pointer border-0 bg-white/15 px-[1rem] py-[0.45rem] font-semibold text-white transition-[background] duration-150 hover:bg-white/25 aria-selected:bg-white aria-selected:text-[#1a1a2e] aria-selected:hover:bg-white"
            aria-selected="true"
            role="tab">中國 → 台灣</button
          >
          <button
            data-dir="tw2cn"
            class="dir-btn cursor-pointer border-0 border-l border-white/25 bg-white/15 px-[1rem] py-[0.45rem] font-semibold text-white transition-[background] duration-150 hover:bg-white/25 aria-selected:bg-white aria-selected:text-[#1a1a2e] aria-selected:hover:bg-white"
            aria-selected="false"
            role="tab">台灣 → 中國</button
          >
        </div>

        <div
          class="flex flex-wrap items-center justify-center gap-x-4 gap-y-2 text-[0.9rem] opacity-80 [&_strong]:text-white [&_strong]:opacity-100"
        >
          <span id="rule-count-display"
            ><strong>{rules.length}</strong> 條轉換規則</span
          >
        </div>

        <div class="flex flex-wrap justify-center gap-2">
          <a
            href="/terminology"
            class="inline-flex items-center gap-[0.4rem] whitespace-nowrap rounded-lg border border-white/25 bg-white/10 px-4 py-[0.45rem] text-[0.88rem] font-semibold text-white no-underline transition-[background,border-color] duration-150 hover:border-white/40 hover:bg-white/20 hover:no-underline"
            >← 回到詞庫</a
          >
          <a
            href="/fork-graph"
            class="inline-flex items-center gap-[0.4rem] whitespace-nowrap rounded-lg border border-white/25 bg-white/10 px-4 py-[0.45rem] text-[0.88rem] font-semibold text-white no-underline transition-[background,border-color] duration-150 hover:border-white/40 hover:bg-white/20 hover:no-underline"
            >🌿 語言分支樹</a
          >
        </div>
      </div>
    </PageHero>

    <!-- ── Main converter area ─────────────────────────────────────── -->
    <div class="flex-1 px-[var(--space-page-x,2rem)] py-8">
      <div class="mx-auto flex max-w-[72rem] flex-col gap-6">
        <!-- Two-column editor -->
        <div class="grid grid-cols-2 gap-5 max-[680px]:grid-cols-1">
          <div class="flex flex-col gap-2">
            <div
              class="text-[0.8rem] font-bold uppercase tracking-[0.08em] text-[#555]"
            >
              輸入文字
            </div>
            <div class="relative">
              <div
                id="input-highlight"
                class="input-highlight pointer-events-none absolute inset-0 box-border overflow-hidden rounded-[10px] border-[1.5px] border-transparent p-4 font-[var(--font-ui,system-ui,sans-serif)] text-base leading-[1.7] text-transparent [overflow-wrap:break-word] [white-space:pre-wrap] [word-break:normal]"
                aria-hidden="true"
              >
              </div>
              <textarea
                id="input-text"
                class="relative z-[1] box-border min-h-[240px] w-full resize-y rounded-[10px] border-[1.5px] border-[#ddd] bg-transparent p-4 font-[var(--font-ui,system-ui,sans-serif)] text-base leading-[1.7] transition-colors duration-150 focus:border-[#1a1a2e] focus:shadow-[0_0_0_3px_rgba(26,26,46,0.1)] focus:outline-none"
                placeholder="在這裡貼入文字…

例如：這個軟件視頻很有用，可以通過下載來使用。"
                spellcheck="false"></textarea>
            </div>
          </div>

          <div class="flex flex-col gap-2">
            <div
              class="text-[0.8rem] font-bold uppercase tracking-[0.08em] text-[#555]"
            >
              轉換結果
            </div>
            <div
              id="output-text"
              class="min-h-[240px] break-words rounded-[10px] border-[1.5px] border-[#ddd] bg-white p-4 font-[var(--font-ui,system-ui,sans-serif)] text-base leading-[1.7] [white-space:pre-wrap]"
              aria-live="polite"
            >
              <span class="italic text-[#aaa]"
                >轉換結果會顯示在這裡，<mark class="sample-mark">替換的詞</mark> 會被醒目標示。</span
              >
            </div>
          </div>
        </div>

        <!-- Action buttons -->
        <div class="flex flex-wrap gap-3">
          <button
            id="btn-convert"
            class="cursor-pointer rounded-lg border-[1.5px] border-[#1a1a2e] bg-[#1a1a2e] px-[1.4rem] py-[0.55rem] text-[0.92rem] font-bold text-white transition-[background,color,border-color,opacity] duration-150 hover:border-[#2d2d50] hover:bg-[#2d2d50] disabled:cursor-not-allowed disabled:opacity-40"
            >🔄 轉換</button
          >
          <button
            id="btn-clear"
            class="cursor-pointer rounded-lg border-[1.5px] border-[#ccc] bg-white px-[1.4rem] py-[0.55rem] text-[0.92rem] font-bold text-[#333] transition-[background,color,border-color,opacity] duration-150 hover:border-[#aaa] hover:bg-[#f3f3f3] disabled:cursor-not-allowed disabled:opacity-40"
            >✕ 清除</button
          >
          <button
            id="btn-copy"
            class="cursor-pointer rounded-lg border-[1.5px] border-[#ccc] bg-white px-[1.4rem] py-[0.55rem] text-[0.92rem] font-bold text-[#333] transition-[background,color,border-color,opacity] duration-150 hover:border-[#aaa] hover:bg-[#f3f3f3] disabled:cursor-not-allowed disabled:opacity-40"
            disabled>📋 複製結果</button
          >
          <span class="mx-1 h-6 w-px self-center bg-[#ddd] max-[680px]:hidden"
          ></span>
          <span
            class="self-center whitespace-nowrap text-[0.82rem] text-[#888] max-[680px]:mt-2 max-[680px]:w-full"
            >試試看：</span
          >
          {
            [
              ['tech', '💻 科技文'],
              ['life', '🍜 生活文'],
              ['news', '📰 新聞稿'],
              ['medical', '🏥 醫療'],
              ['school', '🎓 校園'],
              ['social', '📱 社群'],
              ['gaming', '🎮 遊戲'],
              ['office', '💼 職場'],
            ].map(([key, label]) => (
              <button
                class="cursor-pointer rounded-lg border-[1.5px] border-[#ddd] bg-white px-[0.9rem] py-[0.4rem] text-[0.82rem] font-semibold text-[#555] transition-[background,color,border-color,opacity] duration-150 hover:border-[#3498db] hover:bg-[#f0f7ff] hover:text-[#1a1a2e]"
                data-example={key}
              >
                {label}
              </button>
            ))
          }
        </div>

        <!-- Analysis report -->
        <div
          id="analysis"
          class="flex flex-col gap-4 rounded-xl border-[1.5px] border-[#e0e0e0] bg-white p-6"
          hidden
        >
          <div class="border-b border-[#f0f0f0] pb-3">
            <span
              id="analysis-title"
              class="text-[1.05rem] font-bold text-[#1a1a2e]"></span>
          </div>

          <div
            id="opencc-status"
            class="opencc-status-row mb-1 rounded-md px-3 py-[0.4rem] text-[0.88rem] font-semibold"
            hidden
          >
          </div>

          <div id="must-change" class="flex flex-col gap-2" hidden>
            <div class="text-[0.88rem] font-bold text-[#c0392b]">
              🔴 必換（A / B 類）
            </div>
            <ul id="must-list" class="change-list"></ul>
          </div>

          <div id="suggest-change" class="flex flex-col gap-2" hidden>
            <div class="text-[0.88rem] font-bold text-[#d68910]">
              🟡 建議（其他類）
            </div>
            <ul id="suggest-list" class="change-list"></ul>
          </div>

          <div
            class="flex items-center gap-3 border-t border-[#f0f0f0] pt-3 text-[0.95rem]"
          >
            <span class="font-bold text-[#555]">📊 台灣化指數</span>
            <span
              id="index-before"
              class="text-[1.05rem] font-extrabold text-[#c0392b]"></span>
            <span class="text-[#888]">→</span>
            <span
              id="index-after"
              class="text-[1.05rem] font-extrabold text-[#27ae60]"></span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script define:vars={{ rulesJSON, reverseRulesJSON }}>
    // ── Parse rules injected from build time ────────────────────────────────
    const RULES_CN2TW = JSON.parse(rulesJSON);
    const RULES_TW2CN = JSON.parse(reverseRulesJSON);
    const GITHUB_BASE =
      'https://github.com/frank890417/taiwan-md/blob/main/data/terminology/';

    // ── Direction state (persisted via URL ?dir= + localStorage) ─────────────
    let direction = 'cn2tw'; // 'cn2tw' | 'tw2cn'
    function readInitialDirection() {
      try {
        const params = new URLSearchParams(window.location.search);
        const fromUrl = params.get('dir');
        if (fromUrl === 'cn2tw' || fromUrl === 'tw2cn') return fromUrl;
        const fromStorage = localStorage.getItem('terminology-dir');
        if (fromStorage === 'cn2tw' || fromStorage === 'tw2cn')
          return fromStorage;
      } catch {
        /* ignore storage / URL errors */
      }
      return 'cn2tw';
    }
    direction = readInitialDirection();

    function getRules() {
      return direction === 'cn2tw' ? RULES_CN2TW : RULES_TW2CN;
    }

    // ── OpenCC setup (双方向) ─────────────────────────────────────────────────
    // cn2tw: 简→繁 (用 ConverterFactory + cn → tw locale)
    // tw2cn: 繁→简 (用 ConverterFactory + tw → cn locale)
    // 動態 init 兩個 converter；切換 direction 時 swap activeOpenccConverter
    let openccCn2Tw = null;
    let openccTw2Cn = null;
    let openccStatus = 'loading'; // 'loading' | 'ready' | 'failed'

    function getActiveOpenCC() {
      return direction === 'cn2tw' ? openccCn2Tw : openccTw2Cn;
    }

    async function initOpenCC() {
      // Use full opencc-js entry (includes both Locale.from + Locale.to)
      // The cn2t.js subpath only ships the cn→t Converter, not the bidirectional dictionaries.
      const cdnUrls = [
        'https://cdn.jsdelivr.net/npm/opencc-js@1/dist/esm/full.js',
        'https://unpkg.com/opencc-js@1/dist/esm/full.js',
        // Fallback to cn2t.js (limited to cn→tw direction, tw→cn 將不可用)
        'https://cdn.jsdelivr.net/npm/opencc-js@1/dist/esm/cn2t.js',
        'https://unpkg.com/opencc-js@1/dist/esm/cn2t.js',
      ];
      for (const url of cdnUrls) {
        try {
          const OpenCC = await Promise.race([
            import(/* @vite-ignore */ url),
            new Promise((_, reject) =>
              setTimeout(() => reject(new Error('timeout')), 8000),
            ),
          ]);
          // cn → tw 一定要有
          openccCn2Tw = OpenCC.ConverterFactory(
            OpenCC.Locale.from.cn,
            OpenCC.Locale.to.tw,
          );
          // tw → cn 看 build 是否包進 from.tw + to.cn
          try {
            if (OpenCC.Locale.from.tw && OpenCC.Locale.to.cn) {
              openccTw2Cn = OpenCC.ConverterFactory(
                OpenCC.Locale.from.tw,
                OpenCC.Locale.to.cn,
              );
            }
          } catch (e) {
            console.warn(
              'OpenCC tw→cn 不可用（fallback build），僅 cn→tw 啟用',
            );
          }
          openccStatus = 'ready';
          return;
        } catch (e) {
          console.warn(`OpenCC from ${url} failed:`, e.message);
        }
      }
      console.warn('OpenCC 載入失敗，僅做用語替換（字形轉換不可用）');
      openccStatus = 'failed';
    }
    // Awaitable promise so run() can wait for OpenCC instead of blind 800ms.
    // initOpenCC never throws (loop catches all CDN errors), so this resolves
    // once status is 'ready' or 'failed'.
    const openccReady = initOpenCC();
    // After OpenCC finishes, re-run conversion if input already has content
    // (handles: user pastes / clicks example before CDN finishes).
    openccReady.then(() => {
      if (inputEl && inputEl.value && inputEl.value.trim()) run();
    });

    // Apply active OpenCC to text outside of HTML tags
    function applyOpenCC(html) {
      const conv = getActiveOpenCC();
      if (!conv) return html;
      // Replace text nodes (content between tags) but skip content inside tags themselves
      return html.replace(/>([^<]+)</g, (match, text) => {
        return '>' + conv(text) + '<';
      });
    }

    // ── DOM refs ────────────────────────────────────────────────────────────
    const inputEl = document.getElementById('input-text');
    const outputEl = document.getElementById('output-text');
    const btnConvert = document.getElementById('btn-convert');
    const btnClear = document.getElementById('btn-clear');
    const btnCopy = document.getElementById('btn-copy');
    const analysisEl = document.getElementById('analysis');
    const analysisTitleEl = document.getElementById('analysis-title');
    const openccStatusEl = document.getElementById('opencc-status');
    const mustSection = document.getElementById('must-change');
