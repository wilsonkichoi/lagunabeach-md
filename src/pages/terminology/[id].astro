---
/**
 * Per-term SEO landing page — /terminology/{id}
 * ─────────────────────────────────────────────
 * Answers ONE long-tail query fast: 「{china} 台灣用語」/「{china} 台灣怎麼說」.
 * The /terminology index is a browse grid and /terminology/converter pastes a
 * whole paragraph — neither ranks for a single-word lookup. This page does.
 *
 * SLUG CONTRACT (do not change without updating converter.astro):
 *   slug = d.id || file.replace('.yaml','')   — IDENTICAL to the rule `id`
 *   the converter bakes into RULES_CN2TW. The converter's 📖 link points at
 *   /terminology/{encodeURIComponent(termPageId(m.id))} (termPageId strips the
 *   _simp/_orig suffix). If this slug ever diverges from that id, every 📖 link
 *   for romanized-id entries (AWSL→awsl, OK繃→bandaid, ...) 404s.
 *
 * INCLUSION RULE (mirrors converter ~1,800-pair ruleset):
 *   needs display.taiwan + a display.china that, after cleanChinaSource(),
 *   is non-empty, differs from taiwan, and isn't N/A / （無…）.
 *
 * BUILD PERF (this template generates ~2,300 static pages):
 *   - all YAML is read ONCE in getStaticPaths; nothing is re-read in the body.
 *   - related-term picking is precomputed in getStaticPaths and passed as props.
 *   - the body does only cheap string work on a single already-parsed entry.
 *   Keep it that way — do not add per-page fs reads or O(N) scans here.
 */
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
// NB: fs/path/yaml are imported *inside* getStaticPaths (Astro runs it in an
// isolated context). The page body works purely off Astro.props, so it needs
// none of them at module scope.

// ── fork_type labels / colors — kept in sync with terminology/index.astro ─────
// index.astro ships A–F. The YAML also carries legacy `semantic` / `orthographic`
// values (and a `type` field on older entries); map those onto the closest
// canonical bucket so the badge + explanation never render a bare code.
const forkTypeLabels: Record<string, string> = {
  A: 'A 日語遺產',
  B: 'B 1949分流',
  C: 'C 網路時代',
  D: 'D 台客語底層',
  E: 'E 正在分歧',
  F: 'F 同詞不同語感',
};
const forkTypeColors: Record<string, string> = {
  A: '#e74c3c',
  B: '#3498db',
  C: '#9b59b6',
  D: '#27ae60',
  E: '#f39c12',
  F: '#607d8b',
};
// One-line plain explanation of each bucket (friend-explaining voice, factual).
const forkTypeBlurbs: Record<string, string> = {
  A: '兩岸完全不同的詞，多半是台灣留下的日語底層，中國另起爐灶。',
  B: '1949 年後兩岸分流，同一個概念各自演化出不同說法。',
  C: '網路時代才冒出來的新詞，兩邊各自長出自己的講法。',
  D: '底層來自台語、客語或原住民語，中國沒有對應的在地詞。',
  E: '還在分歧中的詞，兩邊講法都聽得懂，但各有偏好。',
  F: '同一個詞，兩邊語感不一樣，用起來的場合與味道有差。',
};
// (fork_type normalization + china cleaning live inline in getStaticPaths,
//  where the build-time parse needs them; the body receives already-normalized
//  props so it doesn't re-declare them.)

interface RawEntry {
  id?: string;
  category?: string;
  subcategory?: string;
  fork_type?: string;
  type?: string;
  display?: { taiwan?: string; china?: string; hongkong?: string };
  taiwan?: string;
  china?: string;
  english?: string;
  etymology?: {
    origin?: string;
    taiwan_path?: string;
    china_path?: string;
    fork_point?: string;
    fork_cause?: string;
  };
  notes?: string;
  sources?: string[];
  added?: string;
  updated?: string;
}

// Props shape passed from getStaticPaths → body. Pre-flattened so the body does
// no digging into nested/legacy shapes.
interface TermProps {
  id: string;
  taiwan: string; // display.taiwan verbatim (may contain " / " alternatives)
  china: string; // cleaned primary china term (slash/annotations stripped)
  chinaRaw: string; // original display.china (for verbatim display, e.g. "創口貼 / 創可貼")
  hongkong: string;
  english: string;
  category: string;
  subcategory: string;
  forkKey: string; // normalized A–F or ''
  origin: string;
  taiwanPath: string;
  chinaPath: string;
  forkPoint: string;
  forkCause: string;
  notes: string;
  sources: string[];
  updated: string;
  related: { id: string; taiwan: string; china: string }[];
}

export async function getStaticPaths() {
  // NOTE: Astro runs getStaticPaths in an isolated module context, so the
  // helpers above are NOT visible here — everything getStaticPaths needs is
  // (re)declared inline below. This is the same constraint [category]/[slug]
  // documents. Keep the two cleanChinaSource / normalizeForkType copies in sync.
  const { readdir, readFile } = await import('fs/promises');
  const { resolve, join } = await import('path');
  const { parse: parseYaml } = await import('yaml');

  function cleanChina(raw: string): string {
    if (!raw || raw.startsWith('N/A') || raw.startsWith('（無')) return raw;
    let s = raw;
    s = s.replace(/（[^）]*）/g, '');
    s = s.replace(/\([^)]*\)/g, '');
    if (s.includes('/')) s = s.split('/')[0];
    return s.trim();
  }
  function normForkKey(raw: string): string {
    const v = (raw || '').trim();
    if (['A', 'B', 'C', 'D', 'E', 'F'].includes(v)) return v;
    if (v === 'semantic') return 'C';
    if (v === 'orthographic') return 'D';
    return '';
  }
  const flat = (s: unknown) =>
    String(s ?? '')
      .split('\n')
      .join(' ')
      .trim();

  const RESERVED = new Set(['converter', 'index']);
  const termDir = resolve(process.cwd(), 'data/terminology');
  const files = await readdir(termDir);

  // First pass: parse every YAML, keep only valid CN≠TW pairs, dedup by id.
  interface Parsed {
    id: string;
    taiwan: string;
    chinaClean: string;
    chinaRaw: string;
    hongkong: string;
    english: string;
    category: string;
    subcategory: string;
    forkKey: string;
    origin: string;
    taiwanPath: string;
    chinaPath: string;
    forkPoint: string;
    forkCause: string;
    notes: string;
    sources: string[];
    updated: string;
  }
  const entries: Parsed[] = [];
  const seenId = new Set<string>();

  for (const file of files.sort()) {
    if (!file.endsWith('.yaml') || file.startsWith('_')) continue;
    let d: RawEntry | null = null;
    try {
      d = parseYaml(await readFile(join(termDir, file), 'utf-8')) as RawEntry;
    } catch {
      continue; // malformed → skip
    }
    if (!d) continue;

    const taiwan = (d.display?.taiwan ?? d.taiwan ?? '').toString().trim();
    const chinaRaw = (d.display?.china ?? d.china ?? '').toString().trim();
    if (!taiwan || !chinaRaw || chinaRaw === taiwan) continue;

    const chinaClean = cleanChina(chinaRaw);
    if (!chinaClean || chinaClean === taiwan) continue;
    if (chinaClean.startsWith('N/A') || chinaClean.startsWith('（無')) continue;

    const id = (d.id || file.replace(/\.yaml$/, '')).toString();
    if (RESERVED.has(id)) continue; // never shadow /terminology/{converter,index}
    if (seenId.has(id)) continue; // first-wins dedup (matches converter rule order)
    seenId.add(id);

    entries.push({
      id,
      taiwan,
      chinaClean,
      chinaRaw,
      hongkong: (d.display?.hongkong ?? '').toString().trim(),
      english: (d.english ?? '').toString().trim(),
      category: (d.category ?? '').toString().trim(),
      subcategory: (d.subcategory ?? '').toString().trim(),
      forkKey: normForkKey(d.fork_type || d.type || ''),
      origin: flat(d.etymology?.origin),
      taiwanPath: flat(d.etymology?.taiwan_path),
      chinaPath: flat(d.etymology?.china_path),
      forkPoint: flat(d.etymology?.fork_point),
      forkCause: flat(d.etymology?.fork_cause),
      notes: flat(d.notes),
      sources: (d.sources ?? []).filter(Boolean).map((s) => String(s)),
      updated: (d.updated ?? d.added ?? '').toString().trim(),
    });
  }

  // Build a category → sorted-member index ONCE for deterministic related-term
  // picking (no Math.random; nearest neighbours by zh-TW collation of taiwan).
  const byCategory = new Map<string, Parsed[]>();
  for (const e of entries) {
    const key = e.category || '_uncategorized';
    if (!byCategory.has(key)) byCategory.set(key, []);
    byCategory.get(key)!.push(e);
  }
  for (const list of byCategory.values()) {
    list.sort((a, b) => a.taiwan.localeCompare(b.taiwan, 'zh-TW'));
  }

  return entries.map((e) => {
    // Related: same category, window of neighbours around this entry, 4–8 items.
    const sibs = byCategory.get(e.category || '_uncategorized') || [];
    const idx = sibs.findIndex((s) => s.id === e.id);
    let related: { id: string; taiwan: string; china: string }[] = [];
    if (sibs.length > 1) {
      const others = sibs.filter((_, i) => i !== idx);
      // take up to 8 nearest neighbours (4 before + 4 after, then trim)
      const start = Math.max(0, idx - 4);
      const window = others.slice(Math.max(0, start), Math.max(0, start) + 8);
      const picked = (window.length >= 4 ? window : others).slice(0, 8);
      related = picked.map((s) => ({
        id: s.id,
        taiwan: s.taiwan,
        china: s.chinaClean,
      }));
    }

    const props: TermProps = {
      id: e.id,
      taiwan: e.taiwan,
      china: e.chinaClean,
      chinaRaw: e.chinaRaw,
      hongkong: e.hongkong,
      english: e.english,
      category: e.category,
      subcategory: e.subcategory,
      forkKey: e.forkKey,
      origin: e.origin,
      taiwanPath: e.taiwanPath,
      chinaPath: e.chinaPath,
      forkPoint: e.forkPoint,
      forkCause: e.forkCause,
      notes: e.notes,
      sources: e.sources,
      updated: e.updated,
      related,
    };
    return { params: { id: e.id }, props };
  });
}

// ── Body: single entry, cheap string work only ───────────────────────────────
const p = Astro.props as TermProps;

// taiwan may carry " / " alternatives (e.g. "影片 / 影音"); primary = first.
const taiwanPrimary = p.taiwan.split(/\s*\/\s*/)[0];
const forkLabel = p.forkKey ? forkTypeLabels[p.forkKey] : '';
const forkColor = p.forkKey ? forkTypeColors[p.forkKey] : '#94a3b8';
const forkBlurb = p.forkKey ? forkTypeBlurbs[p.forkKey] : '';

// SEO title — tuned to「{china} 台灣怎麼說」. Kept ≤ ~60 chars.
const seoTitle = `「${p.china}」台灣怎麼說？台灣用語是「${taiwanPrimary}」`;
const seoDesc = forkBlurb
  ? `中國說「${p.china}」，台灣說「${p.taiwan}」。${forkBlurb}查兩岸用語差異與詞源，就上 Taiwan.md 用語保存計畫。`
  : `中國說「${p.china}」，台灣說「${p.taiwan}」。查兩岸用語差異與詞源，就上 Taiwan.md 用語保存計畫。`;

// Has any etymology sub-part to show?
const hasEtymology = Boolean(
  p.origin || p.forkPoint || p.forkCause || p.taiwanPath || p.chinaPath,
);

// Etymology rows — only non-empty parts (never an empty label / dangling colon).
const etymologyRows: { label: string; value: string }[] = [];
if (p.origin) etymologyRows.push({ label: '詞源', value: p.origin });
if (p.taiwanPath)
  etymologyRows.push({ label: '台灣這邊', value: p.taiwanPath });
if (p.chinaPath) etymologyRows.push({ label: '中國那邊', value: p.chinaPath });
if (p.forkPoint) etymologyRows.push({ label: '分歧點', value: p.forkPoint });
if (p.forkCause)
  etymologyRows.push({ label: '為什麼會分歧', value: p.forkCause });

// URL helper for sources: treat http(s) as link, everything else as citation.
const isUrl = (s: string) => /^https?:\/\//i.test(s.trim());

// JSON-LD: DefinedTerm — the cleanest schema for a single definitional lookup.
const definedTermLD = {
  '@context': 'https://schema.org',
  '@type': 'DefinedTerm',
  name: taiwanPrimary,
  alternateName: [p.taiwan, p.china, p.chinaRaw, p.english].filter(
    (v, i, a) => v && a.indexOf(v) === i,
  ),
  description:
    `台灣用語「${p.taiwan}」對應中國用語「${p.china}」。${forkBlurb || ''}`.trim(),
  inDefinedTermSet: {
    '@type': 'DefinedTermSet',
    name: 'Taiwan.md 用語保存計畫',
    url: 'https://taiwan.md/terminology',
  },
  inLanguage: 'zh-TW',
  url: `https://taiwan.md/terminology/${encodeURIComponent(p.id)}`,
};
---

<Layout title={seoTitle} description={seoDesc}>
  <main class="flex min-h-screen flex-col bg-[#f8f8f8]">
    <!-- ── Hero: the {china} → {taiwan} answer, stated plainly ─────────────── -->
    <PageHero
      bgVariant="solid"
      bgColor="#1a1a2e"
      bgTone="dark"
      titleVariant="inherit"
      titleSize="md"
      containerWidth="narrow"
      padding="default"
    >
      <Fragment slot="eyebrow">用語保存計畫 ・ 兩岸用語對照</Fragment>
      <Fragment slot="title">
        <span class="block text-[0.6em] font-normal opacity-70">
          中國說「{p.chinaRaw}」，台灣說
        </span>
        {taiwanPrimary}
      </Fragment>
      <Fragment slot="subtitle">
        {
          p.taiwan !== taiwanPrimary
            ? `台灣完整說法：${p.taiwan}`
            : `在台灣，「${p.china}」要說「${taiwanPrimary}」。`
        }
      </Fragment>

      <div class="mt-6 flex flex-wrap justify-center gap-2">
        {
          forkLabel && (
            <span
              class="inline-flex items-center rounded-full border px-3 py-[0.3rem] text-[0.8rem] font-semibold"
              style={`background:${forkColor}22;color:#fff;border-color:${forkColor}88`}
            >
              {forkLabel}
            </span>
          )
        }
        {
          p.hongkong && (
            <span class="inline-flex items-center rounded-full border border-white/25 bg-white/10 px-3 py-[0.3rem] text-[0.8rem] text-white/85">
              香港：{p.hongkong}
            </span>
          )
        }
        {
          p.english && (
            <span class="inline-flex items-center rounded-full border border-white/25 bg-white/10 px-3 py-[0.3rem] text-[0.8rem] italic text-white/85">
              {p.english}
            </span>
          )
        }
      </div>
    </PageHero>

    <!-- ── Body column ───────────────────────────────────────────────────── -->
    <div
      class="mx-auto box-border w-full max-w-[760px] flex-1 px-[var(--space-page-x,2rem)] py-10 max-[640px]:px-4 max-[640px]:py-6"
    >
      <!-- The mapping card: the literal answer, big and scannable -->
      <div
        class="mb-8 flex items-stretch gap-3 rounded-2xl border-[1.5px] border-[#e5e5e5] bg-white p-6 max-[520px]:flex-col"
      >
        <div
          class="flex flex-1 flex-col items-center justify-center gap-1 text-center"
        >
          <span
            class="text-[0.75rem] font-semibold uppercase tracking-[0.1em] text-[#94a3b8]"
            >中國用語</span
          >
          <span
            class="font-[var(--font-editorial,Georgia,serif)] text-[1.6rem] font-bold leading-tight text-[#64748b]"
            >{p.chinaRaw}</span
          >
        </div>
        <div
          class="flex items-center justify-center text-[1.5rem] text-[#cbd5e1] max-[520px]:rotate-90"
        >
          →
        </div>
        <div
          class="flex flex-1 flex-col items-center justify-center gap-1 text-center"
        >
          <span
            class="text-[0.75rem] font-semibold uppercase tracking-[0.1em] text-[#27ae60]"
            >台灣用語</span
          >
          <span
            class="font-[var(--font-editorial,Georgia,serif)] text-[1.6rem] font-bold leading-tight text-[#1a1a2e]"
            >{p.taiwan}</span
          >
        </div>
      </div>

      <!-- fork_type explanation -->
      {
        forkLabel && forkBlurb && (
          <section class="mb-8">
            <h2 class="mb-2 flex items-center gap-2 text-[1.05rem] font-bold text-[#1a1a2e]">
              <span
                class="inline-flex items-center rounded-md px-2 py-[0.15rem] text-[0.8rem] font-bold"
                style={`background:${forkColor}1f;color:${forkColor}`}
              >
                {forkLabel}
              </span>
              這是哪一種分歧？
            </h2>
            <p class="m-0 text-[0.95rem] leading-[1.8] text-[#444]">
              {forkBlurb}
            </p>
          </section>
        )
      }

      <!-- etymology — only non-empty parts -->
      {
        hasEtymology && (
          <section class="mb-8">
            <h2 class="mb-3 text-[1.05rem] font-bold text-[#1a1a2e]">
              詞源與來龍去脈
            </h2>
            <dl class="m-0 flex flex-col gap-3">
              {etymologyRows.map((row) => (
                <div class="rounded-xl border border-[#eee] bg-white p-4">
                  <dt class="mb-1 text-[0.75rem] font-bold uppercase tracking-[0.08em] text-[#94a3b8]">
                    {row.label}
                  </dt>
                  <dd class="m-0 text-[0.92rem] leading-[1.75] text-[#444]">
                    {row.value}
                  </dd>
                </div>
              ))}
            </dl>
          </section>
        )
      }

      <!-- notes (only if present) -->
      {
        p.notes && (
          <section class="mb-8">
            <h2 class="mb-2 text-[1.05rem] font-bold text-[#1a1a2e]">補充</h2>
            <p class="m-0 text-[0.92rem] leading-[1.8] text-[#444]">
              {p.notes}
            </p>
          </section>
        )
      }

      <!-- category / subcategory chips → /terminology (no URL-param filter exists) -->
      <section class="mb-8 flex flex-wrap items-center gap-2">
        <span class="text-[0.8rem] text-[#94a3b8]">分類：</span>
        {
          p.category && (
            <a
              href="/terminology"
              class="rounded-full border border-[#ddd] bg-white px-3 py-[0.25rem] text-[0.8rem] font-semibold text-[#555] no-underline transition-colors hover:border-[#1a1a2e] hover:text-[#1a1a2e]"
            >
              {p.category}
            </a>
          )
        }
        {
          p.subcategory && (
            <a
              href="/terminology"
              class="rounded-full border border-[#ddd] bg-white px-3 py-[0.25rem] text-[0.8rem] text-[#666] no-underline transition-colors hover:border-[#1a1a2e] hover:text-[#1a1a2e]"
            >
              {p.subcategory}
            </a>
          )
        }
      </section>

      <!-- CTA: whole-paragraph converter -->
      <a
        href="/terminology/converter"
        class="mb-10 flex items-center justify-between gap-4 rounded-2xl border-[1.5px] border-[#1a1a2e] bg-[#1a1a2e] p-5 text-white no-underline transition-colors hover:bg-[#2d2d50] hover:no-underline"
      >
        <div class="flex flex-col gap-1">
          <span class="text-[1rem] font-bold">想轉換整段文字？</span>
          <span class="text-[0.85rem] opacity-80"
            >用台灣用語轉換器，一鍵把整篇中國用語換成台灣說法</span
          >
        </div>
        <span class="whitespace-nowrap text-[1.4rem]">🔄</span>
      </a>

      <!-- related terms (internal linking) -->
      {
        p.related.length > 0 && (
          <section class="mb-6">
            <h2 class="mb-3 text-[1.05rem] font-bold text-[#1a1a2e]">
              相關用語
            </h2>
            <div class="grid grid-cols-2 gap-3 max-[480px]:grid-cols-1">
              {p.related.map((r) => (
                <a
                  href={`/terminology/${encodeURIComponent(r.id)}`}
                  class="flex flex-col gap-[0.15rem] rounded-xl border border-[#eee] bg-white p-3 no-underline transition-all hover:border-[#ccc] hover:shadow-[0_2px_10px_rgba(0,0,0,0.06)] hover:no-underline"
                >
                  <span class="font-[var(--font-editorial,Georgia,serif)] text-[1.05rem] font-bold text-[#1a1a2e]">
                    {r.taiwan.split(/\s*\/\s*/)[0]}
                  </span>
                  <span class="text-[0.78rem] text-[#94a3b8]">
                    中國：{r.china}
                  </span>
                </a>
              ))}
            </div>
          </section>
        )
      }

      <!-- sources -->
      {
        p.sources.length > 0 && (
          <section class="mb-6 border-t border-[#eee] pt-5">
            <h2 class="mb-2 text-[0.85rem] font-bold uppercase tracking-[0.08em] text-[#94a3b8]">
              來源
            </h2>
            <ul class="m-0 flex list-disc flex-col gap-1 pl-5">
              {p.sources.map((s) =>
                isUrl(s) ? (
                  <li class="text-[0.82rem] text-[#666]">
                    <a
                      href={s.trim()}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="text-[#00695c] underline"
                    >
                      {s.trim()}
                    </a>
                  </li>
                ) : (
                  <li class="text-[0.82rem] text-[#666]">{s}</li>
                ),
              )}
            </ul>
          </section>
        )
      }

      <!-- back link + GitHub source -->
      <div
        class="flex flex-wrap items-center gap-4 border-t border-[#eee] pt-5 text-[0.85rem]"
      >
        <a
          href="/terminology"
          class="text-[#555] no-underline transition-colors hover:text-[#1a1a2e] hover:underline"
        >
          ← 回到用語詞庫
        </a>
        <a
          href={`https://github.com/frank890417/taiwan-md/blob/main/data/terminology/${encodeURIComponent(p.id)}.yaml`}
          target="_blank"
          rel="noopener noreferrer"
          class="text-[#555] no-underline transition-colors hover:text-[#1a1a2e] hover:underline"
        >
          📂 在 GitHub 看這個詞條
        </a>
      </div>
    </div>
  </main>

  <!-- DefinedTerm JSON-LD — single-term definitional intent -->
  <script
    type="application/ld+json"
    set:html={JSON.stringify(definedTermLD, null, 2)}
  />
</Layout>
