---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
import { readdir, readFile } from 'fs/promises';
import { resolve, join } from 'path';

// ── Build-time: read all YAML files in data/terminology/ ──────────────────────
import { parse as parseYaml } from 'yaml';

interface TermEntry {
  id: string;
  category: string;
  fork_type: string; // A / B / C / D / E / F
  display: {
    taiwan: string;
    china?: string;
    hongkong?: string;
    southeast_asia?: string;
  };
  english?: string;
  etymology: {
    origin?: string;
    taiwan_path?: string;
    china_path?: string;
    fork_point?: string;
    fork_cause?: string;
  };
  usage?: {
    taiwan_formal?: boolean;
    taiwan_casual?: boolean;
    exceptions?: string;
  };
  status?: string;
  notes?: string;
  sources?: string[];
  added?: string;
  updated?: string;
}

const termDir = resolve(process.cwd(), 'data/terminology');
const files = await readdir(termDir);
const terms: TermEntry[] = [];

for (const file of files) {
  if (!file.endsWith('.yaml') || file.startsWith('_')) continue;
  const raw = await readFile(join(termDir, file), 'utf-8');
  try {
    const d = parseYaml(raw) as TermEntry;
    // Support both display.{taiwan,china} and top-level {taiwan,china} formats
    if (d && !d.display && ((d as any).taiwan || (d as any).china)) {
      (d as any).display = {
        taiwan: (d as any).taiwan || '',
        china: (d as any).china || '',
      };
      if (!(d as any).fork_type && (d as any).type) {
        (d as any).fork_type = (d as any).type;
      }
    }
    if (d && d.display && d.display.taiwan) {
      terms.push(d);
    }
  } catch {
    // skip malformed
  }
}

// Sort by fork_type then taiwan display
terms.sort((a, b) => {
  const ft = (a.fork_type || 'Z').localeCompare(b.fork_type || 'Z');
  if (ft !== 0) return ft;
  return (a.display?.taiwan || '').localeCompare(
    b.display?.taiwan || '',
    'zh-TW',
  );
});

const totalTerms = terms.length;
const totalSources = (() => {
  const seen = new Set<string>();
  for (const t of terms) {
    for (const s of t.sources || []) if (s) seen.add(s.trim());
  }
  return seen.size;
})();

const forkTypeLabels: Record<string, string> = {
  A: 'A 日語遺產',
  B: 'B 1949分流',
  C: 'C 網路時代',
  D: 'D 台客語底層',
  E: 'E 正在分歧',
  F: 'F 同詞不同語感',
};
const forkTypeColors: Record<string, string> = {
  A: '#e74c3c',
  B: '#3498db',
  C: '#9b59b6',
  D: '#27ae60',
  E: '#f39c12',
  F: '#607d8b',
};

// Pre-process cards data for template (avoid complex expressions in JSX)
interface CardData {
  fork_type: string;
  taiwan: string;
  china: string;
  hongkong: string;
  english: string;
  fork_label: string;
  fork_color: string;
  fork_point: string;
  notes_short: string;
  notes_full: string;
  origin: string;
  taiwan_path: string;
  china_path: string;
  fork_cause: string;
  exceptions: string;
  sources: string[];
  subcategory: string;
}

const cards: CardData[] = terms.map((t) => {
  const forkColor = forkTypeColors[t.fork_type] || '#999';
  const forkLabel = forkTypeLabels[t.fork_type] || t.fork_type;
  const notesClean = (t.notes || '').split('\n').join(' ').trim();
  const notesShort =
    notesClean.length > 90 ? notesClean.slice(0, 90) + '…' : notesClean;
  return {
    fork_type: t.fork_type || '',
    taiwan: t.display?.taiwan || '',
    china: t.display?.china || '',
    hongkong: t.display?.hongkong || '',
    english: t.english || '',
    fork_label: forkLabel,
    fork_color: forkColor,
    fork_point: t.etymology?.fork_point || '',
    notes_short: notesShort,
    notes_full: notesClean,
    origin: (t.etymology?.origin || '').split('\n').join(' ').trim(),
    taiwan_path: (t.etymology?.taiwan_path || '').split('\n').join(' ').trim(),
    china_path: (t.etymology?.china_path || '').split('\n').join(' ').trim(),
    fork_cause: (t.etymology?.fork_cause || '').split('\n').join(' ').trim(),
    exceptions: (t.usage?.exceptions || '').split('\n').join(' ').trim(),
    sources: (t.sources || []).filter(Boolean),
    subcategory: t.subcategory || '',
  };
});

// Collect subcategories with counts (sorted by count desc, skip empty)
const subcatCounts: Record<string, number> = {};
for (const c of cards) {
  if (c.subcategory) {
    subcatCounts[c.subcategory] = (subcatCounts[c.subcategory] || 0) + 1;
  }
}
const subcategories = Object.entries(subcatCounts)
  .sort((a, b) => b[1] - a[1])
  .map(([name, count]) => ({ name, count }));

// Serialize for client-side JS
const termsJSON = JSON.stringify(terms);
---

<!--
  Phase 6 partial migration — terminology/index.astro
  ───────────────────────────────────────────────────
  - Wrappers (header, filter bar, grid container, footer, fork popup)
    moved to inline Tailwind
  - `.term-page` kept as hook: referenced in global.css
    `body.page-default main.term-page { padding-top: 0 }`
  - Repeating card pattern (.term-card + all .card-* / .expand-* /
    .fork-badge / .fork-point children) stays in scoped <style>
    because it repeats per term (~100s of cards)
  - .filter-btn / .subcat-btn stay scoped because they use the
    `.active` state class + `--fork-color` CSS variable for the
    per-type accent color; inlining would need both [&.active]:
    AND arbitrary `hover:border-[var(--fork-color)]` on every button
-->
<Layout title="📖 用語保存計畫 — Taiwan.md">
  <main class="term-page flex min-h-screen flex-col bg-[#f8f8f8]">
    <!-- ── Header（共用 PageHero 元件） ─────────────────────── -->
    <PageHero
      bgVariant="solid"
      bgColor="#1a1a2e"
      bgTone="dark"
      titleVariant="inherit"
      titleSize="md"
      containerWidth="wide"
      padding="default"
    >
      <Fragment slot="title">
        📖 用語保存計畫
        <span
          class="mt-[0.2em] block font-[var(--font-ui,system-ui,sans-serif)] text-[0.45em] font-normal tracking-[0.04em] opacity-[0.65]"
          >Terminology Preservation</span
        >
      </Fragment>
      <Fragment slot="subtitle">
        Taiwan.md 的文字讀起來像在台灣長大的人寫的，保留語言裡的生活經驗與文化記憶。<br /><br />
        語言彼此滲透是常態，把那份脈絡攤開——你保留哪些字、放下哪些字，由你自己決定。
      </Fragment>
      <Fragment slot="meta">
        <span class="[&_strong]:text-[1.05em] [&_strong]:text-white"
          ><strong>{totalTerms}</strong> 個詞條</span
        >
        <span class="opacity-40">｜</span>
        <span class="[&_strong]:text-[1.05em] [&_strong]:text-white"
          ><strong>6</strong> 種分歧類型</span
        >
        <span class="opacity-40">｜</span>
        <span class="[&_strong]:text-[1.05em] [&_strong]:text-white"
          ><strong>{totalSources}</strong> 個來源</span
        >
      </Fragment>

      <div class="mt-6 flex flex-wrap justify-center gap-2">
        <a
          href="/terminology/converter"
          class="inline-flex items-center gap-[0.4rem] whitespace-nowrap rounded-lg border border-white/25 bg-white/10 px-4 py-[0.45rem] text-[0.88rem] font-semibold text-white no-underline transition-[background,border-color] duration-150 hover:border-white/40 hover:bg-white/20 hover:no-underline"
        >
          🔄 用語轉換器 →
        </a>
        <a
          href="/fork-graph"
          class="inline-flex items-center gap-[0.4rem] whitespace-nowrap rounded-lg border border-white/25 bg-white/10 px-4 py-[0.45rem] text-[0.88rem] font-semibold text-white no-underline transition-[background,border-color] duration-150 hover:border-white/40 hover:bg-white/20 hover:no-underline"
        >
          🌿 語言分支樹 →
        </a>
      </div>
    </PageHero>

    <!-- ── Filter bar ─────────────────────────────────────────── -->
    <div
      class="sticky top-0 z-10 border-b border-[#e5e5e5] bg-white shadow-[0_2px_8px_rgba(0,0,0,0.06)]"
    >
      <div
        class="mx-auto flex max-w-[72rem] flex-wrap items-center gap-4 px-[var(--space-page-x,2rem)] py-[0.85rem] max-[640px]:flex-col max-[640px]:items-stretch max-[640px]:px-4 max-[640px]:py-3"
      >
        <div
          class="flex flex-1 flex-wrap gap-[0.4rem]"
          role="group"
          aria-label="依分歧類型篩選"
        >
          <button class="filter-btn active" data-fork="all">全部</button>
          {
            Object.entries(forkTypeLabels).map(([key, label]) => (
              <button
                class="filter-btn"
                data-fork={key}
                style={`--fork-color: ${forkTypeColors[key]}`}
              >
                {label}
              </button>
            ))
          }
        </div>
        <div class="flex min-w-[180px] items-center gap-2 max-[640px]:w-full">
          <input
            id="term-search"
            type="search"
            placeholder="搜尋詞條…"
            aria-label="搜尋用語詞條"
            class="w-[180px] rounded-md border-[1.5px] border-[#ddd] px-[0.8rem] py-[0.38rem] font-[inherit] text-[0.9rem] outline-none transition-colors duration-200 focus:border-[#1a1a2e] max-[640px]:w-full max-[640px]:flex-1"
          />
          <span
            id="result-count"
            class="whitespace-nowrap text-[0.8rem] text-[#888]"></span>
        </div>
        <div
          class="mt-[0.6rem] flex w-full flex-wrap gap-[0.35rem] border-t border-[#eee] pt-[0.6rem]"
          role="group"
          aria-label="依子分類篩選"
        >
          <button class="subcat-btn active" data-subcat="all">全部分類</button>
          {
            subcategories.map((s) => (
              <button class="subcat-btn" data-subcat={s.name}>
                {s.name}{' '}
                <span class="text-[0.65rem] opacity-60">{s.count}</span>
              </button>
            ))
          }
        </div>
      </div>
    </div>

    <!-- ── Cards grid ─────────────────────────────────────────── -->
    <div
      class="mx-auto box-border w-full max-w-[72rem] flex-1 px-[var(--space-page-x,2rem)] py-8 max-[640px]:px-4 max-[640px]:py-5"
    >
      <div
        class="grid grid-cols-3 gap-5 max-[1024px]:grid-cols-2 max-[640px]:grid-cols-1"
        id="terms-grid"
      >
        {
          cards.map((c, i) => (
            <div
              class="term-card"
              data-fork={c.fork_type}
              data-taiwan={c.taiwan}
              data-china={c.china}
              data-notes={c.notes_full}
              data-subcat={c.subcategory}
              data-id={`card-${i}`}
              role="article"
              tabindex="0"
              aria-expanded="false"
            >
              <div class="card-top">
                <div class="card-main">
                  <span class="taiwan-word">{c.taiwan}</span>
                  {c.china && <span class="china-word">中：{c.china}</span>}
                  {c.hongkong && <span class="hk-word">港：{c.hongkong}</span>}
                </div>
                <div class="card-meta">
                  <button
                    class="fork-tree-btn"
                    title="查看語言分支樹"
                    aria-label={`查看「${c.taiwan}」的語言分支樹`}
                    data-tw={c.taiwan}
                    data-cn={c.china || c.taiwan}
                    data-origin={c.origin || ''}
                    data-fork-point={c.fork_point || ''}
                    data-fork-type={c.fork_type}
                    data-fork-color={c.fork_color}
                    data-tw-path={c.taiwan_path || ''}
                    data-cn-path={c.china_path || ''}
                  >
                    🌿
                  </button>
                  <span
                    class="fork-badge"
                    style={`background: ${c.fork_color}22; color: ${c.fork_color}; border-color: ${c.fork_color}44`}
                  >
                    {c.fork_label}
                  </span>
                  {c.fork_point && (
                    <span class="fork-point">{c.fork_point}</span>
                  )}
                </div>
              </div>
              {c.notes_short && <p class="card-notes-short">{c.notes_short}</p>}
              <div class="card-expand" aria-hidden="true">
                <div class="expand-content">
                  {c.origin && (
                    <div class="expand-section">
                      <h4>詞源</h4>
                      <p>{c.origin}</p>
                    </div>
                  )}
                  {c.taiwan_path && (
                    <div class="expand-section">
                      <h4>台灣路徑</h4>
                      <p>{c.taiwan_path}</p>
                    </div>
                  )}
                  {c.china_path && (
                    <div class="expand-section">
                      <h4>中國路徑</h4>
                      <p>{c.china_path}</p>
                    </div>
                  )}
                  {c.fork_cause && (
                    <div class="expand-section">
                      <h4>分歧原因</h4>
                      <p>{c.fork_cause}</p>
                    </div>
                  )}
                  {c.exceptions && (
                    <div class="expand-section">
                      <h4>例外情境</h4>
                      <p>{c.exceptions}</p>
                    </div>
                  )}
                  {c.sources.length > 0 && (
                    <div class="expand-section sources-section">
                      <h4>來源</h4>
                      <ul>
                        {c.sources.map((src) => (
                          <li>{src}</li>
                        ))}
                      </ul>
                    </div>
                  )}
                  {c.english && (
                    <div class="expand-english">
                      English: <em>{c.english}</em>
                    </div>
                  )}
                </div>
              </div>
              <button
                class="expand-toggle"
                aria-label={`展開 ${c.taiwan} 詞源`}
              >
                <span class="toggle-text">查看詞源</span>
                <span class="toggle-icon">▼</span>
              </button>
            </div>
          ))
        }
      </div>
      <p
        class="hidden py-12 text-center text-[0.95rem] text-[#999]"
        id="no-results"
      >
        找不到符合條件的詞條。
      </p>
    </div>

    <!-- ── Footer ─────────────────────────────────────────────── -->
    <div
      class="mt-auto bg-[#1a1a2e] px-[var(--space-page-x,2rem)] py-8 text-white max-[640px]:px-4 max-[640px]:py-6"
    >
      <div class="mx-auto flex max-w-[72rem] flex-col gap-3">
        <div
          class="flex flex-wrap items-center gap-4 max-[640px]:flex-col max-[640px]:items-start"
        >
          <a
            href="https://github.com/taiwan-md/taiwan-md/tree/main/data/terminology"
            target="_blank"
            rel="noopener noreferrer"
            class="py-[0.3rem] text-[0.9rem] text-white/75 no-underline transition-colors duration-150 hover:text-white hover:underline"
          >
            📂 在 GitHub 瀏覽詞條資料
          </a>
          <a
            href="/contribute"
            class="rounded-md border border-white/30 bg-white/15 px-4 py-[0.4rem] text-[0.9rem] !font-semibold !text-white no-underline transition-colors duration-150 hover:bg-white/[0.22] hover:!no-underline"
          >
            ✏️ 貢獻詞條
          </a>
          <a
            href="/culture/台灣華語的演化"
            class="py-[0.3rem] text-[0.9rem] text-white/75 no-underline transition-colors duration-150 hover:text-white hover:underline"
          >
            📝 台灣華語的演化
          </a>
        </div>
        <p class="m-0 text-[0.8rem] opacity-45">
          用語保存計畫持續收錄中。每個詞條都有詞源考據與使用建議。
        </p>
      </div>
    </div>
    <!-- ── Fork Tree Popup ────────────────────────────────────── -->
    <div
      class="fixed inset-0 z-[9999] hidden items-center justify-center bg-black/50 p-4 backdrop-blur-[4px] [&.visible]:flex"
      id="fork-popup"
      aria-hidden="true"
    >
      <div
        class="relative max-h-[90vh] w-full max-w-[560px] overflow-y-auto rounded-2xl bg-white p-6 shadow-[0_20px_60px_rgba(0,0,0,0.2)]"
      >
        <button
          class="fork-popup-close absolute right-3 top-3 flex h-8 w-8 items-center justify-center rounded-full border-none bg-[#f0f0f0] text-base transition-colors duration-150 hover:bg-[#ddd]"
          aria-label="關閉">✕</button
        >
        <h3
          class="m-0 mb-4 text-[1.2rem] font-bold text-[#1a1a2e]"
          id="fork-popup-title"
        >
        </h3>
        <div class="mb-4 overflow-x-auto">
          <svg id="fork-popup-svg" width="100%" height="180"></svg>
        </div>
        <div
          class="text-[0.85rem] leading-[1.6] text-[#555] [&_.info-label]:min-w-[3.5rem] [&_.info-label]:whitespace-nowrap [&_.info-label]:font-semibold [&_.info-label]:text-[#333] [&_.info-row]:mb-[0.4rem] [&_.info-row]:flex [&_.info-row]:gap-2"
          id="fork-popup-info"
        >
        </div>
      </div>
    </div>
  </main>
</Layout>

<script define:vars={{ termsJSON }}>
  const terms = JSON.parse(termsJSON);
  const grid = document.getElementById('terms-grid');
  const noResults = document.getElementById('no-results');
  const searchInput = document.getElementById('term-search');
  const resultCount = document.getElementById('result-count');
  const filterBtns = document.querySelectorAll('.filter-btn');

  let currentFork = 'all';
  let currentSubcat = 'all';
  let currentQuery = '';

  function applyFilters() {
    const cards = grid ? grid.querySelectorAll('.term-card') : [];
    let visible = 0;
    cards.forEach((card) => {
      const fork = card.dataset.fork || '';
      const subcat = card.dataset.subcat || '';
      const taiwan = (card.dataset.taiwan || '').toLowerCase();
      const china = (card.dataset.china || '').toLowerCase();
      const notes = (card.dataset.notes || '').toLowerCase();
      const q = currentQuery.toLowerCase();

      const forkMatch = currentFork === 'all' || fork === currentFork;
      const subcatMatch = currentSubcat === 'all' || subcat === currentSubcat;
      const queryMatch =
        !q || taiwan.includes(q) || china.includes(q) || notes.includes(q);

      const show = forkMatch && subcatMatch && queryMatch;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });

    if (noResults) {
      noResults.classList.toggle('hidden', visible !== 0);
    }
    if (resultCount) {
      resultCount.textContent =
        currentFork !== 'all' || currentSubcat !== 'all' || currentQuery
          ? `${visible} 個詞條`
          : '';
    }
  }

  // Filter buttons
  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      filterBtns.forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');
      currentFork = btn.dataset.fork || 'all';
      applyFilters();
    });
  });

  // Subcategory filter buttons
  const subcatBtns = document.querySelectorAll('.subcat-btn');
  subcatBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      subcatBtns.forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');
      currentSubcat = btn.dataset.subcat || 'all';
      applyFilters();
    });
  });

  // Search
  if (searchInput) {
    searchInput.addEventListener('input', (e) => {
      currentQuery = e.target.value;
      applyFilters();
    });
  }

  // Expand/collapse cards
  function toggleCard(card) {
    const isOpen = card.getAttribute('aria-expanded') === 'true';
    card.setAttribute('aria-expanded', String(!isOpen));
    const expand = card.querySelector('.card-expand');
    const toggleText = card.querySelector('.toggle-text');
    const toggleIcon = card.querySelector('.toggle-icon');
    if (expand) {
      expand.style.maxHeight = isOpen ? '0' : expand.scrollHeight + 'px';
      expand.setAttribute('aria-hidden', String(isOpen));
    }
    if (toggleText) toggleText.textContent = isOpen ? '查看詞源' : '收起';
    if (toggleIcon) toggleIcon.style.transform = isOpen ? '' : 'rotate(180deg)';
  }

  document.querySelectorAll('.term-card').forEach((card) => {
    const btn = card.querySelector('.expand-toggle');
    if (btn) {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        toggleCard(card);
      });
    }
    card.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        toggleCard(card);
      }
    });
  });

  // ── Fork Tree Popup ──────────────────────────────────────────
  const popup = document.getElementById('fork-popup');
  const popupTitle = document.getElementById('fork-popup-title');
  const popupInfo = document.getElementById('fork-popup-info');
  const popupSvg = document.getElementById('fork-popup-svg');
  const popupClose = popup?.querySelector('.fork-popup-close');

  function openForkPopup(btn) {
    const tw = btn.dataset.tw;
    const cn = btn.dataset.cn;
    const origin = btn.dataset.origin;
    const forkPoint = btn.dataset.forkPoint;
    const forkType = btn.dataset.forkType;
    const forkColor = btn.dataset.forkColor;
    const twPath = btn.dataset.twPath;
    const cnPath = btn.dataset.cnPath;

    popupTitle.textContent = `🌿 ${tw}${cn && cn !== tw ? ` / ${cn}` : ''}`;

    // Draw mini fork tree with SVG (no D3 needed for single term)
    const W = 500,
      H = 160;
    const sameTerm = !cn || cn === tw;
    popupSvg.setAttribute('viewBox', `0 0 ${W} ${H}`);
    popupSvg.innerHTML = '';

    // Layout: origin node left → fork point center → two branches right
    const ox = 60,
      oy = H / 2;
    const fx = W * 0.45,
      fy = H / 2;
    const twX = W - 80,
      twY = 50;
    const cnX = W - 80,
      cnY = H - 50;

    // Path: origin → fork
    const pathOriginFork = `M${ox},${oy} C${fx - 40},${oy} ${fx - 40},${fy} ${fx},${fy}`;
    // Path: fork → taiwan
    const pathTW = `M${fx},${fy} C${fx + 60},${fy} ${twX - 60},${twY} ${twX},${twY}`;
    // Path: fork → china
    const pathCN = sameTerm
      ? ''
      : `M${fx},${fy} C${fx + 60},${fy} ${cnX - 60},${cnY} ${cnX},${cnY}`;

    const twColor = '#e74c3c';
    const cnColor = '#3498db';
    const originColor = '#888';

    let svg = `
      <path d="${pathOriginFork}" fill="none" stroke="${originColor}" stroke-width="2" stroke-dasharray="6,3"/>
      <path d="${pathTW}" fill="none" stroke="${twColor}" stroke-width="2.5"/>
      ${!sameTerm ? `<path d="${pathCN}" fill="none" stroke="${cnColor}" stroke-width="2.5"/>` : ''}
      <circle cx="${ox}" cy="${oy}" r="6" fill="${originColor}"/>
      <circle cx="${fx}" cy="${fy}" r="5" fill="#555"/>
      <circle cx="${twX}" cy="${twY}" r="7" fill="${twColor}"/>
      ${!sameTerm ? `<circle cx="${cnX}" cy="${cnY}" r="7" fill="${cnColor}"/>` : ''}
      <text x="${ox}" y="${oy - 14}" text-anchor="middle" font-size="11" fill="#888">詞源</text>
      <text x="${fx}" y="${fy - 14}" text-anchor="middle" font-size="10" fill="#888">${forkPoint || '分歧點'}</text>
      <text x="${twX}" y="${twY - 14}" text-anchor="middle" font-size="12" font-weight="700" fill="${twColor}">🇹🇼 ${tw}</text>
      ${!sameTerm ? `<text x="${cnX}" y="${cnY + 22}" text-anchor="middle" font-size="12" font-weight="700" fill="${cnColor}">🇨🇳 ${cn}</text>` : ''}
    `;

    if (sameTerm) {
      // F type: same word, different feel
      svg += `<text x="${twX}" y="${twY + 20}" text-anchor="middle" font-size="10" fill="#888">同詞不同語感</text>`;
    }

    popupSvg.innerHTML = svg;

    // Info section
    let info = '';
    if (origin)
      info += `<div class="info-row"><span class="info-label">詞源</span><span>${origin}</span></div>`;
    if (twPath)
      info += `<div class="info-row"><span class="info-label">🇹🇼 台灣</span><span>${twPath}</span></div>`;
    if (cnPath)
      info += `<div class="info-row"><span class="info-label">🇨🇳 中國</span><span>${cnPath}</span></div>`;
    popupInfo.innerHTML = info;

    popup.classList.add('visible');
    popup.setAttribute('aria-hidden', 'false');
  }

  function closeForkPopup() {
    popup.classList.remove('visible');
    popup.setAttribute('aria-hidden', 'true');
  }

  // Bind click events
  document.querySelectorAll('.fork-tree-btn').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      openForkPopup(btn);
    });
  });

  popupClose?.addEventListener('click', closeForkPopup);
  popup?.addEventListener('click', (e) => {
    if (e.target === popup) closeForkPopup();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && popup?.classList.contains('visible'))
      closeForkPopup();
  });
</script>

