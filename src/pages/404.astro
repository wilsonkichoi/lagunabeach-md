---
import Layout from '../layouts/Layout.astro';
import fs from 'fs';
import path from 'path';
import { LANGUAGES, DEFAULT_LANGUAGE } from '../config/languages';

// 2026-04-25 β7 Phase 1：fix B1 cascade (i18n-evolution-roadmap audit)
// 從 LANGUAGES_REGISTRY 動態 derive，取代之前 hardcoded ['en', 'ja', 'ko']
// 透過 define:vars inject 給 client-side script
const nonDefaultLangCodes = LANGUAGES.filter(
  (l) => l.enabled && l.code !== DEFAULT_LANGUAGE.code,
).map((l) => l.code);

// Read article index at build time (inline into page)
let articleIndex: Record<
  string,
  { zhTitle: string; enTitle: string; category: string; langs: string[] }
> = {};
try {
  const indexPath = path.join(
    process.cwd(),
    'public',
    'api',
    'article-index.json',
  );
  if (fs.existsSync(indexPath)) {
    articleIndex = JSON.parse(fs.readFileSync(indexPath, 'utf-8'));
  }
} catch {}

// i18n strings embedded for client-side use
const i18n: Record<string, Record<string, string>> = {
  'zh-TW': {
