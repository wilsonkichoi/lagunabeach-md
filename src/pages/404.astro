const categories = [
  'history',
  'culture',
  'food',
  'art',
  'music',
  'technology',
  'nature',
  'people',
  'economy',
  'society',
];
---

<!--
  Phase 6 page migration #3: 404.astro
  ────────────────────────────────────
  - Scoped <style> removed entirely (~210 lines CSS deleted)
  - .error-page / .search-form kept as semantic hooks (referenced by
    the <script> further down for JS-side form interception)
  - .category-chips uses [&_a]:... arbitrary-child variants for the
    static <a> children rendered from {categories.map(...)}
  - The JS-created .lang-chip elements are now assigned Tailwind
    utility strings directly in the <script> block — no CSS hook
    needed
-->
<Layout title="404 | Taiwan.md">
  <main
    class="error-page flex min-h-[80vh] items-center justify-center px-[var(--space-page-x)] py-8 opacity-0 transition-opacity duration-150"
  >
    <!-- Generic 404 -->
    <div class="max-w-[600px] text-center" id="notfound-generic">
      <h1
        class="m-0 text-[clamp(4rem,10vw,8rem)] font-black leading-none text-[#1a1a2e] opacity-[0.15]"
      >
        404
      </h1>
      <p
        class="my-2 font-[var(--font-editorial)] text-[1.5rem] font-bold"
        data-i18n="generic.title"
      >
        這個頁面不存在
      </p>
      <p class="mb-8 leading-[1.6] text-[#666]" data-i18n="generic.desc">
        可能是連結過期、文章被移動，或是網址打錯了。
      </p>

      <div
        class="mb-10 flex justify-center gap-4 max-[640px]:flex-col max-[640px]:items-center"
      >
        <a
          href="/"
          class="inline-flex items-center rounded-lg bg-[#1a1a2e] px-5 py-[0.6rem] text-[0.95rem] font-semibold text-white no-underline transition-all duration-200 hover:bg-[#2d2d4a]"
          id="back-link"
          data-i18n-text="back">← 回首頁</a
        >
        <a
          href="/graph"
          class="inline-flex items-center rounded-lg bg-[#f0f0f0] px-5 py-[0.6rem] text-[0.95rem] font-semibold text-[#333] no-underline transition-all duration-200 hover:bg-[#e0e0e0]"
          >🕸️ Knowledge Graph</a
        >
      </div>

      <div class="mb-10">
        <p class="mb-3 text-[0.9rem] text-[#888]" data-i18n="search.prompt">
          試試搜尋你要找的內容：
        </p>
        <form
          action="https://www.google.com/search"
          method="get"
          target="_blank"
          class="search-form flex justify-center gap-2 max-[640px]:flex-col max-[640px]:items-center"
        >
          <input type="hidden" name="q" value="site:taiwan.md" />
          <input
            type="text"
            name="q"
            placeholder="搜尋 Taiwan.md…"
            class="w-[280px] rounded-lg border-2 border-[#e0e0e0] px-4 py-2 text-[0.95rem] outline-none transition-colors duration-200 focus:border-[#1a1a2e] max-[640px]:w-full"
            aria-label="搜尋 Taiwan.md"
            data-i18n-placeholder="search.placeholder"
          />
          <button
            type="submit"
            class="inline-flex cursor-pointer items-center rounded-lg border-none bg-[#1a1a2e] px-5 py-[0.6rem] text-[0.95rem] font-semibold text-white no-underline transition-all duration-200 hover:bg-[#2d2d4a]"
            data-i18n-text="search.label">搜尋</button
          >
        </form>
      </div>

      <div
        class="mb-10 rounded-xl border border-[#fcd34d] bg-[#fef3c7] px-6 py-5"
      >
        <p class="m-0 mb-[0.4rem] text-base font-bold" data-i18n="bug.title">
          🐛 這是個 Bug 嗎？
        </p>
        <p class="m-0 mb-4 text-[0.88rem] text-[#666]" data-i18n="bug.desc">
          如果你覺得這個頁面應該存在，歡迎回報讓我們修復：
        </p>
        <a
          href={`https://github.com/frank890417/taiwan-md/issues/new?template=broken-link.yml&title=404:+${encodeURIComponent('[填入你看到的網址]')}&labels=bug,broken-link`}
          class="inline-flex items-center rounded-lg bg-[#f59e0b] px-5 py-[0.6rem] text-[0.9rem] font-semibold text-white no-underline transition-all duration-200 hover:bg-[#d97706]"
          target="_blank"
          rel="noopener"
          id="report-link"
          data-i18n-text="bug.btn"
        >
          📋 回報失效連結 (GitHub Issue)
        </a>
      </div>

      <div
        class="[&_a:hover]:bg-[#1a1a2e] [&_a:hover]:text-white [&_a]:rounded-[20px] [&_a]:bg-[#f5f5f5] [&_a]:px-3 [&_a]:py-[0.35rem] [&_a]:text-[0.85rem] [&_a]:text-[#333] [&_a]:no-underline [&_a]:transition-all [&_a]:duration-200"
      >
        <p class="mb-3 text-[0.9rem] text-[#888]" data-i18n="explore">
          或者探索這些主題：
        </p>
        <div
          class="category-chips flex flex-wrap justify-center gap-2"
          id="category-chips"
        >
          {
            categories.map((cat) => (
              <a
                href={`/${cat}`}
                data-category={cat}
                data-i18n-text={`cat.${cat}`}
              >
                {i18n['zh-TW'][`cat.${cat}`]}
              </a>
            ))
          }
        </div>
      </div>
    </div>

    <!-- Untranslated article notice (hidden by default) -->
    <div class="hidden max-w-[600px] text-center" id="notfound-untranslated">
      <h1
        class="m-0 text-[clamp(4rem,10vw,8rem)] font-black leading-none text-[#1a1a2e] opacity-[0.08]"
      >
        📝
      </h1>
      <p
        class="my-2 font-[var(--font-editorial)] text-[1.5rem] font-bold"
        id="untranslated-title"
        data-i18n="untranslated.title"
      >
        這篇文章尚未翻譯
      </p>
      <p class="mb-8 leading-[1.6] text-[#666]" id="untranslated-desc"></p>

      <div class="my-6" id="lang-links">
        <p class="mb-3 text-[0.9rem] text-[#888]" data-i18n="untranslated.view">
          查看其他語言版本：
        </p>
        <div class="flex flex-wrap justify-center gap-2" id="lang-chips"></div>
      </div>

      <div
        class="mt-6 rounded-xl border border-[#90caf9] bg-[#e3f2fd] px-6 py-5"
      >
        <p
          class="m-0 mb-3 font-semibold text-[#1565c0]"
          id="contribute-text"
          data-i18n="untranslated.contribute"
        >
          想幫忙翻譯？
        </p>
        <a
          href="https://github.com/frank890417/taiwan-md/blob/main/CONTRIBUTING.md"
          class="inline-flex items-center rounded-lg bg-[#1a1a2e] px-5 py-[0.6rem] text-[0.95rem] font-semibold text-white no-underline transition-all duration-200 hover:bg-[#2d2d4a]"
          target="_blank"
          rel="noopener"
        >
          CONTRIBUTING.md
        </a>
      </div>

      <div
        class="mt-8 flex justify-center gap-4 max-[640px]:flex-col max-[640px]:items-center"
      >
        <a
          href="/"
          class="inline-flex items-center rounded-lg bg-[#f0f0f0] px-5 py-[0.6rem] text-[0.95rem] font-semibold text-[#333] no-underline transition-all duration-200 hover:bg-[#e0e0e0]"
          id="back-link-2"
          data-i18n-text="back">← 回首頁</a
        >
      </div>

      <div
        class="mt-8 [&_a:hover]:bg-[#1a1a2e] [&_a:hover]:text-white [&_a]:rounded-[20px] [&_a]:bg-[#f5f5f5] [&_a]:px-3 [&_a]:py-[0.35rem] [&_a]:text-[0.85rem] [&_a]:text-[#333] [&_a]:no-underline [&_a]:transition-all [&_a]:duration-200"
      >
        <p class="mb-3 text-[0.9rem] text-[#888]" data-i18n="explore">
          或者探索這些主題：
        </p>
        <div class="flex flex-wrap justify-center gap-2" id="category-chips-2">
          {
            categories.map((cat) => (
              <a
                href={`/${cat}`}
                data-category={cat}
                data-i18n-text={`cat.${cat}`}
              >
                {i18n['zh-TW'][`cat.${cat}`]}
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </main>
</Layout>

<script define:vars={{ articleIndex, i18n, nonDefaultLangCodes }}>
  (() => {
    const main = document.querySelector('.error-page');
    const pathname = window.location.pathname;

    // Detect language from URL
    // 2026-04-25 β7: 用 LANGUAGES_REGISTRY-derive 清單取代 hardcoded ['en','ja','ko']
    // 修復「進 fr/es 404 後切其他語言會路由疊加」的 cascade bug
    let lang = 'zh-TW';
    let pathWithoutLang = pathname;
    for (const prefix of nonDefaultLangCodes) {
      if (pathname.startsWith(`/${prefix}/`) || pathname === `/${prefix}`) {
        lang = prefix;
        pathWithoutLang = pathname.slice(prefix.length + 1) || '/';
        break;
      }
    }

    const strings = i18n[lang] || i18n['zh-TW'];
    const langPrefix = lang === 'zh-TW' ? '' : `/${lang}`;
    const homeHref = langPrefix || '/';

    // Localize all i18n elements
    document.querySelectorAll('[data-i18n]').forEach((el) => {
      const key = el.getAttribute('data-i18n');
      if (strings[key]) el.textContent = strings[key];
    });
    document.querySelectorAll('[data-i18n-text]').forEach((el) => {
      const key = el.getAttribute('data-i18n-text');
      if (strings[key]) el.textContent = strings[key];
    });
    document.querySelectorAll('[data-i18n-placeholder]').forEach((el) => {
      const key = el.getAttribute('data-i18n-placeholder');
      if (strings[key])
        el.setAttribute(
          'placeholder',
          key === 'search.placeholder' ? strings[key] : strings[key],
        );
    });

    // Update home links
    document.querySelectorAll('#back-link, #back-link-2').forEach((el) => {
      el.setAttribute('href', homeHref);
    });

    // Update category chips with language prefix
    document
      .querySelectorAll('#category-chips a, #category-chips-2 a')
      .forEach((el) => {
        const cat = el.getAttribute('data-category');
        el.setAttribute('href', `${langPrefix}/${cat}`);
      });

    // Auto-fill bug report link
    const reportLink = document.getElementById('report-link');
    if (reportLink) {
      const href = reportLink.getAttribute('href');
      reportLink.setAttribute(
        'href',
        href.replace(
          encodeURIComponent('[填入你看到的網址]'),
          encodeURIComponent(pathname),
        ),
      );
    }

    // Fix Google search form
    const form = document.querySelector('.search-form');
    if (form) {
      form.addEventListener('submit', (e) => {
        const inputs = form.querySelectorAll('input[name="q"]');
        if (inputs.length === 2) {
          const sitePrefix = inputs[0].value;
          const userQuery = inputs[1].value.trim();
          if (userQuery) {
            inputs[0].value = `${sitePrefix} ${userQuery}`;
            inputs[1].removeAttribute('name');
          }
        }
      });
    }

    // Smart detection: is this a known but untranslated article?
    if (lang !== 'zh-TW' && pathWithoutLang !== '/') {
      // Parse: /food/beef-noodle-soup → category=food, slug=beef-noodle-soup
      const parts = pathWithoutLang
        .replace(/^\//, '')
        .replace(/\/$/, '')
        .split('/');
      if (parts.length === 2) {
        const [category, slug] = parts;
        const key = `${category}/${decodeURIComponent(slug)}`;
        const article = articleIndex[key];

        if (article && !article.langs.includes(lang)) {
          // Article exists but not in this language!
          document.getElementById('notfound-generic').classList.add('hidden');
          const untranslatedEl = document.getElementById(
            'notfound-untranslated',
          );
          untranslatedEl.classList.remove('hidden');

          // Build description
          const desc = document.getElementById('untranslated-desc');
          const titleDisplay =
            article.enTitle !== article.zhTitle
              ? `${article.zhTitle} (${article.enTitle})`
              : article.zhTitle;
          desc.textContent = `${strings['untranslated.desc.prefix']}${titleDisplay}${strings['untranslated.desc.suffix']}`;

          // Build language links
          const chipsContainer = document.getElementById('lang-chips');
          const langUrls = {
            'zh-TW': `/${category}/${encodeURIComponent(article.zhTitle)}`,
            en: `/en/${category}/${slug}`,
            ja: `/ja/${category}/${slug}`,
            ko: `/ko/${category}/${slug}`,
          };

          for (const availLang of article.langs) {
            const chip = document.createElement('a');
            chip.href = langUrls[availLang] || '#';
            chip.textContent = strings[`lang.${availLang}`] || availLang;
            // Tailwind utility string — keeps the JS-created chip
            // consistent with the rest of the Tailwind-first markup
            chip.className =
              'inline-flex items-center rounded-lg border border-[#a5d6a7] bg-[#e8f5e9] px-4 py-2 text-[0.95rem] font-semibold text-[#2e7d32] no-underline transition-all duration-200 hover:border-[#66bb6a] hover:bg-[#c8e6c9]';
            chipsContainer.appendChild(chip);
          }
        }
      }
    }

    // Reveal page (prevent FOUC)
    main.style.opacity = '1';

    // ─── 404 Observability (2026-04-11) ───────────────────
    // Track the actual failed URL so we can diagnose which paths 404.
    // GA4 otherwise only tells us "404 page visited" without the path.
    // See reports/sense-2026-04-11.md §2 for the full rationale.
    try {
      if (typeof window !== 'undefined' && typeof window.gtag === 'function') {
        window.gtag('event', 'page_404', {
          failed_path: window.location.pathname,
          failed_url: window.location.href,
          referrer: document.referrer || '(direct)',
          page_lang: document.documentElement.lang || 'unknown',
          had_suggestion: !!article,
        });
      }
    } catch (e) {
      // Never let tracking break the 404 page itself
    }
  })();
</script>
