---
/**
 * zh-TW article slug page — thin wrapper.
 *
 * Per about/dashboard pattern, this page only handles getStaticPaths (per-lang
 * fs scan to enumerate which articles exist) and delegates all rendering to
 * src/templates/article.template.astro.
 *
 * 2026-05-03 sleepy-colden Tier 2.5 Phase B：unified template extraction，
 * 中文 SSOT canonical 版本，其他 5 langs 對齊到這份 wrapper 結構。
 */
import { readdir, readFile } from 'fs/promises';
import { resolve, join, basename } from 'path';
import matter from 'gray-matter';
import ArticleTemplate from '../../templates/article.template.astro';
import {
  buildGitInfoCache,
  emptyGitInfo,
  type GitInfo,
} from '../../utils/contributors';

// ── Git helpers (module-level cache) ─────────────────────────────────────────
let _gitCache: Map<string, GitInfo> | null = null;
function getGitInfo(filePath: string) {
  if (!_gitCache) _gitCache = buildGitInfoCache('knowledge/');
  return _gitCache.get(filePath) || emptyGitInfo();
}

// ── getStaticPaths ───────────────────────────────────────────────────────────
// Astro 限制：getStaticPaths 在獨立 context 跑，不能 access module-level consts。
// 所以 CATEGORY_MAPPING 必須 inline 進 getStaticPaths body。
export async function getStaticPaths() {
  const CATEGORY_MAPPING: Record<string, string> = {
    about: 'About',
    history: 'History',
    geography: 'Geography',
    culture: 'Culture',
    food: 'Food',
    art: 'Art',
    music: 'Music',
    technology: 'Technology',
    nature: 'Nature',
    people: 'People',
    society: 'Society',
    economy: 'Economy',
    lifestyle: 'Lifestyle',
  };

  const safeMatter = (fileContent: string) => {
    try {
      return matter(fileContent);
    } catch {
      const stripped = fileContent.replace(/^---\s*\n[\s\S]*?\n---\s*\n/, '');
      return { data: {}, content: stripped };
    }
  };

  const paths: any[] = [];
  for (const [categorySlug, folderName] of Object.entries(CATEGORY_MAPPING)) {
    try {
      const folderPath = resolve(process.cwd(), 'knowledge', folderName);
      const files = await readdir(folderPath);
      for (const file of files.filter(
        (f) => f.endsWith('.md') && !f.startsWith('_'),
      )) {
        const filePath = join(folderPath, file).normalize('NFC');
        const fileContent = await readFile(filePath, 'utf-8');
        const { data: frontmatter, content } = safeMatter(fileContent);
        const slug = basename(file, '.md');
        let gitInfo = emptyGitInfo();
        try {
          gitInfo = getGitInfo(filePath);
        } catch {}
        paths.push({
          params: { category: categorySlug, slug },
          props: {
            title: frontmatter.title || slug,
            description: frontmatter.description || '',
            content,
            frontmatter,
            lang: 'zh-TW',
            contributors: gitInfo.contributors,
            lastModified: gitInfo.lastModified,
          },
        });
      }
    } catch (err) {
      console.error(
        `[zh getStaticPaths] Error processing category "${categorySlug}":`,
        (err as Error).message,
      );
    }
  }
  if (paths.length === 0) {
    throw new Error(
      '[zh getStaticPaths] Generated 0 paths — all categories failed.',
    );
  }
  return paths;
}

const props = Astro.props;
const { category, slug } = Astro.params;
---

<ArticleTemplate {...props} category={category!} slug={slug!} />
