---
import { readdir, readFile } from 'fs/promises';
import { resolve, join, basename } from 'path';
import matter from 'gray-matter';
import Layout from '../../layouts/Layout.astro';
import { marked } from 'marked';
import ArticleHero from '../../components/ArticleHero.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import ArticleSidebar from '../../components/ArticleSidebar.astro';
import RelatedArticleCard from '../../components/RelatedArticleCard.astro';
import Perspectives from '../../components/Perspectives.astro';
import SporeFootprint from '../../components/SporeFootprint.astro';
import DiaryTeaser from '../../components/DiaryTeaser.astro';
import { useTranslations } from '../../i18n/utils';
import {
  categoryList as categories,
  getCategoryConfigs,
  type CategoryKey,
} from '../../utils/categoryConfig';
import {
  buildGitInfoCache,
  emptyGitInfo,
  type GitInfo,
} from '../../utils/contributors';

// ── Git helpers ───────────────────────────────────────────────────────────────
let _gitCache: Map<string, GitInfo> | null = null;

function buildGitCache() {
  if (_gitCache) return _gitCache;
  _gitCache = buildGitInfoCache('knowledge/');
  return _gitCache;
}

function getGitInfo(filePath: string) {
  return buildGitCache().get(filePath) || emptyGitInfo();
}

// ── Category → folder mapping ─────────────────────────────────────────────────
// Defined at module scope so it's available in both getStaticPaths and the template
const categoryMapping: Record<string, string> = {
  about: 'About',
  history: 'History',
  geography: 'Geography',
  culture: 'Culture',
  food: 'Food',
  art: 'Art',
  music: 'Music',
  technology: 'Technology',
  nature: 'Nature',
  people: 'People',
  society: 'Society',
  economy: 'Economy',
  lifestyle: 'Lifestyle',
};

// ── getStaticPaths ────────────────────────────────────────────────────────────
export async function getStaticPaths() {
  const safeMatter = (fileContent: string) => {
    try {
      return matter(fileContent);
    } catch {
      const stripped = fileContent.replace(/^---\s*\n[\s\S]*?\n---\s*\n/, '');
      return { data: {}, content: stripped };
    }
  };

  const _categoryMapping: Record<string, string> = {
    about: 'About',
    history: 'History',
    geography: 'Geography',
    culture: 'Culture',
    food: 'Food',
    art: 'Art',
    music: 'Music',
    technology: 'Technology',
    nature: 'Nature',
    people: 'People',
    society: 'Society',
    economy: 'Economy',
    lifestyle: 'Lifestyle',
  };
  const paths: any[] = [];
  for (const [categorySlug, folderName] of Object.entries(_categoryMapping)) {
    try {
      const folderPath = resolve(process.cwd(), 'knowledge', folderName);
      const files = await readdir(folderPath);
      for (const file of files.filter(
        (f) => f.endsWith('.md') && !f.startsWith('_'),
      )) {
        const filePath = join(folderPath, file).normalize('NFC');
        const fileContent = await readFile(filePath, 'utf-8');
        const { data: frontmatter, content } = safeMatter(fileContent);
        const slug = basename(file, '.md');
        let gitInfo = emptyGitInfo();
        try {
          gitInfo = getGitInfo(filePath);
        } catch {}
        paths.push({
          params: { category: categorySlug, slug },
          props: {
            title: frontmatter.title || slug,
            description: frontmatter.description || '',
            content,
            frontmatter,
            lang: 'zh-TW',
            contributors: gitInfo.contributors,
            lastModified: gitInfo.lastModified,
          },
        });
      }
    } catch (err) {
      console.error(
        `[getStaticPaths] Error processing category "${categorySlug}":`,
        (err as Error).message,
      );
    }
  }
  if (paths.length === 0) {
    throw new Error(
      '[getStaticPaths] Generated 0 paths — all categories failed. Check knowledge/ directory and YAML frontmatter.',
    );
  }
  return paths;
}

// ── Props ─────────────────────────────────────────────────────────────────────
const {
  title,
  description,
  content,
  frontmatter,
  lang,
  contributors: propsContributors = [],
  lastModified: propsLastModified = '',
} = Astro.props;
const { category, slug } = Astro.params;

// Compute git info at render time (not from props) so it's always fresh
const _renderFilePath = (() => {
  const folderName = categoryMapping[category as string];
  if (!folderName) return '';
  return join(
    resolve(process.cwd(), 'knowledge', folderName),
    slug + '.md',
  ).normalize('NFC');
})();
const _renderGitInfo = _renderFilePath
  ? getGitInfo(_renderFilePath)
  : { contributors: [], lastModified: '', commitHash: '', revisionCount: 0 };
const contributors = _renderGitInfo.contributors.length
  ? _renderGitInfo.contributors
  : propsContributors;
const lastModified = _renderGitInfo.lastModified || propsLastModified;
const commitHash = _renderGitInfo.commitHash;
const revisionCount = _renderGitInfo.revisionCount;

const t = useTranslations(lang ?? 'zh-TW');
const categoryConfigs = getCategoryConfigs(t);
const categoryInfo = categoryConfigs[category as CategoryKey];
if (!categoryInfo) throw new Error(`Unknown category: ${category}`);

// ── Related articles (same category, up to 3) ─────────────────────────────────
let relatedArticles: any[] = [];
try {
  const folderName = categoryMapping[category as string];
  if (folderName) {
    const folderPath = resolve(process.cwd(), 'knowledge', folderName);
    const files = (await readdir(folderPath)).filter(
      (f) => f.endsWith('.md') && !f.startsWith('_'),
    );
    for (const file of files) {
      const articleSlug = basename(file, '.md');
      if (articleSlug === slug) continue;
      const filePath = join(folderPath, file);
      const { data: fm } = safeMatter(await readFile(filePath, 'utf-8'));
      relatedArticles.push({
        title: fm.title || articleSlug,
        slug: articleSlug,
        description: fm.description || '',
        image: fm.image || '',
        category,
      });
    }
    relatedArticles = relatedArticles.slice(0, 3);
  }
} catch {}

// ── Random explore list ───────────────────────────────────────────────────────
let allArticles: Array<{ title: string; slug: string; category: string }> = [];
try {
  for (const [catSlug, folderName] of Object.entries(categoryMapping)) {
    if (catSlug === category) continue;
    try {
      const catPath = resolve(process.cwd(), 'knowledge', folderName);
      for (const file of (await readdir(catPath)).filter(
        (f) => f.endsWith('.md') && !f.startsWith('_'),
      )) {
        const articleSlug = basename(file, '.md');
        const { data: fm } = safeMatter(
          await readFile(join(catPath, file), 'utf-8'),
        );
        allArticles.push({
          title: fm.title || articleSlug,
          slug: articleSlug,
          category: catSlug,
        });
      }
    } catch {}
  }
} catch {}

// ── Other categories (for "Explore more") ────────────────────────────────────
const otherCategories = categories
  .filter((cat) => cat !== category)
  .slice(0, 3)
  .map((cat) => ({ key: cat, ...categoryConfigs[cat as CategoryKey] }));

// ── Markdown → HTML ───────────────────────────────────────────────────────────
function resolveWikilinks(md: string) {
  if (!md) return md;
  return md.replace(
    /\[\[([^\]|]+?)(?:\|([^\]]+?))?\]\]/g,
    (_, target, display) => {
      return `**${display || target}**`;
    },
  );
}

const renderer = new marked.Renderer();

// Inject id attributes on headings for TOC anchor links
renderer.heading = ({ text, depth }) => {
  const id = text
    .toLowerCase()
    .replace(/\s+/g, '-')
    .replace(/[^\w\u4e00-\u9fff-]/g, '')
    .slice(0, 60);
  return `<h${depth} id="${id}">${text}</h${depth}>`;
};

renderer.link = ({ href, title, text }) => {
  const isExternal =
    href?.startsWith('http://') || href?.startsWith('https://');
  const titleAttr = title ? ` title="${title}"` : '';
  const targetAttr = isExternal
    ? ' target="_blank" rel="noopener noreferrer"'
    : '';
  return `<a href="${href}"${titleAttr}${targetAttr}>${text}</a>`;
};

renderer.image = ({ href, title, text }) => {
  const titleAttr = title ? ` title="${title}"` : '';
  return `<img src="${href}" alt="${text || ''}"${titleAttr} loading="lazy" onerror="this.onerror=null;this.classList.add('img-broken')" />`;
};

// ── Footnote preprocessor (GFM-compatible [^n] syntax) ──────────────────────
function processFootnotes(md: string): string {
  // Collect footnote definitions: [^label]: content (may span rest of line)
  const definitions: Record<string, string> = {};
  const defRegex = /^\[\^([^\]]+)\]:\s*(.+?)(?=\n\[\^|\n\n|\n#|\n---|\s*$)/gms;
  let m: RegExpExecArray | null;
  while ((m = defRegex.exec(md)) !== null) {
    definitions[m[1]] = m[2].trim();
  }
  if (Object.keys(definitions).length === 0) return md;

  // Order of first use in the text
  const order: string[] = [];
  let body = md.replace(defRegex, ''); // remove definitions from body

  // Replace inline refs [^label] → superscript HTML
  body = body.replace(/\[(\^[^\]]+)\](?!:)/g, (_, raw) => {
    const label = raw.slice(1); // strip leading ^
    if (!definitions[label]) return `[${raw}]`;
    if (!order.includes(label)) order.push(label);
    const num = order.indexOf(label) + 1;
    const id = `fn-${label}`;
    const refId = `fnref-${label}`;
    return `<sup id="${refId}"><a href="#${id}" class="footnote-ref" aria-label="脚注 ${num}">${num}</a></sup>`;
  });

  // Build footnotes section
  if (order.length > 0) {
    const items = order.map((label, i) => {
      const num = i + 1;
      const id = `fn-${label}`;
      const refId = `fnref-${label}`;
      // Process links inside footnote text via marked inline parser
      const defHtml = marked.parseInline(definitions[label]) as string;
      return `<li id="${id}">${defHtml}<a href="#${refId}" class="footnote-backref" aria-label="返回引用 ${num}">↩</a></li>`;
    });
    body =
      body.trimEnd() +
      `\n\n<section class="footnotes" aria-label="腳注"><ol>${items.join('')}</ol></section>`;
  }

  return body;
}

const fullHtml = marked.parse(processFootnotes(resolveWikilinks(content)), {
  renderer,
  breaks: true,
}) as string;

// Split content before 延伸閱讀/Further Reading to insert SSODT sections
// 2026-05-03 fix: bold paragraph format `**延伸閱讀**：` was silently broken
// — splitIndex stayed -1 → SSODT sections (SporeFootprint / Perspectives /
// DiaryTeaser) didn't render despite hasSSoDT=true. Per format-check both
// `## 延伸閱讀` (h2) and `**延伸閱讀**` (bold p) are canonical accepted formats
// — template MUST also accept both. 121 articles use bold format vs 95 h2;
// 3 articles silently broken (黑冠麻鷺 / 沈伯洋 / 賈永婕 had sporeLinks but
// SporeFootprint never rendered). Fix: add bold paragraph markers (zh + en).
const splitMarkers = [
  '<h2>延伸閱讀</h2>',
  '<h2>Further Reading</h2>',
  '<h2>延伸閱讀<',
  '<p><strong>延伸閱讀</strong>',
  '<p><strong>Further Reading</strong>',
];
let splitIndex = -1;
for (const marker of splitMarkers) {
  const idx = fullHtml.indexOf(marker);
  if (idx !== -1) {
    splitIndex = idx;
    break;
  }
}
// Also try id-based h2 (marked adds ids)
if (splitIndex === -1) {
  const idMatch = fullHtml.match(/<h2[^>]*id="[^"]*"[^>]*>延伸閱讀/);
  if (idMatch && idMatch.index !== undefined) splitIndex = idMatch.index;
}
// Final fallback: any <p><strong> containing 延伸閱讀 (handles whitespace variants)
if (splitIndex === -1) {
  const pMatch = fullHtml.match(/<p>\s*<strong>\s*延伸閱讀/);
  if (pMatch && pMatch.index !== undefined) splitIndex = pMatch.index;
}

const hasSSoDT =
  frontmatter.perspectives?.length > 0 ||
  frontmatter.sporeLinks?.length > 0 ||
  frontmatter.diaryLink;
const contentBeforeReading =
  splitIndex !== -1 && hasSSoDT ? fullHtml.slice(0, splitIndex) : fullHtml;
const contentAfterReading =
  splitIndex !== -1 && hasSSoDT ? fullHtml.slice(splitIndex) : '';
const processedContent = fullHtml;

// ── Estimate reading time if not in frontmatter ────────────────────────────────
const estimatedReadingTime =
  frontmatter.readingTime ||
  Math.max(1, Math.round(content.replace(/\s+/g, ' ').length / 500));

const articleUrl = `https://taiwan.md/${category}/${slug}`;
const encodedUrl = encodeURIComponent(articleUrl);
const encodedTitle = encodeURIComponent(title);

// ── Screenshot mode (?shot=1) — toggled client-side ────────────────────────
// Astro static build strips search params at prerender; so a tiny inline
// script toggles `data-shot="1"` on <main> at runtime. Used by
// scripts/tools/generate-spore-image.mjs for spore image generation.
---

<Layout
  title={title}
  description={description}
  type="article"
  datePublished={frontmatter.date || new Date().toISOString()}
  dateModified={frontmatter.modified ||
    frontmatter.date ||
    new Date().toISOString()}
  content={content}
  tags={frontmatter.tags}
  category={categoryInfo.name}
  slug={slug}
  categorySlug={category}
>
  <!-- Reading progress bar -->
  <div class="reading-progress" id="reading-progress" aria-hidden="true"></div>

  <!--
    Phase 6 partial migration — [category]/[slug].astro (zh-TW)
    ───────────────────────────────────────────────────────────
    Same migration strategy as en/ja/ko [category]/[slug]:
    wrappers → inline Tailwind; .prose :global(*) + .reading-progress
    stay scoped. zh-TW adds a meta-category-link and optional
    meta-subcategory in the meta strip (not present in en/ja/ko).
    Prose font is 'Noto Serif TC' instead of 'Inter'.
  -->
  <!-- Shot-mode watermark 已移至 src/layouts/Layout.astro 共用（2026-04-22 β）。
       JS toggle + CSS 同樣搬走，四語言 article page 統一支援 ?shot=1 模式。 -->

  <main class="article-page min-h-screen bg-[#f8f1e9]" lang="zh-TW">
    <!-- ── Hero ─────────────────────────────────────────────────── -->
    <ArticleHero
      title={title}
      description={description}
      category={category}
      categoryName={categoryInfo.name}
      categoryColor={categoryInfo.color}
      coverImage={categoryInfo.cover}
      slug={slug}
      lang="zh-TW"
    />

    <!-- ── Three-column body ───────────────────────────────────────
         2026-04-27 fix: removed `items-start` from grid parent + made
         TOC/sidebar wrapper divs `h-full`. Reason: `items-start` makes
         each grid cell shrink to content height; the TOC's wrapper div
         was therefore the same height as the TOC nav itself, leaving
         no scroll-room for `position: sticky` to engage. Now grid cells
         stretch to row height (= tall article body) and sticky works
         inside the tall wrapper.
    -->
    <div
      class="mx-auto grid max-w-[1280px] grid-cols-[220px_1fr_200px] [grid-template-areas:'toc_body_sidebar'] gap-14 px-8 pb-20 pt-16 max-lg:grid-cols-1 max-lg:[grid-template-areas:'body'_'sidebar'] max-lg:gap-8 max-lg:px-6 max-lg:pb-16 max-lg:pt-10 max-[640px]:px-4 max-[640px]:pb-12 max-[640px]:pt-6"
    >
      <!-- Left: Table of Contents (h-full lets the wrapper inherit grid row height,
           giving the inner sticky nav room to scroll within) -->
      <div class="h-full [grid-area:toc] max-lg:hidden" aria-label="目錄欄">
        <TableOfContents content={processedContent} />
      </div>

      <!-- Center: Article content -->
      <article class="min-w-0 [grid-area:body]" data-pagefind-body>
        <!-- Status / subcategory strip -->
        <div
          class="mb-10 flex flex-wrap items-center gap-3 border-b border-[rgba(26,60,52,0.08)] pb-8"
        >
          {
            frontmatter.status && (
              <span
                class="rounded-full px-3 py-1 font-['Inter',system-ui,sans-serif] text-[0.72rem] font-semibold uppercase tracking-[0.12em]"
                style={`background:${categoryInfo.colorLight}; color:${categoryInfo.color};`}
              >
                {frontmatter.status}
              </span>
            )
          }
          <a
            href={`/${category}`}
            class="font-['Inter',system-ui,sans-serif] text-[0.82rem] font-semibold no-underline transition-opacity duration-150 hover:opacity-70"
            style={`color:${categoryInfo.color};`}
          >
            {categoryInfo.name}
          </a>
          {
            frontmatter.subcategory && (
              <>
                <span class="text-[0.85rem] text-[#b0bdb4]">›</span>
                <span
                  class="rounded-full px-[0.7rem] py-[0.2rem] font-['Inter',system-ui,sans-serif] text-[0.75rem] font-medium"
                  style={`color:${categoryInfo.color}; background:${categoryInfo.colorLight};`}
                >
                  {frontmatter.subcategory}
                </span>
              </>
            )
          }
        </div>

        <!-- LifeTree CTA banner (experimental feature, links to standalone page) -->
        {
          frontmatter.lifeTree && (
            <a
              href={`/lifetree/${slug}`}
              class="lifetree-cta group mb-8 flex items-center justify-between gap-4 rounded-xl border border-dashed border-[rgba(139,92,246,0.4)] bg-gradient-to-r from-[rgba(139,92,246,0.06)] to-[rgba(236,72,153,0.04)] px-5 py-4 no-underline transition-all duration-200 hover:border-solid hover:border-[#8B5CF6] hover:shadow-md"
              data-experimental
            >
              <div class="flex items-center gap-3">
                <span class="text-2xl" aria-hidden="true">
                  🌳
                </span>
                <div>
                  <p class="m-0 font-['Inter',system-ui,sans-serif] text-[0.7rem] font-semibold uppercase tracking-[0.12em] text-[#8B5CF6]">
                    Experimental · 實驗型功能
                  </p>
                  <p class="m-0 mt-0.5 font-['Noto_Serif_TC',serif] text-[0.95rem] font-medium text-[#1a3c34]">
                    {frontmatter.lifeTree.protagonist} 的人生分支樹（
                    {frontmatter.lifeTree.nodes?.length || 0} 個 turning point）
                  </p>
                </div>
              </div>
              <span class="flex items-center gap-1 font-['Inter',system-ui,sans-serif] text-[0.85rem] font-medium text-[#8B5CF6] transition-transform duration-200 group-hover:translate-x-1">
                看樹 →
              </span>
            </a>
          )
        }

        <!-- Prose body (split at 延伸閱讀 if SSODT sections present) -->
        {
          hasSSoDT && splitIndex !== -1 ? (
            <>
              <div class="prose" set:html={contentBeforeReading} />
              {/* ── SSODT sections between article body and 延伸閱讀 ── */}
              {frontmatter.perspectives &&
                frontmatter.perspectives.length > 0 && (
                  <Perspectives
                    perspectives={frontmatter.perspectives}
                    lang="zh-TW"
                  />
                )}
              {frontmatter.sporeLinks && frontmatter.sporeLinks.length > 0 && (
                <SporeFootprint
                  sporeLinks={frontmatter.sporeLinks}
                  lang="zh-TW"
                />
              )}
              {frontmatter.diaryLink && (
                <DiaryTeaser
                  diaryLink={frontmatter.diaryLink}
                  diaryExcerpt={frontmatter.diaryExcerpt}
                  lang="zh-TW"
                />
              )}
              <div class="prose" set:html={contentAfterReading} />
            </>
          ) : (
            <div class="prose" set:html={processedContent} />
          )
        }

        <!-- Sources -->
        {
          frontmatter.source && frontmatter.source.length > 0 && (
            <div class="my-12 rounded-2xl border border-[rgba(26,60,52,0.08)] bg-[rgba(26,60,52,0.03)] p-8">
              <h3 class="mb-4 font-['Inter',system-ui,sans-serif] text-[0.85rem] font-semibold uppercase tracking-[0.1em] text-[#1a3c34]">
                參考資料
              </h3>
              <ul class="m-0 flex list-none flex-col gap-2 p-0">
                {frontmatter.source.map((url: string) => (
                  <li>
                    <a
                      href={url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="break-all text-[0.82rem] text-[#006d77] no-underline hover:underline"
                    >
                      {url}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )
        }

        <!-- AI Disclaimer -->
        <div
          class="my-12 mb-8 flex items-start gap-4 rounded-xl border border-[rgba(193,125,94,0.18)] bg-[rgba(193,125,94,0.06)] px-6 py-5"
        >
          <div
            class="mt-[0.15rem] flex-shrink-0 text-[#c17d5e]"
            aria-hidden="true"
          >
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              ><circle cx="12" cy="12" r="10"></circle><line
                x1="12"
                y1="8"
                x2="12"
                y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"
              ></line></svg
            >
          </div>
          <div
            class="font-['Inter',system-ui,sans-serif] text-[0.83rem] leading-[1.6] text-[#5a4a42] [&>strong]:mb-[0.3rem] [&>strong]:block [&>strong]:text-[0.8rem] [&>strong]:font-semibold [&>strong]:uppercase [&>strong]:tracking-[0.08em] [&>strong]:text-[#c17d5e]"
          >
            <strong>內容說明</strong>
            本文由 AI 輔助生成，並經人工審核整理。如發現任何錯誤或不完整之處，歡迎透過下方按鈕協助改善。
          </div>
        </div>

        <!-- Contribution row -->
        <div class="my-8 flex flex-wrap gap-3">
          <a
            href={`https://github.com/frank890417/taiwan-md/edit/main/knowledge/${categoryMapping[category as string]}/${slug}.md`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-[0.45rem] rounded-full bg-[#1a3c34] px-[1.1rem] py-[0.55rem] font-['Inter',system-ui,sans-serif] text-[0.82rem] font-medium text-[#f8f1e9] no-underline transition-all duration-200 hover:bg-[#243d36]"
          >
            <svg
              width="15"
              height="15"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              aria-hidden="true"
              ><path
                d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"
              ></path></svg
            >
            在 GitHub 上編輯此頁
          </a>
          <a
            href={`https://github.com/frank890417/taiwan-md/issues/new?title=${encodeURIComponent(`Feedback: ${title}`)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-[0.45rem] rounded-full border border-[rgba(26,60,52,0.2)] bg-transparent px-[1.1rem] py-[0.55rem] font-['Inter',system-ui,sans-serif] text-[0.82rem] font-medium text-[#1a3c34] no-underline transition-all duration-200 hover:bg-[rgba(26,60,52,0.05)]"
          >
            <svg
              width="15"
              height="15"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              aria-hidden="true"
              ><path
                d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"
              ></path></svg
            >
            回報問題
          </a>
        </div>

        <!-- Tags + bottom share row -->
        <div
          class="my-12 mb-8 flex flex-wrap items-center justify-between gap-4 border-t border-[rgba(26,60,52,0.08)] pt-8 max-[640px]:flex-col max-[640px]:items-start"
        >
          {
            frontmatter.tags && frontmatter.tags.length > 0 && (
