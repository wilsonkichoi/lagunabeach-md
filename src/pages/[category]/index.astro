---
/**
 * zh-TW [category]/index.astro — thin wrapper.
 * 2026-05-03 sleepy-colden P1 unification follow-up.
 */
import CategoryHubTemplate from '../../templates/category-hub.template.astro';
import { getCategoryHubStaticPaths } from '../../utils/category-static-paths';

export async function getStaticPaths() {
  return await getCategoryHubStaticPaths('zh-TW');
}

// Force Astro bundler to wrap props access inside createComponent
// (otherwise it hoists `const props = Astro.props` to module top-level
// and triggers UnavailableAstroGlobal error during getStaticPaths phase).
const { category } = Astro.params;
const props = Astro.props;
---

<CategoryHubTemplate {...props} category={category!} />
