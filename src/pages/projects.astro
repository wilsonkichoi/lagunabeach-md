---
import Layout from '../layouts/Layout.astro';

const projects = [
  {
    category: '🍔 美食地圖',
    color: '#e11d48',
    items: [
      {
        name: '台北漢堡地圖',
        description:
          '互動式台北漢堡餐廳排名地圖，依品質分級（T0-T6），可依行政區篩選',
        url: 'https://hsieh-george.github.io/taipei-burger-map/',
        github: 'https://github.com/hsieh-george/taipei-burger-map',
        tags: ['地圖', '美食', '台北'],
        tech: 'JavaScript / Leaflet',
      },
    ],
  },
  {
    category: '🌙 夜市導覽',
    color: '#7c3aed',
    items: [
      {
        name: 'NightMarketSwift',
        description:
          '台灣夜市 iOS App，收錄超過 400 個夜市地點，含營業時間與 Google Maps 導航',
        url: 'https://github.com/hsiu0305/NightMarketSwift',
        github: 'https://github.com/hsiu0305/NightMarketSwift',
        tags: ['iOS', '夜市', '導航'],
        tech: 'Objective-C / Swift',
      },
    ],
  },
  {
    category: '🗳️ 公民科技',
    color: '#059669',
    items: [
      {
        name: 'g0v 零時政府',
        description: '台灣最大公民科技社群，推動開放政府與資訊透明化',
        url: 'https://g0v.tw/',
        github: 'https://github.com/g0v',
        tags: ['開源', '公民', '政府'],
        tech: '多元技術',
      },
      {
        name: 'Cofacts 真的假的',
        description: '群眾協作的事實查核聊天機器人，對抗假訊息',
        url: 'https://cofacts.tw/',
        github: 'https://github.com/cofacts',
        tags: ['事實查核', 'LINE Bot', '群眾協作'],
        tech: 'JavaScript / GraphQL',
      },
      {
        name: 'Disfactory 農地違章工廠',
        description: '公民回報農地上違章工廠的平台，保護台灣農地',
        url: 'https://disfactory.tw/',
        github: 'https://github.com/Disfactory',
        tags: ['環境', '農地', '公民回報'],
        tech: 'Vue.js / Django',
      },
    ],
  },
];

const totalProjects = projects.reduce((sum, cat) => sum + cat.items.length, 0);
---

<Layout
  title="社群專案 - Taiwan.md"
  description="精選台灣相關的有趣社群開源專案，涵蓋美食地圖、公民科技、交通視覺化等多元領域"
>
  <!--
    Phase 6 page migration #4: projects.astro (zh-TW)
    ─────────────────────────────────────────────────
    - Scoped <style> removed entirely (~320 lines CSS deleted)
    - Violet/purple gradient theme with `jf-jinxuanlatte` title font
    - Per-category border color + tech-badge tint still flow through
      inline `style={...}` attributes from the data array
  -->
  <main
    class="min-h-screen bg-[linear-gradient(135deg,#faf5ff_0%,#ede9fe_50%,#e0e7ff_100%)] font-['jf-jinxuanlatte','Noto_Sans_TC',sans-serif]"
  >
    <div class="mx-auto max-w-[var(--container-wide)] p-8 max-[768px]:p-4">
      <!-- Hero Section -->
      <section class="py-16 pb-8 text-center max-[768px]:py-8 max-[768px]:pb-4">
        <div>
          <h1
            class="mb-4 -tracking-[0.02em] [background:linear-gradient(135deg,#7c3aed,#a855f7,#c084fc)] bg-clip-text text-[3.5rem] font-black text-transparent max-[768px]:text-[2.5rem] max-[480px]:text-[2rem]"
          >
            社群專案
          </h1>
          <p
            class="mx-auto mb-6 max-w-[600px] text-[1.3rem] leading-[1.7] text-[#64748b] max-[768px]:text-[1.1rem]"
          >
            精選台灣相關的有趣開源專案<br />
            來自社群的創意與熱情，用程式碼認識台灣
          </p>
          <div
            class="flex items-center justify-center gap-4 text-base font-semibold text-[#7c3aed]"
          >
            <span>{projects.length} 個分類</span>
            <span class="h-[6px] w-[6px] rounded-full bg-[#c084fc]"></span>
            <span>{totalProjects} 個專案</span>
          </div>
        </div>
      </section>

      <!-- Breadcrumb -->
      <nav class="mb-12 flex items-center gap-2 text-[0.95rem] text-[#64748b]">
        <a
          href="/"
          class="text-[#7c3aed] no-underline transition-colors duration-200 ease hover:text-[#5b21b6]"
          >首頁</a
        >
        <span class="text-[#94a3b8]">›</span>
        <span class="font-semibold text-[#374151]">社群專案</span>
      </nav>

      <!-- Project Categories -->
      {
        projects.map((category) => (
          <section class="mb-12">
            <div
              class="mb-6 border-l-4 pl-4"
              style={`border-left-color: ${category.color}`}
            >
              <h2 class="font-['jf-jinxuanlatte','Noto_Sans_TC',sans-serif] text-[1.6rem] font-bold text-[#1e293b] max-[480px]:text-[1.3rem]">
                {category.category}
              </h2>
            </div>
            <div class="grid grid-cols-[repeat(auto-fill,minmax(340px,1fr))] gap-6 max-[768px]:grid-cols-1">
              {category.items.map((project) => (
                <div class="flex flex-col rounded-2xl border border-[#e5e7eb] bg-white p-6 shadow-[0_2px_8px_-2px_rgba(0,0,0,0.08)] transition-all duration-300 ease hover:-translate-y-[3px] hover:border-[#c4b5fd] hover:shadow-[0_12px_30px_-8px_rgba(124,58,237,0.15)] max-[480px]:p-5">
                  <div class="mb-3 flex items-start justify-between gap-3">
                    <h3 class="m-0 text-[1.15rem] font-bold [&_a:hover]:text-[#7c3aed] [&_a]:text-[#1e293b] [&_a]:no-underline [&_a]:transition-colors [&_a]:duration-200">
                      <a
                        href={project.url}
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        {project.name}
                      </a>
                    </h3>
                    <span
                      class="flex-shrink-0 whitespace-nowrap rounded-md px-[0.6rem] py-1 text-[0.75rem] font-semibold"
                      style={`background: ${category.color}15; color: ${category.color}`}
                    >
                      {project.tech}
                    </span>
                  </div>
                  <p class="mb-4 flex-1 text-[0.95rem] leading-[1.6] text-[#64748b]">
                    {project.description}
                  </p>
                  <div class="flex flex-wrap items-center justify-between gap-3">
                    <div class="flex flex-wrap gap-[0.4rem]">
                      {project.tags.map((tag) => (
                        <span class="rounded bg-[#f3f4f6] px-2 py-[0.2rem] text-[0.75rem] text-[#6b7280]">
                          {tag}
                        </span>
                      ))}
                    </div>
                    <div class="flex gap-2">
                      {project.github && (
                        <a
                          href={project.github}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="flex h-8 w-8 items-center justify-center rounded-lg bg-[#f1f5f9] text-base text-[#64748b] no-underline transition-all duration-200 hover:bg-[#e2e8f0] hover:text-[#1e293b]"
                          title="GitHub"
                        >
                          <svg
                            width="16"
                            height="16"
                            viewBox="0 0 16 16"
                            fill="currentColor"
                          >
                            <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z" />
                          </svg>
                        </a>
                      )}
                      <a
                        href={project.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="flex h-8 w-8 items-center justify-center rounded-lg bg-[#7c3aed] text-base text-white no-underline transition-all duration-200 hover:bg-[#6d28d9] hover:text-white"
                        title="前往專案"
                      >
                        ↗
                      </a>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </section>
        ))
      }

      <!-- Call to Action -->
      <section
        class="mt-16 rounded-[20px] bg-white px-8 py-12 text-center shadow-[0_4px_12px_-2px_rgba(0,0,0,0.06)]"
      >
        <h2
          class="mb-3 font-['jf-jinxuanlatte','Noto_Sans_TC',sans-serif] text-[1.8rem] text-[#1e293b]"
        >
          有推薦的專案嗎？
        </h2>
        <p class="mb-8 text-[1.05rem] text-[#64748b]">
          歡迎透過 GitHub Issue 或 PR 推薦更多台灣相關的有趣專案！
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a
            href="https://github.com/frank890417/taiwan-md/issues"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-xl bg-[linear-gradient(135deg,#7c3aed,#a855f7)] px-8 py-[0.875rem] font-semibold text-white no-underline shadow-[0_4px_6px_-1px_rgba(124,58,237,0.3)] transition-all duration-300 ease hover:-translate-y-px hover:bg-[linear-gradient(135deg,#6d28d9,#9333ea)] hover:shadow-[0_8px_15px_-3px_rgba(124,58,237,0.3)]"
          >
            提交推薦
          </a>
          <a
            href="/"
            class="inline-flex items-center gap-2 rounded-xl border-2 border-[#c4b5fd] bg-white px-8 py-[0.875rem] font-semibold text-[#7c3aed] no-underline transition-all duration-300 ease hover:border-[#7c3aed] hover:bg-[#faf5ff]"
          >
            ← 返回首頁
          </a>
        </div>
      </section>
    </div>
  </main>
</Layout>
