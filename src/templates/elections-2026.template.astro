    eyebrow: string;
    titlePrefix: string;
    titleEmphasis: string;
    titleSuffix: string;
    subtitle: string;
    countdownLabel: string;
    dayUnit: string;
    dateLabel: string;
    recentTitle: string;
    recentSubtitle: string;
  };
  role: {
    title: string;
    p1: string;
    p2: string;
    p3: string;
    p4: string;
    primaryCta: string;
    secondaryCta: string;
  };
