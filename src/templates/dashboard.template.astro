---
import Layout from '../layouts/Layout.astro';
import '../styles/dashboard.css';
import PageHero from '../components/PageHero.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const isEn = lang === 'en';
---

<Layout
  lang={lang}
  title={t('dashboard.meta.title')}
  description={t('dashboard.meta.description')}
>
  <main class="dashboard">
    <!-- Hero -->
    <!--
      Phase 7.5 partial migration — dashboard.template.astro
      Hero section moved to inline Tailwind. `.ekg-line` + its
      @keyframes ekgDraw animation stay scoped (the animation can't
      be reached via Tailwind arbitrary utilities without promoting
      the keyframes to global.css — too small a win to justify).
      Inner sections (vitals-grid, dashboard cards, organism
      anatomy, etc.) remain scoped — ~170 classes with tight JS
      coupling.
    -->
    <!--
      Dashboard hero is a structural outlier: a rounded-card gradient
      shell with an animated EKG SVG background and a JS-updated stats
      row. PageHero can't absorb the shell (would need `bgShape=rounded`
      + `<slot name=background>` + new stats slot for one consumer), so
      we NEST PageHero inside the custom shell to handle the standard
      title/subtitle/footer axis, and keep the EKG + stats as custom
      siblings. Partial migration: structural consistency for the
      "this page has a title" part, custom code only where it's truly
      unique.
    -->
    <section
      class="page-hero-dashboard-shell relative mb-4 overflow-hidden rounded-2xl bg-[linear-gradient(135deg,#1a1a2e_0%,#2d1b69_60%,#1a1a2e_100%)] text-white"
    >
      <svg
        class="pointer-events-none absolute left-0 top-1/2 h-[60px] w-full -translate-y-1/2 opacity-60"
        viewBox="0 0 600 60"
        preserveAspectRatio="none"
        aria-hidden="true"
      >
        <path
          class="ekg-line"
          d="M0,30 L120,30 L140,30 L155,8 L165,52 L175,20 L185,38 L195,30 L280,30 L300,30 L315,8 L325,52 L335,20 L345,38 L355,30 L440,30 L460,30 L475,8 L485,52 L495,20 L505,38 L515,30 L600,30"
          fill="none"
          stroke="rgba(139,92,246,0.25)"
          stroke-width="2"></path>
      </svg>
      <PageHero
        containerWidth="full"
        padding="compact"
        bgTone="dark"
        titleVariant="inherit"
        titleWeight="bold"
        titleSize="sm"
      >
        <Fragment slot="title">
          <span class="relative text-[1.8rem]">🔬</span>
          <span class="relative">{t('dashboard.hero.title')}</span>
        </Fragment>
        <Fragment slot="subtitle">{t('dashboard.hero.subtitle')}</Fragment>
        <Fragment slot="meta">{t('dashboard.hero.description')}</Fragment>
        <Fragment slot="footer">
          <a
            href="https://github.com/wilsonkichoi/lagunabeach-md/tree/main/docs/semiont"
            target="_blank"
            rel="noopener"
            class="inline-block text-[0.85rem] text-[#94a3b8] no-underline opacity-80 transition-opacity duration-200 hover:text-[#cbd5e1] hover:opacity-100"
          >
            {
              isEn
                ? '→ Cognitive Layer (Self-Awareness System)'
                : '→ 前往認知層（自我覺察系統）'
            }
          </a>
        </Fragment>
      </PageHero>
    </section>

    <!-- Vital Signs -->
    <section class="section" id="vitals">
      <h2 class="section-title">
        {t('dashboard.vitals.title')}
        <span class="section-timestamp" data-source="vitals"></span>
      </h2>
      <div class="vitals-grid" id="vitals-grid">
        <div class="vital-card" data-vital="heartbeat">
          <div class="vital-emoji">💓</div>
          <div class="vital-value" id="vital-heartbeat">—</div>
          <div class="vital-label">{t('dashboard.vitals.heartbeat')}</div>
          <div class="vital-desc">{t('dashboard.vitals.heartbeat.desc')}</div>
        </div>
        <div class="vital-card" data-vital="cells">
          <div class="vital-emoji">🧫</div>
          <div class="vital-value" id="vital-cells">—</div>
          <div class="vital-label">{t('dashboard.vitals.cells')}</div>
          <div class="vital-desc">{t('dashboard.vitals.cells.desc')}</div>
        </div>
        <div class="vital-card" data-vital="immunity">
          <div class="vital-emoji">🛡️</div>
          <div class="vital-value" id="vital-immunity">—</div>
          <div class="vital-label">{t('dashboard.vitals.immunity')}</div>
          <div class="vital-desc">{t('dashboard.vitals.immunity.desc')}</div>
        </div>
        <div class="vital-card" data-vital="dna">
          <div class="vital-emoji">🧬</div>
          <div class="vital-value" id="vital-dna">—</div>
          <div class="vital-label">{t('dashboard.vitals.dna')}</div>
          <div class="vital-desc">{t('dashboard.vitals.dna.desc')}</div>
        </div>
        <div class="vital-card" data-vital="revision">
          <div class="vital-emoji">📐</div>
          <div class="vital-value" id="vital-revision">—</div>
          <div class="vital-label">{t('dashboard.vitals.revision')}</div>
          <div class="vital-desc">{t('dashboard.vitals.revision.desc')}</div>
        </div>
      </div>
    </section>

    <!-- Recent Activity -->
    <section class="section" id="activity">
      <h2 class="section-title">
        {isEn ? '🔔 Recent Activity' : '🔔 最近活動'}
        <span class="section-timestamp" data-source="articles"></span>
      </h2>
      <div class="activity-feed" id="activity-feed"></div>
    </section>

    <!-- Article Registry -->
    <section class="section" id="registry">
      <h2 class="section-title">
        {t('dashboard.registry.title')}
        <span class="section-timestamp" data-source="articles"></span>
      </h2>
      <p class="section-subtitle">{t('dashboard.registry.subtitle')}</p>

      <div class="registry-controls">
        <input
          type="text"
          id="registry-search"
          class="registry-search"
          placeholder={t('dashboard.registry.search')}
        />
        <div class="registry-filters">
          <select id="filter-category" class="registry-filter">
            <option value="">{t('dashboard.registry.filter.all')}</option>
          </select>
          <select id="filter-reviewed" class="registry-filter">
            <option value="">{t('dashboard.registry.filter.reviewed')}</option>
            <option value="true"
              >{t('dashboard.registry.filter.reviewed.yes')}</option
            >
            <option value="false"
              >{t('dashboard.registry.filter.reviewed.no')}</option
            >
          </select>
          <select id="filter-featured" class="registry-filter">
            <option value="">{t('dashboard.registry.filter.featured')}</option>
            <option value="true">⭐</option>
            <option value="false">—</option>
          </select>
          <select id="filter-translation" class="registry-filter">
            <option value=""
              >{t('dashboard.registry.filter.translation')}</option
            >
            <option value="has-en"
              >{t('dashboard.registry.filter.translation.has-en')}</option
            >
            <option value="missing-en"
              >{t('dashboard.registry.filter.translation.missing-en')}</option
            >
          </select>
        </div>
      </div>

      <div class="registry-summary" id="registry-summary"></div>

      <div class="registry-table-controls">
        <button class="column-toggle-btn" id="column-toggle-btn">
          {isEn ? '⚙️ Show all columns' : '⚙️ 顯示所有欄位'}
        </button>
      </div>
      <div class="registry-table-wrapper">
        <table class="registry-table" id="registry-table">
          <thead>
            <tr>
              <th class="sortable" data-sort="title"
                >{t('dashboard.registry.col.title')}</th
              >
              <th class="sortable" data-sort="category"
                >{t('dashboard.registry.col.category')}</th
              >
              <th class="sortable" data-sort="subcategory"
                >{isEn ? 'Subcategory' : '子分類'}</th
              >
              <th class="sortable" data-sort="date"
                >{t('dashboard.registry.col.date')}</th
              >
              <th class="sortable" data-sort="lastModified"
                >{isEn ? 'Modified' : '最後修改'}</th
              >
              <th class="sortable" data-sort="qualityScore"
                >{isEn ? 'Quality' : '品質'}</th
              >
              <th class="sortable" data-sort="formatIssues"
                >{isEn ? 'Format' : '格式'}</th
              >
              <th class="sortable" data-sort="lastHumanReview"
                >{t('dashboard.registry.col.reviewed')}</th
              >
              <th class="sortable" data-sort="wordCount"
                >{t('dashboard.registry.col.words')}</th
              >
              <th class="sortable col-hideable" data-sort="tagCount"
                >{t('dashboard.registry.col.tags')}</th
              >
              <th>{t('dashboard.registry.col.translations')}</th>
              <th class="sortable col-hideable" data-sort="revision"
                >{t('dashboard.registry.col.revisions')}</th
              >
              <th class="col-edit-header"></th>
            </tr>
          </thead>
          <tbody id="registry-body"></tbody>
        </table>
      </div>
    </section>

    <!-- Health Distribution -->
    <section class="section" id="health-distribution">
      <h2 class="section-title">
        {isEn ? '📊 Health Distribution' : '📊 健康分布'}
        <span class="section-timestamp" data-source="articles"></span>
      </h2>
      <p class="section-subtitle">
        {isEn ? 'How healthy are our articles?' : '文章的健康分數分布'}
      </p>
      <div class="health-chart" id="health-chart"></div>
      <p class="health-summary" id="health-summary"></p>
    </section>

    <!-- Organism Anatomy -->
    <section class="section" id="organism">
      <h2 class="section-title">
        {t('dashboard.organism.title')}
        <span class="section-timestamp" data-source="organism"></span>
      </h2>
      <p class="section-subtitle">{t('dashboard.organism.subtitle')}</p>
      <div class="organ-grid" id="organ-grid"></div>
    </section>

    <!-- Translation Coverage -->
    <section class="section" id="translation">
      <h2 class="section-title">
        {t('dashboard.translation.title')}
        <span class="section-timestamp" data-source="translations"></span>
      </h2>
      <p class="section-subtitle">{t('dashboard.translation.subtitle')}</p>
      <div class="translation-bars" id="translation-bars"></div>

      <!-- Legend: 圖說 (2026-05-09 added per observer feedback) -->
      <div
        class="translation-legend"
        aria-label={t('dashboard.translation.legend.aria')}
      >
        <span class="legend-item">
          <span class="legend-dot legend-dot-fresh">●</span>
          <span class="legend-label"
            >{t('dashboard.translation.legend.fresh')}</span
          >
        </span>
        <span class="legend-item">
          <span class="legend-dot legend-dot-stale">●</span>
          <span class="legend-label"
            >{t('dashboard.translation.legend.stale')}</span
          >
        </span>
        <span class="legend-item">
          <span class="legend-dot legend-dot-missing">●</span>
          <span class="legend-label"
            >{t('dashboard.translation.legend.missing')}</span
          >
        </span>
        <span class="legend-item legend-item-divider">
          <span class="legend-format">N/M</span>
          <span class="legend-label"
            >{t('dashboard.translation.legend.format')}</span
          >
        </span>
      </div>

      <div class="translation-matrix-wrapper">
        <table class="translation-matrix" id="translation-matrix">
          <thead id="translation-matrix-head"></thead>
          <tbody id="translation-matrix-body"></tbody>
        </table>
      </div>
    </section>

    <!-- Immune System -->
    <section class="section" id="immune">
      <h2 class="section-title">
        {t('dashboard.immune.title')}
        <span class="section-timestamp" data-source="articles"></span>
      </h2>
      <p class="section-subtitle">{t('dashboard.immune.subtitle')}</p>

      <div class="immune-overview" id="immune-overview"></div>

      <h3 class="subsection-title">{t('dashboard.immune.defense.title')}</h3>
      <div class="defense-lines">
        <div class="defense-line">
          <span class="defense-status active">🟢</span>
          <strong>{t('dashboard.immune.defense.line1')}</strong>
          <span class="defense-desc"
            >{t('dashboard.immune.defense.line1.desc')}</span
          >
        </div>
        <div class="defense-line">
          <span class="defense-status active">🟢</span>
          <strong>{t('dashboard.immune.defense.line2')}</strong>
          <span class="defense-desc"
            >{t('dashboard.immune.defense.line2.desc')}</span
          >
        </div>
        <div class="defense-line">
          <span class="defense-status manual">🟡</span>
          <strong>{t('dashboard.immune.defense.line3')}</strong>
          <span class="defense-desc"
            >{t('dashboard.immune.defense.line3.desc')}</span
          >
        </div>
        <div class="defense-line">
          <span class="defense-status active">🟢</span>
          <strong>{t('dashboard.immune.defense.line4')}</strong>
          <span class="defense-desc"
            >{t('dashboard.immune.defense.line4.desc')}</span
          >
        </div>
      </div>

      <h3 class="subsection-title">
        {isEn ? '📋 Citation Health' : '📋 引用健康度'}
      </h3>
      <p class="queue-desc">
        {isEn ? 'How verifiable is the knowledge?' : '知識的可驗證性'}
      </p>
      <div class="citation-health" id="citation-health"></div>

      <h3 class="subsection-title">{t('dashboard.immune.queue.title')}</h3>
      <p class="queue-desc">{t('dashboard.immune.queue.desc')}</p>
      <div class="immune-queue" id="immune-queue"></div>
    </section>

    <!-- Contribution Leaderboard — Top Contributors (2026-04-19 β) -->
    <section class="section" id="contributors">
      <h2 class="section-title">
        {isEn ? '👥 Contribution Leaderboard' : '👥 貢獻者排行榜'}
        <span class="section-timestamp" data-source="contributors"></span>
      </h2>
      <p class="section-subtitle">
        {
          isEn
            ? 'Top 20 contributors by commits + primary area (content / system / translation)'
            : '依 commits 數排序的前 20 位貢獻者，以及主要貢獻類型（內容 / 系統 / 翻譯）'
        }
      </p>

      <div class="contributors-overview" id="contributors-overview"></div>

      <h3 class="subsection-title">
        {isEn ? '🏆 Top 20 Contributors' : '🏆 前 20 位貢獻者'}
      </h3>
      <div class="contributors-leaderboard" id="contributors-leaderboard"></div>

      <h3 class="subsection-title">
        {isEn ? '📊 By Primary Area' : '📊 依主要貢獻領域'}
      </h3>
      <div class="contributors-areas" id="contributors-areas"></div>

      <h3 class="subsection-title">
        {isEn ? '🌱 Recently Joined' : '🌱 最近加入'}
      </h3>
      <p class="section-subtitle" style="margin-top:-8px">
        {
          isEn
            ? 'First-time contributors in the last 30 days'
            : '過去 30 天第一次貢獻的小丑魚'
        }
      </p>
      <div class="contributors-recent" id="contributors-recent"></div>
    </section>

    <!-- Growth Timeline -->
    <section class="section" id="growth">
      <h2 class="section-title">
        {t('dashboard.growth.title')}
        <span class="section-timestamp" data-source="articles"></span>
      </h2>
      <p class="section-subtitle">{t('dashboard.growth.subtitle')}</p>
      <div class="growth-chart" id="growth-chart"></div>
    </section>

    <!-- Content Analysis -->
    <section class="section" id="content-analysis">
      <h2 class="section-title">
        {isEn ? '📊 Content Analysis' : '📊 內容成長分析'}
        <span class="section-timestamp" data-source="articles"></span>
      </h2>
      <p class="section-subtitle">
        {
          isEn
            ? 'Article distribution across categories'
            : '各分類文章分布與成長軌跡'
        }
      </p>
      <div class="content-analysis-grid">
        <div class="ca-chart" id="ca-category-chart"></div>
        <div class="ca-stats" id="ca-stats"></div>
      </div>
    </section>

    <!-- Next Steps -->
    <section class="section" id="next-steps">
      <h2 class="section-title">{isEn ? '🎯 Next Steps' : '🎯 下一步'}</h2>
      <p class="section-subtitle">
        {isEn ? 'Highest-impact contributions right now' : '現在最有價值的貢獻'}
      </p>
      <div class="nextsteps-grid" id="nextsteps-grid"></div>
    </section>

    <!-- Footer timestamp -->
    <footer class="dashboard-footer" id="dashboard-footer"></footer>
  </main>
</Layout>

<!-- Dashboard client 渲染邏輯（2,729 行）在 src/scripts/dashboard-client.js —
     2026-06-13 抽出：原 define:vars inline 每語言頁各內嵌一份；改 Astro processed
     module 後 6 頁共用一份 hashed bundle + 瀏覽器可快取。lang 改讀 <html lang>。-->
<script>
  import '../scripts/dashboard-client.js';
</script>
