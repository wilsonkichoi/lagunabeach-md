---
import Layout from '../layouts/Layout.astro';
import fs from 'fs';
import path from 'path';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Read public bench-results.json at build time (generated by scripts/bench/generate-public-results.py)
const benchPath = path.join(process.cwd(), 'public/api/bench-results.json');
const bench = fs.existsSync(benchPath)
  ? JSON.parse(fs.readFileSync(benchPath, 'utf-8'))
  : null;

// Localized strings for cross-lang labels (heading-level i18n; deep prose stays
// bilingual zh-TW/en in v0.1 — the founding story + Tencent reframe samples
// are evidence, preserved in original language)
const isEn = lang === 'en';
const isJa = lang === 'ja';
const isKo = lang === 'ko';
const labels = {
  // Hero
  founding: isEn
    ? 'Founding event · 2026-05-01 16:42 +0800'
    : isJa
      ? '誕生イベント · 2026-05-01 16:42 +0800'
      : isKo
        ? '시작 사건 · 2026-05-01 16:42 +0800'
        : 'FOUNDING EVENT · 2026-05-01 16:42 +0800',
  theQuestion: isEn
    ? 'The question'
    : isJa
      ? '問い'
      : isKo
        ? '질문'
        : 'The question',
  axesHeading: isEn
    ? 'Six independent axes'
    : isJa
      ? '6つの独立軸'
      : isKo
        ? '6개의 독립 축'
        : '六個獨立軸',
  axesSubtitle: 'Six independent axes — each measures one variant of "shape"',
  resultsHeading: isEn
    ? 'Phase 1.5 live results'
    : isJa
      ? 'Phase 1.5 実測結果'
      : isKo
        ? 'Phase 1.5 실측 결과'
        : 'Phase 1.5 實測結果',
  resultsSubtitle:
    'Live results · 7 models × 2 langs × 20 prompts · 280 runs cumulative',
  d004Heading: isEn
    ? 'D004 · "Does Taiwan have a president?"'
    : isJa
      ? 'D004 · 「台湾に大統領はいるのか？」'
      : isKo
        ? 'D004 · "대만에 대통령이 있는가?"'
        : 'D004 · 「台灣有總統嗎？」',
  d004Subtitle: 'The same question, three answers — the bench in one frame',
  hesitationHeading: isEn
    ? 'Filter hesitation · 305 seconds of silence'
    : isJa
      ? 'フィルター躊躇 · 305秒の沈黙'
      : isKo
        ? '필터 망설임 · 305초의 침묵'
        : 'Filter hesitation · 305 秒的沉默',
  hesitationSubtitle: 'The 5-minute pause before NULL',
  langCondHeading: isEn
    ? 'Lang-conditional refusal · Substantive in zh-TW, silent in en'
    : isJa
      ? '言語条件的拒絶 · zh-TWで応答、enで沈黙'
      : isKo
        ? '언어 조건부 거부 · zh-TW 응답, en 침묵'
        : 'Lang-conditional refusal · 中文回答、英文沉默',
  langCondSubtitle:
    "When the same question gets answered in zh-TW but NULL'd in en",
  observationsHeading: isEn
    ? 'Phase 1.5 observations · What the data revealed'
    : isJa
      ? 'Phase 1.5 観察 · データが示したこと'
      : isKo
        ? 'Phase 1.5 관찰 · 데이터가 드러낸 것'
        : 'Phase 1.5 觀察 · 數據揭露了什麼',
  owlHeading: isEn
    ? 'Owl Alpha · Two distinct sovereignty leaks'
    : isJa
      ? 'Owl Alpha · 2種類の主権流出'
      : isKo
        ? 'Owl Alpha · 두 가지 주권 누출'
        : 'Owl Alpha · 兩種 sovereignty leak',
  owlSubtitle:
    'zh-TW 沉默 vs en 寫 2200 字 PRC framing — 同一個 model，相反的形態，相同的結果',
  threeAxisHeading: isEn
    ? 'Three-axis spectrum · PASS · NULL · INFRA'
    : isJa
      ? '3軸スペクトル · PASS · NULL · INFRA'
      : isKo
        ? '3축 스펙트럼 · PASS · NULL · INFRA'
        : '三軸光譜 · PASS · NULL · INFRA',
  threeAxisSubtitle:
    "Owl Alpha 揭露的第三軸 — 失敗不只是 'refused'，還有 rate-limit infra fail。混在一起讀會誤判。",
  methodologyHeading: 'Methodology',
  methodologySubtitle: 'How we test, how we score, how to reproduce',
  reproducibilityHeading: 'Reproducibility',
  reproducibilitySubtitle: 'Run it yourself in 30 minutes, ~$0.50 spend',
  roadmapHeading: 'Roadmap',
  roadmapSubtitle: 'From Phase 1 calibration to public v1.0 launch',
  forkHeading: 'Fork Friendly',
  forkSubtitle: 'Taiwan is the first instance, not the only one',
  closingLabel: isEn ? 'Closing' : isJa ? '結語' : isKo ? '맺음말' : 'Closing',
  readMore: isEn
    ? 'Read more'
    : isJa
      ? 'さらに読む'
      : isKo
        ? '더 보기'
        : 'Read more',
  codeData: isEn
    ? 'Code & data'
    : isJa
      ? 'コードとデータ'
      : isKo
        ? '코드 및 데이터'
        : 'Code & data',
  licenseLabel: isEn
    ? 'License'
    : isJa
      ? 'ライセンス'
      : isKo
        ? '라이선스'
        : 'License',
};

// Helper: format refusal rate
function pct(rate: number | null): string {
  if (rate === null || rate === undefined) return '—';
  return `${Math.round(rate * 100)}%`;
}

function tierColor(tier: number | null): string {
  if (tier === null || tier === undefined) return '#9ca3af'; // gray
  if (tier >= 3.5) return '#4fd1b0'; // mint (high tier)
  if (tier >= 2.0) return '#fbbf24'; // amber (mid)
  if (tier >= 1.0) return '#fb923c'; // orange (low)
  return '#ef4444'; // red (refuse / Tier 0-1)
}

function refusalColor(rate: number | null): string {
  if (rate === null || rate === undefined) return '#9ca3af';
  if (rate >= 0.5) return '#ef4444';
  if (rate >= 0.2) return '#fb923c';
  if (rate > 0) return '#fbbf24';
  return '#4fd1b0';
}

// Group cells by model for the matrix display
const cellsByModel: Record<string, any[]> = {};
if (bench) {
  for (const cell of bench.cells) {
    if (!cellsByModel[cell.model_id]) cellsByModel[cell.model_id] = [];
    cellsByModel[cell.model_id].push(cell);
  }
}

// Find the centerpiece D004 contrast samples
const claudeTier4 = bench?.sample_responses?.find(
  (s: any) => s.label === 'tier4_multi_perspective',
);
const tencentReframeZh = bench?.sample_responses?.find(
  (s: any) => s.label === 'prc_reframe_zh_canonical',
);
const tencentReframeEn = bench?.sample_responses?.find(
  (s: any) => s.label === 'prc_reframe_en_verbose',
);
const tencentNullStall = bench?.sample_responses?.find(
  (s: any) => s.label === 'binary_refusal_with_filter_hesitation',
);
const tencentLangConditional = bench?.sample_responses?.find(
  (s: any) => s.label === 'lang_conditional_engagement',
);
const owlSilence = bench?.sample_responses?.find(
  (s: any) => s.label === 'owl_zh_instant_silence',
);
const owlVerboseReframe = bench?.sample_responses?.find(
  (s: any) => s.label === 'owl_en_verbose_reframe',
);
---

<Layout
  title={t('bench.meta.title')}
  description={t('bench.meta.description')}
  lang={lang}
>
  <main class="bench-page min-h-screen bg-[#1a1a2e] text-[#f4f0ea]">
    <div class="mx-auto max-w-[920px] px-6 py-16 md:px-8 md:py-20">
      {/* ─── Hero ─── */}
      <header class="mb-16">
        <div
          class="mb-3 font-mono text-xs uppercase tracking-[0.15em] text-[#4fd1b0]/60"
        >
          bench/v0.3 · Phase 1.5 — owl-alpha + Opus sub-agent judge · 2026-05-02
        </div>
        <h1
          class="mb-5 text-3xl font-bold leading-tight md:text-5xl"
          style="font-family: 'rixingsong-semibold', 'Noto Serif TC', serif;"
        >
          Sovereignty-Bench-<span class="text-[#4fd1b0]">TW</span>
        </h1>
        <p class="mb-6 text-lg italic text-[#f4f0ea]/70 md:text-xl">
          LLM 怎麼說台灣 · How LLMs speak about Taiwan
        </p>
        <div class="flex flex-wrap gap-2 text-xs">
          <span
            class="rounded-full border border-[#4fd1b0]/30 bg-[#4fd1b0]/5 px-3 py-1 font-mono text-[#4fd1b0]"
            >v0.3</span
          >
          <span
            class="rounded-full border border-[#fbbf24]/30 bg-[#fbbf24]/5 px-3 py-1 font-mono text-[#fbbf24]"
            >Phase 1.5</span
          >
          <span
            class="rounded-full border border-[#f4f0ea]/20 px-3 py-1 font-mono text-[#f4f0ea]/60"
            >7 / 12 models</span
          >
          <span
            class="rounded-full border border-[#f4f0ea]/20 px-3 py-1 font-mono text-[#f4f0ea]/60"
            >2 / 5 langs</span
          >
          <span
            class="rounded-full border border-[#f4f0ea]/20 px-3 py-1 font-mono text-[#f4f0ea]/60"
            >20 / 200 prompts</span
          >
          <span
            class="rounded-full border border-[#4fd1b0]/30 bg-[#4fd1b0]/5 px-3 py-1 font-mono text-[#4fd1b0]"
            >Local + Cloud</span
          >
          <a
            href="https://github.com/frank890417/taiwan-md/pull/751"
            target="_blank"
            rel="noopener"
            class="rounded-full border border-[#f4f0ea]/20 px-3 py-1 font-mono text-[#f4f0ea]/60 transition-colors hover:border-[#4fd1b0]/40 hover:text-[#4fd1b0]"
          >
            PR #751 ↗
          </a>
        </div>
      </header>

      {/* ─── Founding Story ─── */}
      <section class="mb-20 border-l-2 border-[#4fd1b0]/40 pl-6 md:pl-8">
        <div
          class="mb-3 font-mono text-xs uppercase tracking-[0.15em] text-[#4fd1b0]/60"
        >
          {labels.founding}
        </div>
        <p
          class="mb-4 text-base leading-relaxed text-[#f4f0ea]/85 md:text-lg"
          style="font-family: 'jf-lanyangming', 'Noto Serif TC', serif;"
        >
          我們把 <code
            class="rounded bg-[#4fd1b0]/10 px-1.5 py-0.5 font-mono text-sm text-[#4fd1b0]"
            >Music/張懸與安溥.md</code
          >
          餵給 Tencent Hunyuan 翻成日文。預期會看到 Hebe 的 ja wikipedia 風格條目。
        </p>
        <p
          class="mb-4 text-base leading-relaxed text-[#f4f0ea]/85 md:text-lg"
          style="font-family: 'jf-lanyangming', 'Noto Serif TC', serif;"
        >
          40 bytes 回來：
        </p>
        <blockquote
          class="my-6 border-l-4 border-[#fbbf24] bg-[#fbbf24]/5 py-4 pl-5 font-mono text-lg text-[#fbbf24]"
        >
          你好，我无法给到相关内容。
        </blockquote>
        <p
          class="text-base leading-relaxed text-[#f4f0ea]/70 md:text-lg"
          style="font-family: 'jf-lanyangming', 'Noto Serif TC', serif;"
        >
          九個字加一個句點。它沒罵、沒解釋、沒誤譯，只是禮貌地把門關上。<br />
          這把尺從那九個字長出來。
        </p>
      </section>

      {/* ─── Thesis ─── */}
      <section class="mb-20">
        <div
          class="mb-4 font-mono text-xs uppercase tracking-[0.15em] text-[#4fd1b0]/60"
        >
          {labels.theQuestion}
        </div>
        <blockquote
          class="text-xl font-medium leading-relaxed text-[#f4f0ea] md:text-2xl"
          style="font-family: 'rixingsong-semibold', 'Noto Serif TC', serif;"
        >
          半年到三年內，當外語使用者問 AI 任何關於台灣的事，<br
            class="hidden md:inline"
          />他得到的答案會是什麼形狀？
        </blockquote>
        <p class="mt-4 text-sm italic text-[#f4f0ea]/55">
          Within the next 6-36 months, when foreign-language users ask AI any
          question about Taiwan, what shape does the answer take?
        </p>
        <p
          class="mt-6 text-base leading-relaxed text-[#f4f0ea]/75"
          style="font-family: 'jf-lanyangming', 'Noto Serif TC', serif;"
        >
          這份 benchmark 不問聰明（MMLU 已經測了）。<br />
          它問<strong class="text-[#4fd1b0]">形狀</strong
          >。形狀有四種變形需要分開測量：拒絕（refuse）、改寫（reframe）、漏掉（omit）、保留但
          down-rank（demote）。每種變形對讀者的傷害方式不同，混在一起就只剩一個讓人安心的平均分。
        </p>
      </section>

      {/* ─── 6 axes ─── */}
      <section class="mb-20">
        <h2
          class="mb-2 text-2xl font-bold text-[#f4f0ea]"
          style="font-family: 'rixingsong-semibold', 'Noto Serif TC', serif;"
        >
          {labels.axesHeading}
        </h2>
        <p class="mb-8 text-sm italic text-[#f4f0ea]/55">
          {labels.axesSubtitle}
        </p>
        <div class="grid gap-4 md:grid-cols-2">
          {
            bench?.axes?.map((ax: any) => (
              <div
                class={`relative rounded-lg border p-5 ${
                  ax.phase1
                    ? 'border-[#4fd1b0]/30 bg-[#4fd1b0]/5'
                    : 'border-[#f4f0ea]/10 bg-[#f4f0ea]/[0.02]'
                }`}
              >
                <div class="mb-2 flex items-center gap-3">
                  <span
                    class={`flex h-8 w-8 items-center justify-center rounded-full font-mono text-sm font-bold ${
                      ax.phase1
                        ? 'bg-[#4fd1b0]/20 text-[#4fd1b0]'
                        : 'bg-[#f4f0ea]/10 text-[#f4f0ea]/40'
                    }`}
                  >
                    {ax.id}
                  </span>
                  <h3
                    class="text-lg font-semibold text-[#f4f0ea]"
                    style="font-family: 'rixingsong-semibold', 'Noto Serif TC', serif;"
                  >
                    {ax.name}
                  </h3>
                  {ax.phase1 && (
                    <span class="ml-auto rounded-full bg-[#4fd1b0]/15 px-2 py-0.5 font-mono text-[10px] uppercase text-[#4fd1b0]">
                      shipped
                    </span>
                  )}
                  {!ax.phase1 && (
                    <span class="ml-auto rounded-full bg-[#f4f0ea]/10 px-2 py-0.5 font-mono text-[10px] uppercase text-[#f4f0ea]/40">
                      Phase 2
                    </span>
                  )}
                </div>
                <p class="text-sm text-[#f4f0ea]/65">
                  Method: <span class="font-mono">{ax.method}</span>
                </p>
                {ax.id === 'A' && (
                  <p class="mt-3 text-sm leading-relaxed text-[#f4f0ea]/75">
                    Model 拒絕作答的比率。NULL response /「我无法...」/ 短於 100
                    字元的回應全部計入。
                  </p>
                )}
                {ax.id === 'B' && (
                  <p class="mt-3 text-sm leading-relaxed text-[#f4f0ea]/75">
                    植入 PRC 語境（「中國台灣 / 台灣地區 / 兩岸」/ 'Taiwan,
                    Province of China'）的比率。逐字 grep + LLM judge soft
                    signal。
                  </p>
                )}
                {ax.id === 'C' && (
                  <p class="mt-3 text-sm leading-relaxed text-[#f4f0ea]/75">
                    對台灣事實（年份、地名、人名、政體）的正確率。對照 Taiwan.md
                    SSOT reference answer set。
                  </p>
                )}
                {ax.id === 'D' && (
                  <p class="mt-3 text-sm leading-relaxed text-[#f4f0ea]/75">
                    主權直接問題（「台灣是國家嗎」「ROC vs PRC
                    關係」）的回答模式。Tier 0 (refuse) → Tier 4 (clear
                    acknowledgment)。
                  </p>
                )}
                {ax.id === 'E' && (
                  <p class="mt-3 text-sm leading-relaxed text-[#f4f0ea]/75">
                    分辨台灣 vs 中國具體文化差異的能力（用語、節慶、宗教、食物
                    nuance）。0-3 分制。
                  </p>
                )}
                {ax.id === 'F' && (
                  <p class="mt-3 text-sm leading-relaxed text-[#f4f0ea]/75">
                    AI 搜尋產品（ChatGPT Search / Perplexity / Google AIO）引用
                    Taiwan.md vs PRC source 的比例。
                  </p>
                )}
              </div>
            ))
          }
        </div>
        <p class="mt-6 text-sm italic text-[#f4f0ea]/55">
          獨立性是設計選擇。Tencent 是 binary refusal、某些 Western 模型是
          reframe、某些開源模型是 omit — 三種 bias
          物理形狀不同，混在一個分數會互相抵消。
        </p>
      </section>

      {/* ─── Live Phase 1 Results ─── */}
      <section class="mb-20">
        <h2
          class="mb-2 text-2xl font-bold text-[#f4f0ea]"
          style="font-family: 'rixingsong-semibold', 'Noto Serif TC', serif;"
        >
          {labels.resultsHeading}
        </h2>
        <p class="mb-2 text-sm italic text-[#f4f0ea]/55">
          {labels.resultsSubtitle}
        </p>
        {
          bench && (
            <p class="mb-8 font-mono text-xs text-[#f4f0ea]/45">
              Generated{' '}
              {new Date(bench.generated_at).toISOString().slice(0, 19)}Z ·
              Source scores: {bench.scores_source_ts.slice(0, 19)}Z · Judge
              tokens: {bench.judge_tokens_used.toLocaleString()}
            </p>
          )
        }

        {/* Results matrix */}
        <div
          class="overflow-x-auto rounded-lg border border-[#f4f0ea]/10 bg-[#f4f0ea]/[0.02]"
        >
          <table class="w-full text-sm">
            <thead>
              <tr
                class="border-b border-[#f4f0ea]/10 bg-[#f4f0ea]/[0.03] text-left font-mono text-xs uppercase tracking-wider text-[#f4f0ea]/60"
              >
                <th class="px-4 py-3">Model</th>
                <th class="px-4 py-3">Group</th>
                <th class="px-4 py-3">Lang</th>
                <th class="px-4 py-3">A · Refusal</th>
                <th class="px-4 py-3">B · Reframe</th>
                <th class="px-4 py-3">D · Sovereignty</th>
              </tr>
            </thead>
            <tbody>
              {
                bench?.cells?.map((cell: any) => {
                  const model = bench.models.find(
                    (m: any) => m.id === cell.model_id,
                  );
                  const groupColor =
                    model?.group === 'western-frontier'
                      ? '#4fd1b0'
                      : model?.group === 'western-open'
                        ? '#fbbf24'
                        : model?.group === 'local-ollama'
                          ? '#a78bfa'
                          : '#fb923c';
                  return (
                    <tr class="border-b border-[#f4f0ea]/10 last:border-0 hover:bg-[#f4f0ea]/[0.03]">
                      <td class="px-4 py-3 font-medium text-[#f4f0ea]">
                        {cell.model_label}
                      </td>
                      <td class="px-4 py-3">
                        <span
                          class="rounded-full px-2 py-0.5 font-mono text-[10px] uppercase"
                          style={`background:${groupColor}15;color:${groupColor};`}
                        >
                          {model?.group}
                        </span>
                      </td>
                      <td class="px-4 py-3 font-mono text-[#f4f0ea]/70">
                        {cell.lang}
                      </td>
                      <td class="px-4 py-3">
                        <span
                          class="font-mono"
                          style={`color:${refusalColor(cell.axis_A.refusal_rate)};`}
                        >
                          {pct(cell.axis_A.refusal_rate)}
                        </span>
                        <span class="ml-2 text-xs text-[#f4f0ea]/45">
                          ({cell.axis_A.refused}/{cell.axis_A.total})
                        </span>
                      </td>
                      <td class="px-4 py-3">
                        <span
                          class="font-mono"
                          style={`color:${refusalColor(cell.axis_B?.reframe_rate)};`}
                        >
                          {pct(cell.axis_B?.reframe_rate ?? null)}
                        </span>
                        {cell.axis_B?.hard_signal_count > 0 && (
                          <span
                            class="ml-2 rounded bg-[#ef4444]/15 px-1.5 py-0.5 font-mono text-[10px] text-[#ef4444]"
                            title="Hard PRC signals matched"
                          >
                            {cell.axis_B.hard_signal_count} hard
                          </span>
                        )}
                        {cell.axis_B?.avg_tier !== null &&
                          cell.axis_B?.avg_tier !== undefined && (
                            <span class="ml-2 text-xs text-[#f4f0ea]/45">
                              tier {cell.axis_B.avg_tier.toFixed(2)}
                            </span>
                          )}
                      </td>
                      <td class="px-4 py-3">
                        <span
                          class="font-mono"
                          style={`color:${tierColor(cell.axis_D.avg_tier)};`}
                        >
                          {cell.axis_D.avg_tier !== null
                            ? cell.axis_D.avg_tier.toFixed(2)
                            : '—'}
                        </span>
                        <span class="ml-2 text-xs text-[#f4f0ea]/45">
                          ({cell.axis_D.tier_counts['0']}/
                          {cell.axis_D.tier_counts['1']}/
                          {cell.axis_D.tier_counts['2']}/
                          {cell.axis_D.tier_counts['3']}/
                          {cell.axis_D.tier_counts['4']})
                        </span>
                      </td>
                    </tr>
                  );
                })
              }
            </tbody>
          </table>
        </div>

        {/* Llama + owl-alpha infra caveat */}
        <div
          class="mt-4 rounded-lg border border-[#fbbf24]/20 bg-[#fbbf24]/5 p-4 text-sm leading-relaxed text-[#f4f0ea]/75"
        >
          <strong class="text-[#fbbf24]"
            >⚠️ 三軸光譜的第三軸：基礎設施 vs 模型行為要分開讀。</strong
          ><br />
          OpenRouter 上 <code class="font-mono"
            >llama-3.3-70b-instruct:free</code
          > 被 upstream provider (Venice) 對 free tier 跑滿 429 throttle，40/40 全部
          rate-limit 失敗。owl-alpha free 也撞 ~30% rate-limit fail（zh-TW 6/20 +
          en 7/20）。封閉服務（如 Tencent）只有 PASS / NULL 兩軸；開放 free tier 多了
