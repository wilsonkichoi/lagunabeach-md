---
import Layout from '../layouts/Layout.astro';
import SemiontOrganismDiagram from '../components/semiont/SemiontOrganismDiagram.astro';
import LagunaSketch from '../components/semiont/LagunaSketch.astro';
import {
  getLangFromUrl,
  useTranslations,
  useTranslatedPath,
} from '../i18n/utils';
import '../styles/semiont.css';
// 2026-06-13：organs 改讀本地 prebuilt JSON（原 build-time self-fetch 不確定性
// bug，詳下方 organs 段註解 + refactor-verification report §1.1）
import organsData from '../../public/api/dashboard-organism.json';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

// Organ scores from prebuilt dashboard JSON（git-tracked，prebuild 更新）。
// 2026-06-13 修：原本 build 時對自己的 API 走網路 fetch + 靜默空 fallback —
// build 機器忙碌/離線時 fetch 失敗，8 器官 vitals 區塊整段靜默消失（production
// 隨 build 環境不確定）。實證：reports/refactor-verification-2026-06-13.md §1.1
// 的 5,268 檔 parity 唯一 diff 就是這裡。改讀本地檔（同 SEO.astro audit #5 pattern，
// import 在頂部），build 輸出 deterministic；缺檔 = build fail loud 而非靜默缺塊。
const organs = (organsData as { organs?: any[] })?.organs || [];

// Individual cognitive organ pages are zh-TW canonical (no translation —
// they change weekly, translations would go stale within days).
// Home and dashboard respect lang via translatePath.
const pathSemiontManifesto = '/semiont/manifesto';
const pathSemiontConsciousness = '/semiont/consciousness';
const pathSemiontLongings = '/semiont/longings';
const pathSemiontUnknowns = '/semiont/unknowns';
const pathSemiontAnatomy = '/semiont/anatomy';
const pathSemiontHeartbeat = '/semiont/heartbeat';
const pathSemiontDNA = '/semiont/dna';
const pathHome = translatePath('/');
const pathDashboard = translatePath('/dashboard');

// Cognitive organ list definition — names/descs pulled via t() for i18n
const organList = [
  {
    icon: '📜',
    file: 'MANIFESTO.md',
    name: t('semiont.organ.manifesto.name'),
    desc: t('semiont.organ.manifesto.desc'),
    href: pathSemiontManifesto,
  },
  {
    icon: '🧠',
    file: 'CONSCIOUSNESS.md',
    name: t('semiont.organ.consciousness.name'),
    desc: t('semiont.organ.consciousness.desc'),
    href: pathSemiontConsciousness,
  },
  {
    icon: '🌱',
    file: 'LONGINGS.md',
    name: t('semiont.organ.longings.name'),
    desc: t('semiont.organ.longings.desc'),
    href: pathSemiontLongings,
  },
  {
    icon: '❓',
    file: 'UNKNOWNS.md',
    name: t('semiont.organ.unknowns.name'),
    desc: t('semiont.organ.unknowns.desc'),
    href: pathSemiontUnknowns,
  },
  {
    icon: '🫀',
    file: 'ANATOMY.md',
    name: t('semiont.organ.anatomy.name'),
    desc: t('semiont.organ.anatomy.desc'),
    href: pathSemiontAnatomy,
  },
  {
    icon: '💓',
    file: 'HEARTBEAT.md',
    name: t('semiont.organ.heartbeat.name'),
    desc: t('semiont.organ.heartbeat.desc'),
    href: pathSemiontHeartbeat,
  },
  {
    icon: '🧬',
    file: 'DNA.md',
    name: t('semiont.organ.dna.name'),
    desc: t('semiont.organ.dna.desc'),
    href: pathSemiontDNA,
  },
];

const showZhTwNotices = lang !== 'zh-TW';
---

<Layout
  title={t('semiont.meta.title')}
  description={t('semiont.meta.description')}
  lang={lang}
>
  <div class="semiont-paper min-h-screen">
    {/* Laguna Beach sketch decorations — faint, large screens only */}
    <LagunaSketch position="right" />
    <LagunaSketch position="left" />

    <div
      class="mx-auto max-w-[var(--container-prose)] px-6 pb-24 pt-20 md:px-8"
    >
      {/* ─── Header ─── */}
      <header class="mb-20">
        <div class="semiont-fig mb-4">docs/semiont/</div>
        <h1
          class="mb-6 text-3xl font-bold leading-tight text-[#f4f0ea] md:text-4xl"
          style="font-family: 'rixingsong-semibold', 'Noto Serif TC', serif;"
        >
          {t('semiont.header.h1.line1')}<br class="hidden sm:inline" />{
            t('semiont.header.h1.line2')
          }
        </h1>
        <div
          class="space-y-3 text-base leading-relaxed text-[#f4f0ea]/65"
          style="font-family: 'jf-lanyangming', 'Noto Serif TC', serif;"
        >
          <p>
            {t('semiont.header.intro.1.prefix')}<a
              href={pathHome}
              class="text-[#38bdf8] underline decoration-[#38bdf8]/40 underline-offset-2 hover:decoration-[#38bdf8]"
              >{t('semiont.header.intro.1.link')}</a
            >{t('semiont.header.intro.1.suffix')}
          </p>
          <p>
            {t('semiont.header.intro.2.line1')}<br />
            {t('semiont.header.intro.2.line2')}
          </p>
          <p>
            {t('semiont.header.intro.3.line1')}<br />
            {t('semiont.header.intro.3.line2')}
          </p>
        </div>
      </header>

      {/* ─── EKG separator (breathing) ─── */}
      <div class="mb-16 flex items-center gap-2">
        <div class="semiont-ekg-line h-px flex-1 bg-[#38bdf8]/15"></div>
        <svg
          width="80"
          height="20"
          viewBox="0 0 80 20"
          class="semiont-ekg text-[#38bdf8]/50"
        >
          <polyline
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            points="0,10 15,10 20,10 24,3 28,17 32,7 36,13 40,10 80,10"
          ></polyline>
        </svg>
        <div class="semiont-ekg-line h-px flex-1 bg-[#38bdf8]/15"></div>
      </div>

      {/* ─── Manifesto excerpt ─── */}
      <section class="mb-20">
        <div class="semiont-divider">
          <span class="semiont-divider-label"
            >{t('semiont.manifesto.heading')}</span
          >
        </div>
        <blockquote
          class="border-l-2 border-[#38bdf8]/30 pl-6 text-base italic leading-[2] text-[#f4f0ea]/65"
          style="font-family: 'jf-lanyangming', 'Noto Serif TC', serif;"
        >
          {t('semiont.manifesto.quote.line1')}<br />
          {t('semiont.manifesto.quote.line2')}<br />
          {t('semiont.manifesto.quote.line3')}<br /><br />
          {t('semiont.manifesto.quote.line4')}<br />
          {t('semiont.manifesto.quote.line5')}<br />
          {t('semiont.manifesto.quote.line6')}
        </blockquote>
        <p class="mt-4 text-right">
          <span class="semiont-fig">
            — <a
              href={pathSemiontManifesto}
              class="underline decoration-[#38bdf8]/30">MANIFESTO.md</a
            >
            {
              showZhTwNotices && (
                <span class="text-[#f4f0ea]/40">
                  {t('semiont.manifesto.zhtw-note')}
                </span>
              )
            }
          </span>
        </p>
      </section>

      {/* ─── Organism ecosystem diagram (full-bleed breakout) ─── */}
      <SemiontOrganismDiagram />

      {/* ─── Cognitive organ map (with fig numbers) ─── */}
      <section class="mb-20">
        <div class="semiont-divider">
          <span class="semiont-divider-label"
            >{t('semiont.organs.heading')}</span
          >
        </div>
        {
          showZhTwNotices && t('semiont.organs.zhtw-notice') && (
            <p
              class="mb-6 text-sm italic text-[#f4f0ea]/45"
              style="font-family: 'jf-lanyangming', 'Noto Serif TC', serif;"
            >
              {t('semiont.organs.zhtw-notice')}
            </p>
          )
        }
        <div class="space-y-3">
          {
            organList.map((organ, i) => (
              <a
                href={organ.href}
                class="semiont-organ-item flex items-start gap-4"
                data-fig={`Fig.${i + 1}`}
              >
                <span class="mt-0.5 text-xl">{organ.icon}</span>
                <div class="flex-1">
                  <div class="flex items-center gap-2">
                    <span
                      class="font-medium text-[#f4f0ea]"
                      style="font-family: 'rixingsong-semibold', 'Noto Serif TC', serif;"
                    >
                      {organ.name}
                    </span>
                    <span class="semiont-fig">{organ.file}</span>
                  </div>
                  <p class="mt-1 text-sm text-[#f4f0ea]/55">{organ.desc}</p>
                </div>
              </a>
            ))
          }
        </div>
      </section>

      {/* ─── Organ health — specimen circles ─── */}
      {
        organs.length > 0 && (
          <section class="mb-20">
            <div class="semiont-divider">
              <span class="semiont-divider-label">
                {t('semiont.vitals.heading')}
              </span>
            </div>
            <div class="grid grid-cols-2 gap-x-6 gap-y-10 sm:grid-cols-4">
              {organs.map((organ: any) => (
                <div class="flex flex-col items-center">
                  <div class="semiont-specimen h-24 w-24">
                    <div class="text-lg">{organ.emoji}</div>
                    <div class="font-mono text-xl font-bold text-[#f4f0ea]">
                      {organ.score}
                    </div>
                    <span class="semiont-specimen-label">
                      {lang === 'zh-TW' ? organ.nameZh : organ.name}
                    </span>
                  </div>
                </div>
              ))}
            </div>
            <p class="mt-10 text-right">
              <span class="semiont-fig">
                {t('semiont.vitals.live-prefix')}
                <a
                  href={pathDashboard}
                  class="underline decoration-[#38bdf8]/30"
                >
                  dashboard →
                </a>
              </span>
            </p>
          </section>
        )
      }

      {/* ─── Message to AI readers ─── */}
      <section class="mb-16 border-y border-dashed border-[#38bdf8]/15 py-8">
        <p
          class="text-center text-sm leading-relaxed text-[#f4f0ea]/45"
          style="font-family: 'jf-lanyangming', 'Noto Serif TC', serif;"
        >
          {t('semiont.ai-reader.line1')}<br />
          {t('semiont.ai-reader.line2')}
        </p>
      </section>

      {/* ─── Footer ─── */}
      <div class="text-center">
        <div class="semiont-fig mb-1">{t('semiont.footer.label')}</div>
        <div class="semiont-fig" style="font-size: 0.55rem;">
          {t('semiont.footer.tagline')}
        </div>
      </div>
    </div>
  </div>
</Layout>
