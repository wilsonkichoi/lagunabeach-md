---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import {
  getLangFromUrl,
  useTranslations,
  useTranslatedPath,
} from '../i18n/utils';
import {
  getCompanyConfigs,
  getCategories,
  sectorColors,
} from '../utils/dataConfig';
import contentStats from '../data/content-stats.json';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

// Get companies from centralized config
const companies = getCompanyConfigs(t);

const sectors = [...new Set(companies.map((c) => c.sector))];

// Get categories from centralized config
const dataCategories = getCategories(t);
---

<Layout
  lang={lang}
  title={t('data.meta.title')}
  description={t('data.meta.description')}
>
  <!--
    Phase 7.6 — data.template.astro (Tier 1, partial)
    Wrappers migrated to inline Tailwind: `.data-hub`, `.hero`,
    `.hero-title`, `.hero-subtitle`, `.hero-desc`, `.section-divider`,
    `.story-intro`, `.section-title`, `.story-text`. Kept scoped
    (d3 / repeating / :global() territory):
    - All .comparison-card / .country-bar / .company-card repeats
    - .bubble-controls + .toggle-btn / .sector-btn .active state
    - :global(.tooltip) for the d3 bubble chart
    - All d3-styled SVG nodes and population pyramid bars
    - Responsive overrides for the repeating patterns
  -->
  <main
    class="min-h-screen bg-[linear-gradient(135deg,#0f172a_0%,#1e293b_100%)] text-[#e2e8f0]"
  >
    <!-- Hero -->
    <PageHero
      bgTone="dark"
      titleVariant="gradient"
      titleGradient="linear-gradient(135deg,#38bdf8,#818cf8,#c084fc)"
      titleSize="clamp"
      containerWidth="wide"
      title={t('data.hero.title')}
      subtitle={t('data.hero.subtitle')}
    >
      <p
        class="mx-auto mt-4 max-w-[600px] text-base leading-[1.7] text-[#cbd5e1]"
      >
        {t('data.hero.description')}
      </p>
    </PageHero>

    <!-- Taiwan vs World Infographic Section -->
    <section class="taiwan-vs-world-section" id="global">
      <div class="section-divider">
        <div class="divider-line"></div>
      </div>

      <div class="story-intro">
        <h2 class="section-title">{t('data.taiwanVsWorld.title')}</h2>
        <div class="story-text">
          <p>{t('data.taiwanVsWorld.story.p1')}</p>
          <p>{t('data.taiwanVsWorld.story.p2')}</p>
        </div>
      </div>

      <div
        class="mx-auto grid max-w-[1400px] grid-cols-[repeat(auto-fit,minmax(280px,1fr))] gap-6 px-8 max-[640px]:grid-cols-[1fr]"
      >
        <div class="comparison-card">
          <div class="card-emoji">📏</div>
          <div class="card-number">{t('data.taiwanVsWorld.area.number')}</div>
          <div class="card-label">{t('data.taiwanVsWorld.area.label')}</div>
          <div class="card-context">{t('data.taiwanVsWorld.area.context')}</div>
        </div>

        <div class="comparison-card">
          <div class="card-emoji">💰</div>
          <div class="card-number">{t('data.taiwanVsWorld.gdp.number')}</div>
          <div class="card-label">{t('data.taiwanVsWorld.gdp.label')}</div>
          <div class="card-context">{t('data.taiwanVsWorld.gdp.context')}</div>
        </div>

        <div class="comparison-card">
          <div class="card-emoji">🏭</div>
          <div class="card-number">
            {t('data.taiwanVsWorld.semiconductor.number')}
          </div>
          <div class="card-label">
            {t('data.taiwanVsWorld.semiconductor.label')}
          </div>
          <div class="card-context">
            {t('data.taiwanVsWorld.semiconductor.context')}
          </div>
        </div>

        <div class="comparison-card">
          <div class="card-emoji">🗳️</div>
          <div class="card-number">
            {t('data.taiwanVsWorld.democracy.number')}
          </div>
          <div class="card-label">
            {t('data.taiwanVsWorld.democracy.label')}
          </div>
          <div class="card-context">
            {t('data.taiwanVsWorld.democracy.context')}
          </div>
        </div>

        <div class="comparison-card">
          <div class="card-emoji">👶</div>
          <div class="card-number">
            {t('data.taiwanVsWorld.birthRate.number')}
          </div>
          <div class="card-label">
            {t('data.taiwanVsWorld.birthRate.label')}
          </div>
          <div class="card-context">
            {t('data.taiwanVsWorld.birthRate.context')}
          </div>
        </div>

        <div class="comparison-card">
          <div class="card-emoji">🏪</div>
          <div class="card-number">
            {t('data.taiwanVsWorld.convenience.number')}
          </div>
          <div class="card-label">
            {t('data.taiwanVsWorld.convenience.label')}
          </div>
          <div class="card-context">
            {t('data.taiwanVsWorld.convenience.context')}
          </div>
        </div>

        <div class="comparison-card">
          <div class="card-emoji">🚄</div>
          <div class="card-number">{t('data.taiwanVsWorld.hsr.number')}</div>
          <div class="card-label">{t('data.taiwanVsWorld.hsr.label')}</div>
          <div class="card-context">{t('data.taiwanVsWorld.hsr.context')}</div>
        </div>

        <div class="comparison-card">
          <div class="card-emoji">🏥</div>
          <div class="card-number">
            {t('data.taiwanVsWorld.healthcare.number')}
          </div>
          <div class="card-label">
            {t('data.taiwanVsWorld.healthcare.label')}
          </div>
          <div class="card-context">
            {t('data.taiwanVsWorld.healthcare.context')}
          </div>
        </div>
      </div>
    </section>

    <!-- Population Pyramid Section -->
    <section class="population-section" id="population">
      <div class="section-divider">
        <div class="divider-line"></div>
      </div>

      <div class="story-intro">
        <h2 class="section-title">{t('data.population.title')}</h2>
        <div class="story-text">
          <p>{t('data.population.story.p1')}</p>
          <p>{t('data.population.story.p2')}</p>
        </div>
      </div>

      <!-- Population Pyramid Chart -->
      <div class="pyramid-container">
        <div id="population-pyramid"></div>

        <!-- Year Slider -->
        <div class="year-slider-container">
          <div class="slider-track">
            <div class="slider-thumb" id="yearThumb"></div>
          </div>
          <div class="year-labels">
            <span>2000</span>
            <span>2010</span>
            <span>2025</span>
            <span>2050</span>
          </div>
          <div class="current-year" id="currentYear">2025</div>
        </div>
      </div>

      <!-- Key Insights Cards (dynamic, syncs with slider) -->
      <div class="insights">
        <div class="insight-grid">
          <div class="insight-card">
            <div class="insight-label" id="insightLabel1">
              {t('data.population.insights.card1.title')}
            </div>
            <div class="insight-number" id="insightValue1">43</div>
            <div class="insight-detail" id="insightUnit1">
              {t('data.population.insights.card1.subtitle')}
            </div>
          </div>
          <div class="insight-card">
            <div class="insight-label" id="insightLabel2">
              {t('data.population.insights.card2.title')}
            </div>
            <div class="insight-number" id="insightValue2">0.87</div>
            <div class="insight-detail" id="insightUnit2">
              {t('data.population.insights.card2.subtitle')}
            </div>
          </div>
          <div class="insight-card">
            <div class="insight-label" id="insightLabel3">
              {t('data.population.insights.card3.title')}
            </div>
            <div class="insight-number" id="insightValue3">18%</div>
            <div class="insight-detail" id="insightUnit3">
              {t('data.population.insights.card3.subtitle')}
            </div>
          </div>
          <div class="insight-card">
            <div class="insight-label" id="insightLabel4">
              {t('data.population.insights.card4.title')}
            </div>
            <div class="insight-number" id="insightValue4">2,340</div>
            <div class="insight-detail" id="insightUnit4">
              {t('data.population.insights.card4.subtitle')}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Taiwan Shape Section — now a teaser linking to the standalone /taiwan-shape page -->
    <section class="taiwan-shape-section" id="shape">
      <div class="section-divider">
        <div class="divider-line"></div>
      </div>

      <div class="story-intro">
        <h2 class="section-title">{t('data.taiwanShape.title')}</h2>
        <div class="story-text">
          <p>{t('data.taiwanShape.story.p1')}</p>
          <p>{t('data.taiwanShape.story.p2')}</p>
        </div>
      </div>

      <!-- AI vs Real Taiwan Comparison -->
      <div class="taiwan-comparison">
        <h3 class="comparison-title">{t('data.taiwanComparison.title')}</h3>
        <div class="comparison-grid">
          <div class="comparison-item wrong">
            <div class="svg-container">
              <img
                src="/assets/svg/ai-taiwan-wrong.svg"
                alt="AI Generated Taiwan (Wrong)"
              />
            </div>
            <div class="comparison-label wrong">
              {t('data.taiwanComparison.aiGenerated')}
            </div>
          </div>
          <div class="comparison-vs">VS</div>
          <div class="comparison-item correct">
            <div class="svg-container">
              <img
                src="/assets/svg/taiwan-icon-wiki.svg"
                alt="Correct Taiwan Shape"
              />
            </div>
            <div class="comparison-label correct">
              {t('data.taiwanComparison.correct')}
            </div>
          </div>
        </div>
      </div>

      <!-- CTA to standalone page -->
      <div class="shape-cta-card">
        <div class="shape-cta-content">
          <h3>
            {
              lang === 'en'
                ? '🗺️ Explore the full open-source map archive'
                : lang === 'ja'
                  ? '🗺️ オープンソース地図データ全集へ'
                  : lang === 'ko'
                    ? '🗺️ 오픈소스 지도 데이터 전체 보기'
                    : '🗺️ 前往完整開源地圖資料集'
            }
          </h3>
          <p>
            {
              lang === 'en'
                ? 'SVG outlines, TopoJSON for counties and townships, usage examples in D3.js, Leaflet, Python, and Vue, plus administrative code references and other open data sources — all on one dedicated page.'
                : lang === 'ja'
                  ? 'SVG 輪郭、県市と町丁目レベルの TopoJSON、D3.js / Leaflet / Python / Vue の使用例、行政区コード対照、その他のオープンデータソース — すべて専用ページに。'
                  : lang === 'ko'
                    ? 'SVG 윤곽, 현시와 향진 수준의 TopoJSON, D3.js / Leaflet / Python / Vue 사용 예제, 행정구역 코드 대조, 다른 오픈 데이터 소스 — 모두 전용 페이지에서.'
                    : 'SVG 輪廓、縣市與鄉鎮級 TopoJSON、D3.js / Leaflet / Python / Vue 使用範例、行政區代碼對照、其他開源資料來源——全部在專屬頁面。'
            }
          </p>
          <a href={translatePath('/taiwan-shape')} class="btn btn-primary">
            {
              lang === 'en'
                ? "Go to Taiwan's Shape →"
                : lang === 'ja'
                  ? '台湾のかたちへ →'
                  : lang === 'ko'
                    ? '대만의 모양으로 →'
                    : '前往台灣的形狀 →'
            }
          </a>
        </div>
      </div>
    </section>

    <!-- Digital Democracy Timeline Section -->
    <section class="digital-democracy-section" id="democracy">
      <div class="section-divider">
        <div class="divider-line"></div>
      </div>

      <div class="story-intro">
        <h2 class="section-title">{t('data.digitalDemocracy.title')}</h2>
        <div class="story-text">
          <p>{t('data.digitalDemocracy.story.p1')}</p>
          <p>{t('data.digitalDemocracy.story.p2')}</p>
        </div>
      </div>

      <!-- Horizontal Timeline -->
      <div class="timeline-container">
        <div class="timeline-horizontal">
          <div class="timeline-item" data-year="1997">
            <div class="timeline-dot"></div>
            <div class="timeline-content">
              <div class="timeline-year">1997</div>
              <div class="timeline-title">{t('data.timeline.1997.title')}</div>
              <div class="timeline-desc">{t('data.timeline.1997.desc')}</div>
            </div>
          </div>

          <div class="timeline-item" data-year="2003">
            <div class="timeline-dot"></div>
            <div class="timeline-content">
              <div class="timeline-year">2003</div>
              <div class="timeline-title">{t('data.timeline.2003.title')}</div>
              <div class="timeline-desc">{t('data.timeline.2003.desc')}</div>
            </div>
          </div>

          <div class="timeline-item" data-year="2012">
            <div class="timeline-dot"></div>
            <div class="timeline-content">
              <div class="timeline-year">2012</div>
              <div class="timeline-title">{t('data.timeline.2012.title')}</div>
              <div class="timeline-desc">{t('data.timeline.2012.desc')}</div>
            </div>
          </div>

          <div class="timeline-item" data-year="2013">
            <div class="timeline-dot"></div>
            <div class="timeline-content">
              <div class="timeline-year">2013</div>
              <div class="timeline-title">{t('data.timeline.2013.title')}</div>
              <div class="timeline-desc">{t('data.timeline.2013.desc')}</div>
            </div>
          </div>

          <div class="timeline-item" data-year="2014">
            <div class="timeline-dot"></div>
            <div class="timeline-content">
              <div class="timeline-year">2014</div>
              <div class="timeline-title">{t('data.timeline.2014.title')}</div>
              <div class="timeline-desc">{t('data.timeline.2014.desc')}</div>
            </div>
          </div>

          <div class="timeline-item" data-year="2015">
            <div class="timeline-dot"></div>
            <div class="timeline-content">
              <div class="timeline-year">2015</div>
              <div class="timeline-title">{t('data.timeline.2015.title')}</div>
              <div class="timeline-desc">{t('data.timeline.2015.desc')}</div>
            </div>
          </div>

          <div class="timeline-item" data-year="2016">
            <div class="timeline-dot"></div>
            <div class="timeline-content">
              <div class="timeline-year">2016</div>
              <div class="timeline-title">{t('data.timeline.2016.title')}</div>
              <div class="timeline-desc">{t('data.timeline.2016.desc')}</div>
            </div>
          </div>

          <div class="timeline-item" data-year="2020">
            <div class="timeline-dot"></div>
            <div class="timeline-content">
              <div class="timeline-year">2020</div>
              <div class="timeline-title">{t('data.timeline.2020.title')}</div>
              <div class="timeline-desc">{t('data.timeline.2020.desc')}</div>
            </div>
          </div>

          <div class="timeline-item" data-year="2022">
            <div class="timeline-dot"></div>
            <div class="timeline-content">
              <div class="timeline-year">2022</div>
              <div class="timeline-title">{t('data.timeline.2022.title')}</div>
              <div class="timeline-desc">{t('data.timeline.2022.desc')}</div>
            </div>
          </div>

          <div class="timeline-item" data-year="2023">
            <div class="timeline-dot"></div>
            <div class="timeline-content">
              <div class="timeline-year">2023</div>
              <div class="timeline-title">{t('data.timeline.2023.title')}</div>
              <div class="timeline-desc">{t('data.timeline.2023.desc')}</div>
            </div>
          </div>

          <div class="timeline-item" data-year="2024">
            <div class="timeline-dot"></div>
            <div class="timeline-content">
              <div class="timeline-year">2024</div>
              <div class="timeline-title">{t('data.timeline.2024.title')}</div>
              <div class="timeline-desc">{t('data.timeline.2024.desc')}</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Open Data Categories (3-column grid) -->
      <div class="open-data-section" id="opendata">
        <h3
          class="section-title"
          style="margin-top: 5rem; margin-bottom: 2rem;"
        >
          📊 開放資料
        </h3>
        <div class="data-categories-grid">
          {
            dataCategories.map((cat) => (
              <div class="data-category-card">
                <div class="category-header">
                  <span class="category-icon">{cat.icon}</span>
                  <div>
                    <h4 class="category-title">{cat.title}</h4>
                    <p class="category-desc">{cat.description}</p>
                  </div>
                </div>
                <ul class="item-list">
                  {cat.items.map((item) => (
                    <li class="item">
                      <a
                        href={item.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="item-link"
                      >
                        {item.name}
                      </a>
                      <span class="item-desc">— {item.desc}</span>
                    </li>
                  ))}
                </ul>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Enterprise Landscape -->
    <section class="companies-section" id="enterprise">
      <div class="section-divider">
        <div class="divider-line"></div>
      </div>

      <div class="story-intro">
        <h2 class="section-title">{t('data.enterprise.title')}</h2>
        <div class="story-text">
          <p>{t('data.enterprise.story.p1')}</p>
          <p>{t('data.enterprise.story.p2')}</p>
        </div>
      </div>

      <!-- Bubble Chart Controls -->
      <div
        class="mx-auto mb-8 flex max-w-[1400px] flex-col gap-4 px-8 max-[768px]:flex-col max-[768px]:items-start"
      >
        <div
          class="flex flex-wrap items-center gap-2 [&>label]:text-[0.9rem] [&>label]:font-semibold [&>label]:text-[#94a3b8]"
        >
          <label>{t('data.enterprise.controls.sizeLabel')}</label>
          <button class="toggle-btn active" data-mode="marketCap">
            {t('data.enterprise.controls.marketCap')}
          </button>
          <button class="toggle-btn" data-mode="revenue">
            {t('data.enterprise.controls.revenue')}
          </button>
          <button class="toggle-btn" data-mode="employees">
            {t('data.enterprise.controls.employees')}
          </button>
        </div>
        <div class="flex flex-wrap gap-[0.4rem]">
          <button class="sector-btn active" data-sector="all">
            {t('data.enterprise.controls.filterAll')}
          </button>
          {
            sectors.slice(0, 8).map((s) => (
              <button
                class="sector-btn"
                data-sector={s}
                style={`--sector-color: ${sectorColors[s] || '#888'}`}
              >
                <span
                  class="sector-dot"
                  style={`background: ${sectorColors[s] || '#888'}`}
                />
                {t(`data.sector.${s}`)}
              </button>
            ))
          }
        </div>
      </div>

      <!-- Bubble Chart Container -->
      <div id="bubble-chart"></div>

      <!-- Key Insights -->
      <div class="insights">
        <div class="insight-grid">
          <div class="insight-card">
            <div class="insight-number">
              {t('data.enterprise.insights.card1.number')}
            </div>
            <div class="insight-label">
              {t('data.enterprise.insights.card1.label')}
            </div>
            <div class="insight-detail">
              {t('data.enterprise.insights.card1.detail')}
            </div>
          </div>
          <div class="insight-card">
            <div class="insight-number">
              {t('data.enterprise.insights.card2.number')}
            </div>
            <div class="insight-label">
              {t('data.enterprise.insights.card2.label')}
            </div>
            <div class="insight-detail">
              {t('data.enterprise.insights.card2.detail')}
            </div>
          </div>
          <div class="insight-card">
            <div class="insight-number">
              {t('data.enterprise.insights.card3.number')}
            </div>
            <div class="insight-label">
              {t('data.enterprise.insights.card3.label')}
            </div>
            <div class="insight-detail">
              {t('data.enterprise.insights.card3.detail')}
            </div>
          </div>
          <div class="insight-card">
            <div class="insight-number">
              {t('data.enterprise.insights.card4.number')}
            </div>
            <div class="insight-label">
              {t('data.enterprise.insights.card4.label')}
            </div>
            <div class="insight-detail">
              {t('data.enterprise.insights.card4.detail')}
            </div>
          </div>
        </div>
        <div class="explore-more">
          <a href="/economy" class="explore-link">
            {t('data.enterprise.exploreLink')}
          </a>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="data-footer">
      <div class="section-divider">
        <div class="divider-line"></div>
      </div>

      <h3 class="footer-title">{t('data.footer.heading')}</h3>
      <div class="footer-links">
        <a href="/economy" class="footer-link">
          <span class="footer-icon">📈</span>
          <div class="footer-text">
            <span class="footer-name">{t('data.footer.link1.name')}</span>
            <span class="footer-desc">
              {t('data.footer.link1.description')}
            </span>
          </div>
        </a>
        <a href="/graph" class="footer-link">
          <span class="footer-icon">🕸️</span>
          <div class="footer-text">
            <span class="footer-name">{t('data.footer.link2.name')}</span>
            <span class="footer-desc">
              {t('data.footer.link2.description')}
            </span>
          </div>
        </a>
        <a href="/contribute" class="footer-link">
          <span class="footer-icon">✋</span>
          <div class="footer-text">
            <span class="footer-name">{t('data.footer.link3.name')}</span>
            <span class="footer-desc">
              {t('data.footer.link3.description')}
            </span>
          </div>
        </a>
      </div>
    </footer>
  </main>

  <!-- D3 Bubble Chart Script -->
  <script define:vars={{ companies, sectorColors, lang }}>
    const data = companies;
    const colors = sectorColors;
    const currentLang = lang;

    // Load D3
    const script = document.createElement('script');
    script.src = 'https://d3js.org/d3.v7.min.js';
    script.onload = () => initBubbleChart(data, colors, currentLang);
    document.head.appendChild(script);

    function initBubbleChart(data, colors, lang) {
      const container = document.getElementById('bubble-chart');
      const width = container.clientWidth;
      const height = Math.max(500, window.innerHeight * 0.5);

      let currentMode = 'marketCap';
      let currentSector = 'all';

      const svg = d3
        .select('#bubble-chart')
        .append('svg')
        .attr('width', width)
        .attr('height', height)
        .attr('viewBox', `0 0 ${width} ${height}`);

      const tooltip = d3
        .select('#bubble-chart')
        .append('div')
        .attr('class', 'tooltip')
        .style('opacity', 0);

      function getValue(d) {
        return d[currentMode] || 0;
      }

      function getRadius(d) {
        const val = getValue(d);
        const maxVal = d3.max(data, getValue);
        const minR = 12;
        const maxR = Math.min(width, height) * 0.15;
        return minR + (maxR - minR) * Math.sqrt(val / maxVal);
      }

      const simulation = d3
        .forceSimulation(data)
        .force('center', d3.forceCenter(width / 2, height / 2))
        .force('charge', d3.forceManyBody().strength(3))
        .force(
          'collision',
          d3
            .forceCollide()
            .radius((d) => getRadius(d) + 1.5)
            .strength(0.8),
        )
        .force('x', d3.forceX(width / 2).strength(0.05))
        .force('y', d3.forceY(height / 2).strength(0.05));

      const nodes = svg
        .selectAll('g.node')
        .data(data)
        .join('g')
        .attr('class', 'node')
        .call(
          d3
            .drag()
            .on('start', (e, d) => {
              if (!e.active) simulation.alphaTarget(0.3).restart();
              d.fx = d.x;
              d.fy = d.y;
            })
            .on('drag', (e, d) => {
              d.fx = e.x;
              d.fy = e.y;
            })
            .on('end', (e, d) => {
              if (!e.active) simulation.alphaTarget(0);
              d.fx = null;
              d.fy = null;
            }),
        );

      const circles = nodes
        .append('circle')
        .attr('r', (d) => getRadius(d))
        .attr('fill', (d) => colors[d.sector] || '#888')
        .attr('fill-opacity', 0.8)
        .attr('stroke', (d) => colors[d.sector] || '#888')
        .attr('stroke-width', 2)
        .attr('stroke-opacity', 0.3)
        .style('cursor', 'grab');

      const labels = nodes
        .append('text')
        .attr('text-anchor', 'middle')
        .attr('dominant-baseline', 'central')
        .attr('fill', '#fff')
        .attr('font-weight', '600')
        .attr('pointer-events', 'none')
        .each(function (d) {
          const r = getRadius(d);
          const el = d3.select(this);
          const shortName = d.name.split(' ')[0];
          const suffix = lang === 'zh-TW' ? ' 億' : 'B';
          if (r > 40) {
            el.append('tspan')
              .attr('x', 0)
              .attr('dy', '-0.3em')
              .attr('font-size', `${Math.min(12, r / 4)}px`)
              .text(shortName);
            el.append('tspan')
              .attr('x', 0)
              .attr('dy', '1.2em')
              .attr('font-size', `${Math.min(10, r / 5)}px`)
              .attr('fill-opacity', 0.8)
              .text(d.marketCap.toLocaleString() + suffix);
          } else if (r > 20) {
            el.attr('font-size', `${Math.min(10, r / 3)}px`).text(shortName);
          } else {
            el.attr('font-size', '8px').text(shortName.slice(0, 2));
          }
        });

      // Get tooltip labels from translations
      const tooltipData = {
        marketCap: lang === 'zh-TW' ? '市值' : 'Market Cap',
        revenue: lang === 'zh-TW' ? '營收' : 'Revenue',
        employees: lang === 'zh-TW' ? '員工' : 'Employees',
        founded: lang === 'zh-TW' ? '成立' : 'Founded',
        unit: lang === 'zh-TW' ? '億 TWD' : 'B TWD',
        people: lang === 'zh-TW' ? '人' : '',
        year: lang === 'zh-TW' ? '年' : '',
      };

      nodes
        .on('mouseover', (e, d) => {
          tooltip.transition().duration(200).style('opacity', 1);
          tooltip
            .html(
              `
            <strong>${d.name}</strong><br/>
            <span style="color:${colors[d.sector] || '#888'}">● ${d.sector}</span><br/>
            ${tooltipData.marketCap}：${d.marketCap.toLocaleString()} ${tooltipData.unit}<br/>
            ${tooltipData.revenue}：${d.revenue.toLocaleString()} ${tooltipData.unit}<br/>
            ${tooltipData.employees}：${d.employees.toLocaleString()} ${tooltipData.people}<br/>
            ${tooltipData.founded}：${d.founded} ${tooltipData.year}
          `,
            )
            .style('left', e.pageX + 15 + 'px')
            .style('top', e.pageY - 10 + 'px');
          d3.select(e.currentTarget)
            .select('circle')
            .attr('fill-opacity', 1)
            .attr('stroke-width', 3);
        })
        .on('mouseout', (e) => {
          tooltip.transition().duration(300).style('opacity', 0);
          d3.select(e.currentTarget)
            .select('circle')
            .attr('fill-opacity', 0.8)
            .attr('stroke-width', 2);
        })
        .on('click', (e, d) => {
          e.stopPropagation();
          if (d.articleUrl) {
            window.location.href = d.articleUrl;
          }
        })
        .style('cursor', (d) => (d.articleUrl ? 'pointer' : 'default'));

      simulation.on('tick', () => {
        nodes.attr('transform', (d) => {
          d.x = Math.max(getRadius(d), Math.min(width - getRadius(d), d.x));
          d.y = Math.max(getRadius(d), Math.min(height - getRadius(d), d.y));
          return `translate(${d.x},${d.y})`;
        });
      });

      // Toggle controls
      document.querySelectorAll('.toggle-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          document
            .querySelectorAll('.toggle-btn')
            .forEach((b) => b.classList.remove('active'));
          btn.classList.add('active');
          currentMode = btn.dataset.mode;
          updateBubbles();
        });
      });

      document.querySelectorAll('.sector-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          document
            .querySelectorAll('.sector-btn')
            .forEach((b) => b.classList.remove('active'));
          btn.classList.add('active');
          currentSector = btn.dataset.sector;
          updateBubbles();
        });
      });

      function updateBubbles() {
        circles
          .transition()
          .duration(600)
          .attr('r', (d) => {
            if (currentSector !== 'all' && d.sector !== currentSector) return 0;
            return getRadius(d);
          })
          .attr('fill-opacity', (d) => {
            if (currentSector !== 'all' && d.sector !== currentSector) return 0;
            return 0.8;
          });

        labels
          .transition()
          .duration(600)
          .attr('fill-opacity', (d) => {
            if (currentSector !== 'all' && d.sector !== currentSector) return 0;
            return 1;
          });

        simulation
          .force(
            'collision',
            d3
              .forceCollide()
              .radius((d) => {
                if (currentSector !== 'all' && d.sector !== currentSector)
                  return 0;
                return getRadius(d) + 1.5;
              })
              .strength(0.8),
          )
          .alpha(0.6)
          .restart();
      }
    }
  </script>

