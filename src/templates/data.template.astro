---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import {
  getLangFromUrl,
  useTranslations,
  useTranslatedPath,
} from '../i18n/utils';
import { getCategories } from '../utils/dataConfig';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

// Get open data categories from centralized config
const dataCategories = getCategories(t);
---

<Layout
  lang={lang}
  title={t('data.meta.title')}
  description={t('data.meta.description')}
>
  <!--
    Sections: hero, "Laguna Beach by the Numbers" (stat cards),
    population pyramid (Laguna Beach / Orange County / California,
    U.S. Census ACS), "An Art Colony by the Sea" (tourism cards),
    and open data sources. Section wrappers use inline Tailwind; the
    repeating .comparison-card / .data-category-card / pyramid styles
    stay scoped below.
  -->
  <main
    class="min-h-screen bg-[linear-gradient(135deg,#0f172a_0%,#1e293b_100%)] text-[#e2e8f0]"
  >
    <!-- Hero -->
    <PageHero
      bgTone="dark"
      titleVariant="gradient"
      titleGradient="linear-gradient(135deg,#38bdf8,#818cf8,#c084fc)"
      titleSize="clamp"
      containerWidth="wide"
      title={t('data.hero.title')}
      subtitle={t('data.hero.subtitle')}
    >
      <p
        class="mx-auto mt-4 max-w-[600px] text-base leading-[1.7] text-[#cbd5e1]"
      >
        {t('data.hero.description')}
      </p>
    </PageHero>

    <!-- Laguna Beach by the Numbers -->
    <section class="by-numbers-section" id="global">
      <div class="section-divider">
        <div class="divider-line"></div>
      </div>

      <div class="story-intro">
        <h2 class="section-title">{t('data.byNumbers.title')}</h2>
        <div class="story-text">
          <p>{t('data.byNumbers.story.p1')}</p>
          <p>{t('data.byNumbers.story.p2')}</p>
        </div>
      </div>

      <div
        class="mx-auto grid max-w-[var(--container-wide)] grid-cols-[repeat(auto-fit,minmax(280px,1fr))] gap-6 px-8 max-[640px]:grid-cols-[1fr]"
      >
        <div class="comparison-card">
          <div class="card-emoji">📍</div>
          <div class="card-number">
            {t('data.byNumbers.population.number')}
          </div>
          <div class="card-label">{t('data.byNumbers.population.label')}</div>
          <div class="card-context">
            {t('data.byNumbers.population.context')}
          </div>
        </div>

        <div class="comparison-card">
          <div class="card-emoji">👵</div>
          <div class="card-number">{t('data.byNumbers.medianAge.number')}</div>
          <div class="card-label">{t('data.byNumbers.medianAge.label')}</div>
          <div class="card-context">
            {t('data.byNumbers.medianAge.context')}
          </div>
        </div>

        <div class="comparison-card">
          <div class="card-emoji">🏞️</div>
          <div class="card-number">{t('data.byNumbers.area.number')}</div>
          <div class="card-label">{t('data.byNumbers.area.label')}</div>
          <div class="card-context">{t('data.byNumbers.area.context')}</div>
        </div>

        <div class="comparison-card">
          <div class="card-emoji">🌊</div>
          <div class="card-number">
            {t('data.byNumbers.coastline.number')}
          </div>
          <div class="card-label">{t('data.byNumbers.coastline.label')}</div>
          <div class="card-context">
            {t('data.byNumbers.coastline.context')}
          </div>
        </div>

        <div class="comparison-card">
          <div class="card-emoji">🐠</div>
          <div class="card-number">
            {t('data.byNumbers.marineReserve.number')}
          </div>
          <div class="card-label">
            {t('data.byNumbers.marineReserve.label')}
          </div>
          <div class="card-context">
            {t('data.byNumbers.marineReserve.context')}
          </div>
        </div>

        <div class="comparison-card">
          <div class="card-emoji">🌲</div>
          <div class="card-number">
            {t('data.byNumbers.wilderness.number')}
          </div>
          <div class="card-label">{t('data.byNumbers.wilderness.label')}</div>
          <div class="card-context">
            {t('data.byNumbers.wilderness.context')}
          </div>
        </div>

        <div class="comparison-card">
          <div class="card-emoji">🎨</div>
          <div class="card-number">
            {t('data.byNumbers.galleries.number')}
          </div>
          <div class="card-label">{t('data.byNumbers.galleries.label')}</div>
          <div class="card-context">
            {t('data.byNumbers.galleries.context')}
          </div>
        </div>

        <div class="comparison-card">
          <div class="card-emoji">🧳</div>
          <div class="card-number">{t('data.byNumbers.visitors.number')}</div>
          <div class="card-label">{t('data.byNumbers.visitors.label')}</div>
          <div class="card-context">
            {t('data.byNumbers.visitors.context')}
          </div>
        </div>
      </div>
    </section>

    <!-- Population Pyramid Section -->
    <section class="population-section" id="population">
      <div class="section-divider">
        <div class="divider-line"></div>
      </div>

      <div class="story-intro">
        <h2 class="section-title">{t('data.population.title')}</h2>
        <div class="story-text">
          <p>{t('data.population.story.p1')}</p>
          <p>{t('data.population.story.p2')}</p>
        </div>
      </div>

      <!-- Population Pyramid Chart -->
      <div class="pyramid-container">
        <div id="population-pyramid"></div>

        <!-- Year Slider -->
        <div class="year-slider-container">
          <div class="slider-track">
            <div class="slider-thumb" id="yearThumb"></div>
          </div>
          <div class="year-labels">
            <span>{lang === 'zh-TW' ? '拉古納海灘' : 'Laguna Beach'}</span>
            <span>{lang === 'zh-TW' ? '橙縣' : 'Orange County'}</span>
            <span>{lang === 'zh-TW' ? '加州' : 'California'}</span>
          </div>
          <div class="current-year" id="currentYear">
            {lang === 'zh-TW' ? '拉古納海灘' : 'Laguna Beach'}
          </div>
        </div>
      </div>

      <!-- Key Insights Cards (dynamic, syncs with slider) -->
      <div class="insights">
        <div class="insight-grid">
          <div class="insight-card">
            <div class="insight-label" id="insightLabel1">
              {t('data.population.insights.card1.title')}
            </div>
            <div class="insight-number" id="insightValue1">53.9</div>
            <div class="insight-detail" id="insightUnit1">
              {t('data.population.insights.card1.subtitle')}
            </div>
          </div>
          <div class="insight-card">
            <div class="insight-label" id="insightLabel2">
              {t('data.population.insights.card2.title')}
            </div>
            <div class="insight-number" id="insightValue2">30%</div>
            <div class="insight-detail" id="insightUnit2">
              {t('data.population.insights.card2.subtitle')}
            </div>
          </div>
          <div class="insight-card">
            <div class="insight-label" id="insightLabel3">
              {t('data.population.insights.card3.title')}
            </div>
            <div class="insight-number" id="insightValue3">15%</div>
            <div class="insight-detail" id="insightUnit3">
              {t('data.population.insights.card3.subtitle')}
            </div>
          </div>
          <div class="insight-card">
            <div class="insight-label" id="insightLabel4">
              {t('data.population.insights.card4.title')}
            </div>
            <div class="insight-number" id="insightValue4">22,710</div>
            <div class="insight-detail" id="insightUnit4">
              {t('data.population.insights.card4.subtitle')}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Tourism & Arts Section -->
    <section class="by-numbers-section" id="arts">
      <div class="section-divider">
        <div class="divider-line"></div>
      </div>

      <div class="story-intro">
        <h2 class="section-title">{t('data.tourism.title')}</h2>
        <div class="story-text">
          <p>{t('data.tourism.story.p1')}</p>
          <p>{t('data.tourism.story.p2')}</p>
        </div>
      </div>

      <div
        class="mx-auto grid max-w-[var(--container-wide)] grid-cols-[repeat(auto-fit,minmax(280px,1fr))] gap-6 px-8 max-[640px]:grid-cols-[1fr]"
      >
        <div class="comparison-card">
          <div class="card-emoji">🖼️</div>
          <div class="card-number">{t('data.tourism.galleries.number')}</div>
          <div class="card-label">{t('data.tourism.galleries.label')}</div>
          <div class="card-context">
            {t('data.tourism.galleries.context')}
          </div>
        </div>

        <div class="comparison-card">
          <div class="card-emoji">🎭</div>
          <div class="card-number">{t('data.tourism.festivals.number')}</div>
          <div class="card-label">{t('data.tourism.festivals.label')}</div>
          <div class="card-context">
            {t('data.tourism.festivals.context')}
          </div>
        </div>

        <div class="comparison-card">
          <div class="card-emoji">🪵</div>
          <div class="card-number">{t('data.tourism.sawdust.number')}</div>
          <div class="card-label">{t('data.tourism.sawdust.label')}</div>
          <div class="card-context">{t('data.tourism.sawdust.context')}</div>
        </div>

        <div class="comparison-card">
          <div class="card-emoji">🍽️</div>
          <div class="card-number">{t('data.tourism.dining.number')}</div>
          <div class="card-label">{t('data.tourism.dining.label')}</div>
          <div class="card-context">{t('data.tourism.dining.context')}</div>
        </div>
      </div>
    </section>

    <!-- Open Data Sources Section -->
    <section class="open-data-section" id="opendata">
      <div class="section-divider">
        <div class="divider-line"></div>
      </div>

      <div class="story-intro">
        <h2 class="section-title">{t('data.opendata.title')}</h2>
      </div>

      <div class="data-categories-grid">
        {
          dataCategories.map((cat) => (
            <div class="data-category-card">
              <div class="category-header">
                <span class="category-icon">{cat.icon}</span>
                <div>
                  <h4 class="category-title">{cat.title}</h4>
                  <p class="category-desc">{cat.description}</p>
                </div>
              </div>
              <ul class="item-list">
                {cat.items.map((item) => (
                  <li class="item">
                    <a
                      href={item.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="item-link"
                    >
                      {item.name}
                    </a>
                    <span class="item-desc">— {item.desc}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Footer -->
    <footer class="data-footer">
      <div class="section-divider">
        <div class="divider-line"></div>
      </div>

      <h3 class="footer-title">{t('data.footer.heading')}</h3>
      <div class="footer-links">
        <a href={translatePath('/explore')} class="footer-link">
          <span class="footer-icon">🔍</span>
          <div class="footer-text">
            <span class="footer-name">{t('data.footer.link1.name')}</span>
            <span class="footer-desc">
              {t('data.footer.link1.description')}
            </span>
          </div>
        </a>
        <a href={translatePath('/graph')} class="footer-link">
          <span class="footer-icon">🕸️</span>
          <div class="footer-text">
            <span class="footer-name">{t('data.footer.link2.name')}</span>
            <span class="footer-desc">
              {t('data.footer.link2.description')}
            </span>
          </div>
        </a>
        <a href={translatePath('/contribute')} class="footer-link">
          <span class="footer-icon">✋</span>
          <div class="footer-text">
            <span class="footer-name">{t('data.footer.link3.name')}</span>
            <span class="footer-desc">
              {t('data.footer.link3.description')}
            </span>
          </div>
        </a>
      </div>
    </footer>
  </main>

  <!-- Population Pyramid Script -->
  <!-- Population Pyramid client logic (477 lines) in src/scripts/data-client.js —
       2026-06-13 extracted: original define:vars inline duplicated per language page;
       switching to Astro processed module shares one hashed bundle + browser-cacheable.
       lang now reads from <html lang>. -->
  <script>
    import '../scripts/data-client.js';
  </script>

  <style>
    /* Phase 7.6: hero, main wrapper, comparison-cards grid,
       bubble-controls, size-toggle, sector-filters all migrated
       to inline Tailwind utilities on the markup above.
       Kept scoped below: cross-section primitives (section-divider,
       story-intro, section-title, story-text) used 5-6 times
       each, and all d3/chart/card repeating patterns. */

    /* Section Divider (used × 6 across sections) */
    .section-divider {
      padding: 2rem 0;
      display: flex;
      justify-content: center;
    }

    .divider-line {
      width: 100px;
      height: 3px;
      background: linear-gradient(90deg, transparent, #60a5fa, transparent);
      border-radius: 2px;
    }

    /* Story Block */
    .story-intro {
      max-width: 1400px;
      margin: 0 auto;
      padding: 0 2rem 2rem;
    }

    .section-title {
      font-size: 2rem;
      font-weight: 800;
      color: #f8fafc;
      margin-bottom: 1rem;
      text-align: center;
    }

    .story-text {
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 16px;
      padding: 2rem;
    }

    .story-text p {
      color: #cbd5e1;
      line-height: 1.8;
      margin-bottom: 1rem;
      font-size: 1rem;
    }

    .story-text p:first-child {
      font-size: 1.1rem;
      color: #93c5fd;
      font-weight: 600;
    }

    .story-text p:last-child {
      margin-bottom: 0;
    }

    .insights {
      max-width: 1400px;
      margin: 2rem auto 0;
      padding: 0 2rem;
    }

    .insight-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 1rem;
      margin-bottom: 1.5rem;
    }

    .insight-card {
      background: rgba(255, 255, 255, 0.04);
      border-radius: 12px;
      padding: 1.5rem;
      text-align: center;
      border: 1px solid rgba(255, 255, 255, 0.08);
    }

    .insight-number {
      font-size: 1.8rem;
      font-weight: 800;
      color: #60a5fa;
      margin-bottom: 0.3rem;
    }

    .insight-label {
      font-weight: 600;
      color: #e2e8f0;
      font-size: 0.9rem;
      margin-bottom: 0.3rem;
    }

    .insight-detail {
      font-size: 0.8rem;
      color: #94a3b8;
    }

    /* Population Pyramid Section */
    .population-section {
      padding: 2rem 0 4rem;
    }

    .pyramid-container {
      max-width: 1000px;
      margin: 0 auto;
      padding: 0 2rem;
    }

    #population-pyramid {
      width: 100%;
      min-height: 600px;
      background: rgba(255, 255, 255, 0.02);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 16px;
      overflow: hidden;
    }

    #population-pyramid :global(svg) {
      display: block;
      width: 100%;
      height: auto;
    }

    .year-slider-container {
      margin: 2rem auto 0;
      max-width: 400px;
      text-align: center;
    }

    .slider-track {
      position: relative;
      width: 100%;
      height: 8px;
      background: rgba(255, 255, 255, 0.1);
      border-radius: 4px;
      margin-bottom: 1rem;
      cursor: pointer;
    }

    .slider-track::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: linear-gradient(90deg, #3b82f6, #8b5cf6, #ec4899, #f59e0b);
      border-radius: 4px;
      opacity: 0.6;
    }

    .slider-thumb {
      position: absolute;
      width: 24px;
      height: 24px;
      background: #60a5fa;
      border: 3px solid #0f172a;
      border-radius: 50%;
      top: -8px;
      cursor: grab;
      transition: all 0.2s ease;
      box-shadow: 0 2px 12px rgba(96, 165, 250, 0.4);
    }

    .slider-thumb:hover {
      transform: scale(1.1);
      box-shadow: 0 4px 20px rgba(96, 165, 250, 0.6);
    }

    .slider-thumb:active {
      cursor: grabbing;
      transform: scale(1.05);
    }

    .year-labels {
      display: flex;
      justify-content: space-between;
      color: #94a3b8;
      font-size: 0.9rem;
      margin-bottom: 0.5rem;
    }

    .current-year {
      font-size: 1.5rem;
      font-weight: bold;
      color: #60a5fa;
      margin-top: 0.5rem;
    }

    .population-section .insights {
      max-width: 1000px;
      margin: 3rem auto 0;
      padding: 0 2rem;
    }

    .population-section .insight-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 1rem;
      margin-bottom: 1.5rem;
    }

    .population-section .insight-card {
      background: rgba(255, 255, 255, 0.04);
      border-radius: 12px;
      padding: 1.5rem;
      text-align: center;
      border: 1px solid rgba(255, 255, 255, 0.08);
      transition: all 0.3s ease;
    }

    .population-section .insight-card:hover {
      background: rgba(255, 255, 255, 0.08);
      border-color: rgba(255, 255, 255, 0.15);
      transform: translateY(-2px);
    }

    .population-section .insight-number {
      font-size: 1.6rem;
      font-weight: 800;
      color: #60a5fa;
      margin-bottom: 0.3rem;
      line-height: 1.2;
    }

    .population-section .insight-label {
      font-weight: 600;
      color: #e2e8f0;
      font-size: 0.95rem;
      margin-bottom: 0.3rem;
    }

    .population-section .insight-detail {
      font-size: 0.8rem;
      color: #94a3b8;
      line-height: 1.4;
    }

    /* By the Numbers / Tourism / Open Data section wrappers */
    .by-numbers-section,
    .open-data-section {
      padding: 2rem 0 4rem;
    }

    .comparison-card {
      background: rgba(255, 255, 255, 0.04);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 16px;
      padding: 2rem;
      text-align: center;
      transition: all 0.3s ease;
      position: relative;
      overflow: hidden;
    }

    .comparison-card:hover {
      transform: translateY(-4px);
      border-color: rgba(255, 255, 255, 0.15);
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
    }

    .comparison-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 3px;
      background: linear-gradient(90deg, #3b82f6, #8b5cf6, #ec4899);
      opacity: 0;
      transition: opacity 0.3s ease;
    }

    .comparison-card:hover::before {
      opacity: 1;
    }

    .card-emoji {
      font-size: 2.5rem;
      margin-bottom: 1rem;
      display: block;
    }

    .card-number {
      font-size: 2.2rem;
      font-weight: 900;
      color: #60a5fa;
      margin-bottom: 0.5rem;
      line-height: 1;
    }

    .card-label {
      font-size: 1.1rem;
      font-weight: 600;
      color: #e2e8f0;
      margin-bottom: 0.75rem;
      line-height: 1.3;
    }

    .card-context {
      font-size: 0.9rem;
      color: #cbd5e1;
      line-height: 1.5;
    }

    /* Open Data 3-Column Grid */
    .data-categories-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
      max-width: 1400px;
      margin: 0 auto;
      padding: 0 2rem;
    }

    .data-categories-grid .data-category-card:nth-child(4),
    .data-categories-grid .data-category-card:nth-child(5) {
      grid-column: span 1;
      margin: 0 auto;
      max-width: 400px;
    }

    /* Open Data Section (now part of digital democracy) */
    .digital-democracy-section .data-categories {
      max-width: 1400px;
      margin: 0 auto;
      padding: 0 2rem;
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .data-categories {
      max-width: 1400px;
      margin: 0 auto;
      padding: 0 2rem;
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .data-category-card {
      background: rgba(255, 255, 255, 0.04);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 16px;
      padding: 2rem;
      transition: border-color 0.2s ease;
    }

    .data-category-card:hover {
      border-color: rgba(255, 255, 255, 0.15);
    }

    .category-header {
      display: flex;
      align-items: flex-start;
      gap: 1rem;
      margin-bottom: 1.5rem;
    }

    .category-icon {
      font-size: 2rem;
      line-height: 1;
      flex-shrink: 0;
    }

    .category-title {
      font-size: 1.3rem;
      font-weight: 700;
      color: #f1f5f9;
      margin-bottom: 0.25rem;
    }

    .category-desc {
      font-size: 0.9rem;
      color: #94a3b8;
      line-height: 1.5;
    }

    .item-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }

    .item {
      padding: 0.6rem 0;
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
      line-height: 1.6;
    }

    .item:last-child {
      border-bottom: none;
      padding-bottom: 0;
    }

    .item-link {
      color: #7dd3fc !important;
      text-decoration: none;
      font-weight: 600;
      font-size: 0.95rem;
      border-bottom: 1px solid transparent;
      transition: all 0.2s ease;
    }

    .item-link:hover {
      color: #bae6fd !important;
      border-bottom-color: #bae6fd;
    }

    .item-desc {
      color: #cbd5e1;
      font-size: 0.85rem;
    }

    /* Knowledge Graph Section */
    .knowledge-graph-section {
      padding: 2rem 0 4rem;
    }

    .graph-cta {
      text-align: center;
