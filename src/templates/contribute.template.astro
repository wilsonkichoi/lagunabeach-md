---
import fs from 'node:fs';
import path from 'node:path';
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import ProticoScript from '../components/ProticoScript.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Read supporter stats for social-proof line in §金流支持.
// 讀 prebuild 派生的 dashboard-supporters.json；若檔案缺失 fallback 到 0。
let supporterStats = {
  total_received_twd: 0,
  supporter_count: 0,
  transaction_count: 0,
};
try {
  const raw = JSON.parse(
    fs.readFileSync(
      path.join(process.cwd(), 'public/api/dashboard-supporters.json'),
      'utf8',
    ),
  );
  supporterStats = {
    total_received_twd: raw.totals?.total_received_twd || 0,
    supporter_count: raw.totals?.supporter_count || 0,
    transaction_count: raw.totals?.transaction_count || 0,
  };
} catch {
  /* fallback already initialised */
}
---

<Layout
  title={t('contribute.meta.title')}
  description={t('contribute.meta.description')}
  lang={lang}
>
  <div class="contribute-page">
    <!--
      Phase 7.5 partial migration — contribute.template.astro
      Hero section migrated to inline Tailwind; the ~170 classes
      for the form / writing guides / CLI section / token donation
      stay scoped (too many repeating patterns and tight JS coupling
      to inline cleanly).
    -->
    <PageHero
      bgVariant="gradient"
      bgGradient="linear-gradient(135deg,#1e3a5f,#4a7c59)"
      bgTone="dark"
      titleVariant="inherit"
      containerWidth="full"
      title={t('contribute.hero.title')}
      subtitle={t('contribute.hero.subtitle')}
    >
      <p slot="note" set:html={t('contribute.hero.note.html')} />
    </PageHero>

    <!-- How It Works Section - Position 2 -->
    <section class="how-it-works">
      <div class="how-inner">
        <h2>{t('contribute.how.title')}</h2>
        <div class="how-grid">
          <div class="how-card">
            <h3>
              {t('contribute.how.md.icon')}
              {t('contribute.how.md.title')}
            </h3>
            <p set:html={t('contribute.how.md.desc.html')} />
          </div>
          <div class="how-card">
            <h3>
              {t('contribute.how.graph.icon')}
              {t('contribute.how.graph.title')}
            </h3>
            <p>{t('contribute.how.graph.desc')}</p>
          </div>
          <div class="how-card">
            <h3>
              {t('contribute.how.ai.icon')}
              {t('contribute.how.ai.title')}
            </h3>
            <p set:html={t('contribute.how.ai.desc.html')} />
          </div>
        </div>
      </div>
    </section>

    <!-- Paths Section - Position 3 -->
    <section class="paths" id="paths">
      <div class="paths-inner">
        <h2>{t('contribute.paths.title')}</h2>
        <div class="path-grid">
          <div class="path-card semiont">
            <div class="path-badge">{t('contribute.paths.semiont.badge')}</div>
            <h3>{t('contribute.paths.semiont.title')}</h3>
            <p>{t('contribute.paths.semiont.desc')}</p>
            <p class="semiont-subdesc">
              <em>{t('contribute.paths.semiont.subdesc')}</em>
            </p>
            <div class="ai-prompt">
              <code>{t('contribute.paths.semiont.prompt')}</code>
              <button
                class="copy-btn"
                onclick={`navigator.clipboard.writeText(this.previousElementSibling.textContent).then(()=>this.textContent='${t('contribute.copy.copied')}')`}
                >{t('contribute.copy.button')}</button
              >
            </div>
            <ul>
              <li>{t('contribute.paths.semiont.feature1')}</li>
              <li>{t('contribute.paths.semiont.feature2')}</li>
              <li>{t('contribute.paths.semiont.feature3')}</li>
            </ul>
            <details class="semiont-concept">
              <summary>{t('contribute.paths.semiont.concept.title')}</summary>
              <p set:html={t('contribute.paths.semiont.concept.html')} />
            </details>
            <a
              href="https://github.com/wilsonkichoi/lagunabeach-md/blob/main/BECOME_LAGUNABEACH.md"
              target="_blank"
              class="path-btn primary">{t('contribute.paths.semiont.button')}</a
            >
          </div>

          <div class="path-card easy">
            <div class="path-badge">{t('contribute.paths.easy.badge')}</div>
            <h3>{t('contribute.paths.easy.title')}</h3>
            <p set:html={t('contribute.paths.easy.desc.html')} />
            <ul>
              <li>{t('contribute.paths.easy.feature1')}</li>
              <li>{t('contribute.paths.easy.feature2')}</li>
              <li>{t('contribute.paths.easy.feature3')}</li>
              <li>{t('contribute.paths.easy.feature4')}</li>
            </ul>
            <a href="#form" class="path-btn primary"
              >{t('contribute.paths.easy.button')}</a
            >
          </div>

          <div class="path-card medium">
            <div class="path-badge">{t('contribute.paths.medium.badge')}</div>
            <h3>{t('contribute.paths.medium.title')}</h3>
            <p>
              {t('contribute.paths.medium.desc')}
            </p>
            <ul>
              <li set:html={t('contribute.paths.medium.email.html')} />
              <li>{t('contribute.paths.medium.github')}</li>
            </ul>
            <a
              href={`mailto:hello@lagunabeach.md?subject=LagunaBeach.md ${lang === 'en' ? 'Content Contribution' : '內容貢獻'}`}
              class="path-btn secondary"
              >{t('contribute.paths.medium.button')}</a
            >
          </div>

          <div class="path-card ai">
            <div class="path-badge">{t('contribute.paths.ai.badge')}</div>
            <h3>{t('contribute.paths.ai.title')}</h3>
            <p>
              {t('contribute.paths.ai.desc')}
            </p>
            <div class="ai-prompt">
              <code>{t('contribute.paths.ai.prompt')}</code>
              <button
                class="copy-btn"
                onclick={`navigator.clipboard.writeText(this.previousElementSibling.textContent).then(()=>this.textContent='${t('contribute.copy.copied')}')`}
                >{t('contribute.copy.button')}</button
              >
            </div>
            <ul>
              <li>{t('contribute.paths.ai.feature1')}</li>
              <li>{t('contribute.paths.ai.feature2')}</li>
              <li>{t('contribute.paths.ai.feature3')}</li>
              <li>{t('contribute.paths.ai.feature4')}</li>
            </ul>
            <a
              href="https://github.com/wilsonkichoi/lagunabeach-md/blob/main/docs/prompts/CONTRIBUTE_PROMPT.md"
              target="_blank"
              class="path-btn secondary"
              >{t('contribute.paths.ai.fullprompt')}</a
            >
          </div>

          <div class="path-card dev">
            <div class="path-badge">{t('contribute.paths.dev.badge')}</div>
            <h3>{t('contribute.paths.dev.title')}</h3>
            <p set:html={t('contribute.paths.dev.desc.html')} />
            <ul>
              <li set:html={t('contribute.paths.dev.guide.html')} />
              <li set:html={t('contribute.paths.dev.editorial.html')} />
            </ul>
            <a
              href="https://github.com/wilsonkichoi/lagunabeach-md"
              target="_blank"
              class="path-btn secondary">{t('contribute.paths.dev.button')}</a
            >
          </div>
        </div>
      </div>
    </section>

    <!-- Digital Organism Section - Position 4 -->
    <section class="organism-brief" id="organism">
      <div class="organism-brief-inner">
        <h2>{t('contribute.organism.title')}</h2>
        <div class="organism-facts">
          <p set:html={t('contribute.organism.fact1.html')} />
          <p set:html={t('contribute.organism.fact2.html')} />
          <p set:html={t('contribute.organism.fact3.html')} />
        </div>
        <p
          class="organism-alive"
          set:html={t('contribute.organism.alive.html')}
        />
        <p
          class="organism-semiont"
          set:html={t('contribute.organism.semiont.html')}
        />
        <div class="organism-closing">
          <p class="closing-line closing-future">
            {t('contribute.organism.closing3')}
          </p>
        </div>
        <div class="organism-links">
          <a href="/about/#organism" class="organism-more"
            >{t('contribute.organism.readmore')}</a
          >
          <a href="/dashboard/" class="organism-dashboard-link">
            🔬 {lang === 'en' ? 'Real-Time Dashboard' : '即時監測面板'} →
          </a>
        </div>
      </div>
    </section>

    <section class="form-section" id="form">
      <div class="form-inner">
        <h2>{t('contribute.form.title')}</h2>
        <p class="form-desc">
          {t('contribute.form.desc')}
        </p>

        <form id="contribute-form">
          <div class="form-group">
            <label for="content"
              >{t('contribute.form.content.label')}
              <span class="required"
                >{t('contribute.form.content.required')}</span
              ></label
            >
            <textarea
              id="content"
              name="entry.content"
              rows="8"
              required
              placeholder={t('contribute.form.content.placeholder')}></textarea>
          </div>

          <div class="form-group">
            <label for="category">{t('contribute.form.category.label')}</label>
            <select id="category" name="entry.category">
              <option value="">{t('contribute.form.category.unsure')}</option>
              <option value="history"
                >{t('contribute.form.category.history')}</option
              >
              <option value="geography"
                >{t('contribute.form.category.geography')}</option
              >
              <option value="culture"
                >{t('contribute.form.category.culture')}</option
              >
              <option value="food">{t('contribute.form.category.food')}</option>
              <option value="art">{t('contribute.form.category.art')}</option>
              <option value="music"
                >{t('contribute.form.category.music')}</option
              >
              <option value="technology"
                >{t('contribute.form.category.technology')}</option
              >
              <option value="nature"
                >{t('contribute.form.category.nature')}</option
              >
              <option value="people"
                >{t('contribute.form.category.people')}</option
              >
              <option value="society"
                >{t('contribute.form.category.society')}</option
              >
              <option value="economy"
                >{t('contribute.form.category.economy')}</option
              >
              <option value="lifestyle"
                >{t('contribute.form.category.lifestyle')}</option
              >
            </select>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="source-type"
                >{t('contribute.form.sourcetype.label')}</label
              >
              <select id="source-type" name="entry.source_type">
                <option value=""
                  >{t('contribute.form.sourcetype.choose')}</option
                >
                <option value="experience"
                  >{t('contribute.form.sourcetype.experience')}</option
                >
                <option value="family"
                  >{t('contribute.form.sourcetype.family')}</option
                >
                <option value="book"
                  >{t('contribute.form.sourcetype.book')}</option
                >
                <option value="internet"
                  >{t('contribute.form.sourcetype.internet')}</option
                >
                <option value="professional"
                  >{t('contribute.form.sourcetype.professional')}</option
                >
                <option value="other"
                  >{t('contribute.form.sourcetype.other')}</option
                >
              </select>
            </div>
            <div class="form-group">
              <label for="source-ref"
                >{t('contribute.form.sourceref.label')}</label
              >
              <input
                type="text"
                id="source-ref"
                name="entry.source_ref"
                placeholder={t('contribute.form.sourceref.placeholder')}
              />
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="name">{t('contribute.form.name.label')}</label>
              <input
                type="text"
                id="name"
                name="entry.name"
                placeholder={t('contribute.form.name.placeholder')}
              />
            </div>
            <div class="form-group">
              <label for="email">{t('contribute.form.email.label')}</label>
              <input
                type="email"
                id="email"
                name="entry.email"
                placeholder={t('contribute.form.email.placeholder')}
              />
            </div>
          </div>

          <button type="submit" class="submit-btn" id="submit-btn"
            >{t('contribute.form.submit')}</button
          >
        </form>

        <div id="success-msg" class="success-msg" style="display:none;">
          <span class="success-icon">{t('contribute.form.success.icon')}</span>
          <h3>{t('contribute.form.success.title')}</h3>
          <p>
            {t('contribute.form.success.desc')}
          </p>
          <a href={lang === 'en' ? '/en' : '/'} class="back-link"
            >{t('contribute.form.success.back')}</a
          >
        </div>

        <script
          is:inline
          define:vars={{
            errorMsg: t('contribute.form.error'),
            submittingText: t('contribute.form.submitting'),
            submitText: t('contribute.form.submit'),
            anonymousText:
              lang === 'en' ? 'Anonymous Contributor' : '匿名貢獻者',
          }}
        >
          document
            .getElementById('contribute-form')
            .addEventListener('submit', async function (e) {
              e.preventDefault();
              const btn = document.getElementById('submit-btn');
              btn.disabled = true;
              btn.textContent = submittingText;

              const data = {
                timestamp: new Date().toISOString(),
                content: document.getElementById('content').value,
                category: document.getElementById('category').value,
                sourceType: document.getElementById('source-type').value,
                sourceRef: document.getElementById('source-ref').value,
                name: document.getElementById('name').value || anonymousText,
                email: document.getElementById('email').value,
              };

              try {
                const SCRIPT_URL =
                  'https://script.google.com/macros/s/AKfycbzuS3eCR6-cga-OCN34YY34vi0KnkYXYOQLs0VgsMd7WoMAn-gX9OH70Yd_UyF23_5vUA/exec';
                await fetch(SCRIPT_URL, {
                  method: 'POST',
                  mode: 'no-cors',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify(data),
                });
                document.getElementById('contribute-form').style.display =
                  'none';
                document.getElementById('success-msg').style.display = 'block';
              } catch (err) {
                alert(errorMsg);
                btn.disabled = false;
                btn.textContent = submitText;
              }
            });
        </script>
      </div>
    </section>

    <!-- Writing Guides Section - Position 6 -->
    <section class="writing-guides">
      <div class="guides-inner">
        <h2>{t('contribute.guides.title')}</h2>
        <p class="guides-desc">
          {t('contribute.guides.desc')}
        </p>

        <div class="guides-grid">
          <div class="guide-card writing">
            <div class="guide-icon">{t('contribute.guides.writing.icon')}</div>
            <h3>{t('contribute.guides.writing.title')}</h3>
            <div class="guide-content">
              <p>{t('contribute.guides.writing.belief.desc')}</p>
              <ul class="guide-highlights">
                <li set:html={t('contribute.guides.writing.ironlaws.story')} />
                <li set:html={t('contribute.guides.writing.ironlaws.verify')} />
                <li
                  set:html={t('contribute.guides.writing.ironlaws.density')}
                />
              </ul>
              <p set:html={t('contribute.guides.writing.core.good')} />
              <p set:html={t('contribute.guides.writing.core.bad')} />
              <a
                href="https://github.com/wilsonkichoi/lagunabeach-md/blob/main/docs/editorial/EDITORIAL.md"
                target="_blank"
                class="guide-link"
              >
                {
                  lang === 'en'
                    ? '→ Full EDITORIAL Guide'
                    : '→ 完整寫作方法論（EDITORIAL.md）'
                }
              </a>
            </div>
          </div>

          <div class="guide-card ai">
            <div class="guide-icon">{t('contribute.guides.ai.icon')}</div>
            <h3>{t('contribute.guides.ai.title')}</h3>
            <div class="guide-content">
              <p set:html={t('contribute.guides.ai.onerule.desc')} />
              <div class="ai-prompt-box">
                <code>{t('contribute.guides.ai.prompt.text')}</code>
                <button
                  class="copy-btn"
                  onclick={`navigator.clipboard.writeText(this.previousElementSibling.textContent).then(()=>this.textContent='${t('contribute.copy.copied')}')`}
                  >{t('contribute.copy.button')}</button
                >
              </div>
              <a
                href="https://github.com/wilsonkichoi/lagunabeach-md/blob/main/docs/prompts/TRANSLATE_PROMPT.md"
                target="_blank"
                class="guide-link"
              >
                {
                  lang === 'en'
                    ? '→ Full AI Prompt'
                    : '→ 完整 AI 寫作助手 Prompt'
                }
              </a>
            </div>
          </div>

          <div class="guide-card translation">
            <div class="guide-icon">
              {t('contribute.guides.translation.icon')}
            </div>
            <h3>{t('contribute.guides.translation.title')}</h3>
            <div class="guide-content">
              <p>{t('contribute.guides.translation.priority.desc')}</p>
              <ul class="guide-highlights">
                <li set:html={t('contribute.guides.translation.board.check')} />
                <li
                  set:html={t('contribute.guides.translation.board.prompt')}
                />
                <li
                  set:html={t('contribute.guides.translation.board.submit')}
                />
              </ul>

              <h4>{t('contribute.guides.translation.languages')}</h4>
              <ul>
                <li
                  set:html={t('contribute.guides.translation.languages.live')}
                />
                <li
                  set:html={t('contribute.guides.translation.languages.coming')}
                />
                <li
                  set:html={t('contribute.guides.translation.languages.you')}
                />
              </ul>

              <a
                href="https://github.com/wilsonkichoi/lagunabeach-md/blob/main/docs/community/TRANSLATION-BOARD.md"
                target="_blank"
                class="guide-link"
              >
                {lang === 'en' ? '→ Translation Board' : '→ 翻譯看板'}
              </a>
            </div>
          </div>

          <div class="guide-card images">
            <div class="guide-icon">{t('contribute.guides.images.icon')}</div>
            <h3>{t('contribute.guides.images.title')}</h3>
            <div class="guide-content">
              <p>{t('contribute.guides.images.priority.desc')}</p>
              <ul class="guide-highlights">
                <li set:html={t('contribute.guides.images.wikimedia.html')} />
                <li set:html={t('contribute.guides.images.government.html')} />
                <li set:html={t('contribute.guides.images.selftaken.html')} />
              </ul>
              <p class="guide-warning">
                {
                  lang === 'en'
                    ? '⛔ No Unsplash, Google Images, or social media screenshots'
                    : '⛔ 禁止 Unsplash、Google 圖片搜尋、社群媒體截圖'
                }
              </p>
            </div>
          </div>

          <div class="guide-card quality">
            <div class="guide-icon">{t('contribute.guides.quality.icon')}</div>
            <h3>{t('contribute.guides.quality.title')}</h3>
            <div class="guide-content">
              <p>{t('contribute.guides.quality.desc')}</p>
              <ul class="guide-highlights">
                <li
                  set:html={t('contribute.guides.quality.checklist.counter')}
                />
                <li
                  set:html={t('contribute.guides.quality.checklist.sources')}
                />
                <li set:html={t('contribute.guides.quality.checklist.voice')} />
              </ul>
              <p
                class="guide-warning"
                set:html={t('contribute.guides.quality.rejections.plastic')}
              />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Ideas Section - Position 7 -->
    <section class="ideas">
      <div class="ideas-inner">
        <h2>{t('contribute.ideas.title')}</h2>
        <div class="ideas-grid">
          <div class="idea">{t('contribute.ideas.hometown')}</div>
          <div class="idea">{t('contribute.ideas.recipes')}</div>
          <div class="idea">{t('contribute.ideas.history')}</div>
          <div class="idea">{t('contribute.ideas.places')}</div>
          <div class="idea">{t('contribute.ideas.elders')}</div>
          <div class="idea">{t('contribute.ideas.media')}</div>
        </div>
      </div>
    </section>
  </div>

  <!-- Token Donation Section - Position 8 -->
  <section class="token-donation" id="token-donation">
    <div class="token-inner">
      <h2>{t('contribute.token.title')}</h2>
      <p
        class="token-subtitle"
        set:html={t('contribute.token.subtitle.html')}
      />

      <!-- AI 翻譯助手（主要路線） -->
      <div class="one-line-system">
        <h3>{t('contribute.token.oneline.title')}</h3>
        <p>{t('contribute.token.oneline.desc')}</p>

        <div class="ai-prompt">
          <code>{t('contribute.token.oneline.prompt')}</code>
          <button class="copy-btn" data-copy="translate-prompt"
            >{t('contribute.copy.button')}</button
          >
        </div>

        <div class="one-line-features">
          <ul>
            <li>{t('contribute.token.oneline.feature1')}</li>
            <li>{t('contribute.token.oneline.feature2')}</li>
            <li>{t('contribute.token.oneline.feature3')}</li>
            <li>{t('contribute.token.oneline.feature4')}</li>
            <li>{t('contribute.token.oneline.feature5')}</li>
          </ul>
        </div>

        <a
          href="https://github.com/wilsonkichoi/lagunabeach-md/blob/main/docs/prompts/TRANSLATE_PROMPT.md"
          target="_blank"
          class="path-btn secondary"
          >{t('contribute.token.oneline.fullprompt')}</a
        >
      </div>

      <!-- 進階：腳本自動化 -->
      <div class="manual-process">
        <h3>{t('contribute.token.advanced.title')}</h3>
        <p>{t('contribute.token.advanced.desc')}</p>
        <div class="one-line-code">
          <code
            >bash &lt;(curl -s
            https://raw.githubusercontent.com/wilsonkichoi/lagunabeach-md/main/scripts/tools/translate.sh)</code
          >
          <button class="copy-btn" data-copy="one-line-command"
            >{t('contribute.copy.button')}</button
          >
        </div>
      </div>

      <div class="token-languages">
        <h3>{t('contribute.token.languages.title')}</h3>
        <div class="lang-tags">
          <span class="lang-tag">{t('contribute.token.lang.japanese')}</span>
          <span class="lang-tag">{t('contribute.token.lang.korean')}</span>
          <span class="lang-tag">{t('contribute.token.lang.spanish')}</span>
          <span class="lang-tag">{t('contribute.token.lang.french')}</span>
          <span class="lang-tag">{t('contribute.token.lang.german')}</span>
