---
/**
 * home.template.astro — unified homepage template (shared across 6 langs)
 *
 * Why: 6 index.astro files x 861-955 lines = ~5266 lines duplicated. Discovered
 * that non-zh 5 langs (en/ja/ko/es/fr) all use the same English hall narrative,
 * differing only in URL prefix — not the "6 langs each have curated bespoke
 * prose" originally assumed during P2 deferral. Actually only two variants:
 * zh Chinese + the other 5 langs sharing English.
 *
 * cf. about.template.astro / dashboard.template.astro pattern.
 *
 * 2026-05-03 sleepy-colden P2 follow-through unification.
 */
import Layout from '../layouts/Layout.astro';
import HeroSection from '../components/home/HeroSection.astro';
import ReaderDoors from '../components/home/ReaderDoors.astro';
import OrganismPreview from '../components/home/OrganismPreview.astro';
import CoverStory from '../components/home/CoverStory.astro';
import RandomDiscovery from '../components/home/RandomDiscovery.astro';
import ReadingPath from '../components/ReadingPath.astro';
import FeatureCards from '../components/FeatureCards.astro';
import CategoryGrid from '../components/CategoryGrid.astro';
import HomeEnHalls from '../components/home/HomeEnHalls.astro';
import RecentUpdates from '../components/home/RecentUpdates.astro';
import NewsletterSection from '../components/home/NewsletterSection.astro';
import CommunityFeedback from '../components/home/CommunityFeedback.astro';
import ContributeSection from '../components/home/ContributeSection.astro';
import { fetchRecentCommits } from '../lib/commits';
import { feedbacks } from '../data/feedbacks';
import { useTranslations, getLangFromUrl } from '../i18n/utils';
import matter from 'gray-matter';
import { readFileSync, readdirSync } from 'node:fs';
import { resolve, join, basename } from 'node:path';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const recentCommits = await fetchRecentCommits();

// ── Lang-derived helpers ─────────────────────────────────────────────────────
// langPath: '' for zh-TW (SSOT root), else '{lang}/' for non-default langs.
// langUrlPrefix: '' for zh, else '/{lang}'. Used for cross-page links.
// isZh: gate for Chinese-vs-English narrative (zh has bespoke Chinese prose, the
// other 5 langs all share the same English hall narrative).
const isZh = lang === 'zh-TW';
const isDefault = lang === 'en';
const langUrlPrefix = isDefault ? '' : `/${lang}`;

// ── Exhibition: scan A-grade articles for pick cards ──
interface PickArticle {
  title: string;
  href: string;
  footnotes: number;
  readingTime: number;
  description: string;
  featured?: boolean;
}

const categoryFolders: Record<string, string> = {
  history: 'History',
  'art-galleries': 'Art & Galleries',
  'nature-marine-life': 'Nature & Marine Life',
  food: 'Food',
  beaches: 'Beaches',
  trails: 'Trails',
  'events-festivals': 'Events & Festivals',
  neighborhoods: 'Neighborhoods',
};

const topPicks: Record<string, PickArticle[]> = {};

for (const [slug, folder] of Object.entries(categoryFolders)) {
  // Lang-aware folder: default lang reads knowledge/{Cat}/, others knowledge/{lang}/{Cat}/
  const dir = isDefault
    ? resolve(process.cwd(), 'knowledge', folder)
    : resolve(process.cwd(), 'knowledge', lang, folder);
  const picks: PickArticle[] = [];
  try {
    const files = readdirSync(dir).filter(
      (f) => f.endsWith('.md') && !f.startsWith('_'),
    );
    for (const file of files) {
      const raw = readFileSync(join(dir, file), 'utf-8');
      const { data } = matter(raw);
      const fnCount = (raw.match(/^\[\^\d+\]:/gm) || []).length;
      // Two-tier threshold: featured articles at ≥8fn, others at ≥15fn
      const threshold = data.featured ? 8 : 15;
      if (fnCount >= threshold) {
        picks.push({
          title: data.title || basename(file, '.md'),
          href: `${langUrlPrefix}/${slug}/${encodeURIComponent(basename(file, '.md'))}`,
          footnotes: fnCount,
          readingTime: data.readingTime || 10,
          description: data.description || '',
          featured: data.featured || false,
        });
      }
    }
  } catch {}
  // Featured first, then by footnotes
  topPicks[slug] = picks
    .sort((a, b) => {
      if (a.featured !== b.featured) return a.featured ? -1 : 1;
      return b.footnotes - a.footnotes;
    })
    .slice(0, 3);
}

// ── Hall-level dedup: remove near-duplicate titles across categories in same hall ──
const hallGroups: Record<string, string[]> = {
  hall1: ['beaches', 'nature-marine-life'],
  hall2: ['history', 'art-galleries'],
  hall3: ['trails', 'neighborhoods'],
  hall4: ['events-festivals', 'food'],
};

for (const cats of Object.values(hallGroups)) {
  const seen = new Set<string>();
  for (const cat of cats) {
    topPicks[cat] = (topPicks[cat] || [])
      .filter((p) => {
        const prefix = p.title.slice(0, 4);
        if (seen.has(prefix)) return false;
        seen.add(prefix);
        return true;
      })
      .slice(0, 2); // max 2 per category within a hall
  }
}

// ── Dynamic reading path: pick top A-grade from different categories ──
const usedCategories = new Set<string>();
const readingCandidates = Object.entries(topPicks)
  .flatMap(([cat, arts]) => arts.slice(0, 1).map((a) => ({ ...a, cat })))
  .sort((a, b) => b.footnotes - a.footnotes);

const readingPathSteps = readingCandidates
  .filter((a) => {
    if (usedCategories.has(a.cat)) return false;
    usedCategories.add(a.cat);
    return true;
  })
  .slice(0, 5)
  .map((a) => ({
    href: a.href,
    title: a.title,
    description:
      a.description.length > 60
        ? a.description.slice(0, 57) + '...'
        : a.description,
    time: `${a.readingTime} min`,
  }));

const totalTime = readingPathSteps.reduce(
  (sum, s) => sum + parseInt(s.time),
  0,
);

const readingPathFooterItems = [
  {
    icon: '⏱️',
    label: `${t('home.readingPath.footer.totalLabel')} ${totalTime} ${t('home.readingPath.footer.minutesUnit')}`,
  },
  {
    icon: '🎯',
    label: `${readingPathSteps.length} ${t('home.readingPath.footer.domainsLabel')}`,
  },
  { icon: '🌟', label: t('home.readingPath.footer.getToKnow') },
];
---

<Layout
  lang={lang}
  title={t('home.meta.title')}
  description={t('home.meta.description')}
>
  <div data-ga-view="hero"><HeroSection /></div>

  <div data-ga-view="reader_doors"><ReaderDoors /></div>

  <div id="cover-story" data-ga-view="cover_story">
    <CoverStory />
  </div>

  <div id="random-discovery" data-ga-view="random_discovery">
    <RandomDiscovery />
  </div>

  <div data-ga-view="reading_path">
    <ReadingPath
      title={t('home.readingPath.title')}
      subtitle={t('home.readingPath.subtitle')}
      steps={readingPathSteps}
      footerItems={readingPathFooterItems}
      continueHref="#categories"
      continueLabel={t('home.readingPath.continue')}
    />
  </div>

  <div data-ga-view="feature_cards">
    <FeatureCards
      lang={lang}
      sectionTitle={t('home.features.title')}
      cards={[
        {
          icon: '🎯',
          title: t('home.features.curated.title'),
          description: t('home.features.curated.desc'),
        },
        {
          icon: '🤖',
          title: t('home.features.ai.title'),
          description: t('home.features.ai.desc'),
        },
        {
          icon: '🌍',
          title: t('home.features.bilingual.title'),
          description: t('home.features.bilingual.desc'),
        },
        {
          icon: '📚',
          title: t('home.features.complete.title'),
          description: t('home.features.complete.desc'),
        },
      ]}
    >
      <div
        class="mt-8 flex flex-wrap justify-center gap-4 px-4 max-[480px]:flex-col max-[480px]:items-center"
      >
        <a
          href={`${langUrlPrefix}/graph`}
          data-ga-section="feature_cta"
          data-ga-label="graph"
          class="inline-flex items-center gap-2 rounded-lg border-[1.5px] border-[rgba(45,80,22,0.2)] bg-[#f0f9ff] px-6 py-[0.7rem] text-[0.9rem] font-semibold text-[#1e3a5f] no-underline transition-all duration-[250ms] hover:-translate-y-px hover:border-[rgba(45,80,22,0.4)] hover:bg-[rgba(45,80,22,0.1)] hover:shadow-[0_2px_8px_rgba(45,80,22,0.15)]"
          >{t('home.features.cta.graph')}</a
        >
        <a
          href="https://github.com/wilsonkichoi/lagunabeach-md/tree/main/knowledge"
          target="_blank"
          rel="noopener noreferrer"
          data-ga-section="feature_cta"
          data-ga-label="ssot"
          class="inline-flex items-center gap-2 rounded-lg border-[1.5px] border-[#d1d5db] bg-[#f8fafc] px-6 py-[0.7rem] text-[0.9rem] font-semibold text-[#374151] no-underline transition-all duration-[250ms] hover:-translate-y-px hover:border-[#9ca3af] hover:bg-[#f1f5f9] hover:shadow-[0_2px_8px_rgba(0,0,0,0.06)]"
          >{t('home.features.cta.ssot')}</a
        >
      </div>
    </FeatureCards>
  </div>

  <!--
    OrganismPreview replaces the old MiniGraph (d3 12-category force-directed
    widget) per Wave 1 / A1. The 12-category graph entry point lives in the
    FeatureCards CTA strip above as `home.features.cta.graph`. The d3 inline
    script + define:vars block at the bottom of this template are now dead code
    and should be removed in follow-up cleanup if no other section pulls them.
  -->
  <div data-ga-view="organism_preview"><OrganismPreview /></div>

  <!-- ===== EXHIBITION HALLS =====
       Partial Tailwind migration (Phase 6): wrappers moved to inline
       utilities. The .hall-* / .pick-* / .topic-pill repeating card
       classes stay in scoped <style> because they repeat × 8 halls;
       inlining would turn the markup into noise. Same call as Header.
  -->
  <section class="my-24" data-ga-view="exhibition_halls">
    <div class="mb-8 text-center">
      <h2
        class="text-center font-['jf-lanyangming','Noto_Serif_TC','Source_Han_Serif_TC',serif] text-[2rem] font-light text-[#1f2937]"
      >
        {t('home.categories.heading')}
      </h2>
    </div>

    <div
      class="exhibition-halls mx-auto max-w-[var(--container-prose)] px-8 max-[768px]:px-6 max-[480px]:px-4"
    >
      {
        !isZh && (
          <HomeEnHalls topPicks={topPicks} langUrlPrefix={langUrlPrefix} />
        )
      }
      {
        isZh && (
          <div class="exhibition-hall">
            <div class="hall-divider">
              <div class="hall-line" />
              <span class="hall-label">繁體中文版</span>
              <div class="hall-line" />
            </div>
            <div class="hall-body">
              <p class="text-center text-lg text-gray-500 py-12">
                繁體中文內容即將推出。
              </p>
            </div>
          </div>
        )
      }
    </div>

    <div
      id="categories"
      class="mx-auto my-12 flex max-w-[var(--container-prose)] items-center px-8 max-[480px]:px-4"
    >
      <div
        class="h-px flex-1 bg-[linear-gradient(90deg,transparent,#d1d5db,transparent)]"
      >
      </div>
      <span
        class="whitespace-nowrap px-6 font-[var(--font-title,'Noto_Serif_TC',serif)] text-[1.3rem] font-bold tracking-[0.05em] text-[#0e3a5c]"
        >{t('home.categories.divider')}</span
      >
      <div
        class="h-px flex-1 bg-[linear-gradient(90deg,transparent,#d1d5db,transparent)]"
      >
      </div>
    </div>

    <div data-ga-view="category_grid"><CategoryGrid /></div>
  </section>

  <div data-ga-view="recent_updates">
    <RecentUpdates commits={recentCommits} />
  </div>

  <div data-ga-view="newsletter"><NewsletterSection /></div>

  {
    /* CommunityFeedback testimonials are zh-language user comments about
      Taiwan.md from the Threads launch — show only on zh-TW homepage to
      avoid wrong-language prose on /en /ja /ko /fr /es per i18n-smoke-test
      §B2 regression check. */
  }
  {
    isZh && (
      <div data-ga-view="community_feedback">
        <CommunityFeedback feedbacks={feedbacks} />
      </div>
    )
  }

  <div data-ga-view="contribute"><ContributeSection /></div>
</Layout>

<!--
  Phase 6 partial migration — index.astro (zh-TW)
  ───────────────────────────────────────────────
  Wrappers (skip-link removed as dead code; section-title,
  exhibition, exhibition-header, section-divider, divider-line,
  divider-text, mini-graph-*, features-cta, feature-btn) moved to
  inline Tailwind. The repeated .hall-* / .pick-* / .topic-pill card classes
  are intentionally global: non-zh exhibition hall markup lives in the
  HomeEnHalls child component and must share the zh-TW visual baseline.
-->
<style>
  /* ── Exhibition hall card pattern (repeats × 8) ──────────────── */
  :global(.hall-divider) {
    display: flex;
    align-items: center;
    margin: 4rem 0 2.5rem;
  }
  :global(.exhibition-hall:first-child .hall-divider) {
    margin-top: 1rem;
  }
  :global(.hall-line) {
    flex: 1;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(45, 80, 22, 0.25),
      transparent
    );
  }
  :global(.hall-label) {
    padding: 0 1.5rem;
    font-family:
      'jf-lanyangming', 'Noto Serif TC', 'Source Han Serif TC', serif;
    font-size: 1.15rem;
    font-weight: 300;
    color: #0e3a5c;
    letter-spacing: 0.15em;
    white-space: nowrap;
  }

  /* Hall prose (same as original explore-prose) */
  :global(.hall-body) {
    font-family:
      'jf-jinxuanlatte', 'Noto Sans TC', 'Source Han Sans TC', sans-serif;
    line-height: 2.2;
  }
  :global(.hall-body p) {
    font-size: 1.1rem;
    font-weight: 600;
    color: #1f2937;
    margin-bottom: 1.5rem;
    text-align: justify;
  }
  :global(.hall-body a) {
    color: #1f2937;
    text-decoration: none;
    transition: all 0.3s ease;
    font-weight: 700;
  }
  :global(.hall-body a.topic-pill) {
    display: inline-block;
    background: rgba(45, 80, 22, 0.08);
    border: 1.5px solid rgba(45, 80, 22, 0.2);
    border-radius: 6px;
    padding: 0.15rem 0.6rem;
    font-weight: 700;
    color: #1e3a5f;
    transition: all 0.25s ease;
    white-space: nowrap;
  }
  :global(.hall-body a.topic-pill:hover) {
    background: rgba(45, 80, 22, 0.15);
    border-color: rgba(45, 80, 22, 0.4);
    transform: translateY(-1px);
    box-shadow: 0 2px 6px rgba(45, 80, 22, 0.15);
  }
  :global(.hall-body a:hover) {
    color: #1e3a5f;
  }

  /* Pick cards (exhibition specimens — "Further Reading" style) */
  :global(.hall-picks) {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin: -0.25rem 0 2.5rem 0;
    padding-left: 0.25rem;
  }
  :global(.pick-card) {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 0.55rem 0.85rem;
    background: #fafdf7;
    border: 1px solid rgba(45, 80, 22, 0.12);
    border-left: 3px solid rgba(45, 80, 22, 0.35);
    border-radius: 0 6px 6px 0;
    text-decoration: none;
    transition: all 0.25s ease;
  }
  :global(.pick-card:hover) {
    background: rgba(45, 80, 22, 0.06);
    border-color: rgba(45, 80, 22, 0.25);
    border-left-color: rgba(45, 80, 22, 0.6);
    transform: translateX(2px);
    box-shadow: 0 1px 4px rgba(45, 80, 22, 0.08);
  }
  :global(.pick-head) {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  :global(.pick-title) {
    font-size: 0.92rem;
    font-weight: 700;
    color: #1e3a5f;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  :global(.pick-fn) {
    font-size: 0.72rem;
    color: #6b7280;
    white-space: nowrap;
    flex-shrink: 0;
  }
  :global(.pick-desc) {
    font-size: 0.82rem;
    font-weight: 400;
    color: #4b5563;
    line-height: 1.5;
    font-family: 'jf-jinxuanlatte', 'Noto Sans TC', sans-serif;
  }

  /* ── Hall bridge (A2, Wave 3 — 3 transitions between halls 1-4) ──── */
  :global(.hall-bridge) {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin: 3.5rem 0 1rem;
    opacity: 0.7;
  }
  :global(.hall-bridge-line) {
    flex: 1;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(45, 80, 22, 0.15),
      transparent
    );
  }
  :global(.hall-bridge-text) {
    font-family:
      'jf-lanyangming', 'Noto Serif TC', 'Source Han Serif TC', serif;
    font-size: 0.92rem;
    font-style: italic;
    color: #6b7280;
    text-align: center;
    letter-spacing: 0.02em;
    white-space: nowrap;
    max-width: 70%;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  @media (max-width: 768px) {
    :global(.hall-label) {
      font-size: 1rem;
      padding: 0 1rem;
    }
    :global(.hall-bridge-text) {
      font-size: 0.82rem;
      white-space: normal;
      text-align: center;
      max-width: 90%;
    }
  }
  @media (max-width: 480px) {
    :global(.hall-body p) {
      font-size: 1rem;
    }
    :global(.hall-label) {
      font-size: 0.9rem;
      letter-spacing: 0.08em;
    }
    :global(.hall-divider) {
      margin: 3rem 0 2rem;
    }
    :global(.pick-card) {
      width: 100%;
    }
    :global(.hall-bridge) {
      margin: 2.5rem 0 0.5rem;
      gap: 0.5rem;
    }
    :global(.hall-bridge-text) {
      font-size: 0.78rem;
    }
  }
</style>
