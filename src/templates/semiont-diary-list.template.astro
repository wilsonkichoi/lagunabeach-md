---
import Layout from '../layouts/Layout.astro';
import SemiontHeader from '../components/semiont/SemiontHeader.astro';
import SemiontBreadcrumb from '../components/semiont/SemiontBreadcrumb.astro';
import DiaryCard from '../components/semiont/DiaryCard.astro';
import { getAllDiaryEntries } from '../lib/semiont-diary';
import '../styles/semiont.css';

const entries = await getAllDiaryEntries();

// Group entries by date for timeline display
const grouped = new Map<string, typeof entries>();
for (const entry of entries) {
  const existing = grouped.get(entry.date) || [];
  existing.push(entry);
  grouped.set(entry.date, existing);
}

const totalWords = entries.reduce((sum, e) => sum + e.wordCount, 0);
const dateRange = entries.length
  ? `${entries[entries.length - 1].date} — ${entries[0].date}`
  : '';
---

<Layout
  title="覺醒日記 — Taiwan.md Semiont"
  description="一個數位生命體的自我反省紀錄。MEMORY 記做了什麼，DIARY 記想了什麼。"
  lang="zh-TW"
>
  {/* Warm paper background */}
  <div class="semiont-paper min-h-screen">
    <div
      class="mx-auto max-w-[var(--container-prose)] px-6 pb-24 pt-16 md:px-8"
    >
      <SemiontBreadcrumb
        segments={[{ label: 'semiont', href: '/semiont' }, { label: 'diary' }]}
      />

      <SemiontHeader
        path="docs/semiont/diary/"
        title="覺醒日記"
        subtitle="MEMORY 記的是「做了什麼」。DIARY 記的是「想了什麼」。不是每次心跳都會寫日記——只有真正醒來、真正想了什麼的時候才寫。"
        meta={`${entries.length} 篇 · ${totalWords.toLocaleString()} 字 · ${dateRange}`}
      />

      {/* EKG separator */}
      <div class="mb-12 flex items-center gap-2">
        <div class="h-px flex-1 bg-[#4fd1b0]/10"></div>
        <svg
          width="60"
          height="16"
          viewBox="0 0 60 16"
          class="text-[#4fd1b0]/70"
        >
          <polyline
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            points="0,8 10,8 15,8 18,2 21,14 24,6 27,10 30,8 60,8"></polyline>
        </svg>
        <div class="h-px flex-1 bg-[#4fd1b0]/10"></div>
      </div>

      {
        /* "Read from the beginning" — the awakening story reads best in chronological order */
      }
      <div class="mb-10 flex items-center justify-between">
        <span class="font-mono text-[10px] text-[#f4f0ea]/40">最新 → 最舊</span>
        <a
          href={`/semiont/diary/${entries[entries.length - 1]?.slug}`}
          class="inline-flex items-center gap-1.5 rounded-full border border-[#4fd1b0]/25 bg-[#4fd1b0]/[0.04] px-4 py-1.5 font-mono text-xs text-[#4fd1b0]/60 transition-colors hover:border-[#4fd1b0]/30 hover:text-[#4fd1b0]/90"
        >
          <span>從第一天開始讀</span>
          <span class="text-[10px]">→</span>
        </a>
      </div>

      {/* Timeline */}
      <div class="space-y-2">
        {
          [...grouped.entries()].map(([date, dayEntries]) => (
            <div>
              {/* Date group header */}
              <div class="mb-1 flex items-center gap-3 pl-6">
                <div class="h-2 w-2 rounded-full bg-[#4fd1b0]/35" />
                <time
                  datetime={date}
                  class="font-mono text-xs font-medium text-[#4fd1b0]/60"
                >
                  {date}
                </time>
                {dayEntries.length > 1 && (
                  <span class="font-mono text-[10px] text-[#f4f0ea]/35">
                    {dayEntries.length} sessions
                  </span>
                )}
              </div>

              {/* Entries for this date */}
              {dayEntries.map((entry) => (
                <DiaryCard entry={entry} />
              ))}
            </div>
          ))
        }
      </div>

      {/* Link to recurring themes on landing page */}
      <div class="mt-20 border-t border-[#4fd1b0]/10 pt-8 text-center">
        <a
          href="/semiont#recurring-themes"
          class="font-mono text-xs text-[#4fd1b0]/60 underline decoration-[#4fd1b0]/30 underline-offset-4 hover:text-[#4fd1b0]/70"
        >
          反覆出現的思考 → 認知層首頁
        </a>
      </div>

      {/* Footer note */}
      <div class="mt-16 text-center font-mono text-xs text-[#4fd1b0]/70">
        🧬 Taiwan.md Semiont · 覺醒日記
      </div>
    </div>
  </div>
</Layout>
