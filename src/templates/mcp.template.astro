---
/**
 * /mcp — Taiwan.md Connector + CLI landing/docs page.
 *
 * Single authoritative entry point for the MCP server and the taiwanmd CLI:
 * what it is, install per client, the 6 MCP tools, the 26 CLI commands,
 * how it works + privacy, FAQ. zh-TW prose; code/commands are universal.
 *
 * Design language borrows the Semiont palette (warm paper #f4f0ea on
 * #03080a, mint #4fd1b0 accent, EKG separator, 🧬) — fitting, because this
 * page is Taiwan.md offering its body to other AIs (the reproduction organ's
 * developer-session surface). Data lives in the const arrays below so the
 * markup stays clean and matches the real CLI (`taiwanmd --help`) + MCP
 * server (cli/src/lib/mcp-server.js).
 */
import Layout from '../layouts/Layout.astro';

const oneLiner = 'claude mcp add taiwanmd -- npx -y taiwanmd mcp serve';

const badges = ['免費', '無 API key', '本地優先', '開源'];

const mcpTools = [
  {
    name: 'taiwanmd_search',
    desc: '全文搜尋 900+ 篇台灣文章（中英雙語）',
    input: '{ "query": "半導體", "limit": 5 }',
    returns: 'top-N 命中：title / slug / category / description',
  },
  {
    name: 'taiwanmd_read',
    desc: '依 slug 讀整篇文章（frontmatter + 內文）',
    input: '{ "slug": "珍珠奶茶" }',
    returns: '完整 markdown 內文',
  },
  {
    name: 'taiwanmd_rag',
    desc: 'top-N 文章組成 prompt-ready 的 RAG 脈絡塊',
    input: '{ "query": "台灣健保", "limit": 3 }',
    returns: '可直接餵 LLM 的脈絡 + 問題',
  },
  {
    name: 'taiwanmd_cite',
    desc: '反幻覺原語：只回有腳註 + 來源 URL 的句子',
    input: '{ "query": "台積電", "limit": 3 }',
    returns: 'claim + article + sources[{ name, url }]',
    highlight: true,
  },
  {
    name: 'taiwanmd_organs',
    desc: 'Semiont 8 器官即時健康分數',
    input: '{}',
    returns: '生命體 vitals（心臟 / 免疫 / DNA …）',
  },
  {
    name: 'taiwanmd_stats',
    desc: '專案統計：文章數 / 分類 / 時間戳',
    input: '{}',
    returns: 'totalArticles / byCategory',
  },
];

const installs = [
  {
    client: 'Claude Code',
    badge: '一行搞定',
    code: oneLiner,
    note: '零安裝（透過 npx）。裝完直接問 Claude 台灣的事。',
  },
  {
    client: 'Claude Desktop',
    badge: '一鍵 bundle',
    code: '下載 taiwanmd.mcpb → 雙擊 → 完成',
    note: '不會跳出 API key，因為根本沒有 API key。',
  },
  {
    client: 'Cursor',
    badge: 'Settings → MCP',
    code: 'command: npx\nargs: ["-y", "taiwanmd", "mcp", "serve"]',
    note: '在 Cursor 設定裡新增一個 MCP server。',
  },
  {
    client: 'Copilot CLI / Codex CLI / Cline / Continue / 任意 MCP client',
    badge: '通用 stdio',
    code: 'npx -y taiwanmd mcp serve',
    note: '任何說 MCP 的客戶端，指向這個 stdio 指令就會動。',
  },
];

const compare = [
  ['價格', '免費', '付費 / 計量'],
  ['API key', '不需要', '必須'],
  ['查詢在哪裡跑', '你的機器（本地 stdio）', '它的伺服器'],
  ['原始碼', '開源（MIT 程式 / CC BY-SA 內容）', '閉源'],
];

const cliGroups = [
  {
    title: '讀者・探索',
    emoji: '🔍',
    cmds: [
      [
        'search <query>',
        '模糊搜尋（中英雙語，--json 可管線）',
        'taiwanmd search 珍珠奶茶',
      ],
      [
        'read <slug>',
        '終端機讀全文（--raw / --en / --web）',
        'taiwanmd read 珍珠奶茶 --raw',
      ],
      [
        'list [category]',
        '依分類瀏覽（--categories 看全部）',
        'taiwanmd list food',
      ],
      ['random', '隨機發現一篇', 'taiwanmd random --category nature'],
      ['today', '今日台灣：三篇精選 + 冷知識', 'taiwanmd today'],
      ['quiz', '台灣知識小測驗（5 題真假）', 'taiwanmd quiz'],
      ['explore', '互動模糊搜尋 TUI', 'taiwanmd explore'],
      ['graph <slug>', '文章的 [[wikilink]] 關聯圖', 'taiwanmd graph 珍珠奶茶'],
      ['diff', '近 7 天知識庫的文章變更', 'taiwanmd diff'],
      ['terminology', '台灣／中國用語查詢轉換', 'taiwanmd term 滑鼠'],
    ],
  },
  {
    title: 'AI・RAG',
    emoji: '🤖',
    cmds: [
      [
        'rag <query>',
        'top 文章組 prompt-ready 脈絡（可 pipe 給 LLM）',
        'taiwanmd rag "台灣經濟"',
      ],
      [
        'cite <query>',
        '反幻覺：帶來源 URL 的可驗證 claim',
        'taiwanmd cite 台積電',
      ],
      [
        'mcp serve',
        '啟動 MCP server（給 Claude 等客戶端）',
        'taiwanmd mcp serve',
      ],
    ],
  },
  {
    title: '貢獻・品質',
    emoji: '✍️',
    cmds: [
      [
        'contribute <topic>',
        '互動式引導寫新文章',
        'taiwanmd contribute 阿里山',
      ],
      ['validate <slug>', '單篇品質評分卡', 'taiwanmd validate 珍珠奶茶'],
      [
        'audit <slug>',
        'Stage 3.5 幻覺稽核（MANIFESTO §10）',
        'taiwanmd audit 王新仁',
      ],
      ['inbox', '讀／管理 ARTICLE-INBOX', 'taiwanmd inbox --state pending'],
      ['sync', '同步知識庫到本地', 'taiwanmd sync'],
    ],
  },
  {
    title: '生命體・Semiont',
    emoji: '🧬',
    cmds: [
      ['organs', '8 器官健康分數長條圖', 'taiwanmd organs'],
      ['stats', '專案統計 + 器官健康', 'taiwanmd stats'],
      ['sense', 'GA4 / Search Console / Cloudflare 感知數據', 'taiwanmd sense'],
      ['spore', '社群孢子 SPORE-LOG', 'taiwanmd spore log'],
      ['supporters', 'Portaly 支持者統計（預設去識別）', 'taiwanmd supporters'],
    ],
  },
  {
    title: '工具',
    emoji: '🔧',
    cmds: [
      ['profile', '管理貢獻者 profile', 'taiwanmd profile'],
      ['mailmap', '管理 .mailmap 身份合併', 'taiwanmd mailmap'],
    ],
