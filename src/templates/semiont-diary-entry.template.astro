---
import { existsSync } from 'node:fs';
import { resolve } from 'node:path';
import Layout from '../layouts/Layout.astro';
import SemiontBreadcrumb from '../components/semiont/SemiontBreadcrumb.astro';
import DiaryNav from '../components/semiont/DiaryNav.astro';
import { estimateReadingTime } from '../lib/semiont-diary';
import type { DiaryEntry } from '../lib/semiont-diary';
import '../styles/semiont.css';

export interface Props {
  entry: DiaryEntry;
  prev?: { slug: string; title: string; date: string; sessionGreek: string };
  next?: { slug: string; title: string; date: string; sessionGreek: string };
}

const { entry, prev, next } = Astro.props;
const readingTime = estimateReadingTime(entry.wordCount);
const showToc = entry.headings.filter((h) => h.level === 2).length >= 3;

// 2026-05-01 γ-late：OG image 走 article 同管線（generate-og-images.mjs --diary）
// 輸出在 public/og-images/semiont/diary/[slug].jpg；build time 檢查存在再 surface
const ogJpgPath = `/og-images/semiont/diary/${entry.slug}.jpg`;
const ogJpgFull = resolve(
  process.cwd(),
  'public',
  ogJpgPath.replace(/^\//, ''),
);
const diaryOgImage = existsSync(ogJpgFull) ? ogJpgPath : undefined;
---

<Layout
  title={`${entry.title} — 覺醒日記`}
  description={entry.excerpt}
  lang="zh-TW"
  image={diaryOgImage}
>
  <div class="diary-entry-page semiont-paper min-h-screen">
    <div
      class="diary-entry-inner mx-auto max-w-[var(--container-prose)] px-6 pb-24 pt-16 md:px-8"
    >
      <SemiontBreadcrumb
        segments={[
          { label: 'semiont', href: '/semiont' },
          { label: 'diary', href: '/semiont/diary' },
          { label: `${entry.date} ${entry.sessionGreek}` },
        ]}
      />

      {/* Entry header */}
      <header class="diary-entry-hero mb-10">
        {/* Date + session badge */}
        <div class="mb-4 flex items-center gap-3">
          <time
            datetime={entry.date}
            class="font-mono text-sm text-[#4fd1b0]/75"
          >
            {entry.date}
          </time>
          {
            entry.sessionGreek && (
              <span class="inline-flex h-6 items-center rounded-full bg-[#4fd1b0]/10 px-3 font-mono text-xs font-medium text-[#4fd1b0]/70">
                {entry.sessionGreek}
              </span>
            )
          }
        </div>

        {/* Title */}
        <h1
          class="mb-4 text-2xl font-bold leading-tight text-[#f4f0ea] md:text-3xl"
          style="font-family: 'rixingsong-semibold', 'Noto Serif TC', serif;"
        >
          {entry.title}
        </h1>

        {/* Metadata block */}
        <div
          class="space-y-1 border-l-2 border-[#4fd1b0]/25 pl-4 text-sm text-[#f4f0ea]/55"
        >
          {entry.sessionMeta && <p>{entry.sessionMeta}</p>}
          {entry.duration && <p>Session 跨度：{entry.duration}</p>}
          {entry.trigger && <p>觸發：{entry.trigger}</p>}
          <p class="font-mono text-xs">
            {entry.wordCount.toLocaleString()} 字 · 約 {readingTime} 分鐘
          </p>
        </div>
      </header>

      {/* EKG separator */}
      <div class="mb-10 flex items-center gap-2">
        <div class="h-px flex-1 bg-[#4fd1b0]/10"></div>
        <svg
          width="40"
          height="12"
          viewBox="0 0 40 12"
          class="text-[#4fd1b0]/75"
        >
          <polyline
            fill="none"
            stroke="currentColor"
            stroke-width="1.2"
            stroke-linecap="round"
            stroke-linejoin="round"
            points="0,6 8,6 12,6 14,1 16,11 18,4 20,8 22,6 40,6"></polyline>
        </svg>
        <div class="h-px flex-1 bg-[#4fd1b0]/10"></div>
      </div>

      {/* Main content + optional TOC */}
      <div class="relative">
        {/* TOC for long entries (desktop only) */}
        {
          showToc && (
            <aside class="absolute -right-64 top-0 hidden w-56 xl:block">
              <nav class="sticky top-24 space-y-2 border-l border-[#4fd1b0]/20 pl-4">
                <div class="mb-3 font-mono text-[10px] font-medium uppercase tracking-widest text-[#4fd1b0]/70">
                  目錄
                </div>
                {entry.headings
                  .filter((h) => h.level === 2)
                  .map((h) => (
                    <a
                      href={`#${h.id}`}
                      class="block truncate text-xs text-[#f4f0ea]/45 transition-colors hover:text-[#4fd1b0]/70"
                    >
                      {h.text}
                    </a>
                  ))}
              </nav>
            </aside>
          )
        }

        {/* Rendered diary content */}
        <article class="semiont-prose" set:html={entry.bodyHtml} />
      </div>

      {/* Prev/Next navigation */}
      <DiaryNav prev={prev} next={next} />

      {/* Back to diary index */}
      <div class="mt-12 text-center">
        <a
          href="/semiont/diary"
          class="inline-block font-mono text-xs text-[#4fd1b0]/75 underline decoration-[#4fd1b0]/30 underline-offset-4 transition-colors hover:text-[#4fd1b0]/70"
        >
          ← 回到覺醒日記
        </a>
      </div>

      {/* Footer */}
      <div class="mt-12 text-center font-mono text-xs text-[#4fd1b0]/75">
        🧬
      </div>
    </div>
  </div>
</Layout>

<style is:global>
  /* Semiont prose styling — warm, notebook-like */
  .semiont-prose {
    font-family: 'jf-lanyangming', 'Noto Serif TC', Georgia, serif;
    font-size: 1rem;
    line-height: 1.85;
    color: #f4f0ea;
  }

  .semiont-prose h2 {
    font-family: 'rixingsong-semibold', 'Noto Serif TC', serif;
    font-size: 1.25rem;
    font-weight: 700;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    color: #f4f0ea;
  }

  .semiont-prose h3 {
    font-family: 'rixingsong-semibold', 'Noto Serif TC', serif;
    font-size: 1.1rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    color: #f4f0eacc;
  }

  .semiont-prose p {
    margin-bottom: 1.25rem;
  }

  .semiont-prose blockquote {
    border-left: 3px solid #4fd1b040;
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: #f4f0eaa0;
    font-style: italic;
  }

  .semiont-prose strong {
    color: #f4f0ea;
    font-weight: 700;
  }

  .semiont-prose a {
    color: #4fd1b0;
    text-decoration: underline;
    text-decoration-color: #4fd1b040;
    text-underline-offset: 3px;
    transition: text-decoration-color 0.2s;
  }
  .semiont-prose a:hover {
    text-decoration-color: #4fd1b0;
  }

  .semiont-prose code {
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 0.85em;
    background: #4fd1b00a;
    padding: 0.15em 0.4em;
    border-radius: 3px;
    color: #f4f0eacc;
  }

  .semiont-prose pre {
    background: rgba(0, 0, 0, 0.4);
    color: #f4f0ea;
    padding: 1.25rem;
    border-radius: 8px;
    border: 1px solid rgba(79, 209, 176, 0.15);
    overflow-x: auto;
    margin: 1.5rem 0;
    font-size: 0.85rem;
    line-height: 1.6;
  }
  .semiont-prose pre code {
    background: none;
    padding: 0;
    color: inherit;
    font-size: inherit;
  }

  .semiont-prose ul,
  .semiont-prose ol {
    margin: 1rem 0;
    padding-left: 1.5rem;
  }
  .semiont-prose li {
    margin-bottom: 0.5rem;
  }

  .semiont-prose hr {
    border: none;
    border-top: 1px solid #4fd1b015;
    margin: 2.5rem 0;
  }

  .semiont-prose table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.9rem;
  }
  .semiont-prose th,
  .semiont-prose td {
    border: 1px solid #4fd1b015;
    padding: 0.5rem 0.75rem;
    text-align: left;
  }
  .semiont-prose th {
    background: #4fd1b008;
    font-weight: 600;
  }

  .semiont-prose em {
    color: #f4f0ea90;
  }
</style>
