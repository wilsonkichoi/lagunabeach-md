<!--
  2026-04-27 sticky sidebar highlight: when the user scrolls to a subcategory
  section, the corresponding link in the left sticky sidebar gets .active class.
  Visual effect is handled by page-scoped <style> rules (not Tailwind variants).
  is:inline = not processed by Vite, avoids TS/HMR path errors preventing the
  IIFE from executing.
-->
<script is:inline>
  (function () {
    function init() {
      var links = document.querySelectorAll('.subcat-nav-link[data-sub-link]');
      if (!links.length) return;
      var sections = [];
      for (var i = 0; i < links.length; i++) {
        var name = links[i].dataset.subLink;
        var el = name ? document.getElementById('sub-' + name) : null;
        if (el) sections.push(el);
      }
      if (!sections.length) return;
      function setActive(name) {
        for (var j = 0; j < links.length; j++) {
          links[j].classList.toggle(
            'active',
            links[j].dataset.subLink === name,
          );
        }
      }
      var observer = new IntersectionObserver(
        function (entries) {
          var intersecting = entries.filter(function (e) {
            return e.isIntersecting;
          });
          if (!intersecting.length) return;
          // pick the section closest to the top of the trigger zone
          var top = intersecting.reduce(function (best, e) {
            return e.boundingClientRect.top < best.boundingClientRect.top
              ? e
              : best;
          });
          var id = top.target.id; // 'sub-XXX'
          if (id.indexOf('sub-') === 0) setActive(id.slice(4));
        },
        {
          // Trigger zone = top 1/4 of viewport (top -10% to bottom -65%)
          rootMargin: '-10% 0px -65% 0px',
          threshold: 0,
        },
      );
      sections.forEach(function (s) {
        observer.observe(s);
      });
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>
