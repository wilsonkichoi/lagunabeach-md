    // 渲染 Sunburst Chart
    function renderSunburst() {
      const container = document.getElementById('sunburstViz');
      container.innerHTML = '';

      const width = 600;
      const height = 600;
      const radius = Math.min(width, height) / 2 - 10;
      const centerRadius = 80;

      const svg = d3
        .select(container)
        .append('svg')
        .attr('viewBox', `0 0 ${width} ${height}`)
        .attr('width', '100%')
        .attr('height', 'auto');

      const g = svg
        .append('g')
        .attr('transform', `translate(${width / 2}, ${height / 2})`);

      // 準備數據
      const root = d3
        .hierarchy(foodData)
        .sum((d) => (d.children ? 0 : 1))
        .sort((a, b) => b.value - a.value);

      // 分區布局
      const partition = d3.partition().size([2 * Math.PI, radius]);
      partition(root);

      // 弧生成器
      const arc = d3
        .arc()
        .startAngle((d) => d.x0)
        .endAngle((d) => d.x1)
        .innerRadius((d) => Math.max(0, d.y0))
        .outerRadius((d) => Math.max(0, d.y1));

      // 中心文字
      g.append('circle')
        .attr('r', centerRadius)
        .attr('fill', '#fff')
        .attr('stroke', '#e2e8f0')
        .attr('stroke-width', 2);

      g.append('text')
        .attr('text-anchor', 'middle')
        .attr('dy', '-0.1em')
        .style('font-size', '24px')
        .style('font-weight', '700')
        .style('fill', '#1a1a2e')
        .text('🍜');

      g.append('text')
        .attr('text-anchor', 'middle')
        .attr('dy', '1.2em')
        .style('font-size', '16px')
        .style('font-weight', '600')
        .style('fill', '#1a1a2e')
        .text('台灣味');

      // 中心顯示區域（用於 hover 顯示）
      const centerText = g
        .append('text')
        .attr('text-anchor', 'middle')
        .attr('dy', '2.8em')
        .style('font-size', '12px')
        .style('fill', '#64748b')
        .style('opacity', 0);

      // 繪製扇形
      const path = g
        .selectAll('path')
        .data(root.descendants().slice(1))
        .enter()
        .append('path')
        .attr('d', arc)
        .attr('fill', (d) => {
          if (d.depth === 1) {
            return groupColors[d.data.name] || '#94a3b8';
          } else {
            const parent = d.parent;
            const color = groupColors[parent.data.name] || '#94a3b8';
            return d3.color(color).brighter(0.3);
          }
        })
        .attr('stroke', '#fff')
        .attr('stroke-width', 1)
        .style('cursor', (d) =>
          d.depth === 2 && d.data.url ? 'pointer' : 'default',
        )
        .style('opacity', 0.9);

      // 交互效果
      path
        .on('mouseenter', function (event, d) {
          d3.select(this).style('opacity', 1).attr('stroke-width', 2);

          if (d.data.desc) {
            centerText
              .text(d.data.desc)
              .style('opacity', 1)
              .transition()
              .duration(200)
              .style('opacity', 0.8);
          }
        })
        .on('mouseleave', function (event, d) {
          d3.select(this).style('opacity', 0.9).attr('stroke-width', 1);

          centerText.transition().duration(200).style('opacity', 0);
        })
        .on('click', function (event, d) {
          if (d.depth === 2 && d.data.url) {
            window.location.href = d.data.url;
          }
        });

      // 添加文字標籤（僅第一層）
      const text = g
        .selectAll('text.category-label')
        .data(root.children)
        .enter()
        .append('text')
        .attr('class', 'category-label')
        .attr('transform', function (d) {
          const angle = (((d.x0 + d.x1) / 2) * 180) / Math.PI;
          const radius = (d.y0 + d.y1) / 2;
          return `rotate(${angle - 90}) translate(${radius},0) rotate(${angle < 180 ? 0 : 180})`;
        })
        .attr('dy', '0.35em')
        .style('text-anchor', function (d) {
          const angle = (d.x0 + d.x1) / 2;
          return angle < Math.PI ? 'start' : 'end';
        })
        .style('font-size', '12px')
        .style('font-weight', '600')
        .style('fill', '#1a1a2e')
        .text((d) => d.data.name);
    }

    // 渲染 Force-Directed Graph
    function renderNetwork() {
      const container = document.getElementById('networkViz');
      container.innerHTML = '';

      const width = 800;
      const height = 500;

      const svg = d3
        .select(container)
        .append('svg')
        .attr('viewBox', `0 0 ${width} ${height}`)
        .attr('width', '100%')
        .attr('height', 'auto');

      // 支援縮放和拖移
      const zoom = d3
        .zoom()
        .scaleExtent([0.5, 3])
        .on('zoom', function (event) {
          g.attr('transform', event.transform);
        });

      svg.call(zoom);

      const g = svg.append('g');

      // 準備數據
      const nodes = networkData.nodes.map((d) => ({ ...d }));
      const links = networkData.links.map((d) => ({ ...d }));

      // 力導向模擬
      const simulation = d3
        .forceSimulation(nodes)
        .force(
          'link',
          d3
            .forceLink(links)
            .id((d) => d.id)
            .distance((d) => 80 / d.strength),
        )
        .force('charge', d3.forceManyBody().strength(-200))
        .force('center', d3.forceCenter(width / 2, height / 2))
        .force('collision', d3.forceCollide().radius(30));

      // 繪製連線
      const link = g
        .append('g')
        .attr('stroke', '#999')
        .attr('stroke-opacity', 0.3)
        .selectAll('line')
        .data(links)
        .join('line')
        .attr('stroke-width', (d) => Math.sqrt(d.strength * 3));

      // 繪製節點
      const node = g
        .append('g')
        .selectAll('circle')
        .data(nodes)
        .join('circle')
        .attr('r', (d) => {
          const degree = links.filter(
            (l) => l.source.id === d.id || l.target.id === d.id,
          ).length;
          return Math.max(8, Math.sqrt(degree) * 4);
        })
        .attr('fill', (d) => groupColors[d.group] || '#94a3b8')
        .attr('stroke', '#fff')
        .attr('stroke-width', 2)
        .style('cursor', 'pointer')
        .call(drag(simulation));

      // 節點標籤
      const label = g
        .append('g')
        .selectAll('text')
        .data(nodes)
        .join('text')
        .text((d) => d.id)
        .style('font-size', '11px')
        .style('font-weight', '500')
        .style('fill', '#1a1a2e')
        .attr('text-anchor', 'middle')
        .attr('dy', '0.35em')
        .style('pointer-events', 'none');

      // 拖拽功能
      function drag(simulation) {
        function dragstarted(event) {
          if (!event.active) simulation.alphaTarget(0.3).restart();
          event.subject.fx = event.subject.x;
          event.subject.fy = event.subject.y;
        }

        function dragged(event) {
          event.subject.fx = event.x;
          event.subject.fy = event.y;
        }

        function dragended(event) {
          if (!event.active) simulation.alphaTarget(0);
          event.subject.fx = null;
          event.subject.fy = null;
        }

        return d3
          .drag()
          .on('start', dragstarted)
          .on('drag', dragged)
          .on('end', dragended);
      }

      // 交互效果
      node
        .on('mouseenter', function (event, d) {
          // 高亮相關節點和連線
          const connectedNodes = new Set([d.id]);
          const connectedLinks = links.filter(
            (l) => l.source.id === d.id || l.target.id === d.id,
          );

          connectedLinks.forEach((l) => {
            connectedNodes.add(l.source.id);
            connectedNodes.add(l.target.id);
          });

          // 淡化其他元素
          node.style('opacity', (n) => (connectedNodes.has(n.id) ? 1 : 0.1));
          link.style('opacity', (l) =>
            l.source.id === d.id || l.target.id === d.id ? 0.8 : 0.05,
          );
          label.style('opacity', (n) => (connectedNodes.has(n.id) ? 1 : 0.2));
        })
        .on('mouseleave', function () {
          // 恢復所有元素
          node.style('opacity', 1);
          link.style('opacity', 0.3);
          label.style('opacity', 1);
        })
        .on('click', function (event, d) {
          if (d.url) {
            window.location.href = d.url;
          }
        });

      // 更新位置
      simulation.on('tick', () => {
        link
          .attr('x1', (d) => d.source.x)
          .attr('y1', (d) => d.source.y)
          .attr('x2', (d) => d.target.x)
          .attr('y2', (d) => d.target.y);

        node.attr('cx', (d) => d.x).attr('cy', (d) => d.y);

        label.attr('x', (d) => d.x).attr('y', (d) => d.y);
      });
    }

    // 初始化
    createLegend();
    renderSunburst();
  });
</script>

<!--
  2026-04-27 sticky sidebar highlight：當使用者捲動到某個 subcategory 區塊
  （如「音樂與表演」「政治人物」），左側 sticky 主題側邊欄對應連結加 .active
  class。是 page-scoped <style> 規則（不是 Tailwind 變體）負責視覺效果。
  is:inline = 不被 Vite 處理，避免 TS/HMR 路徑出錯導致 IIFE 不執行。
-->
<script is:inline>
  (function () {
    function init() {
      var links = document.querySelectorAll('.subcat-nav-link[data-sub-link]');
      if (!links.length) return;
      var sections = [];
      for (var i = 0; i < links.length; i++) {
        var name = links[i].dataset.subLink;
        var el = name ? document.getElementById('sub-' + name) : null;
        if (el) sections.push(el);
      }
      if (!sections.length) return;
      function setActive(name) {
        for (var j = 0; j < links.length; j++) {
          links[j].classList.toggle(
            'active',
            links[j].dataset.subLink === name,
          );
        }
      }
      var observer = new IntersectionObserver(
        function (entries) {
          var intersecting = entries.filter(function (e) {
            return e.isIntersecting;
          });
          if (!intersecting.length) return;
          // pick the section closest to the top of the trigger zone
          var top = intersecting.reduce(function (best, e) {
            return e.boundingClientRect.top < best.boundingClientRect.top
              ? e
              : best;
          });
          var id = top.target.id; // 'sub-XXX'
          if (id.indexOf('sub-') === 0) setActive(id.slice(4));
        },
        {
          // 觸發區 = viewport 上 1/4（從頂端 -10% 到底部 -65%）
          rootMargin: '-10% 0px -65% 0px',
          threshold: 0,
        },
      );
      sections.forEach(function (s) {
        observer.observe(s);
      });
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>
