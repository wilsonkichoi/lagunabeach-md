<script define:vars={{ taiexData, cpiData, salaryData, housingData, isEconomy }}
>
  function init() {
    document.addEventListener('DOMContentLoaded', () => {
      const chartConfigs = {
        taiex: {
          data: taiexData,
          color: '#dc2626',
          yKey: 'close',
          label: '加權指數',
          format: (v) => v.toLocaleString() + ' 點',
        },
        cpi: {
          data: cpiData,
          color: '#2563eb',
          yKey: 'value',
          label: 'CPI',
          format: (v) => v.toFixed(1),
        },
        salary: {
          data: salaryData,
          color: '#059669',
          yKey: 'value',
          label: '月薪',
          format: (v) => 'NT$ ' + v.toLocaleString(),
        },
        housing: {
          data: housingData,
          color: '#7c3aed',
          yKey: 'value',
          label: '房價指數',
          format: (v) => v.toFixed(1),
        },
      };

      document.querySelectorAll('.econ-chart-wrapper').forEach((wrapper) => {
        const chartType = wrapper.dataset.chart;
        const config = chartConfigs[chartType];
        if (!config || !config.data || config.data.length === 0) return;

        const svg = wrapper.querySelector('.econ-chart-svg');
        const tooltip = wrapper.querySelector('.econ-chart-tooltip');
        const data = config.data;
        const ns = 'http://www.w3.org/2000/svg';

        const W = 800,
          H = 300;
        const pad = { top: 30, right: 20, bottom: 40, left: 65 };
        const cw = W - pad.left - pad.right;
        const ch = H - pad.top - pad.bottom;

        const years = data.map((d) => d.year);
        const values = data.map((d) => d[config.yKey]);
        const minY = Math.min(...values) * 0.9;
        const maxY = Math.max(...values) * 1.1;

        const xScale = (year) =>
          pad.left +
          ((year - years[0]) / (years[years.length - 1] - years[0])) * cw;
        const yScale = (val) =>
          pad.top + ch - ((val - minY) / (maxY - minY)) * ch;

        // Grid lines
        const gridCount = 5;
        for (let i = 0; i <= gridCount; i++) {
          const yVal = minY + (maxY - minY) * (i / gridCount);
          const y = yScale(yVal);
          const line = document.createElementNS(ns, 'line');
          line.setAttribute('x1', pad.left);
          line.setAttribute('x2', W - pad.right);
          line.setAttribute('y1', y);
          line.setAttribute('y2', y);
          line.setAttribute('stroke', '#e2e8f0');
          line.setAttribute('stroke-width', '1');
          svg.appendChild(line);
          const label = document.createElementNS(ns, 'text');
          label.setAttribute('x', pad.left - 8);
          label.setAttribute('y', y + 4);
          label.setAttribute('text-anchor', 'end');
          label.setAttribute('fill', '#94a3b8');
          label.setAttribute('font-size', '10');
          label.textContent =
            chartType === 'salary'
              ? Math.round(yVal / 1000) + 'K'
              : chartType === 'taiex'
                ? Math.round(yVal).toLocaleString()
                : yVal.toFixed(0);
          svg.appendChild(label);
        }

        // X axis labels
        const yearStep = Math.max(1, Math.floor(years.length / 8));
        for (let i = 0; i < years.length; i += yearStep) {
          const x = xScale(years[i]);
          const label = document.createElementNS(ns, 'text');
          label.setAttribute('x', x);
          label.setAttribute('y', H - 8);
          label.setAttribute('text-anchor', 'middle');
          label.setAttribute('fill', '#94a3b8');
          label.setAttribute('font-size', '10');
          label.textContent = years[i];
          svg.appendChild(label);
        }

        // Area fill
        let areaPath = `M ${xScale(years[0])} ${yScale(values[0])}`;
        for (let i = 1; i < data.length; i++) {
          areaPath += ` L ${xScale(years[i])} ${yScale(values[i])}`;
        }
        areaPath += ` L ${xScale(years[years.length - 1])} ${pad.top + ch} L ${xScale(years[0])} ${pad.top + ch} Z`;
        const area = document.createElementNS(ns, 'path');
        area.setAttribute('d', areaPath);
        area.setAttribute('fill', config.color);
        area.setAttribute('opacity', '0.08');
        svg.appendChild(area);

        // Line
        let linePath = `M ${xScale(years[0])} ${yScale(values[0])}`;
        for (let i = 1; i < data.length; i++) {
          linePath += ` L ${xScale(years[i])} ${yScale(values[i])}`;
        }
        const line = document.createElementNS(ns, 'path');
        line.setAttribute('d', linePath);
        line.setAttribute('fill', 'none');
        line.setAttribute('stroke', config.color);
        line.setAttribute('stroke-width', '2.5');
        line.setAttribute('stroke-linejoin', 'round');
        svg.appendChild(line);

        // Milestones & interactive dots
        data.forEach((d, i) => {
          const x = xScale(d.year);
          const y = yScale(d[config.yKey]);

          if (d.milestone) {
            const dot = document.createElementNS(ns, 'circle');
            dot.setAttribute('cx', x);
            dot.setAttribute('cy', y);
            dot.setAttribute('r', '5');
            dot.setAttribute('fill', config.color);
            dot.setAttribute('stroke', 'white');
            dot.setAttribute('stroke-width', '2');
            dot.setAttribute('class', 'econ-milestone-dot');
            svg.appendChild(dot);
            const mlabel = document.createElementNS(ns, 'text');
            mlabel.setAttribute('x', x);
            mlabel.setAttribute('y', y - 12);
            mlabel.setAttribute('class', 'econ-milestone-label');
            mlabel.textContent = d.milestone;
            svg.appendChild(mlabel);
          }

          // Invisible hover area
          const hover = document.createElementNS(ns, 'rect');
          const barW = cw / data.length;
          hover.setAttribute('x', x - barW / 2);
          hover.setAttribute('y', pad.top);
          hover.setAttribute('width', barW);
          hover.setAttribute('height', ch);
          hover.setAttribute('fill', 'transparent');
          hover.setAttribute('cursor', 'crosshair');

          hover.addEventListener('mouseenter', () => {
            tooltip.style.display = 'block';
            tooltip.innerHTML = `<strong>${d.year}</strong>　${config.label}：${config.format(d[config.yKey])}`;
          });
          hover.addEventListener('mousemove', (e) => {
            const rect = wrapper
              .querySelector('.econ-chart-svg-wrap')
              .getBoundingClientRect();
            tooltip.style.left = e.clientX - rect.left + 'px';
            tooltip.style.top = e.clientY - rect.top + 'px';
          });
          hover.addEventListener('mouseleave', () => {
            tooltip.style.display = 'none';
          });
          svg.appendChild(hover);
        });
      });
    });
  }

  if (isEconomy) init();
</script>

