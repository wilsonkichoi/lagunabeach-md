---
/**
 * category-hub.template.astro — 統一 [category]/index.astro template (6 langs 共用)
 *
 * 為什麼：6 個 [category]/index.astro 從 943~3006 行（總 ~9280 行）高度重複，
 * 各 lang copy-paste 了相同 hub layout / top picks / subcategory grouping 邏輯。
 * unification 預估 -82% 行數 + 消除 6 處改一個 pattern 的維護負擔。
 *
 * 對照 article.template.astro：
 *   src/pages/[category]/index.astro                  → thin wrapper getStaticPaths
 *   src/pages/{lang}/[category]/index.astro × 5       → thin wrappers
 *   src/templates/category-hub.template.astro (本檔)  → 全部 UI 邏輯
 *
 * 中文 zh-TW 是 SSOT canonical（含 Economy 特殊 dashboard 等 zh-only feature，
 * 條件 render 在 lang === 'zh-TW' && category === 'economy' 時才 load）。
 *
 * 2026-05-03 sleepy-colden P1 follow-up unification（在 article.template.astro 之後）。
 */
import { resolve, join } from 'path';
import { marked } from 'marked';
import Layout from '../layouts/Layout.astro';
import { useTranslations } from '../i18n/utils';
import {
  categoryList as categories,
  getCategoryConfigs,
  type CategoryKey,
} from '../utils/categoryConfig';
import type { Lang } from '../config/languages';

interface ArticleSummary {
  slug: string;
  title: string;
  description: string;
  status: string;
  readingTime: number | null;
  date: string | null;
  featured: boolean;
  tags: string[];
  lang: string;
  image: string | null;
  imageAlt: string;
  imageCredit: string;
  subcategory: string;
  footnotes: number;
}

interface Props {
  category: string;
  hubContent: string;
  topPicks: ArticleSummary[];
  articles: ArticleSummary[];
  lang: Lang;
}

const { category, hubContent, articles, topPicks, lang } = Astro.props;

// ── Lang-derived URL prefix (for cross-page links) ────────────────────────────
// zh-TW: '' (root URL convention)
// non-zh: '/{lang}' prefix
const langUrlPrefix = lang === 'zh-TW' ? '' : `/${lang}`;

// Compute unique tags for filter
const allTagsSet = new Set();
articles.forEach((a: any) => {
  if (a.tags) a.tags.forEach((t: string) => allTagsSet.add(t));
});
const uniqueTags = [...allTagsSet].sort().slice(0, 12) as string[];

// Load economic data for economy category
let taiexData: any[] = [];
let cpiData: any[] = [];
let salaryData: any[] = [];
let housingData: any[] = [];
// Economy dashboard 只在 zh-TW 顯示（Economy 系列數據是 zh-only feature；
// 其他 lang 沒對應翻譯資料源）。其他 lang 看到一般 hub markdown。
if (category === 'economy' && lang === 'zh-TW') {
  const [taiexJson, cpiJson, salaryJson, housingJson] = await Promise.all([
    import('../data/taiex-yearly.json'),
    import('../data/taiwan-cpi.json'),
    import('../data/taiwan-salary.json'),
    import('../data/taiwan-housing.json'),
  ]);
  taiexData = taiexJson.data;
  cpiData = cpiJson.data;
  salaryData = salaryJson.data;
  housingData = housingJson.data;
}

function resolveWikilinks(md: string, currentCategory: string) {
  if (!md) return md;

  function resolveOne(target: string, display?: string, bold = false) {
    const label = display || target;
    if (target.startsWith('_')) {
      const catName = target
        .replace(/^_/, '')
        .replace(/ Hub$/, '')
        .toLowerCase();
      return bold
        ? `<a class="topic-pill" href="${langUrlPrefix}/${catName}"><strong>${label}</strong></a>`
        : `<a class="topic-pill" href="${langUrlPrefix}/${catName}">${label}</a>`;
    }
    const matchArticle = articles.find(
      (a: any) =>
        a.title === target ||
        a.slug === target ||
        a.slug === encodeURIComponent(target),
    );
    if (matchArticle) {
      const url = `/${currentCategory}/${matchArticle.slug}`;
      return bold
        ? `<a class="topic-pill" href="${url}"><strong>${label}</strong></a>`
        : `<a class="topic-pill" href="${url}">${label}</a>`;
    }
    return bold ? `**${label}**` : label;
  }

  // First pass: **[[X]]** → [**resolved**](/url) (bold inside link for marked CJK compat)
  md = md.replace(
    /\*\*\[\[([^\]|]+?)(?:\|([^\]]+?))?\]\]\*\*/g,
    (_, target, display) => resolveOne(target, display, true),
  );
  // Second pass: remaining [[X]]
  md = md.replace(/\[\[([^\]|]+?)(?:\|([^\]]+?))?\]\]/g, (_, target, display) =>
    resolveOne(target, display),
  );
  return md;
}

const resolvedContent = hubContent
  ? resolveWikilinks(hubContent, category)
  : '';

// Build set of article URLs for topic-pill detection
const articleUrlSet = new Set(
  articles.map((a: any) => `/${category}/${a.slug}`),
);
// Also add cross-category hub URLs
const categoryKeys = Object.keys({
  history: 1,
  geography: 1,
  culture: 1,
  food: 1,
  art: 1,
  music: 1,
  technology: 1,
  nature: 1,
  people: 1,
  society: 1,
  economy: 1,
  lifestyle: 1,
});

// Broken image fallback + topic-pill link for hub pages
const hubRenderer = new marked.Renderer();
hubRenderer.image = ({ href, title, text }) => {
  const titleAttr = title ? ` title="${title}"` : '';
  const altText = text || '';
  return `<img src="${href}" alt="${altText}"${titleAttr} loading="lazy" onerror="this.onerror=null;this.classList.add('img-broken')" />`;
};
hubRenderer.link = ({ href, title, text }) => {
  const titleAttr = title ? ` title="${title}"` : '';
  const h = href || '';
  // Check if link points to an article or a hub category page
  const isArticleLink = articleUrlSet.has(decodeURIComponent(h));
  const isCategoryLink = categoryKeys.some(
    (k) => h === `/${k}` || h === `/${k}/`,
  );
  if (isArticleLink || isCategoryLink) {
    return `<a class="topic-pill" href="${h}"${titleAttr}>${text}</a>`;
  }
  return `<a href="${h}"${titleAttr}>${text}</a>`;
};
const rawHubHtml = resolvedContent
  ? marked.parse(resolvedContent, { renderer: hubRenderer, breaks: true })
  : '';

// Post-process: add callout/pull-quote classes to blockquotes
function enrichBlockquotes(html: string): string {
  if (!html) return html;
  const calloutMap: Record<string, string> = {
    '📝': 'callout-note',
    '⚠️': 'callout-warning',
    '💡': 'callout-tip',
    '📊': 'callout-data',
  };
  return (html as string).replace(
    /<blockquote>([\s\S]*?)<\/blockquote>/g,
    (match, inner) => {
      // Pull quote: contains ✦
      if (inner.includes('✦')) {
        return `<blockquote class="pull-quote">${inner}</blockquote>`;
      }
      // Callout: starts with emoji + bold
      for (const [emoji, cls] of Object.entries(calloutMap)) {
        if (inner.includes(emoji) && inner.includes('<strong>')) {
          return `<blockquote class="${cls}">${inner}</blockquote>`;
        }
      }
      return match;
    },
  );
}
const hubHtml = enrichBlockquotes(rawHubHtml as string);

// Split hub HTML into hook (first 2-3 paragraphs, no headings) and full essay
let hubHook = '';
let hubFull = hubHtml;
if (hubHtml) {
  // Strip leading headings (h1, h2) from the beginning
  let stripped = (hubHtml as string)
    .replace(/^(\s*<h[12][^>]*>[\s\S]*?<\/h[12]>\s*)+/i, '')
    .trim();
  // Find the end of the 3rd </p> tag
  let cutIndex = -1;
  let pCount = 0;
  const pCloseRegex = /<\/p>/gi;
  let match;
  while ((match = pCloseRegex.exec(stripped)) !== null) {
    pCount++;
    if (pCount === 3) {
      cutIndex = match.index + match[0].length;
      break;
    }
  }
  if (cutIndex > 0 && cutIndex < stripped.length * 0.7) {
    hubHook = stripped.slice(0, cutIndex);
    hubFull = hubHtml;
  }
}

// Split hub HTML into sections at <h2> boundaries for chart injection (economy only)
const isEconomy = category === 'economy' && lang === 'zh-TW';
type HubSection = { html: string; chartAfter?: string };
let hubSections: HubSection[] = [];
if (isEconomy && hubHtml) {
  const parts = (hubHtml as string).split(/(?=<h2>)/);
  hubSections = parts.map((part) => {
    let chartAfter: string | undefined;
    if (part.includes('從零到英雄')) chartAfter = 'cpi';
    else if (part.includes('矽島的誕生')) chartAfter = 'taiex';
    else if (part.includes('服務經濟')) chartAfter = 'salary';
    else if (part.includes('面向未來')) chartAfter = 'housing';
    return { html: part, chartAfter };
  });
}

// Group articles by subcategory
const subcategoryGroups: { name: string; articles: any[] }[] = [];
const subcatMap = new Map<string, any[]>();
for (const article of articles) {
  const sub = (article as any).subcategory || '其他';
  if (!subcatMap.has(sub)) subcatMap.set(sub, []);
  subcatMap.get(sub)!.push(article);
}
// Sort: named subcategories first (alphabetically), then "其他" last
for (const [name, arts] of [...subcatMap.entries()].sort((a, b) => {
  if (a[0] === '其他') return 1;
  if (b[0] === '其他') return -1;
  return a[0].localeCompare(b[0]);
})) {
  subcategoryGroups.push({ name, articles: arts });
}

// lang 已從 props 取得，不再從 URL derive
const t = useTranslations(lang);

const categoryConfigs = getCategoryConfigs(t);
const categoryInfo = categoryConfigs[category];

// 其他分類（sidebar 跨分類導航用）
const otherCategories = categories
  .filter((cat) => cat !== category)
  .map((cat) => ({
    key: cat,
    ...categoryConfigs[cat as CategoryKey],
  }));
---

<Layout
  title={`${categoryInfo.name} - Taiwan.md`}
  description={`${categoryInfo.description} - 台灣知識庫`}
  category={categoryInfo.name}
>
  <!--
    Phase 6 partial migration — [category]/index.astro (zh-TW)
    ──────────────────────────────────────────────────────────
    Same wrapper migration as en/ja [category]/index. zh-TW adds
    two extra conditional sections beyond what en/ja have:
    (1) Food visualization (when category === 'food') — sunburst
        + network d3 viz, keeps all .food-viz / .viz-* classes in
        the scoped <style> because they repeat and are animated
        by script/index.astro's d3 code.
    (2) Economy hub with inline charts (when isEconomy) — uses
        .econ-chart-* classes rendered inline around hubSections,
        also kept fully scoped.
  -->
  <main class="category-page">
    <!-- Category Header (compact bar + curatorial hook fused) -->
    <div
      class="bg-[var(--categoryColorLight)] pb-5 pt-3"
      style={`border-bottom: 2px solid ${categoryInfo.color};`}
    >
      <div class="mx-auto max-w-[1200px] px-8 max-[768px]:px-4">
        <nav
          class="mb-1 flex items-center gap-2 text-[0.9rem] [&>a:hover]:underline [&>a]:font-medium [&>a]:no-underline"
        >
          <a
            href={langUrlPrefix === '' ? '/' : langUrlPrefix}
            style={`color: ${categoryInfo.color};`}>{t('article.home')}</a
          >
          <span class="text-[#9ca3af]">›</span>
          <span class="font-semibold text-[#6b7280]">{categoryInfo.name}</span>
        </nav>
        <div class="flex flex-wrap items-baseline gap-2">
          <span class="text-[1.5rem]">{categoryInfo.icon}</span>
          <h1
            class="m-0 text-[1.5rem] font-extrabold"
            style={`color: ${categoryInfo.color}`}
          >
            {categoryInfo.name}
          </h1>
          <span class="font-light text-[#94a3b8] max-[768px]:hidden">·</span>
          <span
            class="max-w-[50%] truncate text-[0.88rem] text-[#64748b] max-[768px]:hidden"
            >{categoryInfo.description}</span
          >
          <span
            class="ml-auto rounded-[12px] bg-[#f1f5f9] px-2 py-[0.15rem] text-[0.78rem] text-[#94a3b8]"
            >{
              t('category.articleCount').replace('{n}', String(articles.length))
            }</span
          >
        </div>
        {
          hubHook && (
            <div class="mt-3 max-w-[800px] text-[0.92rem] leading-[1.75] text-[#475569] max-[768px]:text-[0.85rem]">
              <div class="header-hook-prose" set:html={hubHook} />
              <a
                href="#hub-essay"
                class="mt-2 inline-block text-[0.82rem] font-semibold text-[var(--categoryColor)] no-underline transition-all duration-150 hover:underline"
              >
                {t('category.readGuide')}
              </a>
            </div>
          )
        }
      </div>
    </div>

    <div
      class="mx-auto max-w-[1200px] px-8 py-8 max-[768px]:px-4 max-[768px]:py-4"
    >
      {
        /* Main two-column layout: sidebar + content
           Sticky aside must keep content-height (`self-start` / `h-fit`) so
           the parent flex (= taller article column) provides the scroll
           context. Items-start on parent enforces that. */
      }
      {
        articles.length > 0 ? (
          <div class="mt-4 flex items-start gap-8 max-[768px]:flex-col max-[768px]:gap-0">
            <aside class="sticky top-[72px] w-[180px] flex-shrink-0 self-start max-[768px]:static max-[768px]:w-full max-[768px]:max-h-none max-[768px]:overflow-visible">
              {/* Subcategory nav */}
              {subcategoryGroups.length > 1 && (
                <nav class="flex flex-col gap-1 max-[768px]:flex-row max-[768px]:flex-wrap max-[768px]:gap-[0.3rem] max-[768px]:border-b max-[768px]:border-[#e2e8f0] max-[768px]:pb-4 max-[768px]:mb-4">
                  <span class="mb-[0.3rem] border-b border-[#e2e8f0] px-2 pb-[0.4rem] text-[0.7rem] font-bold uppercase tracking-[0.1em] text-[#94a3b8] max-[768px]:hidden">
                    {t('category.topic')}
                  </span>
                  {subcategoryGroups.map((group) => (
                    <a
                      href={`#sub-${group.name}`}
                      data-sub-link={group.name}
                      class="subcat-nav-link flex items-center justify-between rounded border-l-2 border-transparent px-2 py-[0.35rem] text-[0.82rem] text-[#475569] no-underline transition-all duration-150 hover:bg-[rgba(45,80,22,0.06)] hover:text-[var(--categoryColor,#2d5016)] max-[768px]:rounded-2xl max-[768px]:border max-[768px]:border-[#e2e8f0] max-[768px]:bg-[#f8fafc] max-[768px]:px-[0.6rem] max-[768px]:py-1 max-[768px]:text-[0.78rem]"
                    >
                      {group.name}
                      <span class="min-w-[1.2rem] rounded-lg bg-[#f1f5f9] px-[0.35rem] py-[0.1rem] text-center text-[0.7rem] text-[#94a3b8]">
                        {group.articles.length}
                      </span>
                    </a>
                  ))}
                </nav>
              )}

              {/* Cross-category nav (replaces bottom explore cards) */}
              <div class="my-3 h-px bg-[#e2e8f0] max-[768px]:hidden" />
              <nav class="flex flex-col gap-1 max-[768px]:hidden">
                <span class="mb-[0.3rem] border-b border-[#e2e8f0] px-2 pb-[0.4rem] text-[0.7rem] font-bold uppercase tracking-[0.1em] text-[#94a3b8]">
                  {t('category.otherTopics')}
                </span>
                {otherCategories.map((cat) => (
                  <a
                    href={`${langUrlPrefix}/${cat.key}`}
                    class="flex items-center justify-between rounded px-2 py-[0.35rem] text-[0.78rem] text-[#475569] no-underline opacity-75 transition-all duration-150 hover:bg-[rgba(45,80,22,0.06)] hover:text-[var(--categoryColor,#2d5016)] hover:opacity-100"
                  >
                    <span>
                      {cat.icon} {cat.name}
                    </span>
                  </a>
                ))}
              </nav>
            </aside>

            <div class="min-w-0 flex-1">
              {/* Featured Picks (horizontal chips) */}
              {topPicks && topPicks.length > 0 && (
                <div class="mb-4 flex flex-wrap items-center gap-2 border-b border-[#e2e8f0] pb-3 max-[768px]:flex-nowrap max-[768px]:overflow-x-auto max-[768px]:pb-2 max-[768px]:[-webkit-overflow-scrolling:touch]">
                  <span class="flex-shrink-0 text-[0.72rem] font-bold uppercase tracking-[0.08em] text-[var(--categoryColor)]">
                    {t('category.featured')}
                  </span>
                  {topPicks.slice(0, 3).map((article: any) => (
                    <a
                      href={`${langUrlPrefix}/${category}/${encodeURIComponent(article.slug)}`}
                      class="whitespace-nowrap rounded-2xl border border-transparent bg-[var(--categoryColorLight)] px-[0.6rem] py-[0.2rem] text-[0.82rem] font-semibold text-[var(--categoryColor)] no-underline transition-all duration-150 hover:border-[var(--categoryColor)] hover:bg-white"
                    >
                      ★ {article.title}
                    </a>
                  ))}
                </div>
              )}

              {/* Articles list */}
              <div class="articles-main min-w-0 flex-1" id="articlesGrid">
                <div class="mb-4">
                  <input
                    type="text"
                    class="w-full max-w-[320px] rounded-md border border-[#e2e8f0] px-3 py-[0.45rem] text-[0.85rem] outline-none transition-colors duration-200 focus:border-[var(--categoryColor,#2d5016)] focus:shadow-[0_0_0_2px_rgba(45,80,22,0.08)]"
                    id="articleFilter"
                    placeholder={t('category.searchPlaceholder')}
                    autocomplete="off"
                  />
                </div>

                {subcategoryGroups.map((group) => (
                  <div class="subcategory-section" id={`sub-${group.name}`}>
                    {subcategoryGroups.length > 1 && (
                      <h3 class="mb-2 mt-6 flex items-center gap-2 border-b-2 border-[var(--categoryColor,#e2e8f0)] pb-[0.4rem] text-[1rem] font-bold text-[#334155] [.subcategory-section:first-child_&]:mt-0">
                        {group.name}
                        <span class="text-[0.72rem] font-normal text-[#94a3b8]">
                          {group.articles.length}
                        </span>
                      </h3>
                    )}
                    <div class="flex flex-col">
                      {group.articles.map((article: any) => (
                        <a
                          href={`${langUrlPrefix}/${category}/${encodeURIComponent(article.slug)}`}
                          class={`article-row ${article.featured ? 'is-featured' : ''}`}
                          data-title={article.title}
                          data-date={article.date || ''}
                          data-reading={article.readingTime || 0}
                          data-featured={article.featured ? '1' : '0'}
                          data-tags={JSON.stringify(article.tags || [])}
                          data-subcategory={article.subcategory || ''}
                        >
                          <div class="row-main">
                            <div class="row-title-line">
                              {article.featured && (
                                <span class="row-star">★</span>
                              )}
                              <h3 class="row-title">{article.title}</h3>
                            </div>
                            {article.description && (
                              <p class="row-desc">
                                {article.description.length > 120
                                  ? article.description.slice(0, 117) + '...'
                                  : article.description}
                              </p>
                            )}
                          </div>
                          <div class="row-meta">
                            {(article.footnotes || 0) > 0 && (
                              <span class="row-fn">
                                {t('category.citations').replace(
                                  '{n}',
                                  String(article.footnotes),
                                )}
                              </span>
                            )}
                            {article.readingTime && (
                              <span class="row-time">
                                {article.readingTime} min
                              </span>
                            )}
                          </div>
                        </a>
                      ))}
                    </div>
                  </div>
                ))}

                <div
                  class="hidden p-8 text-center text-[#94a3b8]"
                  id="noResults"
                >
                  <p>{t('category.noResults')}</p>
                </div>
              </div>

              {/* Food Visualization */}
              {category === 'food' && (
                <section class="food-viz">
                  <div class="food-viz-inner">
                    <h2>🍜 探索台灣美食宇宙</h2>
                    <p class="food-viz-subtitle">
                      點擊扇區或節點，深入了解每一道台灣味
                    </p>
                    <div class="viz-tabs">
                      <button class="viz-tab active" data-viz="sunburst">
                        🎯 風味輪
                      </button>
                      <button class="viz-tab" data-viz="network">
                        🕸️ 關係圖
                      </button>
                    </div>
                    <div class="viz-container" id="sunburstViz" />
                    <div
                      class="viz-container"
                      id="networkViz"
                      style="display:none;"
                    />
                    <div class="viz-legend" id="vizLegend" />
                  </div>
                </section>
              )}

              {/* Full Hub Essay (not collapsed — the soul of Taiwan.md) */}
              {hubHtml && !isEconomy && (
                <section
                  class="my-8 mb-12 rounded-2xl border border-[#e2e8f0] bg-white p-10 shadow-[0_1px_3px_rgba(0,0,0,0.04)]"
                  id="hub-essay"
                >
                  <h2 class="mb-2 mt-12 border-t-2 border-[#e2e8f0] pt-8 text-[1.15rem] font-bold text-[#334155]">
                    {categoryInfo.icon} 策展導讀
                  </h2>
                  <div class="hub-prose" set:html={hubHtml} />
                </section>
              )}

              {/* Economy with charts */}
              {isEconomy && hubSections.length > 0 && (
                <section
                  class="my-8 mb-12 rounded-2xl border border-[#e2e8f0] bg-white p-10 shadow-[0_1px_3px_rgba(0,0,0,0.04)]"
                  id="hub-essay"
                >
                  <h2 class="mb-2 mt-12 border-t-2 border-[#e2e8f0] pt-8 text-[1.15rem] font-bold text-[#334155]">
                    {categoryInfo.icon} 策展導讀
                  </h2>
                  <div class="hub-prose">
                    {hubSections.map((section) => (
                      <Fragment>
                        <div set:html={section.html} />
                        {section.chartAfter && (
                          <div
                            class="econ-chart-wrapper"
                            data-chart={section.chartAfter}
                          >
                            <div class="econ-chart-container">
                              <div class="econ-chart-header">
                                <h4 class="econ-chart-title">
                                  {section.chartAfter === 'taiex' &&
                                    '📈 歷年台灣加權股價指數 (TAIEX)'}
                                  {section.chartAfter === 'cpi' &&
                                    '📊 歷年消費者物價指數 (CPI)'}
                                  {section.chartAfter === 'salary' &&
                                    '💰 歷年每月經常性薪資'}
                                  {section.chartAfter === 'housing' &&
                                    '🏠 信義房價指數'}
                                </h4>
                                <span class="econ-chart-source">
                                  {section.chartAfter === 'taiex' &&
                                    '資料來源：臺灣證券交易所'}
                                  {section.chartAfter === 'cpi' &&
                                    '資料來源：行政院主計總處'}
                                  {section.chartAfter === 'salary' &&
                                    '資料來源：行政院主計總處'}
                                  {section.chartAfter === 'housing' &&
                                    '資料來源：信義房屋'}
                                </span>
                              </div>
                              <div class="econ-chart-svg-wrap">
                                <svg
                                  class="econ-chart-svg"
                                  viewBox="0 0 800 300"
                                  preserveAspectRatio="xMidYMid meet"
                                />
                                <div class="econ-chart-tooltip" />
                              </div>
                            </div>
                          </div>
                        )}
                      </Fragment>
                    ))}
                  </div>
                </section>
              )}
            </div>
          </div>
        ) : (
