  function generateCategoryArticles() {
    const container = document.getElementById('articlesByCategory');
    const sidebarMarkers = markersForSidebar(markersData);

    // 按分類分組文章
    const articlesByCategory = {};
    sidebarMarkers.forEach((marker) => {
      const category = marker.category;
      if (!articlesByCategory[category]) {
        articlesByCategory[category] = [];
      }
      articlesByCategory[category].push(marker);
    });

    // 按分類文章數量排序
    const sortedCategories = Object.entries(articlesByCategory)
      .sort(([, a], [, b]) => b.length - a.length)
      .slice(0, 6); // 只顯示前6個分類，避免太長

    // T1.4 22 縣市 grid 在最上方
    const counties22HTML = render22CountiesGrid();

    container.innerHTML = counties22HTML + sortedCategories
      .map(
        ([category, articles]) => `
      <div class="category-group">
        <div class="category-group-header">
          <span class="article-category-dot" style="background: ${categoryColors[category] || '#16a34a'}"></span>
          <span class="category-group-title">${categoryNames[category] || category}</span>
          <span class="category-group-count">${articles.length}</span>
        </div>
        ${articles
          .slice(0, 4)
          .map(
            (article) => `
          <div class="sidebar-article-item article-card" data-link="${article.link}" data-title="${article.title}"
               data-desc="${article.desc}" data-category="${article.category}">
            <span class="article-card-dot" style="background: ${categoryColors[article.category] || '#16a34a'}"></span>
            <div class="article-card-body">
              <h4 class="article-card-title">${article.title}</h4>
              <p class="article-card-desc">${article.desc.substring(0, 60)}${article.desc.length > 60 ? '...' : ''}</p>
              <span class="article-card-meta">${categoryNames[article.category] || article.category}</span>
            </div>
          </div>
        `,
          )
          .join('')}
        ${articles.length > 4 ? `<div style="color:#999;font-size:0.8rem;margin:8px 0;">${i18n_moreArticles} ${articles.length - 4} ${i18n_moreArticlesSuffix}</div>` : ''}
      </div>
    `,
      )
      .join('');

    // 添加點擊事件
    container.querySelectorAll('.sidebar-article-item').forEach((item) => {
      item.addEventListener('click', () => {
        const link = item.getAttribute('data-link');
        window.open(link, '_blank');
      });
    });

    // T1.4 22 縣市 grid card 點擊 → 觸發同 polygon click 行為
    container.querySelectorAll('.county-grid-card').forEach((card) => {
      card.addEventListener('click', () => {
        const countyName = card.getAttribute('data-county-name');
        // 觸發對應 polygon 的 click，這樣同時 highlight 地圖跟開 sidebar
        const polygon = document.querySelector(
          `.county[data-county="${countyName}"]`,
        );
        if (polygon) {
          polygon.dispatchEvent(new MouseEvent('click', { bubbles: true }));
          // scroll map into view on mobile
          if (window.innerWidth <= 768) {
            document
              .querySelector('.map-panel')
              ?.scrollIntoView({ block: 'start', behavior: 'smooth' });
          }
        } else {
          // fallback: 開新分頁
          const data = counties22[countyName];
          if (data) window.open(data.link, '_blank', 'noopener');
