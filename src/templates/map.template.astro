</style>

<script src="https://cdn.jsdelivr.net/npm/d3@7/dist/d3.min.js"></script>
<script
  src="https://cdn.jsdelivr.net/npm/topojson-client@3/dist/topojson-client.min.js"
></script>

<script
  is:inline
  define:vars={{
    pageLang: lang,
    i18n_tooltipArticles: t('map.tooltip.county.articles'),
    i18n_tooltipClick: t('map.tooltip.county.click'),
    i18n_readingTime: t('map.tooltip.marker.reading-time'),
    i18n_noArticles: t('map.sidebar.county.no-articles'),
    i18n_moreArticles: t('map.sidebar.more-articles'),
    i18n_moreArticlesSuffix: t('map.sidebar.more-articles-suffix'),
    i18n_articlesCount: t('map.sidebar.county.articles-count'),
    categoryNames: {
      history: t('map.category.history'),
      geography: t('map.category.geography'),
      culture: t('map.category.culture'),
      food: t('map.category.food'),
      art: t('map.category.art'),
      music: t('map.category.music'),
      technology: t('map.category.technology'),
      nature: t('map.category.nature'),
      people: t('map.category.people'),
      society: t('map.category.society'),
      economy: t('map.category.economy'),
      lifestyle: t('map.category.lifestyle'),
    },
  }}
>
  const markersData = JSON.parse(
    document.getElementById('mapData').getAttribute('data-markers'),
  );
  const routesData = JSON.parse(
    document.getElementById('mapData').getAttribute('data-routes'),
  );
  const counties22 = JSON.parse(
    document.getElementById('mapData').getAttribute('data-counties22'),
  );

  // 縣市名稱別名（topojson 用 臺，knowledge/Geography 可能用 台）
  const COUNTY_ALIASES = {
    台北市: '臺北市',
    台中市: '臺中市',
    台南市: '臺南市',
    台東縣: '臺東縣',
  };
  function lookupCounty(name) {
    const canonical = COUNTY_ALIASES[name] || name;
    return counties22[canonical] || counties22[name] || null;
  }

  /** 側欄：僅顯示與目前頁面語系相同的 markers；若無則 fallback zh-TW */
  function markerLang(m) {
    return m.lang || 'zh-TW';
  }
  function markersForSidebar(all) {
    const want =
      pageLang === 'en' ||
      pageLang === 'ja' ||
      pageLang === 'ko' ||
      pageLang === 'zh-TW'
        ? pageLang
        : 'zh-TW';
    let list = all.filter((m) => markerLang(m) === want);
    if (list.length === 0) {
      list = all.filter((m) => markerLang(m) === 'zh-TW');
    }
    return list;
  }

  function localizePathForPage(href) {
    if (!href || href === '#') return href || '#';
    if (pageLang === 'zh-TW') return href;
    if (href.startsWith(`/${pageLang}/`)) return href;
    return `/${pageLang}${href}`;
  }

  const categoryColors = {
    history: '#e74c3c',
    geography: '#2ecc71',
    culture: '#9b59b6',
    food: '#f39c12',
    art: '#e91e63',
    music: '#00bcd4',
    technology: '#3498db',
    nature: '#27ae60',
    people: '#ff9800',
    society: '#607d8b',
    economy: '#ff5722',
    lifestyle: '#8bc34a',
  };

  let activeRegionFilter = 'all';
  let activeCategoryFilter = 'all';
  let mapZoom = null;
  let svgSelection = null;
  let activeRoute = null;

  async function drawTaiwanMap() {
    try {
      const response = await fetch(
        'https://cdn.jsdelivr.net/npm/taiwan-atlas@0.0.3/counties-10t.json',
      );
      const topology = await response.json();
      const geojson = topojson.feature(topology, topology.objects.counties);
      const projection = d3.geoMercator().fitSize([800, 1000], geojson);
      const pathGenerator = d3.geoPath().projection(projection);

      // 保存 projection 到全域（供路線使用）
      window._mapProjection = projection;

      // 縣市名對照
      const countyToRegion = {
        臺北市: 'north',
        新北市: 'north',
        基隆市: 'north',
        桃園市: 'north',
        新竹市: 'north',
        新竹縣: 'north',
        宜蘭縣: 'north',
        臺中市: 'central',
        彰化縣: 'central',
        南投縣: 'central',
        雲林縣: 'central',
        苗栗縣: 'central',
        嘉義市: 'south',
        嘉義縣: 'south',
        臺南市: 'south',
        高雄市: 'south',
        屏東縣: 'south',
        花蓮縣: 'east',
        臺東縣: 'east',
        澎湖縣: 'islands',
        金門縣: 'islands',
        連江縣: 'islands',
      };

      // 畫縣市 + 熱力圖
      const group = document.getElementById('taiwanCounties');
      geojson.features.forEach((feature) => {
        const path = document.createElementNS(
          'http://www.w3.org/2000/svg',
          'path',
        );
        const d = pathGenerator(feature);
        if (!d) return;
        path.setAttribute('d', d);
        path.setAttribute('class', 'county');

        // 計算該縣市的 marker 數
        const countyName = feature.properties.COUNTYNAME;
        const region = countyToRegion[countyName];
        const markerCount = markersData.filter(
          (m) => m.city && countyName.includes(m.city.replace('台', '臺')),
        ).length;

        // 熱力圖：marker 越多顏色越深
        const intensity = Math.min(markerCount / 15, 1); // 15 markers = 最深
        const green = Math.round(247 - intensity * 100);
        path.setAttribute(
          'fill',
          `rgb(${187 - intensity * 80}, ${green}, ${208 - intensity * 80})`,
        );

        path.setAttribute('stroke', '#4ade80');
        path.setAttribute('stroke-width', '0.8');
        path.setAttribute('data-county', countyName);
        path.setAttribute('data-count', markerCount);

        // Hover 效果（22 縣市深度文章升級版：顯示核心矛盾）
        path.addEventListener('mouseenter', () => {
          path.style.opacity = '0.8';
          path.style.cursor = 'pointer';
          const tooltip = document.getElementById('tooltip');
          const deepArticle = lookupCounty(countyName);
          tooltip.querySelector('.tooltip-title').textContent = countyName;
          if (deepArticle) {
            // 22 縣市深度文章：顯示核心矛盾
            tooltip.querySelector('.tooltip-category').textContent =
              '📖 ' + deepArticle.core_contradiction;
            tooltip.querySelector('.tooltip-desc').textContent =
              `${markerCount} ${i18n_tooltipArticles} · 點擊開啟深度文章`;
          } else {
            // fallback: 原始 marker 數字 tooltip
            tooltip.querySelector('.tooltip-category').textContent =
              `${markerCount} ${i18n_tooltipArticles}`;
            tooltip.querySelector('.tooltip-desc').textContent =
              i18n_tooltipClick;
          }
          tooltip.style.opacity = '1';
        });

        path.addEventListener('mouseleave', () => {
          path.style.opacity = '1';
          document.getElementById('tooltip').style.opacity = '0';
        });

        // Click 篩選該縣市
        path.addEventListener('click', () => {
          showCountyArticles(countyName, region);
        });

        group.appendChild(path);
      });

      // 動態產生 markers
      const markersGroup = document.getElementById('markers');
      markersData.forEach((m) => {
        const [x, y] = projection([m.lng, m.lat]);
        const circle = document.createElementNS(
          'http://www.w3.org/2000/svg',
          'circle',
        );
        circle.setAttribute('cx', String(x));
        circle.setAttribute('cy', String(y));
        circle.setAttribute('r', '5');
        circle.setAttribute('class', 'marker');
        circle.setAttribute('fill', categoryColors[m.category] || '#16a34a');
        circle.setAttribute('data-region', m.region);
        circle.setAttribute('data-category', m.category);
        circle.setAttribute('data-title', m.title);
        circle.setAttribute('data-link', m.link);
        circle.setAttribute('data-desc', m.desc);
        markersGroup.appendChild(circle);
      });

      // D3 zoom
      const svg = document.getElementById('taiwanMap');
      svgSelection = d3.select(svg);
      mapZoom = d3
        .zoom()
        .scaleExtent([1, 8])
        .on('zoom', (event) => {
          document
            .getElementById('zoomGroup')
            .setAttribute('transform', event.transform);
          const scale = event.transform.k;
          document.querySelectorAll('.marker').forEach((marker) => {
            const originalR = 5;
            marker.setAttribute('r', String(originalR / scale));
          });
          // 更新 clusters
          updateClusters(event.transform.k);
        });
      svgSelection.call(mapZoom);
    } catch (err) {
      console.warn('Taiwan TopoJSON 載入失敗，使用備用輪廓', err);
      const group = document.getElementById('taiwanCounties');
      const fallback = document.createElementNS(
        'http://www.w3.org/2000/svg',
        'path',
      );
      fallback.setAttribute(
        'd',
        'M400 100 C450 100, 480 130, 485 180 C490 220, 485 260, 480 300 C475 340, 470 380, 465 420 C460 460, 455 500, 450 540 C445 580, 440 620, 435 660 C430 700, 425 740, 415 780 C405 820, 390 850, 370 870 C350 890, 320 895, 290 890 C260 885, 230 875, 210 860 C190 845, 175 825, 165 800 C155 775, 150 745, 155 710 C160 675, 170 640, 175 605 C180 570, 175 535, 180 500 C185 465, 195 430, 205 395 C215 360, 225 325, 235 290 C245 255, 255 220, 270 190 C285 160, 310 135, 340 125 C370 115, 390 105, 400 100 Z',
      );
      fallback.setAttribute('fill', 'url(#taiwanGradient)');
      fallback.setAttribute('stroke', '#2d5016');
      fallback.setAttribute('stroke-width', '2');
      group.appendChild(fallback);
    }
  }

  function initMap() {
    const svg = document.getElementById('taiwanMap');
    const tooltip = document.getElementById('tooltip');
    const regionFilters = document.getElementById('regionFilters');
    const categoryFilters = document.getElementById('categoryFilters');

    // Marker hover tooltip
    const markerTooltip = document.getElementById('marker-tooltip');

    svg.addEventListener('mouseover', (e) => {
      const marker = e.target.closest('.marker');
      if (!marker) return;

      const title = marker.getAttribute('data-title');
      const category = marker.getAttribute('data-category');
      const desc = marker.getAttribute('data-desc');

      markerTooltip.querySelector('.tooltip-title').textContent = title;
      markerTooltip.querySelector('.tooltip-meta').textContent =
        `${categoryNames[category] || category} · ${Math.ceil(desc.length / 100)}${i18n_readingTime}`;
      markerTooltip.querySelector('.tooltip-desc').textContent =
        desc.substring(0, 80) + (desc.length > 80 ? '...' : '');
      markerTooltip.style.opacity = '1';
    });

    svg.addEventListener('mousemove', (e) => {
      const marker = e.target.closest('.marker');
      if (!marker) return;

      const rect = svg.getBoundingClientRect();
      markerTooltip.style.left = e.clientX - rect.left + 10 + 'px';
      markerTooltip.style.top = e.clientY - rect.top - 10 + 'px';
    });

    svg.addEventListener('mouseout', (e) => {
      const marker = e.target.closest('.marker');
      if (!marker) return;
      markerTooltip.style.opacity = '0';
    });

    // Marker click → 新分頁開啟文章
    svg.addEventListener('click', (e) => {
      const marker = e.target.closest('.marker');
      if (marker) {
        const link = marker.getAttribute('data-link');
        window.open(link, '_blank');
        return;
      }
    });

    // 舊的 tooltip for 縣市 hover
    svg.addEventListener('mouseover', (e) => {
      const county = e.target.closest('.county');
      if (!county) return;

      const countyName = county.getAttribute('data-county');
      const markerCount = county.getAttribute('data-count');

      tooltip.querySelector('.tooltip-title').textContent = countyName;
      tooltip.querySelector('.tooltip-category').textContent =
        `${markerCount} ${i18n_tooltipArticles}`;
      tooltip.querySelector('.tooltip-desc').textContent = i18n_tooltipClick;
      tooltip.style.opacity = '1';
    });

    svg.addEventListener('mousemove', (e) => {
      const county = e.target.closest('.county');
      if (!county) return;

      const rect = svg.getBoundingClientRect();
      tooltip.style.left = e.clientX - rect.left + 10 + 'px';
      tooltip.style.top = e.clientY - rect.top - 10 + 'px';
    });

    svg.addEventListener('mouseout', (e) => {
      const county = e.target.closest('.county');
      if (!county) return;
      tooltip.style.opacity = '0';
    });

    // Zoom buttons
    document.getElementById('zoomIn').addEventListener('click', () => {
      if (svgSelection && mapZoom) {
        svgSelection.transition().duration(300).call(mapZoom.scaleBy, 1.5);
      }
    });

    document.getElementById('zoomOut').addEventListener('click', () => {
      if (svgSelection && mapZoom) {
        svgSelection.transition().duration(300).call(mapZoom.scaleBy, 0.67);
      }
    });

    document.getElementById('resetZoom').addEventListener('click', () => {
      if (svgSelection && mapZoom) {
        svgSelection
          .transition()
          .duration(500)
          .call(mapZoom.transform, d3.zoomIdentity);
      }
    });

    // Region filter
    regionFilters.addEventListener('click', (e) => {
      if (!e.target.classList.contains('filter-btn')) return;
      regionFilters
        .querySelectorAll('.filter-btn')
        .forEach((btn) => btn.classList.remove('active'));
      e.target.classList.add('active');
      activeRegionFilter = e.target.getAttribute('data-filter');
      applyFilters();
      updateURL('region', activeRegionFilter);
    });

    // Category filter
    categoryFilters.addEventListener('click', (e) => {
      if (!e.target.classList.contains('filter-btn')) return;
      categoryFilters
        .querySelectorAll('.filter-btn')
        .forEach((btn) => btn.classList.remove('active'));
      e.target.classList.add('active');
      activeCategoryFilter = e.target.getAttribute('data-filter');
      applyFilters();
      updateURL('category', activeCategoryFilter);
    });

    // === Mirror filter chips（sidebar collapsible 版）===
    // 把 hidden #regionFilters / #categoryFilters 的 buttons clone 進 mirror containers，
    // 點 mirror 觸發 hidden 原版 click（避免重複 logic）。
    function setupFilterMirror(sourceId, mirrorId, stateKey) {
      const src = document.getElementById(sourceId);
      const mirror = document.getElementById(mirrorId);
      if (!src || !mirror) return;
      mirror.innerHTML = Array.from(src.querySelectorAll('.filter-btn'))
        .map(
          (b, i) =>
            `<button class="filter-chip${b.classList.contains('active') ? ' active' : ''}" data-mirror-index="${i}">${b.textContent.trim()}</button>`,
        )
        .join('');
      mirror.addEventListener('click', (ev) => {
        const chip = ev.target.closest('.filter-chip');
        if (!chip) return;
        const idx = parseInt(chip.dataset.mirrorIndex);
        const targetBtn = src.querySelectorAll('.filter-btn')[idx];
        if (targetBtn) targetBtn.click();
        // 同步 chip 狀態
        mirror
          .querySelectorAll('.filter-chip')
          .forEach((c) => c.classList.remove('active'));
        chip.classList.add('active');
        // 更新 summary state label
        const stateLabel = document.getElementById('filtersStateLabel');
        if (stateLabel && stateKey === 'region') {
          stateLabel.textContent = chip.textContent.trim();
        }
      });
    }
    setupFilterMirror('regionFilters', 'regionFiltersMirror', 'region');
    setupFilterMirror('categoryFilters', 'categoryFiltersMirror', 'category');

    // 返回按鈕
