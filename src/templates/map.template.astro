      stop.link || '#',
    );

    const categoryEl = document.getElementById('articleCategory');
    categoryEl.textContent = route.name;
    categoryEl.style.background = route.color + '33';
    categoryEl.style.color = route.color;

    if (window.innerWidth <= 768) {
      openMobilePanel();
    }
  }

  function initRoutes() {
    const container = document.getElementById('routeButtons');
    // emoji 預先從 route.name 取出（route name 開頭通常是 emoji），否則 fallback
    const ROUTE_EMOJI_FALLBACK = {
      counties22: '📍',
      nightMarkets: '🍜',
      nationalParks: '🏔️',
      historyTrail: '📜',
      oldStreets: '🏮',
    };
    routesData.forEach((route) => {
      const btn = document.createElement('button');
      btn.className = 'route-pill';
      btn.dataset.route = route.id;
      btn.style.setProperty('--route-color', route.color);
      // 拆 emoji 跟 label
      const match = route.name.match(/^(\p{Emoji}+\s*)(.*)$/u);
      const emoji = match ? match[1].trim() : ROUTE_EMOJI_FALLBACK[route.id] || '📌';
      const label = match ? match[2].trim() : route.name;
      const stopCount = route.stops?.length || 0;
      btn.innerHTML =
        `<span class="route-pill-emoji">${emoji}</span>` +
        `<span class="route-pill-label">${label}</span>` +
        (stopCount > 0
          ? `<span class="route-pill-count">${stopCount}</span>`
          : '');
      container.appendChild(btn);
    });

    container.addEventListener('click', (e) => {
      const btn = e.target.closest('.route-pill');
      if (!btn) return;
      container
        .querySelectorAll('.route-pill')
        .forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');

      const routeId = btn.dataset.route;
      if (routeId === 'none') {
        drawRoute(null);
        // hide route sidebar panel + restore default
        const routePanel = document.getElementById('sidebarRoute');
        if (routePanel) routePanel.style.display = 'none';
        showDefaultSidebar();
        updateURL('route', null);
      } else {
        const route = routesData.find((r) => r.id === routeId);
        if (route) {
          drawRoute(route);
          updateURL('route', routeId);
        }
      }
    });

    // 結束路線按鈕 → 等同點「一般模式」
    const clearRouteBtn = document.getElementById('clearRouteBtn');
    if (clearRouteBtn) {
      clearRouteBtn.addEventListener('click', () => {
        const noneBtn = container.querySelector('[data-route="none"]');
        if (noneBtn) noneBtn.click();
      });
    }
  }

  // Phase 5: URL Routing
  function updateURL(key, value) {
    const url = new URL(window.location);
    if (value && value !== 'all' && value !== 'none') {
      url.searchParams.set(key, value);
    } else {
      url.searchParams.delete(key);
    }
    history.replaceState(null, '', url);
  }

  function applyURLParams() {
    const params = new URLSearchParams(window.location.search);

    // Route
    const routeId = params.get('route');
    if (routeId) {
      const route = routesData.find((r) => r.id === routeId);
      if (route) {
        const routeButtons = document.getElementById('routeButtons');
        routeButtons
          ?.querySelectorAll('.route-pill, .route-btn')
          .forEach((b) => b.classList.remove('active'));
        drawRoute(route);
        document
          .querySelector(`[data-route="${routeId}"]`)
          ?.classList.add('active');
      }
    }

    // Region filter
    const region = params.get('region');
    if (region) {
      activeRegionFilter = region;
      document.querySelectorAll('#regionFilters .filter-btn').forEach((btn) => {
        btn.classList.remove('active');
        if (btn.getAttribute('data-filter') === region) {
          btn.classList.add('active');
        }
      });
      applyFilters();
    }

    // Highlight specific marker
    const highlight = params.get('highlight');
    if (highlight) {
      const marker = document.querySelector(
        `.marker[data-title="${highlight}"]`,
      );
      if (marker) {
        marker.setAttribute('r', '12');
        marker.setAttribute('stroke', '#ff0000');
        marker.setAttribute('stroke-width', '3');
        // Zoom to it
        const cx = parseFloat(marker.getAttribute('cx'));
        const cy = parseFloat(marker.getAttribute('cy'));
        setTimeout(() => {
          if (svgSelection && mapZoom) {
            svgSelection
              .transition()
              .duration(800)
              .call(
                mapZoom.transform,
                d3.zoomIdentity
                  .translate(400, 500)
                  .scale(4)
                  .translate(-cx, -cy),
              );
          }
        }, 500);
      }
    }
  }

  document.addEventListener('DOMContentLoaded', async () => {
    await drawTaiwanMap();
    initMap();
    initRoutes();

    // 初始化側欄
    showDefaultSidebar();

    updateClusters(1); // 初始化 clusters
    applyURLParams(); // 處理 URL 參數
  });
</script>
