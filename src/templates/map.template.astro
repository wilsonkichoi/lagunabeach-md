  function showCountyArticles(countyName, region) {
    const sidebarMarkers = markersForSidebar(markersData);
    // 過濾該縣市的文章
    const countyArticles = sidebarMarkers.filter((m) => {
      // 精確匹配城市或縣市名稱
      const cityMatch =
        m.city &&
        (countyName.includes(m.city.replace('台', '臺')) ||
          m.city.replace('台', '臺').includes(countyName.replace('台', '臺')));
      // 也用 region 作為 fallback
      const regionMatch = m.region === region;
      return cityMatch || (regionMatch && !m.city);
    });

    // 高亮該縣市
    document.querySelectorAll('.county').forEach((path) => {
      if (path.getAttribute('data-county') === countyName) {
        path.style.fill = '#22c55e'; // 更深的綠色
        path.style.stroke = '#16a34a';
        path.style.strokeWidth = '2';
      } else {
        // 重置其他縣市
        const markerCount = parseInt(path.getAttribute('data-count') || 0);
        const intensity = Math.min(markerCount / 15, 1);
        const green = Math.round(247 - intensity * 100);
        path.style.fill = `rgb(${187 - intensity * 80}, ${green}, ${208 - intensity * 80})`;
        path.style.stroke = '#4ade80';
        path.style.strokeWidth = '0.8';
      }
    });

    // 顯示縣市文章側欄
    showCountySidebar(countyName, countyArticles);

    // 手機版打開面板
    if (window.innerWidth <= 768) {
      openMobilePanel();
