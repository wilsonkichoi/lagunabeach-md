---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import markersData from '../data/map-markers.json';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Laguna-only Leaflet map. Markers come from src/data/map-markers.json, generated
// by scripts/core/generate-map-markers.js from knowledge/ + laguna-beach-geocode.json.

// Category display labels + marker colors (Laguna's 8 categories).
const CATEGORY_META = {
  history: { label: 'History', color: '#e74c3c' },
  'art-galleries': { label: 'Art & Galleries', color: '#e91e63' },
  'nature-marine-life': { label: 'Nature & Marine Life', color: '#16a085' },
  food: { label: 'Food', color: '#f39c12' },
  beaches: { label: 'Beaches', color: '#2980b9' },
  trails: { label: 'Trails', color: '#27ae60' },
  'events-festivals': { label: 'Events & Festivals', color: '#8e44ad' },
  neighborhoods: { label: 'Neighborhoods', color: '#7f8c8d' },
};

// Canonical filter lists, shown regardless of current marker coverage (markers
// fill in as more articles get geocoded). Category excludes "neighborhoods" —
// that dimension is the Neighborhoods (area) filter instead.
const CATEGORY_ORDER = [
  'history',
  'food',
  'events-festivals',
  'art-galleries',
  'beaches',
  'nature-marine-life',
  'trails',
];
const NEIGHBORHOODS = [
  'The Village',
  'Top of the World',
  'North Laguna',
  'South Laguna',
  'Victoria Beach',
];
---

<Layout
  lang={lang}
  title="Map of Laguna Beach"
  description="An interactive map of Laguna Beach — beaches, art galleries, trails, neighborhoods, and the stories behind them."
>
  <link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.css"
  />

  <div class="map-page">
    <PageHero
      layout="inline"
      bgVariant="gradient"
      bgGradient="linear-gradient(135deg, #0e3a5c 0%, #1e5a8a 100%)"
      bgTone="dark"
      titleVariant="inherit"
      titleFont="sans"
      titleWeight="bold"
      containerWidth="wide"
      title="Map of Laguna Beach"
      subtitle="Explore the places behind the articles — pick a category or area, or tap a marker."
    />

    <section class="map-body">
      <div class="map-layout">
        <!-- Map -->
        <div class="map-panel">
          <div
            id="leafletMap"
            style="width:100%; height:100%; min-height:520px; border-radius:12px; z-index:1;"
          >
          </div>
        </div>

        <!-- Sidebar: filters + place list -->
        <div class="sidebar-panel">
          <div class="sidebar-filters">
            <div class="filter-row">
              <span class="filter-row-label">Neighborhoods</span>
              <div class="filter-chips" id="regionFilters">
                <button class="filter-btn active" data-filter="all">All</button>
                {
                  NEIGHBORHOODS.map((r) => (
                    <button class="filter-btn" data-filter={r}>
                      {r}
                    </button>
                  ))
                }
              </div>
            </div>
            <div class="filter-row">
              <span class="filter-row-label">Category</span>
              <div class="filter-chips" id="categoryFilters">
                <button class="filter-btn active" data-filter="all">All</button>
                {
                  CATEGORY_ORDER.map((c) => (
                    <button class="filter-btn" data-filter={c}>
                      {CATEGORY_META[c].label}
                    </button>
                  ))
                }
              </div>
            </div>
          </div>

          <p class="place-count" id="placeCount"></p>
          <div class="place-list" id="placeList"></div>
        </div>
      </div>
    </section>
  </div>
</Layout>

<script
  is:inline
  src="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.js"></script>

<script
  is:inline
  define:vars={{ markersData, categoryMeta: CATEGORY_META, pageLang: lang }}
>
  // Localize an article href for the current page language (en = no prefix).
  function localizePath(href) {
    if (!href || href === '#') return href || '#';
    if (pageLang === 'en') return href;
    if (href.startsWith(`/${pageLang}/`)) return href;
    return `/${pageLang}${href}`;
  }

  const places = markersData.filter(
    (m) => (m.lang || 'en') === (pageLang || 'en'),
  );
  // Fallback to English markers if none exist for this language.
  const data = places.length
    ? places
    : markersData.filter((m) => (m.lang || 'en') === 'en');

  const map = L.map('leafletMap', { scrollWheelZoom: false }).setView(
    [33.5427, -117.7854],
    14,
  );
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '&copy; OpenStreetMap contributors',
    maxZoom: 19,
  }).addTo(map);
  // Wheel zoom stays off so the page scrolls past the map; the default +/- controls
  // and click-to-zoom still work.

  const state = { category: 'all', region: 'all' };
  const layer = L.layerGroup().addTo(map);
  const markerById = new Map();

  function meta(cat) {
    return categoryMeta[cat] || { label: cat, color: '#64748b' };
  }

  function visible(m) {
    return (
      (state.category === 'all' || m.category === state.category) &&
      (state.region === 'all' || m.region === state.region)
    );
  }

  function fitToVisible(list) {
    if (!list.length) return;
    const bounds = L.latLngBounds(list.map((m) => [m.lat, m.lng]));
    map.fitBounds(bounds, { padding: [40, 40], maxZoom: 15 });
  }

  function render() {
    const shown = data.filter(visible);
    layer.clearLayers();
    markerById.clear();

    shown.forEach((m, i) => {
      const c = meta(m.category);
      const marker = L.circleMarker([m.lat, m.lng], {
        radius: 9,
        color: '#fff',
        weight: 2,
        fillColor: c.color,
        fillOpacity: 0.95,
      }).addTo(layer);
      const href = localizePath(m.link);
      marker.bindPopup(
        `<strong>${m.title}</strong><br/>` +
          `<span style="color:${c.color};font-size:.8rem">${c.label}</span>` +
          (m.region
            ? ` · <span style="font-size:.8rem">${m.region}</span>`
            : '') +
          `<br/><p style="margin:.4rem 0 .3rem">${m.desc || ''}</p>` +
          `<a href="${href}">Read the article →</a>`,
      );
      markerById.set(i, marker);
    });

    renderList(shown);
    fitToVisible(shown);
  }

  function renderList(shown) {
    const count = document.getElementById('placeCount');
    count.textContent = shown.length
      ? `${shown.length} place${shown.length === 1 ? '' : 's'}`
      : 'No places match these filters.';

    const list = document.getElementById('placeList');
    list.innerHTML = '';
    shown.forEach((m, i) => {
      const c = meta(m.category);
      const card = document.createElement('div');
      card.className = 'place-card';
      card.innerHTML =
        `<span class="place-dot" style="background:${c.color}"></span>` +
        `<span class="place-body">` +
        `<span class="place-title">${m.title}</span>` +
        `<span class="place-meta">${c.label}${m.region ? ' · ' + m.region : ''}</span>` +
        `<span class="place-desc">${m.desc || ''}</span>` +
        `<a class="place-link" href="${localizePath(m.link)}">Read the article →</a>` +
        `</span>`;
      // Clicking the card (but not its link) flies to the marker + opens popup.
      card.addEventListener('click', (e) => {
        if (e.target.closest('.place-link')) return;
        const marker = markerById.get(i);
        if (marker) {
          map.flyTo([m.lat, m.lng], 16, { duration: 0.6 });
          marker.openPopup();
        }
      });
      list.appendChild(card);
    });
  }

  function wireFilters(containerId, key) {
    const container = document.getElementById(containerId);
    if (!container) return;
    container.addEventListener('click', (e) => {
      const btn = e.target.closest('.filter-btn');
      if (!btn) return;
      state[key] = btn.dataset.filter;
      container
        .querySelectorAll('.filter-btn')
        .forEach((b) => b.classList.toggle('active', b === btn));
      render();
    });
  }
  wireFilters('categoryFilters', 'category');
  wireFilters('regionFilters', 'region');

  render();
</script>

<style>
  .map-page {
    padding-bottom: 2rem;
  }

  .map-body {
    max-width: 1280px;
    margin: 1.5rem auto 0;
    padding: 0 1rem;
  }

  .map-layout {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 1.25rem;
    align-items: stretch;
  }

  .map-panel {
    min-height: 520px;
  }

  .sidebar-panel {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-height: 70vh;
    overflow-y: auto;
  }

  .sidebar-filters {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .filter-row {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .filter-row-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #6b7280;
  }

  .filter-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .filter-btn {
    padding: 0.4rem 0.85rem;
    border: 1px solid #d1d5db;
    background: #ffffff;
    border-radius: 20px;
    font-size: 0.82rem;
    cursor: pointer;
    transition: all 0.15s;
    color: #374151;
  }

  .filter-btn:hover {
    border-color: #0e3a5c;
    color: #0e3a5c;
  }

  .filter-btn.active {
    background: #0e3a5c;
    border-color: #0e3a5c;
    color: #ffffff;
  }

  .place-count {
    font-size: 0.8rem;
    color: #6b7280;
    margin: 0;
  }

  .place-list {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  /* Cards are built in JS (createElement), so Astro's scoped class hashing never
     reaches them — these must be :global or they render unstyled. */
  :global(.place-card) {
    display: flex;
    gap: 0.7rem;
    text-align: left;
    padding: 0.75rem;
    border: 1px solid #e5e7eb;
    border-radius: 10px;
    background: #ffffff;
    cursor: pointer;
    transition:
      border-color 0.15s,
      box-shadow 0.15s;
  }

  :global(.place-card:hover) {
    border-color: #0e3a5c;
    box-shadow: 0 2px 8px rgba(14, 58, 92, 0.12);
  }

  :global(.place-dot) {
    flex: 0 0 auto;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    margin-top: 0.35rem;
  }

  :global(.place-body) {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  :global(.place-title) {
    font-weight: 700;
    color: #111827;
  }

  :global(.place-meta) {
    font-size: 0.75rem;
    color: #6b7280;
  }

  :global(.place-desc) {
    font-size: 0.85rem;
    color: #374151;
    line-height: 1.4;
  }

  :global(.place-link) {
    align-self: flex-start;
    margin-top: 0.3rem;
    font-size: 0.82rem;
    font-weight: 600;
    color: #0e3a5c;
    text-decoration: none;
  }

  :global(.place-link:hover) {
    text-decoration: underline;
  }

  @media (max-width: 860px) {
    .map-layout {
      grid-template-columns: 1fr;
    }
    .sidebar-panel {
      max-height: none;
    }
  }
</style>
