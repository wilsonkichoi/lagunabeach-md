---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import ArticleCard from '../components/ArticleCard.astro';
import markersData from '../data/map-markers.json';
import counties22Data from '../data/counties-22.json';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { getMapRoutes } from '../utils/mapConfig';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const routesData = getMapRoutes(t);
---

<Layout
  lang={lang}
  title={t('map.meta.title')}
  description={t('map.meta.description')}
>
  <div class="map-page">
    <div
      id="mapData"
      data-markers={JSON.stringify(markersData)}
      data-routes={JSON.stringify(routesData)}
      data-counties22={JSON.stringify(counties22Data)}
      style="display:none"
    >
    </div>

    <!--
      Phase 7.5 partial migration — map.template.astro
      ────────────────────────────────────────────────
      Wrappers (hero, controls layout, body container) moved to
      inline Tailwind. Kept scoped: interactive map internals
      (.filter-btn state, .taiwan-svg cursor, .zoom-btn, .tooltip,
      .marker-tooltip, :global(.county), :global(.marker)),
      sidebar list pattern (.sidebar-article-item, .article-*,
      .category-group*), and the route picker (.route-btn states).
    -->
    <!-- Compact hero — 用共用 PageHero 的 layout="inline" variant -->
    <PageHero
      layout="inline"
      bgVariant="gradient"
      bgGradient="linear-gradient(135deg, #1a3c34 0%, #14532d 100%)"
      bgTone="dark"
      titleVariant="inherit"
      titleFont="sans"
      titleWeight="bold"
      containerWidth="wide"
      title={t('map.hero.title')}
      subtitle={t('map.hero.subtitle')}
    />

    <!-- Hidden: 確保 ArticleCard 的 is:global CSS 被 bundled 進頁面（即使動態 innerHTML 用） -->
    <div style="display:none" aria-hidden="true">
      <ArticleCard title="_" density="compact" />
    </div>

    <!-- 隱藏：保留 regionFilters / categoryFilters DOM 給既有 JS 用，但實際 UI 在 sidebar -->
    <div id="hiddenFiltersHost" style="display:none">
      <div id="regionFilters">
        <button class="filter-btn active" data-filter="all"
          >{t('map.controls.region.all')}</button
        >
        <button class="filter-btn" data-filter="north"
          >{t('map.controls.region.north')}</button
        >
        <button class="filter-btn" data-filter="central"
          >{t('map.controls.region.central')}</button
        >
        <button class="filter-btn" data-filter="south"
          >{t('map.controls.region.south')}</button
        >
        <button class="filter-btn" data-filter="east"
          >{t('map.controls.region.east')}</button
        >
        <button class="filter-btn" data-filter="islands"
          >{t('map.controls.region.islands')}</button
        >
      </div>
      <div id="categoryFilters">
        <button class="filter-btn active" data-filter="all"
          >{t('map.controls.category.all')}</button
        >
        <button class="filter-btn" data-filter="food"
          >{t('map.controls.category.food')}</button
        >
        <button class="filter-btn" data-filter="history"
          >{t('map.controls.category.history')}</button
        >
        <button class="filter-btn" data-filter="nature"
          >{t('map.controls.category.nature')}</button
        >
        <button class="filter-btn" data-filter="culture"
          >{t('map.controls.category.culture')}</button
        >
        <button class="filter-btn" data-filter="technology"
          >{t('map.controls.category.technology')}</button
        >
        <button class="filter-btn" data-filter="economy"
          >{t('map.controls.category.economy')}</button
        >
        <button class="filter-btn" data-filter="lifestyle"
          >{t('map.controls.category.lifestyle')}</button
        >
        <button class="filter-btn" data-filter="art"
          >{t('map.controls.category.art')}</button
        >
        <button class="filter-btn" data-filter="geography"
          >{t('map.controls.category.geography')}</button
        >
      </div>
    </div>

    <!-- 策展路線 pill bar：緊湊單行水平 scroll，緊貼 hero 下方 -->
    <section class="route-bar">
      <div class="route-bar-inner">
        <div class="route-pills" id="routeButtons">
          <button class="route-pill active" data-route="none"
            ><span class="route-pill-emoji">⚪</span><span
              class="route-pill-label">{t('map.route.normal-mode')}</span
            ></button
          >
          <!-- 動態生成其他 route pills -->
        </div>
      </div>
    </section>

    <section class="map-body">
      <div class="map-layout">
        <!-- 左側地圖面板 (60%) -->
        <div class="map-panel">
          <div class="map-canvas">
            <svg id="taiwanMap" viewBox="0 0 800 1000" class="taiwan-svg">
              <defs>
                <linearGradient
                  id="taiwanGradient"
                  x1="0%"
                  y1="0%"
                  x2="0%"
                  y2="100%"
                >
                  <stop offset="0%" stop-color="#dcfce7"></stop>
                  <stop offset="50%" stop-color="#bbf7d0"></stop>
                  <stop offset="100%" stop-color="#86efac"></stop>
                </linearGradient>
              </defs>
              <!-- zoom group wraps both counties and markers -->
              <g id="zoomGroup">
                <g id="taiwanCounties"></g>
                <g id="markers"></g>
              </g>
            </svg>

            <!-- Zoom controls -->
            <div class="zoom-controls">
              <button class="zoom-btn" id="zoomIn">{t('map.zoom.in')}</button>
              <button class="zoom-btn" id="zoomOut">{t('map.zoom.out')}</button>
              <button class="zoom-btn" id="resetZoom"
                >{t('map.zoom.reset')}</button
              >
            </div>

            <!-- Marker tooltip -->
            <div id="marker-tooltip" class="marker-tooltip">
              <h4 class="tooltip-title"></h4>
              <span class="tooltip-meta"></span>
              <p class="tooltip-desc"></p>
            </div>

            <div id="tooltip" class="tooltip">
              <div class="tooltip-title"></div>
              <div class="tooltip-category"></div>
              <div class="tooltip-desc"></div>
            </div>
          </div>
        </div>

        <!-- 右側文章列表面板 (40%) -->
        <div class="sidebar-panel">
          <div id="sidebar-content">
            <!-- 預設狀態：探索提示 + 全部文章 -->
            <div class="sidebar-default" id="sidebarDefault">
              <div class="sidebar-header">
                <h3>{t('map.sidebar.default.title')}</h3>
                <p class="sidebar-hint">{t('map.sidebar.default.hint')}</p>
              </div>

              <!-- 篩選 collapsible（從上方移到 sidebar 後的緊湊版）-->
              <details class="sidebar-filters">
                <summary class="sidebar-filters-summary">
                  <span class="sidebar-filters-icon">🔍</span>
                  <span class="sidebar-filters-label"
                    >{t('map.controls.region.title')} / {
                      t('map.controls.category.title')
                    }</span
                  >
                  <span class="sidebar-filters-state" id="filtersStateLabel"
                    >{t('map.controls.region.all')}</span
                  >
                </summary>
                <div class="sidebar-filters-body">
                  <div class="sidebar-filters-row">
                    <span class="sidebar-filters-row-label"
                      >{t('map.controls.region.title')}</span
                    >
                    <div class="sidebar-filters-chips" id="regionFiltersMirror">
                      <!-- mirror 進 #regionFilters click -->
                    </div>
                  </div>
                  <div class="sidebar-filters-row">
                    <span class="sidebar-filters-row-label"
                      >{t('map.controls.category.title')}</span
                    >
                    <div
                      class="sidebar-filters-chips"
                      id="categoryFiltersMirror"
                    >
                      <!-- mirror 進 #categoryFilters click -->
                    </div>
                  </div>
                </div>
              </details>

              <div class="articles-by-category" id="articlesByCategory">
                <!-- 動態生成分類文章列表 -->
              </div>
            </div>

            <!-- 策展路線狀態：route description + stop cards -->
            <div
              class="sidebar-route"
              id="sidebarRoute"
              style="display: none;"
            >
              <div class="sidebar-header">
                <button
                  class="clear-selection-btn"
                  id="clearRouteBtn"
                  type="button">✕ 結束路線</button
                >
                <h3 id="selectedRouteName">策展路線</h3>
                <p class="route-desc" id="routeDesc"></p>
              </div>
              <div class="route-stops" id="routeStops">
                <!-- 動態生成 stop cards -->
              </div>
            </div>

            <!-- 縣市篩選狀態：該縣市文章列表 -->
            <div
              class="sidebar-county"
              id="sidebarCounty"
              style="display: none;"
            >
              <div class="sidebar-header">
                <button class="clear-selection-btn" id="clearSelectionBtn"
                  >{t('map.sidebar.county.clear')}</button
                >
                <h3 id="selectedCountyName">縣市名稱</h3>
                <p class="county-article-count" id="countyArticleCount">
                  0 {t('map.sidebar.county.articles-count')}
                </p>
              </div>

              <div class="county-articles" id="countyArticles">
                <!-- 動態生成該縣市文章 -->
              </div>
            </div>

            <!-- 單篇文章詳情 -->
            <div
              class="sidebar-article"
              id="sidebarArticle"
              style="display: none;"
            >
              <div class="sidebar-header">
                <button class="back-btn" id="backBtn"
                  >{t('map.sidebar.article.back')}</button
                >
                <h3 id="articleTitle"></h3>
                <div class="article-meta">
                  <span class="article-category" id="articleCategory"></span>
                </div>
              </div>

              <div class="article-content">
                <p id="articleDesc"></p>
                <a id="articleLink" class="read-more-btn" target="_blank"
                  >{t('map.sidebar.article.read-more')}</a
                >
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- 手機版遮罩 -->
      <div class="mobile-overlay" id="mobileOverlay"></div>
    </section>
  </div>
</Layout>
<style>
  .map-page {
    padding-bottom: 2rem;
  }

  .filter-btn {
    padding: 0.5rem 1rem;
    border: 1px solid #d1d5db;
    background: #ffffff;
    border-radius: 20px;
    font-size: 0.85rem;
    cursor: pointer;
    transition: all 0.2s;
    color: #374151;
  }
  .filter-btn:hover {
    border-color: #16a34a;
    background: #f0fdf4;
  }
  .filter-btn.active {
    background: #16a34a;
    border-color: #16a34a;
    color: white;
  }

  .map-body {
    max-width: 1400px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .map-layout {
    display: flex;
    gap: 24px;
    min-height: 80vh;
  }

  .map-panel {
    flex: 0 0 60%;
    position: sticky;
    top: 80px;
    height: calc(100vh - 100px);
    overflow: hidden;
  }

  .sidebar-panel {
    flex: 0 0 38%;
    overflow-y: auto;
    max-height: calc(100vh - 100px);
    position: sticky;
    top: 80px;
    background: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 16px;
    padding: 1.5rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
  }

  .map-canvas {
    position: relative;
    background: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 16px;
    padding: 1.5rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
    width: 100%;
    height: 100%;
  }
  .taiwan-svg {
    width: 100%;
    height: 100%;
    cursor: grab;
  }
  .taiwan-svg:active {
    cursor: grabbing;
  }

  /* Zoom controls */
  .zoom-controls {
    position: absolute;
    bottom: 2rem;
    right: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .zoom-btn {
    width: 36px;
    height: 36px;
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    cursor: pointer;
    font-size: 1.1rem;
    font-weight: 600;
    color: #374151;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.08);
  }
  .zoom-btn:hover {
    background: #f0fdf4;
    border-color: #16a34a;
    color: #16a34a;
  }

  :global(.county) {
    fill: #bbf7d0;
    stroke: #4ade80;
    stroke-width: 0.8;
    transition: fill 0.2s;
  }
  :global(.county:hover) {
    fill: #86efac;
  }

  :global(.marker) {
    cursor: pointer;
    transition: all 0.3s ease;
    filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.2));
  }
  :global(.marker:hover) {
    filter: drop-shadow(0 4px 8px rgba(0, 0, 0, 0.3)) brightness(1.1);
  }
  :global(.marker.hidden) {
    opacity: 0;
    pointer-events: none;
  }

  .tooltip {
    position: absolute;
    background: rgba(0, 0, 0, 0.9);
    color: white;
    padding: 0.75rem;
    border-radius: 8px;
    font-size: 0.85rem;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.2s;
    z-index: 1000;
    max-width: 200px;
  }
  .tooltip-title {
    font-weight: 600;
    margin-bottom: 0.25rem;
  }
  .tooltip-category {
    font-size: 0.75rem;
    opacity: 0.8;
    margin-bottom: 0.25rem;
  }
  .tooltip-desc {
    font-size: 0.75rem;
    line-height: 1.3;
  }

  /* 側欄樣式 */
  .sidebar-header {
    margin-bottom: 1.5rem;
  }

  .sidebar-header h3 {
    font-size: 1.3rem;
    color: #2d5016;
    margin-bottom: 0.5rem;
    font-family: 'jf-jinxuanlatte', 'Noto Sans TC', sans-serif;
  }

  .sidebar-hint {
    font-size: 0.9rem;
    color: #6b7280;
    margin-bottom: 0;
  }

  .clear-selection-btn,
  .back-btn {
    background: none;
    border: none;
    color: #6b7280;
    cursor: pointer;
    font-size: 0.9rem;
    margin-bottom: 1rem;
    padding: 0.5rem 0;
    transition: color 0.2s;
  }
  .clear-selection-btn:hover,
  .back-btn:hover {
    color: #16a34a;
  }

  .county-article-count {
    font-size: 0.9rem;
    color: #16a34a;
    font-weight: 500;
  }

  /* 22 縣市深度文章 featured card（T1.1 evolution）— :global 因為 dynamic innerHTML 沒 astro cid */
  :global(.deep-article-card) {
    display: block;
    margin: 8px 0 16px;
    border: 1px solid #d1fae5;
    border-radius: 12px;
    background: linear-gradient(135deg, #f0fdf4 0%, #ecfdf5 100%);
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    transition:
      transform 0.2s,
      box-shadow 0.2s;
  }
  :global(.deep-article-card:hover) {
    transform: translateY(-2px);
    box-shadow: 0 8px 16px rgba(22, 163, 74, 0.12);
    border-color: #16a34a;
  }
  :global(.deep-card-hero) {
    height: 120px;
    background-size: cover;
    background-position: center;
    background-color: #16a34a;
  }
  :global(.deep-card-body) {
    padding: 12px 14px 14px;
  }
  :global(.deep-card-badge) {
    display: inline-block;
    font-size: 0.7rem;
    color: #15803d;
    background: #dcfce7;
    padding: 2px 8px;
    border-radius: 10px;
    margin-bottom: 8px;
    font-weight: 600;
  }
  :global(.deep-card-title) {
    font-size: 0.95rem;
    font-weight: 700;
    color: #14532d;
    margin: 0 0 8px;
    line-height: 1.35;
  }
  :global(.deep-card-contradiction) {
    font-size: 0.85rem;
    color: #166534;
    line-height: 1.5;
    margin: 0 0 10px;
    font-style: italic;
    padding-left: 8px;
    border-left: 3px solid #16a34a;
  }
  :global(.deep-card-meta) {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.75rem;
  }
  :global(.deep-card-cta) {
    color: #16a34a;
    font-weight: 600;
  }
  :global(.deep-card-read) {
    color: #6b7280;
  }

  /* T1.4 22 縣市 grid（default sidebar 頂端 panel）*/
  :global(.counties-22-panel) {
    margin: 0 0 20px;
    padding: 12px;
    background: #fafdf6;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
  }
  :global(.counties-22-header) {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 10px;
    flex-wrap: wrap;
    gap: 4px;
  }
  :global(.counties-22-header h4) {
    margin: 0;
    font-size: 0.95rem;
    font-weight: 700;
    color: #14532d;
  }
  :global(.counties-22-hint) {
    font-size: 0.7rem;
    color: #6b7280;
  }
  :global(.counties-22-grid) {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 8px;
  }
  :global(.county-grid-card) {
    text-align: left;
    padding: 8px 10px;
    border: 1px solid #d1fae5;
    background: white;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.18s;
    display: flex;
    flex-direction: column;
    gap: 4px;
    font-family: inherit;
  }
  :global(.county-grid-card:hover) {
    border-color: #16a34a;
    background: #f0fdf4;
    transform: translateY(-1px);
    box-shadow: 0 2px 8px rgba(22, 163, 74, 0.08);
  }
  :global(.county-grid-name) {
    font-size: 0.8rem;
    font-weight: 700;
    color: #14532d;
  }
  :global(.county-grid-contradiction) {
    font-size: 0.68rem;
    color: #166534;
    line-height: 1.35;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  /* === Sidebar 緊湊 filters（從上方移過來，collapsible details）=== */
  .sidebar-filters {
    margin: 4px 0 12px;
    border: 1px solid #e5e7eb;
    border-radius: 10px;
    background: white;
    overflow: hidden;
  }
  .sidebar-filters[open] {
    border-color: #d1fae5;
    background: #fafdf6;
  }
  .sidebar-filters-summary {
    list-style: none;
    cursor: pointer;
    padding: 10px 12px;
    display: flex;
    align-items: center;
    gap: 8px;
    user-select: none;
    transition: background 0.16s;
  }
  .sidebar-filters-summary::-webkit-details-marker {
    display: none;
  }
  .sidebar-filters-summary:hover {
    background: #f0fdf4;
  }
  .sidebar-filters-summary::after {
    content: '▾';
    margin-left: auto;
    color: #9ca3af;
    transition: transform 0.16s;
  }
  .sidebar-filters[open] .sidebar-filters-summary::after {
    transform: rotate(180deg);
  }
  .sidebar-filters-icon {
    font-size: 0.95rem;
  }
  .sidebar-filters-label {
    font-size: 0.85rem;
    font-weight: 600;
    color: #14532d;
  }
  .sidebar-filters-state {
    font-size: 0.72rem;
    color: #16a34a;
    background: #dcfce7;
    padding: 1px 8px;
    border-radius: 8px;
    margin-left: 6px;
  }
  .sidebar-filters-body {
    padding: 4px 12px 12px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .sidebar-filters-row {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .sidebar-filters-row-label {
    font-size: 0.7rem;
    font-weight: 600;
    color: #6b7280;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .sidebar-filters-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }
  :global(.filter-chip) {
    padding: 4px 10px;
    border: 1px solid #d1d5db;
    background: white;
    border-radius: 12px;
    font-size: 0.72rem;
    cursor: pointer;
    transition: all 0.14s;
    color: #4b5563;
    font-family: inherit;
  }
  :global(.filter-chip:hover) {
    border-color: #16a34a;
    color: #15803d;
  }
  :global(.filter-chip.active) {
    background: #16a34a;
    color: white;
    border-color: #16a34a;
  }

  /* Article card 樣式全部在 src/components/ArticleCard.astro 內 is:global，
     map.template 不需重複定義；route-stop-card 客製化也內化進 ArticleCard。
     Sidebar legacy class .sidebar-article-item 同時帶 article-card class
     確保套用 base styles，下方僅補 dynamic-only legacy alias： */
  :global(.sidebar-article-item:not(.article-card)) {
    /* fallback for any legacy callsite that didn't get article-card class */
    display: flex;
    padding: 12px 14px;
    border: 1px solid #e5e7eb;
    border-radius: 10px;
    background: white;
    margin: 6px 0;
  }

  .article-category-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 6px;
  }

  .article-info {
    flex: 1;
    min-width: 0;
  }

  .article-title {
    font-size: 0.9rem;
    font-weight: 600;
    color: #1a1a1a;
    margin: 0 0 4px 0;
    line-height: 1.3;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .article-desc {
    font-size: 0.8rem;
    color: #666;
    line-height: 1.4;
    margin: 0 0 6px 0;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .article-meta {
    font-size: 0.75rem;
    color: #888;
  }

  /* 分類分組樣式 */
  .category-group {
    margin-bottom: 1.5rem;
  }

  .category-group-header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 8px;
    padding-bottom: 6px;
    border-bottom: 1px solid #e5e7eb;
  }

  .category-group-title {
    font-size: 1rem;
    font-weight: 600;
    color: #374151;
  }

  .category-group-count {
    font-size: 0.8rem;
