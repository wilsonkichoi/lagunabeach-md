  /* Timeline */
  .timeline {
    position: relative;
    margin: 3rem 0 4rem;
    padding-left: 2rem;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 7px;
    top: 8px;
    bottom: 8px;
    width: 2px;
    background: linear-gradient(to bottom, #1e40af, #3b82f6, #93c5fd);
  }

  .timeline-item {
    position: relative;
    margin-bottom: 2.5rem;
    padding-left: 1.5rem;
  }

  .timeline-item:last-child {
    margin-bottom: 0;
  }

  .timeline-marker {
    position: absolute;
    left: -2rem;
    top: 6px;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: #1e40af;
    border: 3px solid #fff;
    box-shadow: 0 0 0 2px #1e40af;
    z-index: 1;
  }

