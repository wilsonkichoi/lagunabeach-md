---
/**
 * /opendata — OpenData 策展（台灣開放資料 × Twinkle Hub 的意義層導覽）。
 *
 * 數據 nav 群組的子頁。三層架構：
 *   - 機器資料：src/data/opendata-curation.json（scripts/tools/twinkle-hub-crawl.py
 *     即時爬取 MCP 端點 — 21 tools / 20 domains / 15 showcase datasets）
 *   - 策展內容：src/data/opendata-content.ts（per-lang，zh-TW canonical，
 *     其他語言 fallback zh-TW — 跟 mcp-content.ts 同機制）
 *   - 本 template：把兩層縫起來渲染
 *
 * 誕生：2026-06-10 哲宇 directive「OpenData策展 subnav + 完整盤點 Twinkle Hub
 * + 怎麼組合分析 + 對應文章」，週五與 Twinkle Hub 創辦人對談的 demo 頁。
 * 設計語言跟 data.template 同家族（slate 深底 + sky/indigo 漸層）。
 */
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import { getLangFromUrl } from '../i18n/utils';
import { OPENDATA_CONTENT, type OpendataLang } from '../data/opendata-content';
import curation from '../data/opendata-curation.json';
import langSwitchMap from '../../public/api/lang-switch-map.json';

const lang = getLangFromUrl(Astro.url) as OpendataLang;
const c = OPENDATA_CONTENT[lang] ?? OPENDATA_CONTENT['zh-TW'];

// 文章連結跨語言解析：content 層的 href 一律寫 zh 路徑（SSOT），
// 非中文頁面渲染時查 prebuilt lang-switch-map 換成該語言的譯版路徑；
// 沒有譯版 → fallback zh（連得到內容，不 404）。
const fromZh: Record<string, string> =
  lang === 'zh-TW'
    ? {}
    : ((langSwitchMap as any).registry?.[lang]?.fromZh ?? {});
function articleHref(zhHref: string): string {
  if (lang === 'zh-TW') return zhHref;
  const mapped = fromZh[zhHref] ?? fromZh[decodeURIComponent(zhHref)];
  if (mapped) return mapped;
  // 單段路徑 = 分類 hub（全語言都由 [category].astro 生成）→ 帶語言前綴
  if (zhHref.split('/').filter(Boolean).length === 1)
    return `/${lang}${zhHref}`;
  return zhHref;
}

// ── 機器資料層 ──────────────────────────────────────────────────────────────
const crawledAt = (curation.crawled_at || '').slice(0, 10);
const domains = curation.domains as {
  key: string;
  name_zh: string;
  scope: string;
  typical_questions: string[];
}[];
const tools = curation.tools as { name: string; description: string }[];

// domain key → 策展對應（articles / blankNote）
const domainMapByKey = new Map(c.domains.map.map((m) => [m.key, m]));

// 工具描述取第一句、去 markdown 粗體
function toolFirstLine(desc: string): string {
  const first = desc.split('\n')[0].replace(/\*\*/g, '').trim();
  return first.length > 90 ? first.slice(0, 90) + '…' : first;
}
const toolByName = new Map(tools.map((t) => [t.name, t]));
const toolGroups = c.tools.groups.map((g) => ({
  label: g.label,
  items: g.prefix.map((name) => toolByName.get(name)).filter(Boolean) as {
    name: string;
    description: string;
  }[],
}));
const groupedNames = new Set(c.tools.groups.flatMap((g) => g.prefix));
const ungrouped = tools.filter((t) => !groupedNames.has(t.name));

const dimIcons = ['🗃️', '🫀', '⚡'];
const layerIcons = ['🏛️', '🔌', '🧬'];

// 垂直語料庫量級條（對數尺度；順序對齊 c.verticals.items：專利/國考/判決書/藥品/營養）
const corpusCounts: (number | null)[] = [null, 320663, 1240000, 71836, 226825];
const maxLogCount = Math.log10(1240000);
function corpusBarPct(count: number | null): number | null {
  if (!count) return null;
  return Math.round(((Math.log10(count) - 4) / (maxLogCount - 4)) * 100);
}

// 更新頻率光譜：本頁引用的 showcase 資料集按頻率分桶（高解析 → 低解析 → 不定期）
const FREQ_ORDER = [
  '每半月',
  '每1月',
  '每3月',
  '每1年',
  '每4年',
  '每5年',
  '不定期更新',
];
const showcaseOk = (curation.showcase_datasets as any[]).filter(
  (d) => !d.error && d.name,
);
const freqBuckets = FREQ_ORDER.map((f) => ({
  freq: f,
  items: showcaseOk.filter((d) => d.update_freq === f),
})).filter((b) => b.items.length > 0);

// ── Hero 資料星系（D3 force graph）的真實資料 ──────────────────────────────
// 節點全部來自本頁既有的爬取與策展，沒有裝飾用假節點。
const verticalCorpora = [
  {
    id: 'v-judicial',
    label: '判決書',
    count: 1240000,
    domain: 'judicial_legal',
  },
  {
    id: 'v-exam',
    label: '國考題庫',
    count: 320663,
    domain: 'education_research',
  },
  {
    id: 'v-nutrition',
    label: '食品營養',
    count: 226825,
    domain: 'health_food',
  },
  { id: 'v-drug', label: '藥品許可證', count: 71836, domain: 'health_food' },
  {
    id: 'v-patent',
    label: '發明專利',
    count: null,
    domain: 'economy_business',
  },
];
const articleNodes = new Map<
  string,
  { id: string; label: string; href: string }
>();
for (const m of c.domains.map) {
  for (const a of m.articles ?? []) {
    if (!articleNodes.has(a.href)) {
      articleNodes.set(a.href, { id: a.href, label: a.title, href: a.href });
    }
  }
}
const graphData = {
  nodes: [
    { id: 'c', type: 'center', label: c.hero.viz.legend.center },
    ...domains.map((d) => ({ id: d.key, type: 'domain', label: d.name_zh })),
    ...verticalCorpora.map((v) => ({
      id: v.id,
      type: 'vertical',
      label: v.label,
      count: v.count,
    })),
    ...[...articleNodes.values()].map((a) => ({
      id: a.id,
      type: 'article',
      label: a.label,
      href: articleHref(a.href),
    })),
  ],
  links: [
    ...domains.map((d) => ({ source: d.key, target: 'c', kind: 'spine' })),
    ...verticalCorpora.map((v) => ({
      source: v.id,
      target: v.domain,
      kind: 'corpus',
    })),
    ...c.domains.map.flatMap((m) =>
      (m.articles ?? []).map((a) => ({
        source: m.key,
        target: a.href,
        kind: 'curation',
      })),
    ),
  ],
};
---

<Layout lang={lang} title={c.meta.title} description={c.meta.description}>
  <main
    class="min-h-screen bg-[linear-gradient(160deg,#0f172a_0%,#1e293b_70%,#172033_100%)] pb-20 text-[#e2e8f0]"
  >
    <!-- Hero -->
    <PageHero
      bgTone="dark"
      titleVariant="gradient"
      titleGradient="linear-gradient(135deg,#38bdf8,#818cf8,#c084fc)"
      titleSize="clamp"
      containerWidth="wide"
      eyebrow={c.hero.eyebrow}
      title={c.hero.title}
      subtitle={c.hero.subtitle}
    >
      <div class="mx-auto mt-5 max-w-[680px] space-y-4 text-left">
        {
          c.hero.intro.map((p) => (
            <p class="text-base leading-[1.85] text-[#cbd5e1]">{p}</p>
          ))
        }
      </div>
    </PageHero>

    <!-- 資料的力量：真實數字帶 + 資料星系 -->
    <div class="mx-auto mt-4 max-w-[var(--container-wide)] px-5">
      <div class="grid grid-cols-2 gap-3 sm:grid-cols-5">
        {
          c.hero.viz.stats.map((s) => (
            <div class="rounded-2xl border border-white/10 bg-white/[0.04] px-3 py-4 text-center">
              <div
                class="stat-n text-[1.55rem] font-extrabold leading-none"
                style="background:linear-gradient(135deg,#38bdf8,#818cf8,#c084fc);-webkit-background-clip:text;background-clip:text;color:transparent;"
                data-count={s.n}
                data-suffix={s.suffix}
              >
                0
              </div>
              <div class="mt-1.5 text-xs text-[#94a3b8]">{s.label}</div>
            </div>
          ))
        }
      </div>

      <p
        class="mx-auto mt-7 max-w-[720px] text-center text-sm leading-[1.8] text-[#94a3b8]"
      >
        {c.hero.viz.graphHint}
      </p>
      <div
        id="opendata-galaxy"
        class="relative mt-4 h-[540px] w-full cursor-grab overflow-hidden rounded-2xl border border-white/10 bg-[radial-gradient(ellipse_at_center,#0d1830_0%,#090e1b_75%)] max-md:h-[440px]"
      >
      </div>
      <div
        class="mt-3 flex flex-wrap items-center justify-center gap-x-5 gap-y-1.5 text-xs text-[#94a3b8]"
      >
        <span class="flex items-center gap-1.5">
          <span class="inline-block h-2.5 w-2.5 rounded-full bg-[#38bdf8]"
          ></span>
          {c.hero.viz.legend.domain}
        </span>
        <span class="flex items-center gap-1.5">
          <span class="inline-block h-2.5 w-2.5 rounded-full bg-[#c084fc]"
          ></span>
          {c.hero.viz.legend.vertical}
        </span>
        <span class="flex items-center gap-1.5">
          <span class="inline-block h-2.5 w-2.5 rounded-full bg-[#34d399]"
          ></span>
          {c.hero.viz.legend.article}
        </span>
        <span class="flex items-center gap-1.5">
          <span
            class="inline-block h-2.5 w-2.5 rounded-full border border-[#34d399] bg-transparent"
          ></span>
          {c.hero.viz.legend.center} 🧬
        </span>
      </div>
    </div>
    <script
      type="application/json"
      id="opendata-graph-data"
      set:html={JSON.stringify(graphData)}
    />

    <div class="mx-auto max-w-[var(--container-wide)] px-5">
      <!-- 生態地圖 -->
      <section id="ecosystem" class="mt-14">
        <h2 class="mb-2 text-2xl font-bold text-[#f1f5f9]">
          {c.ecosystem.title}
        </h2>
        <p class="mb-7 max-w-[720px] leading-[1.8] text-[#94a3b8]">
          {c.ecosystem.lead}
        </p>
        <div class="grid gap-5 md:grid-cols-3">
          {
            c.ecosystem.layers.map((layer, i) => (
              <div class="rounded-2xl border border-white/10 bg-white/[0.04] p-6">
                <div class="mb-3 text-3xl">{layerIcons[i]}</div>
                <div class="text-xs font-semibold uppercase tracking-wider text-sky-400">
                  {layer.role}
                </div>
                <h3 class="mb-2 mt-1 text-lg font-bold text-[#f1f5f9]">
                  {layer.name}
                </h3>
                <p class="text-sm leading-[1.8] text-[#a8b6c8]">{layer.desc}</p>
                <div class="mt-4 inline-block rounded-full bg-sky-500/15 px-3 py-1 text-xs font-semibold text-sky-300">
                  {layer.stat}
                </div>
              </div>
            ))
          }
        </div>
      </section>

      <!-- 三維評估 -->
      <section id="assessment" class="mt-16">
        <h2 class="mb-2 text-2xl font-bold text-[#f1f5f9]">
          {c.assessment.title}
        </h2>
        <p class="mb-7 max-w-[720px] leading-[1.8] text-[#94a3b8]">
          {c.assessment.lead}
        </p>
        <div class="grid gap-5 lg:grid-cols-3">
          {
            c.assessment.dims.map((dim, i) => (
              <div class="flex flex-col rounded-2xl border border-white/10 bg-white/[0.04] p-6">
                <div class="mb-1 flex items-center gap-2">
                  <span class="text-2xl">{dimIcons[i]}</span>
                  <h3 class="text-lg font-bold text-[#f1f5f9]">{dim.name}</h3>
                </div>
                <div class="mb-4 text-sm font-semibold text-indigo-300">
                  {dim.verdict}
                </div>
                <ul class="mb-4 space-y-2.5">
                  {dim.points.map((p) => (
                    <li class="flex gap-2 text-sm leading-[1.75] text-[#a8b6c8]">
                      <span class="mt-0.5 shrink-0 text-emerald-400">✓</span>
                      <span>{p}</span>
                    </li>
                  ))}
                </ul>
                <div class="mt-auto rounded-xl border border-amber-400/20 bg-amber-400/[0.06] p-4">
                  <div class="mb-2 text-xs font-semibold uppercase tracking-wider text-amber-300">
                    {c.assessment.gapsLabel}
                  </div>
                  <ul class="space-y-2">
                    {dim.gaps.map((g) => (
                      <li class="flex gap-2 text-[13px] leading-[1.7] text-[#c8b89a]">
                        <span class="mt-0.5 shrink-0 text-amber-400">△</span>
                        <span>{g}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            ))
          }
        </div>
      </section>

      <!-- 五個垂直語料庫 -->
      <section id="verticals" class="mt-16">
        <h2 class="mb-2 text-2xl font-bold text-[#f1f5f9]">
          {c.verticals.title}
        </h2>
        <p class="mb-7 max-w-[720px] leading-[1.8] text-[#94a3b8]">
          {c.verticals.lead}
        </p>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-5">
          {
            c.verticals.items.map((v, i) => {
              const pct = corpusBarPct(corpusCounts[i]);
              return (
                <div class="rounded-2xl border border-white/10 bg-white/[0.04] p-5">
                  <h3 class="text-base font-bold text-[#f1f5f9]">{v.name}</h3>
                  <div class="mb-2 mt-1 text-xs font-semibold text-sky-300">
                    {v.stat}
                  </div>
                  {pct !== null ? (
                    <div class="mb-3 h-1.5 w-full overflow-hidden rounded-full bg-white/10">
                      <div
                        class="h-full rounded-full bg-[linear-gradient(90deg,#818cf8,#c084fc)]"
                        style={`width:${pct}%`}
                      />
                    </div>
                  ) : (
                    <div class="mb-3 text-[11px] text-[#a78bda]">
                      全文語意檢索
                    </div>
                  )}
                  <p class="text-[13px] leading-[1.7] text-[#a8b6c8]">
                    {v.desc}
                  </p>
                </div>
              );
            })
          }
        </div>
        <p class="mt-3 text-xs text-[#64748b]">{c.verticals.logNote}</p>
      </section>

      <!-- 分析組合 recipes -->
      <section id="recipes" class="mt-16">
        <h2 class="mb-2 text-2xl font-bold text-[#f1f5f9]">
          {c.recipes.title}
        </h2>
        <p class="mb-7 max-w-[720px] leading-[1.8] text-[#94a3b8]">
          {c.recipes.lead}
        </p>
        <div class="grid gap-5 lg:grid-cols-2">
          {
            c.recipes.items.map((r) => (
              <div class="rounded-2xl border border-indigo-400/20 bg-indigo-500/[0.05] p-6">
                <h3 class="mb-4 text-lg font-bold leading-snug text-[#f1f5f9]">
                  {r.question}
                </h3>
                <div class="mb-4 flex flex-wrap gap-2">
                  {r.datasets.map((d) => (
                    <a
                      href={d.href}
                      target="_blank"
                      rel="noopener"
                      class="rounded-full border border-sky-400/30 bg-sky-500/10 px-3 py-1 text-xs font-medium text-sky-200 transition hover:bg-sky-500/25"
                    >
                      {d.name} · {d.freq}
                    </a>
                  ))}
                </div>
                <div class="space-y-3 text-sm leading-[1.8] text-[#a8b6c8]">
                  <p>
                    <strong class="text-indigo-300">
                      {c.recipes.combineLabel}：
                    </strong>
                    {r.combine}
                  </p>
                  <p>
                    <strong class="text-indigo-300">
                      {c.recipes.methodLabel}：
                    </strong>
                    {r.method}
                  </p>
                </div>
                <div class="mt-4 border-t border-white/10 pt-3 text-sm">
                  <span class="mr-2 text-xs font-semibold uppercase tracking-wider text-[#94a3b8]">
                    {c.recipes.articlesLabel}
                  </span>
                  {r.articles.map((a, i) => (
                    <Fragment>
                      {i > 0 && <span class="mx-1 text-[#475569]">·</span>}
                      <a
                        href={articleHref(a.href)}
                        class="font-medium text-sky-300 underline-offset-4 hover:underline"
                      >
                        {a.title}
                      </a>
                    </Fragment>
                  ))}
                </div>
              </div>
            ))
          }
        </div>
      </section>

      <!-- 20 domains × 故事地圖 -->
      <section id="domains" class="mt-16">
        <h2 class="mb-2 text-2xl font-bold text-[#f1f5f9]">
          {c.domains.title}
        </h2>
        <p class="mb-7 max-w-[720px] leading-[1.8] text-[#94a3b8]">
          {c.domains.lead}
        </p>
        <div class="grid gap-4 md:grid-cols-2">
          {
            domains.map((d) => {
              const m = domainMapByKey.get(d.key);
              return (
                <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-5">
                  <div class="mb-1 flex items-baseline justify-between gap-3">
                    <h3 class="text-base font-bold text-[#f1f5f9]">
                      {d.name_zh}
                    </h3>
                    <code class="shrink-0 text-[11px] text-[#64748b]">
                      {d.key}
                    </code>
                  </div>
                  <p class="mb-3 text-[13px] leading-[1.7] text-[#8fa0b3]">
                    {d.scope}
                  </p>
                  {d.typical_questions?.length > 0 && (
                    <p class="mb-3 text-[13px] leading-[1.7] text-[#a8b6c8]">
                      <span class="font-semibold text-sky-400/90">
                        {c.domains.questionsLabel}：
                      </span>
                      {d.typical_questions.join('；')}
                    </p>
                  )}
                  {m?.articles ? (
                    <div class="text-sm">
                      <span class="mr-2 text-xs font-semibold uppercase tracking-wider text-[#94a3b8]">
                        {c.domains.articlesLabel}
                      </span>
                      {m.articles.map((a, i) => (
                        <Fragment>
                          {i > 0 && <span class="mx-1 text-[#475569]">·</span>}
                          <a
                            href={articleHref(a.href)}
                            class="font-medium text-sky-300 underline-offset-4 hover:underline"
                          >
                            {a.title}
                          </a>
                        </Fragment>
                      ))}
                    </div>
                  ) : m?.proposed ? (
                    <div class="rounded-xl border border-dashed border-amber-400/30 bg-amber-400/[0.05] p-4">
                      <div class="mb-2 text-sm font-bold leading-snug text-amber-100">
                        <span class="mr-2 rounded bg-amber-400/20 px-1.5 py-0.5 align-[2px] text-[11px] font-bold text-amber-300">
                          {c.domains.blankLabel}
                        </span>
                        {m.proposed.story}
                      </div>
                      <div class="mb-2.5 flex flex-wrap gap-1.5">
                        {m.proposed.datasets.map((d) => (
                          <a
                            href={d.href}
                            target="_blank"
                            rel="noopener"
                            class="rounded-full border border-amber-400/25 bg-amber-400/10 px-2.5 py-0.5 text-[11px] font-medium text-amber-200 transition hover:bg-amber-400/25"
                          >
                            {d.name} · {d.freq}
                          </a>
                        ))}
                      </div>
                      <p class="text-[13px] leading-[1.7] text-[#c8b89a]">
                        <strong class="text-amber-200/90">
                          {c.domains.proposedHowLabel}：
                        </strong>
                        {m.proposed.how}
                      </p>
                    </div>
                  ) : null}
                </div>
              );
            })
          }
        </div>
      </section>

      <!-- 串連方法論 -->
      <section id="method" class="mt-16">
        <h2 class="mb-2 text-2xl font-bold text-[#f1f5f9]">{c.method.title}</h2>
        <p class="mb-7 max-w-[720px] leading-[1.8] text-[#94a3b8]">
          {c.method.lead}
        </p>

        <!-- 更新頻率光譜（本頁引用的 showcase 資料集分桶） -->
        <div
          class="mb-8 rounded-2xl border border-white/10 bg-white/[0.03] p-6"
        >
          <h3 class="mb-1 text-base font-bold text-[#f1f5f9]">
            {c.method.spectrum.title}
          </h3>
          <p class="mb-6 text-[13px] leading-[1.7] text-[#8fa0b3]">
            {c.method.spectrum.note}
          </p>
          <div class="flex items-end gap-2 overflow-x-auto pb-1">
            {
              freqBuckets.map((b) => (
                <div class="flex min-w-[88px] flex-1 flex-col items-center gap-2.5">
                  <div class="flex max-w-[120px] flex-wrap items-end justify-center gap-1.5">
                    {b.items.map((d) => (
                      <span
                        class="block h-4 w-4 cursor-help rounded-full bg-[linear-gradient(135deg,#38bdf8,#818cf8)] opacity-85 transition hover:scale-125 hover:opacity-100"
                        title={`${d.name}（${d.agency}）`}
                      />
                    ))}
                  </div>
                  <div class="h-px w-full bg-white/15" />
                  <div class="text-center text-[12px] font-medium text-[#a8b6c8]">
                    {b.freq.replace('更新', '')}
                    <span class="ml-1 text-[#64748b]">×{b.items.length}</span>
                  </div>
                </div>
              ))
            }
          </div>
          <div class="mt-4 flex flex-wrap justify-between gap-2 text-[12px]">
            <span class="text-[#7dd3fc]">{c.method.spectrum.left}</span>
            <span class="text-[#c8b89a]">{c.method.spectrum.right}</span>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {
            c.method.items.map((m) => (
              <div class="rounded-2xl border border-white/10 bg-white/[0.04] p-5">
                <h3 class="mb-2 text-base font-bold text-[#f1f5f9]">
                  {m.name}
                </h3>
                <p class="text-[13px] leading-[1.75] text-[#a8b6c8]">
                  {m.desc}
                </p>
              </div>
            ))
          }
        </div>
      </section>

      <!-- 工具型錄 -->
      <section id="tools" class="mt-16">
        <h2 class="mb-2 text-2xl font-bold text-[#f1f5f9]">{c.tools.title}</h2>
        <p class="mb-7 max-w-[720px] leading-[1.8] text-[#94a3b8]">
          {c.tools.lead}
        </p>
        <div class="space-y-5">
          {
            toolGroups.map((g) => (
              <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-5">
                <h3 class="mb-3 text-sm font-bold uppercase tracking-wider text-indigo-300">
                  {g.label}
                  <span class="ml-2 font-normal text-[#64748b]">
                    ×{g.items.length}
                  </span>
                </h3>
                <ul class="grid gap-x-8 gap-y-2 md:grid-cols-2">
                  {g.items.map((t) => (
                    <li class="text-[13px] leading-[1.7] text-[#a8b6c8]">
                      <code class="mr-1.5 rounded bg-white/10 px-1.5 py-0.5 text-[12px] text-sky-200">
                        {t.name}
                      </code>
                      {toolFirstLine(t.description)}
                    </li>
                  ))}
                </ul>
              </div>
            ))
          }
          {
            ungrouped.length > 0 && (
              <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-5">
                <ul class="grid gap-x-8 gap-y-2 md:grid-cols-2">
                  {ungrouped.map((t) => (
                    <li class="text-[13px] leading-[1.7] text-[#a8b6c8]">
                      <code class="mr-1.5 rounded bg-white/10 px-1.5 py-0.5 text-[12px] text-sky-200">
                        {t.name}
                      </code>
                      {toolFirstLine(t.description)}
                    </li>
                  ))}
                </ul>
              </div>
            )
          }
        </div>
      </section>

      <!-- pilot 文章 + 收尾 -->
      <section id="pilot" class="mt-16">
        <div
          class="rounded-2xl border border-emerald-400/20 bg-emerald-500/[0.05] p-7"
        >
          <h2 class="mb-2 text-xl font-bold text-[#f1f5f9]">
            {c.footer.pilotTitle}
          </h2>
          <p class="mb-4 max-w-[760px] text-sm leading-[1.8] text-[#a8b6c8]">
            {c.footer.pilotLead}
          </p>
          <div class="flex flex-wrap gap-2">
            {
              c.footer.pilotArticles.map((a) => (
                <a
                  href={articleHref(a.href)}
                  class="rounded-full border border-emerald-400/30 bg-emerald-500/10 px-4 py-1.5 text-sm font-medium text-emerald-200 transition hover:bg-emerald-500/25"
                >
                  {a.title}
                </a>
              ))
            }
          </div>
        </div>
        <p class="mt-8 max-w-[760px] text-sm leading-[1.8] text-[#8fa0b3]">
          {c.footer.note}
        </p>
        <p class="mt-3 text-xs text-[#64748b]">
          {c.footer.crawledLabel}
          {crawledAt} ·
          <a
            href="https://hub.twinkleai.tw/"
            target="_blank"
            rel="noopener"
            class="text-sky-400/80 underline-offset-4 hover:underline"
          >
            hub.twinkleai.tw
          </a>
          ·
          <a
            href="https://data.gov.tw/"
            target="_blank"
            rel="noopener"
            class="text-sky-400/80 underline-offset-4 hover:underline"
          >
            data.gov.tw
          </a>
          🧬
        </p>
      </section>
    </div>
  </main>

  <script is:inline src="https://cdn.jsdelivr.net/npm/d3@7.9.0/dist/d3.min.js"
  ></script>
  <script is:inline>
    // ── 數字帶 count-up ──────────────────────────────────────────────────
    (function () {
      var reduced = window.matchMedia(
        '(prefers-reduced-motion: reduce)',
      ).matches;
      var els = document.querySelectorAll('.stat-n');
      function setFinal(el) {
        el.textContent =
          Number(el.dataset.count).toLocaleString('en-US') +
          (el.dataset.suffix || '');
      }
      if (reduced || !('IntersectionObserver' in window)) {
        els.forEach(setFinal);
        return;
      }
      var io = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (e) {
            if (!e.isIntersecting) return;
            io.unobserve(e.target);
            var el = e.target;
            var target = Number(el.dataset.count);
            var suffix = el.dataset.suffix || '';
            var t0 = performance.now();
            var dur = 1400;
            (function tick(now) {
              var p = Math.min((now - t0) / dur, 1);
              var eased = 1 - Math.pow(1 - p, 3);
              el.textContent =
                Math.round(target * eased).toLocaleString('en-US') +
                (p === 1 ? suffix : '');
              if (p < 1) requestAnimationFrame(tick);
            })(t0);
          });
        },
        { threshold: 0.4 },
      );
      els.forEach(function (el) {
        io.observe(el);
      });
    })();

    // ── 資料星系：20 領域 × 5 語料庫 × 文章 的 force graph ────────────────
    (function () {
      var host = document.getElementById('opendata-galaxy');
      var dataEl = document.getElementById('opendata-graph-data');
      if (!host || !dataEl || typeof d3 === 'undefined') return;
      var data = JSON.parse(dataEl.textContent);
      var reduced = window.matchMedia(
        '(prefers-reduced-motion: reduce)',
      ).matches;
      var W = host.clientWidth;
      var H = host.clientHeight;
      var narrow = W < 700;

      var COLOR = {
        domain: '#38bdf8',
        vertical: '#c084fc',
        article: '#34d399',
        center: '#34d399',
      };
      function radius(n) {
        if (n.type === 'center') return narrow ? 22 : 30;
        if (n.type === 'vertical')
          return n.count
            ? 10 + Math.log10(n.count) * (narrow ? 2.2 : 3.2)
            : narrow
              ? 14
              : 20;
        if (n.type === 'domain') return narrow ? 9 : 13;
        return narrow ? 5.5 : 8;
      }
      // type → 水平帶：語料庫(最左) → 領域 → 意義層 → 文章(最右)
      function bandX(n) {
        if (n.type === 'vertical') return W * 0.12;
        if (n.type === 'domain') return W * 0.32;
        if (n.type === 'center') return W * 0.58;
        return W * 0.82;
      }

      var svg = d3
        .select(host)
        .append('svg')
        .attr('width', W)
        .attr('height', H)
        .attr('viewBox', '0 0 ' + W + ' ' + H);

      var link = svg
        .append('g')
        .selectAll('line')
        .data(data.links)
        .join('line')
        .attr('stroke', function (l) {
          return l.kind === 'curation'
            ? '#34d399'
            : l.kind === 'corpus'
              ? '#c084fc'
              : '#38bdf8';
        })
        .attr('stroke-opacity', function (l) {
          return l.kind === 'spine' ? 0.12 : 0.35;
        })
        .attr('stroke-width', function (l) {
          return l.kind === 'spine' ? 1 : 1.4;
        });

      var node = svg
        .append('g')
        .selectAll('circle')
        .data(data.nodes)
        .join('circle')
        .attr('r', radius)
        .attr('fill', function (n) {
          return n.type === 'center' ? 'transparent' : COLOR[n.type];
        })
        .attr('fill-opacity', function (n) {
          return n.type === 'article' ? 0.85 : 0.75;
        })
        .attr('stroke', function (n) {
          return n.type === 'center' ? COLOR.center : 'rgba(255,255,255,0.25)';
        })
        .attr('stroke-width', function (n) {
          return n.type === 'center' ? 2 : 1;
        })
        .style('cursor', function (n) {
          return n.type === 'article' || n.type === 'domain'
            ? 'pointer'
            : 'grab';
        });

      var labelData = data.nodes.filter(function (n) {
        if (n.type === 'article') return !narrow;
        return true;
      });
      var label = svg
        .append('g')
        .selectAll('text')
        .data(labelData)
        .join('text')
        .text(function (n) {
          if (n.type === 'center') return n.label + ' 🧬';
          // 長領域名只顯示第一段，完整名在 tooltip
          if (n.type === 'domain') return n.label.split(/[、／（]/)[0];
          return n.label;
        })
        .attr('font-size', function (n) {
          return n.type === 'center' ? 13 : n.type === 'article' ? 10 : 11;
        })
        .attr('fill', function (n) {
          return n.type === 'article' ? '#86efac' : '#cbd5e1';
        })
        .attr('text-anchor', 'middle')
        .attr('pointer-events', 'none')
        .attr('paint-order', 'stroke')
        .attr('stroke', '#090e1b')
        .attr('stroke-width', 3);

      var tip = document.createElement('div');
      tip.style.cssText =
        'position:absolute;pointer-events:none;background:rgba(8,12,22,0.95);border:1px solid rgba(255,255,255,0.15);color:#e2e8f0;font-size:12px;padding:6px 10px;border-radius:8px;opacity:0;transition:opacity .15s;max-width:240px;z-index:5;';
      host.appendChild(tip);

      var sim = d3
        .forceSimulation(data.nodes)
        .force(
          'link',
          d3
            .forceLink(data.links)
            .id(function (n) {
              return n.id;
            })
            .distance(function (l) {
              return l.kind === 'spine'
                ? narrow
                  ? 90
                  : 150
                : narrow
                  ? 50
                  : 80;
            })
            .strength(function (l) {
              return l.kind === 'spine' ? 0.04 : 0.3;
            }),
        )
        .force('charge', d3.forceManyBody().strength(narrow ? -60 : -110))
        .force(
          'x',
          d3.forceX(bandX).strength(function (n) {
            return n.type === 'center' ? 0.5 : 0.18;
          }),
        )
        .force('y', d3.forceY(H / 2).strength(0.08))
        .force(
          'collide',
          d3.forceCollide(function (n) {
            // domain 節點多留 label 空間，避免文字互疊
            var pad = n.type === 'domain' ? (narrow ? 14 : 22) : narrow ? 4 : 8;
            return radius(n) + pad;
          }),
        );

      sim.on('tick', function () {
        data.nodes.forEach(function (n) {
          var r = radius(n);
          n.x = Math.max(r + 4, Math.min(W - r - 4, n.x));
          n.y = Math.max(r + 14, Math.min(H - r - 8, n.y));
        });
        link
          .attr('x1', function (l) {
            return l.source.x;
          })
          .attr('y1', function (l) {
            return l.source.y;
          })
          .attr('x2', function (l) {
            return l.target.x;
          })
          .attr('y2', function (l) {
            return l.target.y;
          });
        node
          .attr('cx', function (n) {
            return n.x;
          })
          .attr('cy', function (n) {
            return n.y;
          });
        label
          .attr('x', function (n) {
            return n.x;
          })
          .attr('y', function (n) {
            return n.y - radius(n) - 5;
          });
      });

      if (reduced) {
        sim.tick(300);
        sim.stop();
      }

      node.call(
        d3
          .drag()
          .on('start', function (ev, n) {
            if (!ev.active && !reduced) sim.alphaTarget(0.25).restart();
            n.fx = n.x;
            n.fy = n.y;
          })
          .on('drag', function (ev, n) {
            n.fx = ev.x;
            n.fy = ev.y;
          })
          .on('end', function (ev, n) {
            if (!ev.active) sim.alphaTarget(0);
            n.fx = null;
            n.fy = null;
          }),
      );

      function neighborsOf(id) {
        var set = {};
        data.links.forEach(function (l) {
          if (l.source.id === id) set[l.target.id] = true;
          if (l.target.id === id) set[l.source.id] = true;
        });
        return set;
      }
      node
        .on('mouseenter', function (ev, n) {
          var nb = neighborsOf(n.id);
          node.attr('opacity', function (m) {
            return m.id === n.id || nb[m.id] ? 1 : 0.18;
          });
          link.attr('stroke-opacity', function (l) {
            return l.source.id === n.id || l.target.id === n.id ? 0.7 : 0.05;
          });
          var kind =
            n.type === 'domain'
              ? '資料領域'
              : n.type === 'vertical'
                ? '垂直語料庫' +
                  (n.count
                    ? '・' + n.count.toLocaleString('en-US') + ' 筆'
                    : '')
                : n.type === 'article'
                  ? 'Taiwan.md 文章・點擊閱讀'
                  : '意義策展層';
          tip.innerHTML = '<strong>' + n.label + '</strong><br>' + kind;
          tip.style.opacity = '1';
        })
        .on('mousemove', function (ev) {
          var rect = host.getBoundingClientRect();
          tip.style.left =
            Math.min(ev.clientX - rect.left + 14, W - 250) + 'px';
          tip.style.top = ev.clientY - rect.top + 10 + 'px';
        })
        .on('mouseleave', function () {
          node.attr('opacity', 1);
          link.attr('stroke-opacity', function (l) {
            return l.kind === 'spine' ? 0.12 : 0.35;
          });
          tip.style.opacity = '0';
        })
        .on('click', function (ev, n) {
          if (n.type === 'article' && n.href) window.location.href = n.href;
          if (n.type === 'domain') {
            var sec = document.getElementById('domains');
            if (sec)
              sec.scrollIntoView({ behavior: reduced ? 'auto' : 'smooth' });
          }
        });
    })();
  </script>
</Layout>
