        </div>
        <div class="grid grid-cols-[repeat(auto-fill,minmax(280px,1fr))] gap-5">
          {
            otherCategories.map((cat) => (
              <a
                href={`/${cat.key}`}
                class="flex overflow-hidden rounded-2xl border border-[rgba(26,60,52,0.06)] bg-white no-underline shadow-[0_2px_8px_rgba(26,60,52,0.05)] transition-[transform,box-shadow] duration-[250ms] hover:-translate-y-1 hover:shadow-[0_8px_32px_rgba(26,60,52,0.12)]"
              >
                <div
                  class="w-[5px] flex-shrink-0"
                  style={`background:${cat.color};`}
                  aria-hidden="true"
                />
                <div class="flex flex-col gap-[0.4rem] px-6 py-[1.4rem]">
                  <span
                    class="font-['Inter',system-ui,sans-serif] text-[0.92rem] font-bold -tracking-[0.01em]"
                    style={`color:${cat.color};`}
                  >
                    {cat.name}
                  </span>
                  <p class="m-0 font-['Inter',system-ui,sans-serif] text-[0.82rem] leading-[1.55] text-[#6a7d72]">
                    {cat.description}
                  </p>
                  <span
                    class="mt-[0.35rem] inline-flex items-center gap-[0.3rem] font-['Inter',system-ui,sans-serif] text-[0.78rem] font-semibold"
                    style={`color:${cat.color};`}
                  >
                    {t('article.startExplore')}
                    <svg
                      width="12"
                      height="12"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2.5"
                      aria-hidden="true"
                    >
                      <polyline points="9 18 15 12 9 6" />
                    </svg>
                  </span>
                </div>
              </a>
            ))
          }
        </div>
      </div>
    </section>
  </main>

  {
    /* Tag the markdown-rendered footnote section as a tracked landmark so the
      site-wide EventTracker (mounted in Layout) observes it — lets us see how
      far readers get, esp. 延伸閱讀 / footnotes. */
  }
  <script is:inline>
    (function () {
      var fn = document.querySelector('.prose .footnotes');
      if (fn && !fn.hasAttribute('data-ga-view'))
        fn.setAttribute('data-ga-view', 'footnotes');
    })();
  </script>
</Layout>

<!-- Screenshot mode (?shot=1) 的 JS toggle + CSS 已搬到 src/layouts/Layout.astro
     + src/styles/shot-mode.css（2026-04-22 β），四語言 article page 共用。 -->

<script>
  // Reading progress bar
  function updateProgress() {
    const body = document.querySelector('.prose') as HTMLElement;
    if (!body) return;
    const scrolled = window.scrollY;
    const top = body.offsetTop;
    const height = body.offsetHeight;
    const winH = window.innerHeight;
    const progress = Math.min(
      Math.max(((scrolled - top + winH * 0.3) / height) * 100, 0),
      100,
    );
    const bar = document.getElementById('reading-progress');
    if (bar) bar.style.width = progress + '%';
  }
  window.addEventListener('scroll', updateProgress, { passive: true });
  window.addEventListener('resize', updateProgress, { passive: true });
  updateProgress();

  // Bottom copy button
  const copyBtnBottom =
    document.querySelector<HTMLButtonElement>('.copy-btn-bottom');
  if (copyBtnBottom) {
    copyBtnBottom.addEventListener('click', () => {
      navigator.clipboard
        .writeText(window.location.href)
        .then(() => {
          copyBtnBottom.style.color = '#006D77';
          setTimeout(() => {
            copyBtnBottom.style.color = '';
          }, 2200);
        })
        .catch(() => {
          const ta = document.createElement('textarea');
          ta.value = window.location.href;
          document.body.appendChild(ta);
          ta.select();
          document.execCommand('copy');
          document.body.removeChild(ta);
        });
    });
  }
</script>

<script define:vars={{ randomIndexUrl, category }}>
  const btn = document.getElementById('randomBtn');
  if (btn) {
    let poolPromise = null;
    const loadPool = () => {
      poolPromise ??= fetch(randomIndexUrl)
        .then((r) => (r.ok ? r.json() : null))
        .then((data) => {
          if (!data?.byCat) return [];
          // 維持原行為：隨機池排除當前分類
          return Object.entries(data.byCat)
            .filter(([cat]) => cat !== category)
            .flatMap(([, hrefs]) => hrefs);
        })
        .catch(() => []);
      return poolPromise;
    };
    // hover/touch 預熱，click 時通常已就緒
    btn.addEventListener('mouseenter', loadPool, { once: true });
    btn.addEventListener('touchstart', loadPool, { once: true, passive: true });
    btn.addEventListener('click', async () => {
      const pool = await loadPool();
      if (pool.length) {
        window.location.href = pool[Math.floor(Math.random() * pool.length)];
      }
    });
  }
</script>

<style
  define:vars={{
    catColor: categoryInfo.color,
    catColorLight: categoryInfo.colorLight,
    proseFont,
  }}
>
  /* ── Screenshot mode (?shot=1) global overrides moved to <style is:global>
     above the main <style> block — Astro scoped CSS doesn't cross
     component boundaries (ArticleHero section, Layout header/footer).
     ──────────────────────────────────────────────────────────────────── */

  /* ── Reading progress ──────────────────────────────────────────────────── */
  /* ── Reading progress (JS animates width via requestAnimationFrame,
     `var(--catColor)` comes from the `define:vars` block above) ─ */
  .reading-progress {
    position: fixed;
    top: 0;
    left: 0;
    width: 0%;
    height: 3px;
    background: var(--catColor);
    z-index: 9999;
    transition: width 0.1s linear;
  }

  /* ── Prose (article body rendered via `set:html={processedContent}`
     — these `:global()` rules are essential because the markdown
     elements can't be reached by Tailwind classes) ─────────────── */
  .prose {
    font-family: var(--proseFont);
    font-size: 1.05rem;
    line-height: 1.72;
    color: #2c2c2c;
  }

  .prose :global(h1) {
    font-size: clamp(1.6rem, 3vw, 2.1rem);
    font-weight: 700;
    color: #0e3a5c;
    margin: 2.5rem 0 1rem;
    line-height: 1.25;
