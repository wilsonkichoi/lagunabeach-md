      )
    }

    <!-- ── Explore other categories ──────────────────────────────── -->
    <section class="bg-[#f8f1e9] px-8 py-20 max-[640px]:px-4 max-[640px]:py-14">
      <div class="mx-auto max-w-[var(--container-article)]">
        <div class="mb-12 text-center">
          <p
            class="mb-[0.6rem] font-['Inter',system-ui,sans-serif] text-[0.72rem] font-semibold uppercase tracking-[0.2em] text-[#9aa89e]"
          >
            {t('article.exploreTaiwan')}
          </p>
          <h2
            class="font-['Inter',serif] text-[clamp(1.5rem,3vw,2rem)] font-bold leading-[1.25] text-[#1a3c34]"
          >
            {t('article.moreAspects')}
          </h2>
        </div>
        <div class="grid grid-cols-[repeat(auto-fill,minmax(280px,1fr))] gap-5">
          {
            otherCategories.map((cat) => (
              <a
                href={`/${cat.key}`}
                class="flex overflow-hidden rounded-2xl border border-[rgba(26,60,52,0.06)] bg-white no-underline shadow-[0_2px_8px_rgba(26,60,52,0.05)] transition-[transform,box-shadow] duration-[250ms] hover:-translate-y-1 hover:shadow-[0_8px_32px_rgba(26,60,52,0.12)]"
              >
                <div
                  class="w-[5px] flex-shrink-0"
                  style={`background:${cat.color};`}
                  aria-hidden="true"
                />
                <div class="flex flex-col gap-[0.4rem] px-6 py-[1.4rem]">
                  <span
                    class="font-['Inter',system-ui,sans-serif] text-[0.92rem] font-bold -tracking-[0.01em]"
                    style={`color:${cat.color};`}
                  >
                    {cat.name}
                  </span>
                  <p class="m-0 font-['Inter',system-ui,sans-serif] text-[0.82rem] leading-[1.55] text-[#6a7d72]">
                    {cat.description}
                  </p>
                  <span
                    class="mt-[0.35rem] inline-flex items-center gap-[0.3rem] font-['Inter',system-ui,sans-serif] text-[0.78rem] font-semibold"
                    style={`color:${cat.color};`}
                  >
                    {t('article.startExplore')}
                    <svg
                      width="12"
                      height="12"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2.5"
                      aria-hidden="true"
                    >
                      <polyline points="9 18 15 12 9 6" />
                    </svg>
                  </span>
                </div>
              </a>
            ))
          }
        </div>
      </div>
    </section>
  </main>
</Layout>

<!-- Screenshot mode (?shot=1) 的 JS toggle + CSS 已搬到 src/layouts/Layout.astro
     + src/styles/shot-mode.css（2026-04-22 β），四語言 article page 共用。 -->

<script>
  // Reading progress bar
  function updateProgress() {
    const body = document.querySelector('.prose') as HTMLElement;
    if (!body) return;
    const scrolled = window.scrollY;
    const top = body.offsetTop;
    const height = body.offsetHeight;
    const winH = window.innerHeight;
    const progress = Math.min(
      Math.max(((scrolled - top + winH * 0.3) / height) * 100, 0),
      100,
    );
    const bar = document.getElementById('reading-progress');
    if (bar) bar.style.width = progress + '%';
  }
  window.addEventListener('scroll', updateProgress, { passive: true });
  window.addEventListener('resize', updateProgress, { passive: true });
  updateProgress();

  // Bottom copy button
  const copyBtnBottom =
    document.querySelector<HTMLButtonElement>('.copy-btn-bottom');
  if (copyBtnBottom) {
    copyBtnBottom.addEventListener('click', () => {
      navigator.clipboard
        .writeText(window.location.href)
        .then(() => {
          copyBtnBottom.style.color = '#006D77';
          setTimeout(() => {
            copyBtnBottom.style.color = '';
          }, 2200);
        })
        .catch(() => {
          const ta = document.createElement('textarea');
          ta.value = window.location.href;
          document.body.appendChild(ta);
          ta.select();
          document.execCommand('copy');
          document.body.removeChild(ta);
        });
    });
  }
</script>

<script define:vars={{ allArticles }}>
  const btn = document.getElementById('randomBtn');
  if (btn && allArticles?.length) {
    btn.addEventListener('click', () => {
      const pick = allArticles[Math.floor(Math.random() * allArticles.length)];
      window.location.href = '/' + pick.category + '/' + pick.slug;
    });
  }
</script>

<style
  define:vars={{
    catColor: categoryInfo.color,
    catColorLight: categoryInfo.colorLight,
    proseFont,
  }}
>
  /* ── Screenshot mode (?shot=1) global overrides moved to <style is:global>
     above the main <style> block — Astro scoped CSS doesn't cross
     component boundaries (ArticleHero section, Layout header/footer).
     ──────────────────────────────────────────────────────────────────── */

  /* ── Reading progress ──────────────────────────────────────────────────── */
  /* ── Reading progress (JS animates width via requestAnimationFrame,
     `var(--catColor)` comes from the `define:vars` block above) ─ */
  .reading-progress {
    position: fixed;
    top: 0;
    left: 0;
    width: 0%;
    height: 3px;
    background: var(--catColor);
    z-index: 9999;
    transition: width 0.1s linear;
  }

  /* ── Prose (article body rendered via `set:html={processedContent}`
     — these `:global()` rules are essential because the markdown
     elements can't be reached by Tailwind classes) ─────────────── */
  .prose {
    font-family: var(--proseFont);
    font-size: 1.05rem;
    line-height: 1.72;
    color: #2c2c2c;
  }

  .prose :global(h1) {
    font-size: clamp(1.6rem, 3vw, 2.1rem);
    font-weight: 700;
    color: #1a3c34;
    margin: 2.5rem 0 1rem;
    line-height: 1.25;
    letter-spacing: 0.01em;
  }
  .prose :global(h2) {
    font-size: clamp(1.3rem, 2.5vw, 1.65rem);
    font-weight: 700;
    color: #1a3c34;
    margin: 2.5rem 0 0.85rem;
    padding-bottom: 0.5rem;
    border-bottom: 1.5px solid rgba(26, 60, 52, 0.12);
    line-height: 1.3;
  }
  .prose :global(h3) {
    font-size: clamp(1.05rem, 2vw, 1.25rem);
    font-weight: 600;
    color: #1a3c34;
    margin: 1.75rem 0 0.65rem;
    padding-left: 0.85rem;
    border-left: 3px solid var(--catColor);
    line-height: 1.35;
  }
  .prose :global(h4) {
    font-size: 1rem;
    font-weight: 600;
    color: #3a4f44;
    margin: 1.25rem 0 0.5rem;
  }

  .prose :global(p) {
    margin-bottom: 1.1rem;
    color: #2c2c2c;
  }

  .prose :global(a) {
    color: #006d77;
    text-decoration: underline;
    text-decoration-color: rgba(0, 109, 119, 0.35);
    text-underline-offset: 3px;
    /* Cancel global.css's `main a:not(...)` border-bottom — that rule lives
       inside `@layer base` so unlayered rules (this one) win for declared
       properties only. Without explicitly nulling border-bottom, BOTH the
       layered border AND this layer's text-decoration render → visible
       double underline (reported 2026-05-04). */
    border-bottom: none;
    padding-bottom: 0;
    transition: text-decoration-color 0.2s;
  }
  .prose :global(a:hover) {
    text-decoration-color: #006d77;
  }

  .prose :global(ul) {
    list-style: disc;
    padding-left: 1.5rem;
    margin-bottom: 1.1rem;
  }
  .prose :global(ol) {
    list-style: decimal;
    padding-left: 1.5rem;
    margin-bottom: 1.1rem;
  }
  .prose :global(li) {
    margin-bottom: 0.3rem;
    line-height: 1.65;
  }

  .prose :global(blockquote) {
    border-left: 4px solid var(--catColor);
    background: linear-gradient(to right, rgba(26, 60, 52, 0.04), transparent);
    margin: 2.5rem 0;
    padding: 1.5rem 1.75rem;
    border-radius: 0 12px 12px 0;
    font-style: italic;
    color: #3a4f44;
    font-size: 1.05rem;
  }
  .prose :global(blockquote p) {
    margin-bottom: 0;
  }

  .prose :global(strong) {
    font-weight: 700;
    color: #1a3c34;
  }

  .prose :global(code) {
    font-family: 'Courier New', monospace;
    font-size: 0.88em;
    background: rgba(26, 60, 52, 0.06);
    color: #1a3c34;
    padding: 0.15em 0.45em;
    border-radius: 4px;
  }

  .prose :global(pre) {
    background: #1a3c34;
    color: #f8f1e9;
    padding: 1.5rem;
    border-radius: 12px;
    overflow-x: auto;
    margin: 2rem 0;
    font-size: 0.875rem;
  }
  .prose :global(pre code) {
    background: transparent;
    color: inherit;
    padding: 0;
    font-size: inherit;
  }

  /* Image wrapper */
  .prose :global(p:has(img)) {
    margin: 2.5rem 0;
    text-align: center;
  }
  .prose :global(img) {
    width: 100%;
    max-height: 480px;
    object-fit: cover;
    border-radius: 12px;
    margin: 0;
    box-shadow: 0 4px 24px rgba(26, 60, 52, 0.1);
  }
  /* Hide the <br> between img and em */
  .prose :global(p:has(img) br) {
    display: none;
  }
  /* Caption style */
  .prose :global(p:has(img) em) {
    display: block;
    margin-top: 0.4rem;
    font-size: 0.85rem;
    color: #6a7d72;
    font-style: italic;
    text-align: center;
  }
  .prose :global(img.img-broken) {
    min-height: 120px;
    background: rgba(26, 60, 52, 0.04);
    border: 2px dashed rgba(26, 60, 52, 0.15);
    border-radius: 12px;
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 2rem 0;
    font-size: 0.9rem;
  }
  .prose :global(th) {
    background: rgba(26, 60, 52, 0.05);
    color: #1a3c34;
    font-weight: 600;
    text-align: left;
    padding: 0.75rem 1rem;
    border-bottom: 2px solid rgba(26, 60, 52, 0.12);
  }
  .prose :global(td) {
    padding: 0.65rem 1rem;
    border-bottom: 1px solid rgba(26, 60, 52, 0.06);
    color: #3a4f44;
  }
  .prose :global(tr:hover td) {
    background: rgba(26, 60, 52, 0.02);
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid rgba(26, 60, 52, 0.1);
    margin: 3rem 0;
  }

  /* ── Footnotes ──────────────────────────────────────────────────────────── */

  /* Footnote section (文末 section.footnotes) */
  .prose :global(.footnotes) {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid #e5e7eb;
    font-size: 0.85rem;
    line-height: 1.6;
    color: #6b7280;
  }

  .prose :global(.footnotes ol) {
    padding-left: 1.5rem;
    margin: 0;
  }

  .prose :global(.footnotes li) {
    margin-bottom: 0.5rem;
    line-height: 1.6;
  }

  .prose :global(.footnotes li p) {
    display: inline;
    margin: 0;
    color: #6b7280;
  }

  .prose :global(.footnotes a) {
    color: #6b7280;
    text-decoration: underline;
    text-decoration-color: rgba(107, 114, 128, 0.4);
    text-underline-offset: 2px;
  }
  .prose :global(.footnotes a:hover) {
    color: #374151;
    text-decoration-color: #6b7280;
  }

  /* Inline superscript footnote reference */
  .prose :global(sup) {
    line-height: 0; /* don't affect line-height */
    font-size: 0.75em;
    vertical-align: super;
  }

  .prose :global(.footnote-ref) {
    color: #2563eb;
    font-weight: 600;
    text-decoration: none;
    border-bottom: none;
    padding: 0 0.05em;
    transition:
      color 0.15s,
      text-decoration-color 0.15s;
  }
  .prose :global(.footnote-ref:hover) {
    color: #1d4ed8;
    text-decoration: underline;
    text-decoration-color: #2563eb;
  }

  /* Back-arrow (↩) */
  .prose :global(.footnote-backref) {
    margin-left: 0.35em;
    color: #9ca3af;
    font-size: 0.9em;
    text-decoration: none;
    border-bottom: none;
    transition: color 0.15s;
  }
  .prose :global(.footnote-backref:hover) {
    color: #6b7280;
    text-decoration: none;
  }

  /* Mobile: bigger tap targets */
  @media (max-width: 768px) {
    .prose :global(.footnote-ref) {
      padding: 0.5rem 0.3rem;
      margin: -0.5rem -0.3rem;
    }
    .prose :global(.footnote-backref) {
      padding: 0.5rem 0.4rem;
      margin: -0.5rem -0.4rem;
      display: inline-block;
