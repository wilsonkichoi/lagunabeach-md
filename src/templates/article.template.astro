---
/**
 * article.template.astro — 統一 article page template (6 langs 共用)
 *
 * 為什麼: 之前 6 個 [slug].astro × 1100~1300 行 = ~7400 行高度重複；發現過 PR #758
 * ship es/fr 帶 JA copy-paste bug (related articles 顯示日文 / es/fr getStaticPaths
 * 用 zhToJa 過濾)。Template unification 一次性消除這類 class of bug。
 *
 * 對照 about/dashboard pattern：
 *   src/pages/about.astro                → 5 行 <AboutTemplate />
 *   src/templates/about.template.astro   → 全部 UI 邏輯
 *
 * 中文 zh-TW 是 SSOT canonical，本 template 從 src/pages/[category]/[slug].astro
 * 複製過來，再 parameterize on lang prop。其他 5 langs 的差異全變 prop / data。
 *
 * 2026-05-03 sleepy-colden Tier 2.5 unified template extraction (Phase B)。
 */
import Layout from '../layouts/Layout.astro';
import { renderArticleHtml } from '../utils/article-render';
import ArticleHero from '../components/ArticleHero.astro';
import TableOfContents from '../components/TableOfContents.astro';
import ArticleSidebar from '../components/ArticleSidebar.astro';
import ArticleCard from '../components/ArticleCard.astro';
import Perspectives from '../components/Perspectives.astro';
import SporeFootprint from '../components/SporeFootprint.astro';
import DiaryTeaser from '../components/DiaryTeaser.astro';
import RelatedDiaries from '../components/RelatedDiaries.astro';
import { useTranslations } from '../i18n/utils';
import {
  categoryList as categories,
  getCategoryConfigs,
  type CategoryKey,
} from '../utils/categoryConfig';
import {
  buildGitInfoCache,
  emptyGitInfo,
  type GitInfo,
} from '../utils/contributors';
import { getRelatedArticles, getAllArticles } from '../utils/articles-index';
import { resolve, join } from 'path';
import type { Lang } from '../config/languages';
import contentDatesData from '../data/content-dates.json';

interface Props {
  title: string;
  description: string;
  content: string;
  frontmatter: Record<string, any>;
  lang: Lang;
  contributors?: any[];
  lastModified?: string;
  category: string;
  slug: string;
}

const {
  title,
  description,
  content,
  frontmatter,
  lang,
  contributors: propsContributors = [],
  lastModified: propsLastModified = '',
  category,
  slug,
} = Astro.props;

// ── SEO freshness dates (reports/seo-optimization-plan-2026-06-07.md §1.1) ──
// dateModified comes from content-dates.json (git last-meaningful-commit,
// cosmetic-filtered) so EVOLVE'd articles signal real freshness instead of a
// build-time "now". frontmatter.modified (set by EVOLVE) is the explicit
// override; falls back to git date → publish date. Same source as the sitemap
// <lastmod> so visible/structured dates stay consistent (a Google requirement).
const _seoUrlPath =
  lang === 'en' ? `/${category}/${slug}/` : `/${lang}/${category}/${slug}/`;
const _toISO = (v: unknown): string | undefined =>
  v instanceof Date ? v.toISOString() : typeof v === 'string' ? v : undefined;
const seoDatePublished = _toISO(frontmatter.date);
const seoDateModified =
  _toISO(frontmatter.modified) ||
  ((contentDatesData as { dates?: Record<string, string> }).dates || {})[
    _seoUrlPath
  ] ||
  seoDatePublished;

// ── Lang-derived helpers ─────────────────────────────────────────────────────
// langPath: '' for zh-TW (SSOT root), else '{lang}/' for non-default langs.
// Used for: knowledge folder path, github edit URL, taiwan.md article URL.
const langPath = lang === 'en' ? '' : `${lang}/`;
const langUrlPrefix = lang === 'en' ? '' : `/${lang}`;

// Per-lang prose font (wired into <style define:vars> below as --prose-font).
// zh-TW uses jf-jinxuanlatte (justfont 金萱拿鐵) to match site body cascade
// — restored 2026-05-04 after Tailwind migration silently flipped it to
// Noto Serif TC. en/es/fr use Inter; ja/ko use Noto Serif JP/KR.
const proseFontMap: Record<string, string> = {
  'zh-TW': "'jf-jinxuanlatte','Noto Sans TC','Source Han Sans TC',sans-serif",
  en: "'Inter',system-ui,sans-serif",
  ja: "'Noto Serif JP',serif",
  ko: "'Noto Serif KR',serif",
  es: "'Inter',system-ui,sans-serif",
  fr: "'Inter',system-ui,sans-serif",
};
const proseFont = proseFontMap[lang] ?? proseFontMap['zh-TW'];

// ── Category → folder mapping ─────────────────────────────────────────────────
const categoryMapping: Record<string, string> = {
  history: 'History',
  'art-galleries': 'Art & Galleries',
  'nature-marine-life': 'Nature & Marine Life',
  food: 'Food',
  beaches: 'Beaches',
  trails: 'Trails',
  'events-festivals': 'Events & Festivals',
  neighborhoods: 'Neighborhoods',
};

// ── Git info ─────────────────────────────────────────────────────────────────
// buildGitInfoCache 在 utils/contributors.ts 內按 knowledgePath memoize：
// 整個 build 每語言只跑一次 git log。cache 不能放這裡 — frontmatter 是
// per-render scope，放這裡 = 每頁重跑 git log 子程序（2026-06-13 修掉的 bug）。
function getGitInfoForLang(lang: Lang, filePath: string): GitInfo {
  const knowledgeBase = lang === 'en' ? 'knowledge/' : `knowledge/${lang}/`;
  return buildGitInfoCache(knowledgeBase).get(filePath) || emptyGitInfo();
}

// Compute git info at render time (not from props) so it's always fresh
const _renderFilePath = (() => {
  const folderName = categoryMapping[category as string];
  if (!folderName) return '';
  const knowledgeRoot =
    lang === 'en'
      ? resolve(process.cwd(), 'knowledge', folderName)
      : resolve(process.cwd(), 'knowledge', lang, folderName);
  return join(knowledgeRoot, slug + '.md').normalize('NFC');
})();
const _renderGitInfo = _renderFilePath
  ? getGitInfoForLang(lang, _renderFilePath)
  : { contributors: [], lastModified: '', commitHash: '', revisionCount: 0 };
const contributors = _renderGitInfo.contributors.length
  ? _renderGitInfo.contributors
  : propsContributors;
const lastModified = _renderGitInfo.lastModified || propsLastModified;
const commitHash = _renderGitInfo.commitHash;
const revisionCount = _renderGitInfo.revisionCount;

const t = useTranslations(lang);
const categoryConfigs = getCategoryConfigs(t);
const categoryInfo = categoryConfigs[category as CategoryKey];
if (!categoryInfo) throw new Error(`Unknown category: ${category}`);

// ── Related articles (semantic neighbours) ───────────────────────────────────
// 2026-06-14 RAG Phase 1：getRelatedArticles 改讀 bge-m3 語意鄰居（跨 category、
// 依意思而非同類）— src/data/related/{lang}.json 離線預算、烘進 HTML、零瀏覽器
// 模型；語意索引缺檔時自動 fallback 回同 category。Tier 1.4 shared cache 不變。
// 預抓 8 篇當備用（資料層 TOP_K=8）；前端響應式呈現 4/3/3（桌機/平板/手機）。
let relatedArticles: any[] = [];
try {
  relatedArticles = await getRelatedArticles(
    lang,
    category as string,
    slug as string,
    8,
  );
} catch {}

// ── Random explore ───────────────────────────────────────────────────────────
// 2026-06-10 build audit §5.1: 原本把整語言文章清單 define:vars 內嵌進每一頁
// （~50KB × 4,895 頁 ≈ dist +250MB）。改為按鈕 click 時 lazy fetch per-lang
// 共用 pool（build-latest.mjs 產 /api/random-index-{lang}.json），frontmatter
// 只留「有沒有得跳」的布林。pool href 自帶 lang prefix（順手修譯文頁隨機
// 跳轉漏 /en 前綴的 latent bug）。
let hasRandomPool = false;
try {
  hasRandomPool = (await getAllArticles(lang, category as string)).length > 0;
} catch {}
const randomIndexUrl = `/api/random-index-${lang}.json`;

// ── Other categories (for "Explore more") ────────────────────────────────────
const otherCategories = categories
  .filter((cat) => cat !== category)
  .slice(0, 3)
  .map((cat) => ({ key: cat, ...categoryConfigs[cat as CategoryKey] }));

// Localized category meta (name/color/icon) for the client-side 站上最新 rail —
// fills the cloned ArticleCard (premium) slots (badge / cover icon / colours)
// per latest item, without a per-item server render (keeps freshness).
const latestCatMeta = Object.fromEntries(
  categories.map((c) => {
    const cfg = categoryConfigs[c as CategoryKey];
    return [
      c,
      {
        name: cfg?.name ?? c,
        color: cfg?.color ?? '#475569',
        icon: cfg?.icon ?? '📄',
      },
    ];
  }),
);

// ── Markdown → HTML ─────────────────────────────────────────────────────────
// Pipeline 本體（17 tw-* 模組 renderer / 腳註 / wikilink / 延伸閱讀 split）住在
// src/utils/article-render.ts — module scope，整個 build 只配置一次（.astro
// frontmatter 是 per-render scope，不放可共享的邏輯與 cache）。
const { fullHtml, splitIndex } = renderArticleHtml(title, content);

const hasSSoDT =
  frontmatter.perspectives?.length > 0 ||
  frontmatter.sporeLinks?.length > 0 ||
  frontmatter.diaryLink;
const contentBeforeReading =
  splitIndex !== -1 && hasSSoDT ? fullHtml.slice(0, splitIndex) : fullHtml;
const contentAfterReading =
  splitIndex !== -1 && hasSSoDT ? fullHtml.slice(splitIndex) : '';
const processedContent = fullHtml;

// ── Estimate reading time if not in frontmatter ────────────────────────────────
const estimatedReadingTime =
  frontmatter.readingTime ||
  Math.max(1, Math.round(content.replace(/\s+/g, ' ').length / 500));

const articleUrl = `https://lagunabeach.md${langUrlPrefix}/${category}/${slug}`;
const encodedUrl = encodeURIComponent(articleUrl);
const encodedTitle = encodeURIComponent(title);

// ── Screenshot mode (?shot=1) — toggled client-side ────────────────────────
// Astro static build strips search params at prerender; so a tiny inline
// script toggles `data-shot="1"` on <main> at runtime. Used by
// scripts/tools/generate-spore-image.mjs for spore image generation.
---

<Layout
  lang={lang}
  title={title}
  description={description}
  type="article"
  datePublished={seoDatePublished}
  dateModified={seoDateModified}
  content={content}
  tags={frontmatter.tags}
  category={categoryInfo.name}
  slug={slug}
  categorySlug={category}
  readerSettings
  feedback
>
  <!-- Reading progress bar -->
  <div class="reading-progress" id="reading-progress" aria-hidden="true"></div>

  <!--
    Phase 6 partial migration — [category]/[slug].astro (zh-TW)
    ───────────────────────────────────────────────────────────
    Same migration strategy as en/ja/ko [category]/[slug]:
    wrappers → inline Tailwind; .prose :global(*) + .reading-progress
    stay scoped. zh-TW adds a meta-category-link and optional
    meta-subcategory in the meta strip (not present in en/ja/ko).
    Prose font is 'Noto Serif TC' instead of 'Inter'.
  -->
  <!-- Shot-mode watermark 已移至 src/layouts/Layout.astro 共用（2026-04-22 β）。
       JS toggle + CSS 同樣搬走，四語言 article page 統一支援 ?shot=1 模式。 -->

  <main class="article-page min-h-screen bg-[#f8f1e9]" lang={lang}>
    <!-- ── Hero ─────────────────────────────────────────────────── -->
    <ArticleHero
      title={title}
      description={description}
      category={category}
      categoryName={categoryInfo.name}
      categoryColor={categoryInfo.color}
      subcategory={frontmatter.subcategory}
      status={frontmatter.status}
      coverImage={frontmatter.image ? '' : categoryInfo.cover}
      slug={slug}
      lang={lang}
    />

    <!-- ── Three-column body ───────────────────────────────────────
         2026-04-27 fix: removed `items-start` from grid parent + made
         TOC/sidebar wrapper divs `h-full`. Reason: `items-start` makes
         each grid cell shrink to content height; the TOC's wrapper div
         was therefore the same height as the TOC nav itself, leaving
         no scroll-room for `position: sticky` to engage. Now grid cells
         stretch to row height (= tall article body) and sticky works
         inside the tall wrapper.
    -->
    <div
      class="mx-auto grid max-w-[var(--container-article)] grid-cols-[220px_1fr_200px] [grid-template-areas:'toc_body_sidebar'] gap-14 px-8 pb-20 pt-16 max-lg:grid-cols-1 max-lg:[grid-template-areas:'body'_'sidebar'] max-lg:gap-8 max-lg:px-6 max-lg:pb-16 max-lg:pt-10 max-[640px]:px-4 max-[640px]:pb-12 max-[640px]:pt-6"
    >
      <!-- Left: Table of Contents (h-full lets the wrapper inherit grid row height,
           giving the inner sticky nav room to scroll within) -->
      <div class="h-full [grid-area:toc] max-lg:hidden" aria-label="目錄欄">
        <TableOfContents content={processedContent} />
      </div>

      <!-- Center: Article content -->
      <article class="min-w-0 [grid-area:body]" data-pagefind-body>
        <!-- LifeTree CTA banner (experimental feature, links to standalone page) -->
        {
          frontmatter.lifeTree && (
            <a
              href={`/lifetree/${slug}`}
              class="lifetree-cta group mb-8 flex items-center justify-between gap-4 rounded-xl border border-dashed border-[rgba(139,92,246,0.4)] bg-gradient-to-r from-[rgba(139,92,246,0.06)] to-[rgba(236,72,153,0.04)] px-5 py-4 no-underline transition-all duration-200 hover:border-solid hover:border-[#8B5CF6] hover:shadow-md"
              data-experimental
            >
              <div class="flex items-center gap-3">
                <span class="text-2xl" aria-hidden="true">
                  🌳
                </span>
                <div>
                  <p class="m-0 font-['Inter',system-ui,sans-serif] text-[0.7rem] font-semibold uppercase tracking-[0.12em] text-[#8B5CF6]">
                    Experimental · {t('article.lifeTree.experimental')}
                  </p>
                  <p class="m-0 mt-0.5 font-['Noto_Serif_TC',serif] text-[0.95rem] font-medium text-[#0e3a5c]">
                    {t('article.lifeTree.protagonistTree')
                      .replace('{name}', frontmatter.lifeTree.protagonist)
                      .replace(
                        '{n}',
                        String(frontmatter.lifeTree.nodes?.length || 0),
                      )}
                  </p>
                </div>
              </div>
              <span class="flex items-center gap-1 font-['Inter',system-ui,sans-serif] text-[0.85rem] font-medium text-[#8B5CF6] transition-transform duration-200 group-hover:translate-x-1">
                {t('article.lifeTree.viewTree')}
              </span>
            </a>
          )
        }

        <!-- Hero image (if frontmatter declares one) — moved out of the
             ArticleHero background and into the article body so its
             credit/license info has visible context. Hero section above
             becomes solid color when frontmatter.image is set; articles
             without an explicit image still get the category default cover
             behind the hero. 2026-05-04. -->
        {
          frontmatter.image && (
            <figure class="mb-10 max-[640px]:-mx-2">
              <img
                src={frontmatter.image}
                alt={title}
                loading="eager"
                class="aspect-[16/9] w-full rounded-2xl object-cover"
              />
              {(frontmatter.imageCredit ||
                frontmatter.imageLicense ||
                frontmatter.imageSource) && (
                <figcaption class="mt-3 px-1 font-['Inter',system-ui,sans-serif] text-[0.78rem] leading-relaxed text-[rgba(26,60,52,0.6)]">
                  {frontmatter.imageCredit && (
                    <span>
                      {t('article.imageCredit') || '圖片'}：
                      {frontmatter.imageCredit}
                    </span>
                  )}
                  {frontmatter.imageLicense && (
                    <span> · {frontmatter.imageLicense}</span>
                  )}
                  {frontmatter.imageSource && (
                    <span>
                      {' '}
                      ·{' '}
                      <a
                        href={frontmatter.imageSource}
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        {t('article.imageSource') || '原始來源'}
                      </a>
                    </span>
                  )}
                </figcaption>
              )}
            </figure>
          )
        }

        <!-- Prose body (split at 延伸閱讀 if SSODT sections present) -->
        {
          hasSSoDT && splitIndex !== -1 ? (
            <>
              <div class="prose" set:html={contentBeforeReading} />
              {/* ── SSODT sections between article body and 延伸閱讀 ── */}
              {frontmatter.perspectives &&
                frontmatter.perspectives.length > 0 && (
                  <Perspectives
                    perspectives={frontmatter.perspectives}
                    lang={lang}
                  />
                )}
              {frontmatter.sporeLinks && frontmatter.sporeLinks.length > 0 && (
                <SporeFootprint
                  sporeLinks={frontmatter.sporeLinks}
                  lang={lang}
                />
              )}
              {frontmatter.relatedDiary &&
              frontmatter.relatedDiary.length > 0 ? (
                <RelatedDiaries
                  relatedDiary={frontmatter.relatedDiary}
                  lang={lang}
                />
              ) : frontmatter.diaryLink ? (
                <DiaryTeaser
                  diaryLink={frontmatter.diaryLink}
                  diaryExcerpt={frontmatter.diaryExcerpt}
                  lang={lang}
                />
              ) : null}
              <div class="prose" set:html={contentAfterReading} />
            </>
          ) : (
            <>
              <div class="prose" set:html={processedContent} />
              {/* 無 SSODT split 的文章（多數 About / 短文）footer 也要能掛日記 */}
              {frontmatter.relatedDiary &&
              frontmatter.relatedDiary.length > 0 ? (
                <RelatedDiaries
                  relatedDiary={frontmatter.relatedDiary}
                  lang={lang}
                />
              ) : frontmatter.diaryLink ? (
                <DiaryTeaser
                  diaryLink={frontmatter.diaryLink}
                  diaryExcerpt={frontmatter.diaryExcerpt}
                  lang={lang}
                />
              ) : null}
            </>
          )
        }

        <!-- Sources -->
        {
          frontmatter.source && frontmatter.source.length > 0 && (
            <div class="my-12 rounded-2xl border border-[rgba(26,60,52,0.08)] bg-[rgba(26,60,52,0.03)] p-8">
              <h3 class="mb-4 font-['Inter',system-ui,sans-serif] text-[0.85rem] font-semibold uppercase tracking-[0.1em] text-[#0e3a5c]">
                {t('article.sources')}
              </h3>
              <ul class="m-0 flex list-none flex-col gap-2 p-0">
                {frontmatter.source.map((url: string) => (
                  <li>
                    <a
                      href={url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="break-all text-[0.82rem] text-[#0369a1] no-underline hover:underline"
                    >
                      {url}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )
        }

        <!-- AI Disclaimer -->
        <div
          class="my-12 mb-8 flex items-start gap-4 rounded-xl border border-[rgba(193,125,94,0.18)] bg-[rgba(193,125,94,0.06)] px-6 py-5"
        >
          <div
            class="mt-[0.15rem] flex-shrink-0 text-[#c17d5e]"
            aria-hidden="true"
          >
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              ><circle cx="12" cy="12" r="10"></circle><line
                x1="12"
                y1="8"
                x2="12"
                y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"
              ></line></svg
            >
          </div>
          <div
            class="font-['Inter',system-ui,sans-serif] text-[0.83rem] leading-[1.6] text-[#5a4a42] [&>strong]:mb-[0.3rem] [&>strong]:block [&>strong]:text-[0.8rem] [&>strong]:font-semibold [&>strong]:uppercase [&>strong]:tracking-[0.08em] [&>strong]:text-[#c17d5e]"
          >
            <strong>{t('article.disclaimer.title')}</strong>
            {t('article.disclaimer.body')}
          </div>
        </div>

        <!-- Contribution row -->
        <div class="my-8 flex flex-wrap gap-3">
          <a
            href={`https://github.com/wilsonkichoi/lagunabeach-md/edit/main/knowledge/${categoryMapping[category as string]}/${slug}.md`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-[0.45rem] rounded-full bg-[#0e3a5c] px-[1.1rem] py-[0.55rem] font-['Inter',system-ui,sans-serif] text-[0.82rem] font-medium text-[#f8f1e9] no-underline transition-all duration-200 hover:bg-[#243d36]"
          >
            <svg
              width="15"
              height="15"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              aria-hidden="true"
              ><path
                d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"
              ></path></svg
            >
            {t('article.editPage')}
          </a>
          <a
            href={`https://github.com/wilsonkichoi/lagunabeach-md/issues/new?title=${encodeURIComponent(`Feedback: ${title}`)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-[0.45rem] rounded-full border border-[rgba(26,60,52,0.2)] bg-transparent px-[1.1rem] py-[0.55rem] font-['Inter',system-ui,sans-serif] text-[0.82rem] font-medium text-[#0e3a5c] no-underline transition-all duration-200 hover:bg-[rgba(26,60,52,0.05)]"
          >
            <svg
              width="15"
              height="15"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              aria-hidden="true"
              ><path
                d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"
              ></path></svg
            >
            {t('article.reportIssue')}
          </a>
        </div>

        <!-- Tags + bottom share row -->
        <div
          class="my-12 mb-8 flex flex-wrap items-center justify-between gap-4 border-t border-[rgba(26,60,52,0.08)] pt-8 max-[640px]:flex-col max-[640px]:items-start"
        >
          {
            frontmatter.tags && frontmatter.tags.length > 0 && (
              <div class="flex flex-wrap gap-[0.4rem]">
                {frontmatter.tags.map((tag: string) => (
                  <span
                    class="rounded-full border px-[0.7rem] py-1 font-['Inter',system-ui,sans-serif] text-[0.75rem] font-medium"
                    style={`color:${categoryInfo.color}; background:${categoryInfo.colorLight}; border-color:${categoryInfo.color}28;`}
                  >
                    {tag}
                  </span>
                ))}
              </div>
            )
          }

          <div class="flex items-center gap-[0.4rem]">
            <span
              class="mr-1 font-['Inter',system-ui,sans-serif] text-[0.78rem] text-[#7a8b7e]"
              >{t('article.share')}</span
            >
            <a
              href={`https://twitter.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}`}
              target="_blank"
              rel="noopener noreferrer"
              class="no-external-icon inline-flex h-[34px] w-[34px] cursor-pointer items-center justify-center rounded-full border-none bg-[rgba(26,60,52,0.06)] text-[#0e3a5c] no-underline transition-[background,color] duration-200 hover:bg-[#0e3a5c] hover:text-[#f8f1e9]"
              aria-label={t('article.sidebar.shareX')}
            >
              <svg
                width="15"
                height="15"
                viewBox="0 0 24 24"
                fill="currentColor"
                ><path
                  d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.256 5.636L18.244 2.25zm-1.161 17.52h1.833L7.084 4.126H5.117z"
                ></path></svg
              >
            </a>
            <a
              href={`https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`}
              target="_blank"
              rel="noopener noreferrer"
