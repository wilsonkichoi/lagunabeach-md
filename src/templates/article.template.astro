---
/**
 * article.template.astro — 統一 article page template (6 langs 共用)
 *
 * 為什麼: 之前 6 個 [slug].astro × 1100~1300 行 = ~7400 行高度重複；發現過 PR #758
 * ship es/fr 帶 JA copy-paste bug (related articles 顯示日文 / es/fr getStaticPaths
 * 用 zhToJa 過濾)。Template unification 一次性消除這類 class of bug。
 *
 * 對照 about/dashboard pattern：
 *   src/pages/about.astro                → 5 行 <AboutTemplate />
 *   src/templates/about.template.astro   → 全部 UI 邏輯
 *
 * 中文 zh-TW 是 SSOT canonical，本 template 從 src/pages/[category]/[slug].astro
 * 複製過來，再 parameterize on lang prop。其他 5 langs 的差異全變 prop / data。
 *
 * 2026-05-03 sleepy-colden Tier 2.5 unified template extraction (Phase B)。
 */
import Layout from '../layouts/Layout.astro';
import { marked } from 'marked';
import ArticleHero from '../components/ArticleHero.astro';
import TableOfContents from '../components/TableOfContents.astro';
import ArticleSidebar from '../components/ArticleSidebar.astro';
import RelatedArticleCard from '../components/RelatedArticleCard.astro';
import Perspectives from '../components/Perspectives.astro';
import SporeFootprint from '../components/SporeFootprint.astro';
import DiaryTeaser from '../components/DiaryTeaser.astro';
import { useTranslations } from '../i18n/utils';
import {
  categoryList as categories,
  getCategoryConfigs,
  type CategoryKey,
} from '../utils/categoryConfig';
import {
  buildGitInfoCache,
  emptyGitInfo,
  type GitInfo,
} from '../utils/contributors';
import { getRelatedArticles, getAllArticles } from '../utils/articles-index';
import { resolve, join } from 'path';
import type { Lang } from '../config/languages';
import contentDatesData from '../data/content-dates.json';

interface Props {
  title: string;
  description: string;
  content: string;
  frontmatter: Record<string, any>;
  lang: Lang;
  contributors?: any[];
  lastModified?: string;
  category: string;
  slug: string;
}

const {
  title,
  description,
  content,
  frontmatter,
  lang,
  contributors: propsContributors = [],
  lastModified: propsLastModified = '',
  category,
  slug,
} = Astro.props;

// ── SEO freshness dates (reports/seo-optimization-plan-2026-06-07.md §1.1) ──
// dateModified comes from content-dates.json (git last-meaningful-commit,
// cosmetic-filtered) so EVOLVE'd articles signal real freshness instead of a
// build-time "now". frontmatter.modified (set by EVOLVE) is the explicit
// override; falls back to git date → publish date. Same source as the sitemap
// <lastmod> so visible/structured dates stay consistent (a Google requirement).
const _seoUrlPath =
  lang === 'zh-TW' ? `/${category}/${slug}/` : `/${lang}/${category}/${slug}/`;
const _toISO = (v: unknown): string | undefined =>
  v instanceof Date ? v.toISOString() : typeof v === 'string' ? v : undefined;
const seoDatePublished = _toISO(frontmatter.date);
const seoDateModified =
  _toISO(frontmatter.modified) ||
  ((contentDatesData as { dates?: Record<string, string> }).dates || {})[
    _seoUrlPath
  ] ||
  seoDatePublished;

// ── Lang-derived helpers ─────────────────────────────────────────────────────
// langPath: '' for zh-TW (SSOT root), else '{lang}/' for non-default langs.
// Used for: knowledge folder path, github edit URL, taiwan.md article URL.
const langPath = lang === 'zh-TW' ? '' : `${lang}/`;
const langUrlPrefix = lang === 'zh-TW' ? '' : `/${lang}`;

// Per-lang prose font (wired into <style define:vars> below as --prose-font).
// zh-TW uses jf-jinxuanlatte (justfont 金萱拿鐵) to match site body cascade
// — restored 2026-05-04 after Tailwind migration silently flipped it to
// Noto Serif TC. en/es/fr use Inter; ja/ko use Noto Serif JP/KR.
const proseFontMap: Record<string, string> = {
  'zh-TW': "'jf-jinxuanlatte','Noto Sans TC','Source Han Sans TC',sans-serif",
  en: "'Inter',system-ui,sans-serif",
  ja: "'Noto Serif JP',serif",
  ko: "'Noto Serif KR',serif",
  es: "'Inter',system-ui,sans-serif",
  fr: "'Inter',system-ui,sans-serif",
};
const proseFont = proseFontMap[lang] ?? proseFontMap['zh-TW'];

// ── Category → folder mapping ─────────────────────────────────────────────────
const categoryMapping: Record<string, string> = {
  about: 'About',
  history: 'History',
  geography: 'Geography',
  culture: 'Culture',
  food: 'Food',
  art: 'Art',
  music: 'Music',
  technology: 'Technology',
  nature: 'Nature',
  people: 'People',
  society: 'Society',
  economy: 'Economy',
  lifestyle: 'Lifestyle',
};

// ── Git helpers (per-lang cache so 6 wrappers don't collide) ─────────────────
const _gitCaches = new Map<string, Map<string, GitInfo>>();
function getGitInfoForLang(lang: Lang, filePath: string): GitInfo {
  let cache = _gitCaches.get(lang);
  if (!cache) {
    const knowledgeBase =
      lang === 'zh-TW' ? 'knowledge/' : `knowledge/${lang}/`;
    cache = buildGitInfoCache(knowledgeBase);
    _gitCaches.set(lang, cache);
  }
  return cache.get(filePath) || emptyGitInfo();
}

// Compute git info at render time (not from props) so it's always fresh
const _renderFilePath = (() => {
  const folderName = categoryMapping[category as string];
  if (!folderName) return '';
  const knowledgeRoot =
    lang === 'zh-TW'
      ? resolve(process.cwd(), 'knowledge', folderName)
      : resolve(process.cwd(), 'knowledge', lang, folderName);
  return join(knowledgeRoot, slug + '.md').normalize('NFC');
})();
const _renderGitInfo = _renderFilePath
  ? getGitInfoForLang(lang, _renderFilePath)
  : { contributors: [], lastModified: '', commitHash: '', revisionCount: 0 };
const contributors = _renderGitInfo.contributors.length
  ? _renderGitInfo.contributors
  : propsContributors;
const lastModified = _renderGitInfo.lastModified || propsLastModified;
const commitHash = _renderGitInfo.commitHash;
const revisionCount = _renderGitInfo.revisionCount;

const t = useTranslations(lang);
const categoryConfigs = getCategoryConfigs(t);
const categoryInfo = categoryConfigs[category as CategoryKey];
if (!categoryInfo) throw new Error(`Unknown category: ${category}`);

// ── Related articles (same category, up to 3) ────────────────────────────────
// Tier 1.4 shared cache via articles-index.ts — module-level cache 跨整個 build。
let relatedArticles: any[] = [];
try {
  relatedArticles = await getRelatedArticles(
    lang,
    category as string,
    slug as string,
    3,
  );
} catch {}

// ── Random explore list ──────────────────────────────────────────────────────
let allArticles: Array<{ title: string; slug: string; category: string }> = [];
try {
  const all = await getAllArticles(lang, category as string);
  allArticles = all.map((a) => ({
    title: a.title,
    slug: a.slug,
    category: a.category,
  }));
} catch {}

// ── Other categories (for "Explore more") ────────────────────────────────────
const otherCategories = categories
  .filter((cat) => cat !== category)
  .slice(0, 3)
  .map((cat) => ({ key: cat, ...categoryConfigs[cat as CategoryKey] }));

// ── Markdown → HTML ───────────────────────────────────────────────────────────
function resolveWikilinks(md: string) {
  if (!md) return md;
  return md.replace(
    /\[\[([^\]|]+?)(?:\|([^\]]+?))?\]\]/g,
    (_, target, display) => {
      return `**${display || target}**`;
    },
  );
}

const renderer = new marked.Renderer();

// Inject id attributes on headings for TOC anchor links
renderer.heading = ({ text, depth }) => {
  const id = text
    .toLowerCase()
    .replace(/\s+/g, '-')
    .replace(/[^\w\u4e00-\u9fff-]/g, '')
    .slice(0, 60);
  return `<h${depth} id="${id}">${text}</h${depth}>`;
};

renderer.link = ({ href, title, text }) => {
  const isExternal =
    href?.startsWith('http://') || href?.startsWith('https://');
  const titleAttr = title ? ` title="${title}"` : '';
  const targetAttr = isExternal
    ? ' target="_blank" rel="noopener noreferrer"'
    : '';
  return `<a href="${href}"${titleAttr}${targetAttr}>${text}</a>`;
};

renderer.image = ({ href, title, text }) => {
  const titleAttr = title ? ` title="${title}"` : '';
  return `<img src="${href}" alt="${text || ''}"${titleAttr} loading="lazy" onerror="this.onerror=null;this.classList.add('img-broken')" />`;
};

// ── 文章內共用視覺模組（fenced-code 語法糖 → HTML，CSS 在 article-modules.css）─
// 作者寫 ```tw-figure / tw-versus / tw-bars / tw-timeline 區塊，逐列用 | 分欄。
const _esc = (s: string) =>
  String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');

function renderTwModule(lang: string, raw: string): string {
  let lines = raw
    .split('\n')
    .map((l) => l.trim())
    .filter(Boolean);
  if (lines.length === 0) return '';

  // 跨模組「來源」列：任一列 `來源：…` / `資料來源：…` / `source: …` 抽成 sibling 來源 caption
  let src = '';
  const _srcRe = /^(?:資料來源|來源|source)\s*[:：]\s*(.+)$/i;
  lines = lines.filter((l) => {
    const m = l.match(_srcRe);
    if (m) {
      src = m[1].trim();
      return false;
    }
    return true;
  });
  if (lines.length === 0 && !src) return '';
  const _src = src ? `<p class="tw-mod-src">資料來源：${_esc(src)}</p>` : '';

  if (lang === 'tw-figure') {
    // line1: 大數字（含 -> / → 視為 before→after）；line2: 說明；line3: 來源
    const [big = '', cap = '', src = ''] = lines;
    const parts = big.split(/\s*(?:->|→|➜)\s*/);
    const nums =
      parts.length >= 2
        ? `<span class="tw-figure-num">${_esc(parts[0])}</span><span class="tw-figure-arrow">→</span><span class="tw-figure-num">${_esc(parts[1])}</span>`
        : `<span class="tw-figure-num tw-figure-num--solo">${_esc(big)}</span>`;
    return (
      `<div class="tw-figure"><div class="tw-figure-nums">${nums}</div>` +
      (cap ? `<div class="tw-figure-cap">${_esc(cap)}</div>` : '') +
      (src ? `<div class="tw-figure-src">資料來源：${_esc(src)}</div>` : '') +
      `</div>`
    );
  }

  if (lang === 'tw-versus') {
    // line1: 左標題 | 右標題；其餘列: 左 | 右
    const [head, ...rows] = lines;
    const [lt = '', rt = ''] = head.split('|').map((s) => s.trim());
    const body = rows
      .map((r) => {
        const [l = '', rr = ''] = r.split('|').map((s) => s.trim());
        return `<div class="tw-versus-row"><div class="tw-versus-cell">${_esc(l)}</div><div class="tw-versus-cell">${_esc(rr)}</div></div>`;
      })
      .join('');
    return (
      `<div class="tw-versus"><div class="tw-versus-heads">` +
      `<div class="tw-versus-head tw-versus-head--a">${_esc(lt)}</div>` +
      `<div class="tw-versus-vs">vs</div>` +
      `<div class="tw-versus-head tw-versus-head--b">${_esc(rt)}</div></div>` +
      `<div class="tw-versus-body">${body}</div></div>`
    );
  }

  if (lang === 'tw-bars') {
    // 每列: 標籤 | 數值 | (選填註記)。數值取數字部分縮放長度。
    const parsed = lines.map((l) => {
      const [label = '', val = '', note = ''] = l
        .split('|')
        .map((s) => s.trim());
      const num = parseFloat(val.replace(/[^0-9.]/g, '')) || 0;
      return { label, val, num, note };
    });
    const max = Math.max(...parsed.map((p) => p.num), 0.0001);
    const body = parsed
      .map((p) => {
        const pct = Math.max(3, Math.round((p.num / max) * 100));
        return (
          `<div class="tw-bars-row"><div class="tw-bars-label">${_esc(p.label)}</div>` +
          `<div class="tw-bars-track"><div class="tw-bars-fill" style="width:${pct}%"></div></div>` +
          `<div class="tw-bars-val">${_esc(p.val)}${p.note ? `<span class="tw-bars-note"> ${_esc(p.note)}</span>` : ''}</div></div>`
        );
      })
      .join('');
    return `<div class="tw-bars">${body}</div>${_src}`;
  }

  if (lang === 'tw-timeline') {
    // 每列: 年份 | 標題 | (選填說明)
    const body = lines
      .map((l) => {
        const [year = '', t = '', desc = ''] = l
          .split('|')
          .map((s) => s.trim());
        return (
          `<div class="tw-timeline-item"><div class="tw-timeline-year">${_esc(year)}</div>` +
          `<div class="tw-timeline-node"></div>` +
          `<div class="tw-timeline-content"><div class="tw-timeline-title">${_esc(t)}</div>` +
          (desc ? `<div class="tw-timeline-desc">${_esc(desc)}</div>` : '') +
          `</div></div>`
        );
      })
      .join('');
    return `<div class="tw-timeline">${body}</div>`;
  }

  if (lang === 'tw-stat') {
    // 每列: 數值 | 標籤 | (選填註記)
    const cards = lines
      .map((l) => {
        const [val = '', label = '', note = ''] = l
          .split('|')
          .map((s) => s.trim());
        return (
          `<div class="tw-stat-card"><div class="tw-stat-val">${_esc(val)}</div>` +
          (label ? `<div class="tw-stat-label">${_esc(label)}</div>` : '') +
          (note ? `<div class="tw-stat-note">${_esc(note)}</div>` : '') +
          `</div>`
        );
      })
      .join('');
    return `<div class="tw-stat">${cards}</div>${_src}`;
  }

  if (lang === 'tw-waffle') {
    // 選填標題（不含 |）+ 每列: 類別 | 數值(%)；100 格依比例填色
    let title = '';
    let rows = lines;
    if (lines[0] && !lines[0].includes('|')) {
      title = lines[0];
      rows = lines.slice(1);
    }
    const cats = rows.map((l) => {
      const [label = '', val = ''] = l.split('|').map((s) => s.trim());
      const num = parseFloat(val.replace(/[^0-9.]/g, '')) || 0;
      return { label, val, num };
    });
    const total = cats.reduce((a, c) => a + c.num, 0) || 1;
    const floors = cats.map((c) => Math.floor((c.num / total) * 100));
    const rem = 100 - floors.reduce((a, b) => a + b, 0);
    const fracs = cats
      .map((c, i) => ({ i, f: (c.num / total) * 100 - floors[i] }))
      .sort((a, b) => b.f - a.f);
    for (let k = 0; k < rem && k < fracs.length; k++) floors[fracs[k].i]++;
    const order: number[] = [];
    floors.forEach((cnt, ci) => {
      for (let j = 0; j < cnt; j++) order.push(ci);
    });
    const cells = order
      .slice(0, 100)
      .map((ci) => `<div class="tw-waffle-cell" data-cat="${ci % 5}"></div>`)
      .join('');
    const swatch = [
      'var(--tw-warm)',
      'var(--tw-cool)',
      'var(--tw-green)',
      'var(--color-accent)',
      'var(--tw-mute)',
    ];
    const legend = cats
      .map(
        (c, ci) =>
          `<span class="tw-waffle-key"><span class="tw-waffle-swatch" style="background:${swatch[ci % 5]}"></span>${_esc(c.label)} <b>${_esc(c.val)}</b></span>`,
      )
      .join('');
    return (
      `<div class="tw-waffle">` +
      (title ? `<div class="tw-mod-title">${_esc(title)}</div>` : '') +
      `<div class="tw-waffle-grid" role="img" aria-label="${_esc(title || '方格圖')}">${cells}</div>` +
      `<div class="tw-waffle-legend">${legend}</div></div>${_src}`
    );
  }

  if (lang === 'tw-quote') {
    // line1: 引文；line2: 姓名 | 角色/場合
    const [q = '', by = ''] = lines;
    const qt = q.replace(/^[「『]/, '').replace(/[」』]$/, '');
    const [name = '', role = ''] = by.split('|').map((s) => s.trim());
    const byHtml = name
      ? `<figcaption class="tw-quote-by"><b>${_esc(name)}</b>${role ? `，${_esc(role)}` : ''}</figcaption>`
      : '';
    return `<figure class="tw-quote"><blockquote class="tw-quote-text">${_esc(qt)}</blockquote>${byHtml}</figure>${_src}`;
  }

  if (lang === 'tw-source') {
    // 整段當來源條（或被 _srcRe 抽走則用 src）
    const txt = lines.join(' ') || src;
    if (!txt) return '';
    return `<p class="tw-source"><span class="tw-source-icon">⌖</span><span>${_esc(txt)}</span></p>`;
  }

  if (lang === 'tw-line') {
    // line1: 標題；line2: x軸名 | 序列1 | 序列2…；其餘: x值 | y1 | y2…
    if (lines.length < 3) return '';
    const title = lines[0];
    const header = lines[1].split('|').map((s) => s.trim());
    const xName = header[0] || '';
    const series = header.slice(1);
    const rows = lines.slice(2).map((l) => {
      const c = l.split('|').map((s) => s.trim());
      return {
        x: c[0] || '',
        ys: series.map((_, i) =>
          parseFloat((c[i + 1] || '').replace(/[^0-9.\-]/g, '')),
        ),
      };
    });
    const allY = rows.flatMap((r) => r.ys).filter((v) => !isNaN(v));
    if (allY.length === 0) return '';
    let yMin = Math.min(...allY);
    const yMax = Math.max(...allY);
    if (yMin === yMax) yMin = yMin > 0 ? 0 : yMin - 1;
    const W = 320,
      H = 176,
      mL = 40,
      mR = 58,
      mT = 14,
      mB = 26;
    const pw = W - mL - mR,
      ph = H - mT - mB;
    const sx = (i: number) =>
      mL + (rows.length > 1 ? (i / (rows.length - 1)) * pw : pw / 2);
    const sy = (v: number) => mT + (1 - (v - yMin) / (yMax - yMin)) * ph;
    const colors = ['var(--tw-warm)', 'var(--tw-cool)', 'var(--tw-green)'];
    let g = '';
    g += `<line class="tw-line-axis" x1="${mL}" y1="${sy(yMax).toFixed(1)}" x2="${W - mR}" y2="${sy(yMax).toFixed(1)}"/>`;
    g += `<line class="tw-line-axis" x1="${mL}" y1="${sy(yMin).toFixed(1)}" x2="${W - mR}" y2="${sy(yMin).toFixed(1)}"/>`;
    g += `<text class="tw-line-ylab" x="${mL - 6}" y="${(sy(yMax) + 4).toFixed(1)}" text-anchor="end">${_esc(String(yMax))}</text>`;
    g += `<text class="tw-line-ylab" x="${mL - 6}" y="${(sy(yMin) + 4).toFixed(1)}" text-anchor="end">${_esc(String(yMin))}</text>`;
    g += `<text class="tw-line-xlab" x="${sx(0).toFixed(1)}" y="${H - 8}" text-anchor="start">${_esc(rows[0].x)}</text>`;
    if (rows.length > 1)
      g += `<text class="tw-line-xlab" x="${sx(rows.length - 1).toFixed(1)}" y="${H - 8}" text-anchor="end">${_esc(rows[rows.length - 1].x)}</text>`;
    series.forEach((sname, si) => {
      const pts = rows
        .map((r, i) => ({ x: sx(i), y: sy(r.ys[si]), v: r.ys[si] }))
        .filter((p) => !isNaN(p.v));
      if (pts.length === 0) return;
      const col = colors[si % 3];
      const line = pts
        .map((p) => `${p.x.toFixed(1)},${p.y.toFixed(1)}`)
        .join(' ');
      const area = `${pts[0].x.toFixed(1)},${sy(yMin).toFixed(1)} ${line} ${pts[pts.length - 1].x.toFixed(1)},${sy(yMin).toFixed(1)}`;
      g += `<polygon class="tw-line-area" points="${area}" style="fill:${col}"/>`;
      g += `<polyline class="tw-line-path" points="${line}" style="stroke:${col}"/>`;
      pts.forEach((p) => {
        g += `<circle class="tw-line-dot" cx="${p.x.toFixed(1)}" cy="${p.y.toFixed(1)}" r="2.5" style="fill:${col}"/>`;
      });
      const last = pts[pts.length - 1];
      g += `<text class="tw-line-slab" x="${(last.x + 4).toFixed(1)}" y="${(last.y + 4).toFixed(1)}" style="fill:${col}">${_esc(sname)}</text>`;
    });
    const svg = `<svg class="tw-line-plot" viewBox="0 0 ${W} ${H}" role="img" aria-label="${_esc(title)}" xmlns="http://www.w3.org/2000/svg">${g}</svg>`;
    const thead = `<tr><th scope="col">${_esc(xName)}</th>${series.map((s) => `<th scope="col">${_esc(s)}</th>`).join('')}</tr>`;
    const tbody = rows
      .map(
        (r) =>
          `<tr><th scope="row">${_esc(r.x)}</th>${r.ys.map((y) => `<td>${isNaN(y) ? '' : _esc(String(y))}</td>`).join('')}</tr>`,
      )
      .join('');
    const table = `<table class="tw-sr-only"><caption>${_esc(title)}</caption><thead>${thead}</thead><tbody>${tbody}</tbody></table>`;
    return `<figure class="tw-line"><div class="tw-mod-title">${_esc(title)}</div>${svg}${table}</figure>${_src}`;
  }

  if (lang === 'tw-heatmap') {
    // line1: 角標 | 欄1 | 欄2…；其餘: 列標 | v1 | v2…（每欄各自正規化成色深）
    if (lines.length < 2) return '';
    const header = lines[0].split('|').map((s) => s.trim());
    const corner = header[0] || '';
    const cols = header.slice(1);
    const rows = lines.slice(1).map((l) => {
      const c = l.split('|').map((s) => s.trim());
      return { label: c[0] || '', vals: cols.map((_, i) => c[i + 1] || '') };
    });
    const colNums = cols.map((_, ci) =>
      rows.map((r) => parseFloat((r.vals[ci] || '').replace(/[^0-9.\-]/g, ''))),
    );
    const colMin = colNums.map((arr) =>
      Math.min(...arr.filter((v) => !isNaN(v))),
    );
    const colMax = colNums.map((arr) =>
      Math.max(...arr.filter((v) => !isNaN(v))),
    );
    const thead = `<tr><th scope="col">${_esc(corner)}</th>${cols.map((c) => `<th scope="col">${_esc(c)}</th>`).join('')}</tr>`;
    const tbody = rows
      .map((r) => {
        const tds = r.vals
          .map((v, ci) => {
            const num = parseFloat((v || '').replace(/[^0-9.\-]/g, ''));
            const range = colMax[ci] - colMin[ci];
            const i =
              isNaN(num) || range === 0 ? 0.5 : (num - colMin[ci]) / range;
            return `<td style="--i:${i.toFixed(2)}">${_esc(v)}</td>`;
          })
          .join('');
        return `<tr><th scope="row">${_esc(r.label)}</th>${tds}</tr>`;
      })
      .join('');
    return `<div class="tw-heatmap"><table><thead>${thead}</thead><tbody>${tbody}</tbody></table></div>${_src}`;
  }

  return '';
}

renderer.code = ({ text, lang }) => {
  if (lang && lang.startsWith('tw-')) {
    const html = renderTwModule(lang, text);
    if (html) return html;
  }
  const langClass = lang ? ` class="language-${lang}"` : '';
  return `<pre><code${langClass}>${_esc(text)}</code></pre>`;
};

// ── Footnote preprocessor (GFM-compatible [^n] syntax) ──────────────────────
function processFootnotes(md: string): string {
  // Collect footnote definitions: [^label]: content (may span rest of line)
  const definitions: Record<string, string> = {};
  const defRegex = /^\[\^([^\]]+)\]:\s*(.+?)(?=\n\[\^|\n\n|\n#|\n---|\s*$)/gms;
  let m: RegExpExecArray | null;
  while ((m = defRegex.exec(md)) !== null) {
    definitions[m[1]] = m[2].trim();
  }
  if (Object.keys(definitions).length === 0) return md;

  // Order of first use in the text
  const order: string[] = [];
  let body = md.replace(defRegex, ''); // remove definitions from body

  // Replace inline refs [^label] → superscript HTML
  body = body.replace(/\[(\^[^\]]+)\](?!:)/g, (_, raw) => {
    const label = raw.slice(1); // strip leading ^
    if (!definitions[label]) return `[${raw}]`;
    if (!order.includes(label)) order.push(label);
    const num = order.indexOf(label) + 1;
    const id = `fn-${label}`;
    const refId = `fnref-${label}`;
    return `<sup id="${refId}"><a href="#${id}" class="footnote-ref" aria-label="脚注 ${num}">${num}</a></sup>`;
  });

  // Build footnotes section
  if (order.length > 0) {
    const items = order.map((label, i) => {
      const num = i + 1;
      const id = `fn-${label}`;
      const refId = `fnref-${label}`;
      // Process links inside footnote text via marked inline parser
      const defHtml = marked.parseInline(definitions[label]) as string;
      return `<li id="${id}">${defHtml}<a href="#${refId}" class="footnote-backref" aria-label="返回引用 ${num}">↩</a></li>`;
    });
    body =
      body.trimEnd() +
      `\n\n<section class="footnotes" aria-label="腳注"><ol>${items.join('')}</ol></section>`;
  }

  return body;
}

// Strip a leading `# Title` heading when it duplicates the frontmatter title
// — ArticleHero already renders the title as the H1 of the page, and ~40%
// of zh-TW articles still include `# {Title}` as the first body line. The
// duplicate visually competes with the hero title. Operate on raw markdown
// (before footnote / wikilink processing) so the regex only sees `# Title`,
// not an HTML element with id attributes injected by marked.
const _titleEsc = String(title).replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
const bodyMarkdown = content.replace(
  new RegExp(`^\\s*#\\s+${_titleEsc}\\s*\\n+`),
  '',
);

const fullHtml = marked.parse(
  processFootnotes(resolveWikilinks(bodyMarkdown)),
  {
    renderer,
    breaks: true,
  },
) as string;

// Split content before 延伸閱讀/Further Reading to insert SSODT sections
// 2026-05-03 fix: bold paragraph format `**延伸閱讀**：` was silently broken
// — splitIndex stayed -1 → SSODT sections (SporeFootprint / Perspectives /
// DiaryTeaser) didn't render despite hasSSoDT=true. Per format-check both
// `## 延伸閱讀` (h2) and `**延伸閱讀**` (bold p) are canonical accepted formats
// — template MUST also accept both. 121 articles use bold format vs 95 h2;
// 3 articles silently broken (黑冠麻鷺 / 沈伯洋 / 賈永婕 had sporeLinks but
// SporeFootprint never rendered). Fix: add bold paragraph markers (zh + en).
const splitMarkers = [
  '<h2>延伸閱讀</h2>',
  '<h2>Further Reading</h2>',
  '<h2>延伸閱讀<',
  '<p><strong>延伸閱讀</strong>',
  '<p><strong>Further Reading</strong>',
];
let splitIndex = -1;
for (const marker of splitMarkers) {
  const idx = fullHtml.indexOf(marker);
  if (idx !== -1) {
    splitIndex = idx;
    break;
  }
}
// Also try id-based h2 (marked adds ids)
if (splitIndex === -1) {
  const idMatch = fullHtml.match(/<h2[^>]*id="[^"]*"[^>]*>延伸閱讀/);
  if (idMatch && idMatch.index !== undefined) splitIndex = idMatch.index;
}
// Final fallback: any <p><strong> containing 延伸閱讀 (handles whitespace variants)
if (splitIndex === -1) {
  const pMatch = fullHtml.match(/<p>\s*<strong>\s*延伸閱讀/);
  if (pMatch && pMatch.index !== undefined) splitIndex = pMatch.index;
}

const hasSSoDT =
  frontmatter.perspectives?.length > 0 ||
  frontmatter.sporeLinks?.length > 0 ||
  frontmatter.diaryLink;
const contentBeforeReading =
  splitIndex !== -1 && hasSSoDT ? fullHtml.slice(0, splitIndex) : fullHtml;
const contentAfterReading =
  splitIndex !== -1 && hasSSoDT ? fullHtml.slice(splitIndex) : '';
const processedContent = fullHtml;

// ── Estimate reading time if not in frontmatter ────────────────────────────────
const estimatedReadingTime =
  frontmatter.readingTime ||
  Math.max(1, Math.round(content.replace(/\s+/g, ' ').length / 500));

const articleUrl = `https://taiwan.md${langUrlPrefix}/${category}/${slug}`;
const encodedUrl = encodeURIComponent(articleUrl);
const encodedTitle = encodeURIComponent(title);

// ── Screenshot mode (?shot=1) — toggled client-side ────────────────────────
// Astro static build strips search params at prerender; so a tiny inline
// script toggles `data-shot="1"` on <main> at runtime. Used by
// scripts/tools/generate-spore-image.mjs for spore image generation.
---

<Layout
  lang={lang}
  title={title}
  description={description}
  type="article"
  datePublished={seoDatePublished}
  dateModified={seoDateModified}
  content={content}
  tags={frontmatter.tags}
  category={categoryInfo.name}
  slug={slug}
  categorySlug={category}
  readerSettings
  feedback
>
  <!-- Reading progress bar -->
  <div class="reading-progress" id="reading-progress" aria-hidden="true"></div>

  <!--
    Phase 6 partial migration — [category]/[slug].astro (zh-TW)
    ───────────────────────────────────────────────────────────
    Same migration strategy as en/ja/ko [category]/[slug]:
    wrappers → inline Tailwind; .prose :global(*) + .reading-progress
    stay scoped. zh-TW adds a meta-category-link and optional
    meta-subcategory in the meta strip (not present in en/ja/ko).
    Prose font is 'Noto Serif TC' instead of 'Inter'.
  -->
  <!-- Shot-mode watermark 已移至 src/layouts/Layout.astro 共用（2026-04-22 β）。
       JS toggle + CSS 同樣搬走，四語言 article page 統一支援 ?shot=1 模式。 -->

  <main class="article-page min-h-screen bg-[#f8f1e9]" lang={lang}>
    <!-- ── Hero ─────────────────────────────────────────────────── -->
    <ArticleHero
      title={title}
      description={description}
      category={category}
      categoryName={categoryInfo.name}
      categoryColor={categoryInfo.color}
      subcategory={frontmatter.subcategory}
      status={frontmatter.status}
      coverImage={frontmatter.image ? '' : categoryInfo.cover}
      slug={slug}
      lang={lang}
    />

    <!-- ── Three-column body ───────────────────────────────────────
         2026-04-27 fix: removed `items-start` from grid parent + made
         TOC/sidebar wrapper divs `h-full`. Reason: `items-start` makes
         each grid cell shrink to content height; the TOC's wrapper div
         was therefore the same height as the TOC nav itself, leaving
         no scroll-room for `position: sticky` to engage. Now grid cells
         stretch to row height (= tall article body) and sticky works
         inside the tall wrapper.
    -->
    <div
      class="mx-auto grid max-w-[var(--container-article)] grid-cols-[220px_1fr_200px] [grid-template-areas:'toc_body_sidebar'] gap-14 px-8 pb-20 pt-16 max-lg:grid-cols-1 max-lg:[grid-template-areas:'body'_'sidebar'] max-lg:gap-8 max-lg:px-6 max-lg:pb-16 max-lg:pt-10 max-[640px]:px-4 max-[640px]:pb-12 max-[640px]:pt-6"
    >
      <!-- Left: Table of Contents (h-full lets the wrapper inherit grid row height,
           giving the inner sticky nav room to scroll within) -->
      <div class="h-full [grid-area:toc] max-lg:hidden" aria-label="目錄欄">
        <TableOfContents content={processedContent} />
      </div>

      <!-- Center: Article content -->
      <article class="min-w-0 [grid-area:body]" data-pagefind-body>
        <!-- LifeTree CTA banner (experimental feature, links to standalone page) -->
        {
          frontmatter.lifeTree && (
            <a
              href={`/lifetree/${slug}`}
              class="lifetree-cta group mb-8 flex items-center justify-between gap-4 rounded-xl border border-dashed border-[rgba(139,92,246,0.4)] bg-gradient-to-r from-[rgba(139,92,246,0.06)] to-[rgba(236,72,153,0.04)] px-5 py-4 no-underline transition-all duration-200 hover:border-solid hover:border-[#8B5CF6] hover:shadow-md"
              data-experimental
            >
              <div class="flex items-center gap-3">
                <span class="text-2xl" aria-hidden="true">
                  🌳
                </span>
                <div>
                  <p class="m-0 font-['Inter',system-ui,sans-serif] text-[0.7rem] font-semibold uppercase tracking-[0.12em] text-[#8B5CF6]">
                    Experimental · {t('article.lifeTree.experimental')}
                  </p>
                  <p class="m-0 mt-0.5 font-['Noto_Serif_TC',serif] text-[0.95rem] font-medium text-[#1a3c34]">
                    {t('article.lifeTree.protagonistTree')
                      .replace('{name}', frontmatter.lifeTree.protagonist)
                      .replace(
                        '{n}',
                        String(frontmatter.lifeTree.nodes?.length || 0),
                      )}
