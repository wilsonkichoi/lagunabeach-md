    <!-- ── 站上最新 (時序主軸 rail) ─────────────────────────────────
         CLIENT-SIDE on purpose: the cards are injected from /api/latest.json
         after load, so the static HTML of every article page stays stable when
         a new article ships (no crawl churn / 不重蹈 c1403e259 freshness 反模式).
         Wrapped <aside data-nosnippet>. Design: WS3. ── -->
    <aside
      id="latest-rail"
      data-nosnippet
      data-ga-view="latest_rail"
      data-lang={lang}
      data-slug={slug}
      data-cat-meta={JSON.stringify(latestCatMeta)}
      data-min-label={t('latest.minRead')}
      aria-label={t('latest.railHeading')}
      hidden
      class="border-t border-[rgba(26,60,52,0.08)] bg-white px-8 py-16 max-[640px]:px-4 max-[640px]:py-12"
    >
      <div class="mx-auto max-w-[var(--container-article)]">
        <div class="mb-8 text-center">
          <p
            class="mb-[0.6rem] font-['Inter',system-ui,sans-serif] text-[0.72rem] font-semibold uppercase tracking-[0.2em] text-[#9aa89e]"
