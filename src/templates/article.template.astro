          >
            {t('latest.railHeading')}
          </h2>
        </div>
        {
          /* Single source of the card markup: one server-rendered ArticleCard
            (premium) the client clones + fills per latest item — reuses the real
            component instead of hand-rolling, no :global string-building.
            Placeholders force every premium slot to render so the clone has them. */
        }
        <template id="latest-card-tpl">
          <ArticleCard
            density="premium"
            href="#"
            title="·"
            description="·"
            categoryLabel="·"
            categoryColor="#475569"
            categoryIcon="·"
            date="·"
            readingTime="·"
            openIn="same-tab"
          />
        </template>
        <div
          id="latest-rail-cards"
          class="grid gap-6 grid-cols-1 min-[640px]:grid-cols-3 min-[1024px]:grid-cols-4 [&>*:nth-child(4)]:hidden min-[1024px]:[&>*:nth-child(4)]:flex"
        >
        </div>
        <div class="mt-8 text-center">
          <a
            href={lang === 'en' ? '/latest' : `/${lang}/latest`}
            data-ga-section="article_latest_rail"
            data-ga-label="view_all"
            class="inline-flex items-center gap-2 rounded-full border-[1.5px] border-[#10b981]/40 px-6 py-[0.6rem] font-['Inter',system-ui,sans-serif] text-[0.88rem] font-semibold text-[#065f46] no-underline transition-all hover:bg-[#ecfdf5]"
          >
            {t('latest.railViewAll')}{' '}
            →
          </a>
        </div>
      </div>
    </aside>
    <script is:inline>
      (function () {
        var rail = document.getElementById('latest-rail');
        if (!rail) return;
        var lang = rail.getAttribute('data-lang') || 'zh-TW';
        var slug = rail.getAttribute('data-slug') || '';
        var box = document.getElementById('latest-rail-cards');
        var tpl = document.getElementById('latest-card-tpl');
        if (!box || !tpl) return;
        // Localized category meta (name/color/icon) injected server-side; each
        // card is a CLONE of the server-rendered <ArticleCard> template below
        // (reuses the real component — no hand-rolled markup, no :global strings).
        var META = {};
        try {
          META = JSON.parse(rail.getAttribute('data-cat-meta') || '{}');
        } catch (_) {}
        var MIN = rail.getAttribute('data-min-label') || 'min';
        var encSlug = encodeURIComponent(slug);
        fetch('/api/latest.json')
          .then(function (r) {
            return r.ok ? r.json() : null;
          })
          .then(function (data) {
            if (!data || !data.byLang) return;
            var list = (data.byLang[lang] || [])
              .filter(function (a) {
                return a.href.split('/').pop() !== encSlug;
              })
              .slice(0, 4);
            if (!list.length) return;
            var frag = document.createDocumentFragment();
            list.forEach(function (a) {
              var m = META[a.category] || {
                name: a.category,
                color: '#475569',
                icon: '📄',
              };
              var col = m.color || '#475569';
              var dt = new Date(a.date);
              var day = dt.getMonth() + 1 + '/' + dt.getDate();
              // clone the server-rendered ArticleCard (premium) + fill the slots
              var card = tpl.content.firstElementChild.cloneNode(true);
              card.setAttribute('href', a.href);
              card.setAttribute('aria-label', a.title);
              card.setAttribute('data-ga-section', 'article_latest_rail');
              var hero = card.querySelector('.article-card-hero');
              var icon = card.querySelector('.article-card-hero-icon');
              if (a.image) {
                hero.style.background = '';
                hero.style.backgroundImage = "url('" + a.image + "')";
                if (icon) icon.remove();
                var ov = document.createElement('span');
                ov.className = 'article-card-hero-overlay';
                hero.appendChild(ov);
              } else {
                hero.style.background =
                  'linear-gradient(135deg,' + col + '22,' + col + '44)';
                if (icon) {
                  icon.textContent = m.icon || '📄';
                  icon.style.color = col;
                }
              }
              var badge = card.querySelector('.article-card-badge');
              if (badge) {
                badge.textContent = m.name;
                badge.style.color = col;
                badge.style.background = col + '14';
                badge.style.borderColor = col + '28';
              }
              var pdate = card.querySelector('.article-card-premdate');
              if (pdate) pdate.textContent = day;
              var title = card.querySelector('.article-card-title');
              if (title) title.textContent = a.title;
              var desc = card.querySelector('.article-card-desc');
              if (desc) {
                if (a.desc) desc.textContent = a.desc;
                else desc.remove();
              }
              var cta = card.querySelector('.article-card-cta');
              if (cta) cta.style.color = col;
              var ctaLabel = card.querySelector('.article-card-cta-label');
              if (ctaLabel)
                ctaLabel.textContent = a.readingTime
                  ? a.readingTime + ' ' + MIN
                  : '閱讀全文';
              frag.appendChild(card);
            });
            box.appendChild(frag);
            rail.hidden = false;
          })
          .catch(function () {});
      })();
    </script>

    <!-- ── Random explore ────────────────────────────────────────── -->
    {
