    <!-- ── 站上最新 (時序主軸 rail) ─────────────────────────────────
         CLIENT-SIDE on purpose: the cards are injected from /api/latest.json
         after load, so the static HTML of every article page stays stable when
         a new article ships (no crawl churn / 不重蹈 c1403e259 freshness 反模式).
         Wrapped <aside data-nosnippet>. Design: WS3. ── -->
    <aside
      id="latest-rail"
      data-nosnippet
      data-lang={lang}
      data-slug={slug}
      aria-label={t('latest.railHeading')}
      hidden
      class="border-t border-[rgba(26,60,52,0.08)] bg-white px-8 py-16 max-[640px]:px-4 max-[640px]:py-12"
