                </div>
              </div>
              <span class="flex items-center gap-1 font-['Inter',system-ui,sans-serif] text-[0.85rem] font-medium text-[#8B5CF6] transition-transform duration-200 group-hover:translate-x-1">
                {t('article.lifeTree.viewTree')}
              </span>
            </a>
          )
        }

        <!-- Hero image (if frontmatter declares one) — moved out of the
             ArticleHero background and into the article body so its
             credit/license info has visible context. Hero section above
             becomes solid color when frontmatter.image is set; articles
             without an explicit image still get the category default cover
             behind the hero. 2026-05-04. -->
        {
          frontmatter.image && (
            <figure class="mb-10 max-[640px]:-mx-2">
              <img
                src={frontmatter.image}
                alt={title}
                loading="eager"
                class="aspect-[16/9] w-full rounded-2xl object-cover"
              />
              {(frontmatter.imageCredit ||
                frontmatter.imageLicense ||
                frontmatter.imageSource) && (
                <figcaption class="mt-3 px-1 font-['Inter',system-ui,sans-serif] text-[0.78rem] leading-relaxed text-[rgba(26,60,52,0.6)]">
                  {frontmatter.imageCredit && (
                    <span>
                      {t('article.imageCredit') || '圖片'}：
                      {frontmatter.imageCredit}
                    </span>
                  )}
                  {frontmatter.imageLicense && (
                    <span> · {frontmatter.imageLicense}</span>
                  )}
                  {frontmatter.imageSource && (
                    <span>
                      {' '}
                      ·{' '}
                      <a
                        href={frontmatter.imageSource}
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        {t('article.imageSource') || '原始來源'}
                      </a>
                    </span>
                  )}
                </figcaption>
              )}
            </figure>
          )
        }

        <!-- Prose body (split at 延伸閱讀 if SSODT sections present) -->
        {
          hasSSoDT && splitIndex !== -1 ? (
            <>
              <div class="prose" set:html={contentBeforeReading} />
              {/* ── SSODT sections between article body and 延伸閱讀 ── */}
              {frontmatter.perspectives &&
                frontmatter.perspectives.length > 0 && (
                  <Perspectives
                    perspectives={frontmatter.perspectives}
                    lang={lang}
                  />
                )}
              {frontmatter.sporeLinks && frontmatter.sporeLinks.length > 0 && (
                <SporeFootprint
                  sporeLinks={frontmatter.sporeLinks}
                  lang={lang}
                />
              )}
              {frontmatter.diaryLink && (
                <DiaryTeaser
                  diaryLink={frontmatter.diaryLink}
                  diaryExcerpt={frontmatter.diaryExcerpt}
                  lang={lang}
                />
              )}
              <div class="prose" set:html={contentAfterReading} />
            </>
          ) : (
            <div class="prose" set:html={processedContent} />
          )
        }

        <!-- Sources -->
        {
          frontmatter.source && frontmatter.source.length > 0 && (
            <div class="my-12 rounded-2xl border border-[rgba(26,60,52,0.08)] bg-[rgba(26,60,52,0.03)] p-8">
              <h3 class="mb-4 font-['Inter',system-ui,sans-serif] text-[0.85rem] font-semibold uppercase tracking-[0.1em] text-[#1a3c34]">
