---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Administrative division code reference (used in the codes table)
const divisionCodes = [
  { code: '63000', name: '臺北市 Taipei', type: 'municipality' },
  { code: '64000', name: '高雄市 Kaohsiung', type: 'municipality' },
  { code: '65000', name: '新北市 New Taipei', type: 'municipality' },
  { code: '66000', name: '臺中市 Taichung', type: 'municipality' },
  { code: '67000', name: '臺南市 Tainan', type: 'municipality' },
  { code: '68000', name: '桃園市 Taoyuan', type: 'municipality' },
  { code: '10002', name: '宜蘭縣 Yilan', type: 'county' },
  { code: '10004', name: '新竹縣 Hsinchu', type: 'county' },
  { code: '10005', name: '苗栗縣 Miaoli', type: 'county' },
  { code: '10007', name: '彰化縣 Changhua', type: 'county' },
  { code: '10008', name: '南投縣 Nantou', type: 'county' },
  { code: '10009', name: '雲林縣 Yunlin', type: 'county' },
  { code: '10010', name: '嘉義縣 Chiayi', type: 'county' },
  { code: '10013', name: '屏東縣 Pingtung', type: 'county' },
  { code: '10014', name: '臺東縣 Taitung', type: 'county' },
  { code: '10015', name: '花蓮縣 Hualien', type: 'county' },
  { code: '10016', name: '澎湖縣 Penghu', type: 'county' },
  { code: '10017', name: '基隆市 Keelung', type: 'city' },
  { code: '10018', name: '新竹市 Hsinchu City', type: 'city' },
  { code: '10020', name: '嘉義市 Chiayi City', type: 'city' },
  { code: '09007', name: '連江縣 Lienchiang (Matsu)', type: 'offshore' },
  { code: '09020', name: '金門縣 Kinmen', type: 'offshore' },
];

const typeLabel: Record<string, Record<string, string>> = {
  'zh-TW': {
    municipality: '直轄市',
    county: '縣',
    city: '市',
    offshore: '離島縣',
  },
  en: {
    municipality: 'Special Municipality',
    county: 'County',
    city: 'City',
    offshore: 'Offshore County',
  },
  ja: {
    municipality: '直轄市',
    county: '県',
    city: '市',
    offshore: '離島県',
  },
  ko: {
    municipality: '직할시',
    county: '현',
    city: '시',
    offshore: '부속 현',
  },
};

const municipalityFiles = [
  { code: '63000', name: '臺北市 Taipei', size: '11 KB' },
  { code: '64000', name: '高雄市 Kaohsiung', size: '35 KB' },
  { code: '65000', name: '新北市 New Taipei', size: '13 KB' },
  { code: '66000', name: '臺中市 Taichung', size: '11 KB' },
  { code: '67000', name: '臺南市 Tainan', size: '15 KB' },
  { code: '68000', name: '桃園市 Taoyuan', size: '7 KB' },
];
---

<Layout
  title={t('taiwanShape.meta.title')}
  description={t('taiwanShape.meta.description')}
  lang={lang}
>
  <!--
    Phase 7.6 — taiwan-shape.template.astro (Tier 1 — undiscovered)
    Wrappers, hero, single-use blocks, btn variants inlined.
    Kept scoped: repeating patterns (.svg-card × N, .comparison-item,
    .geo-download-card, .format-box, .codes-table rows), shared
    `.taiwan-shape-page` typography (`h2 / h3 / p` descendant rules
    used throughout the page), and their responsive overrides.
    The `.taiwan-shape-page` class itself is kept as a hook so the
    scoped descendant selectors keep matching.
  -->
  <main
    class="taiwan-shape-page mx-auto max-w-[980px] px-6 pb-16 text-[#1a1a1a]"
  >
    <!-- Hero -->
    <PageHero
      containerWidth={820}
      padding="spacious"
      titleFont="sans"
      titleWeight="extrabold"
      titleSize="clamp"
      titleColor="#111"
      accentColor="#c73e3a"
      eyebrowTracking="tight"
      eyebrow={t('taiwanShape.hero.kicker')}
      title={t('taiwanShape.hero.title')}
      subtitle={t('taiwanShape.hero.subtitle')}
    />

    <!-- Story -->
    <section class="shape-story">
      <div class="section-inner">
        <h2>{t('taiwanShape.story.heading')}</h2>
        <p>{t('taiwanShape.story.p1')}</p>
        <p>{t('taiwanShape.story.p2')}</p>
      </div>
    </section>

    <!-- AI vs Real Comparison -->
    <section class="shape-comparison">
      <div class="section-inner">
        <h2 class="comparison-title">{t('taiwanShape.comparison.title')}</h2>
        <div class="comparison-grid">
          <figure class="comparison-item wrong">
            <div class="svg-container">
              <img
                src="/assets/svg/ai-taiwan-wrong.svg"
                alt="AI-generated Taiwan shape (wrong)"
                loading="lazy"
              />
            </div>
            <figcaption class="comparison-label wrong">
              {t('taiwanShape.comparison.aiLabel')}
            </figcaption>
          </figure>
          <div class="comparison-vs" aria-hidden="true">VS</div>
          <figure class="comparison-item correct">
            <div class="svg-container">
              <img
                src="/assets/svg/taiwan-icon-wiki.svg"
                alt="Correct Taiwan shape from Wikipedia"
                loading="lazy"
              />
            </div>
            <figcaption class="comparison-label correct">
              {t('taiwanShape.comparison.correctLabel')}
            </figcaption>
          </figure>
        </div>
      </div>
    </section>

    <!-- SVG Downloads -->
    <section class="shape-svg">
      <div class="section-inner">
        <h2>{t('taiwanShape.svg.heading')}</h2>
        <p class="section-description">
          {t('taiwanShape.svg.description')}
        </p>

        <div class="svg-grid">
          <article class="svg-card">
            <div class="svg-preview">
              <img
                src="/assets/svg/taiwan-icon-wiki.svg"
                alt="Taiwan icon — Wikipedia"
                loading="lazy"
              />
            </div>
            <div class="svg-info">
              <h3>taiwan-icon.svg</h3>
              <p class="svg-desc">
                {
                  lang === 'en'
                    ? 'Simple filled outline — great for icons, favicons, buttons.'
                    : lang === 'ja'
                      ? 'シンプルな塗りつぶし輪郭 — アイコン、favicon、ボタンに最適。'
                      : lang === 'ko'
                        ? '심플한 채워진 윤곽 — 아이콘, 파비콘, 버튼에 최적.'
                        : '簡潔的填色輪廓 — 適合做 icon、favicon、按鈕。'
                }
              </p>
              <p class="svg-meta">Wikimedia Commons · CC</p>
              <div class="svg-actions">
                <a
                  href="/assets/svg/taiwan-icon-wiki.svg"
                  download
                  class="btn btn-primary"
                >
                  {t('taiwanShape.download.svg')}
                </a>
                <button
                  class="btn btn-outline"
                  onclick="copySVG('taiwan-icon-wiki.svg', this)"
                  data-copied={t('taiwanShape.copy.copied')}
                  data-default={t('taiwanShape.copy.button')}
                >
                  {t('taiwanShape.copy.button')}
                </button>
              </div>
            </div>
          </article>

          <article class="svg-card">
            <div class="svg-preview">
              <img
                src="/assets/svg/taiwan-simplemaps.svg"
                alt="Taiwan outline — SimpleMaps"
                loading="lazy"
              />
            </div>
            <div class="svg-info">
              <h3>taiwan-simplemaps.svg</h3>
              <p class="svg-desc">
                {
                  lang === 'en'
                    ? 'Clean vector — great for web embedding.'
                    : lang === 'ja'
                      ? 'クリーンなベクター — Web 埋め込みに最適。'
                      : lang === 'ko'
                        ? '깨끗한 벡터 — 웹 임베딩에 최적.'
                        : '乾淨向量檔 — 適合網頁嵌入。'
                }
              </p>
              <p class="svg-meta">SimpleMaps · 5 KB</p>
              <div class="svg-actions">
                <a
                  href="/assets/svg/taiwan-simplemaps.svg"
                  download
                  class="btn btn-primary"
                >
                  {t('taiwanShape.download.svg')}
                </a>
                <button
                  class="btn btn-outline"
                  onclick="copySVG('taiwan-simplemaps.svg', this)"
                  data-copied={t('taiwanShape.copy.copied')}
                  data-default={t('taiwanShape.copy.button')}
                >
                  {t('taiwanShape.copy.button')}
                </button>
              </div>
            </div>
          </article>

          <article class="svg-card">
            <div class="svg-preview">
              <img
                src="/assets/svg/taiwan-location-map.svg"
                alt="Taiwan location map with city markers"
                loading="lazy"
              />
            </div>
            <div class="svg-info">
              <h3>taiwan-location-map.svg</h3>
              <p class="svg-desc">
                {
                  lang === 'en'
                    ? 'Location map with lat/lon grid and city markers.'
                    : lang === 'ja'
                      ? '位置マップ — 経緯度・都市マーカー付き。'
                      : lang === 'ko'
                        ? '위치 지도 — 경위도 · 도시 마커 포함.'
                        : '位置地圖 — 含經緯度網格與城市標記。'
                }
              </p>
              <p class="svg-meta">Wikimedia Commons · CC</p>
              <div class="svg-actions">
                <a
                  href="/assets/svg/taiwan-location-map.svg"
                  download
                  class="btn btn-primary"
                >
                  {t('taiwanShape.download.svg')}
                </a>
                <button
                  class="btn btn-outline"
                  onclick="copySVG('taiwan-location-map.svg', this)"
                  data-copied={t('taiwanShape.copy.copied')}
                  data-default={t('taiwanShape.copy.button')}
                >
                  {t('taiwanShape.copy.button')}
                </button>
              </div>
            </div>
          </article>

          <article class="svg-card">
            <div class="svg-preview">
              <img
                src="/assets/svg/taiwan-political-division.svg"
                alt="Taiwan political division map with counties"
                loading="lazy"
              />
            </div>
            <div class="svg-info">
              <h3>taiwan-political-division.svg</h3>
              <p class="svg-desc">
                {
                  lang === 'en'
                    ? 'County borders — colored administrative divisions.'
                    : lang === 'ja'
                      ? '県市境界 — カラー行政区分。'
                      : lang === 'ko'
                        ? '현시 경계 — 컬러 행정구역.'
                        : '縣市邊界 — 彩色行政區劃。'
                }
              </p>
              <p class="svg-meta">Wikimedia Commons · CC</p>
              <div class="svg-actions">
                <a
                  href="/assets/svg/taiwan-political-division.svg"
                  download
                  class="btn btn-primary"
                >
                  {t('taiwanShape.download.svg')}
                </a>
                <button
                  class="btn btn-outline"
                  onclick="copySVG('taiwan-political-division.svg', this)"
                  data-copied={t('taiwanShape.copy.copied')}
                  data-default={t('taiwanShape.copy.button')}
                >
                  {t('taiwanShape.copy.button')}
                </button>
              </div>
            </div>
          </article>
        </div>

        <div class="usage-box">
          <h3>{t('taiwanShape.svg.usageHeading')}</h3>
          <div class="code-block">
            <pre><code>{`<!-- HTML -->
<img src="https://lagunabeach.md/assets/svg/taiwan-icon-wiki.svg" alt="Taiwan" width="200">

/* CSS */
background-image: url('https://lagunabeach.md/assets/svg/taiwan-icon-wiki.svg');

<!-- Markdown -->
![Taiwan](https://lagunabeach.md/assets/svg/taiwan-icon-wiki.svg)`}</code></pre>
          </div>
          <p class="license-note">{t('taiwanShape.svg.licenseNote')}</p>
        </div>
      </div>
    </section>

    <!-- TopoJSON Section -->
    <section class="shape-geo">
      <div class="section-inner">
        <h2>{t('taiwanShape.geo.heading')}</h2>
        <p>{t('taiwanShape.geo.intro1')}</p>
        <p>{t('taiwanShape.geo.intro2')}</p>

        <h3>{t('taiwanShape.geo.formatHeading')}</h3>
        <div class="format-compare">
          <div class="format-box topo">
            <div class="format-label">TopoJSON</div>
            <p>{t('taiwanShape.geo.formatTopo')}</p>
          </div>
          <div class="format-box geo">
            <div class="format-label">GeoJSON</div>
            <p>{t('taiwanShape.geo.formatGeo')}</p>
          </div>
        </div>

        <h3>{t('taiwanShape.geo.countryHeading')}</h3>
        <p>{t('taiwanShape.geo.countryDesc')}</p>
        <div class="geo-download-card">
          <div class="geo-file-name"><code>taiwan-country.topo.json</code></div>
          <div class="geo-file-meta">TopoJSON · 22 features · ~21 KB</div>
          <a
            href="/assets/geo/taiwan-country.topo.json"
            download
            class="btn btn-primary"
          >
            {t('taiwanShape.download.topo')}
          </a>
        </div>

        <h3>{t('taiwanShape.geo.townsHeading')}</h3>
        <p>{t('taiwanShape.geo.townsDesc')}</p>
        <div class="geo-grid">
          {
            municipalityFiles.map((f) => (
              <div class="geo-download-card small">
                <div class="geo-file-name">
                  <code>taiwan-towns-{f.code}.topo.json</code>
                </div>
                <div class="geo-file-meta">
                  {f.name} · {f.size}
                </div>
                <a
                  href={`/assets/geo/taiwan-towns-${f.code}.topo.json`}
                  download
                  class="btn btn-outline btn-small"
                >
                  {t('taiwanShape.download.topo')}
                </a>
              </div>
            ))
          }
        </div>
        <p class="geo-note">
          {
            lang === 'en'
              ? 'For the full 22-county set of township files, see '
              : lang === 'ja'
                ? '22 県市全体の町丁目ファイルは '
                : lang === 'ko'
                  ? '22개 현시 전체의 향진 파일은 '
                  : '完整 22 縣市鄉鎮檔案請見 '
          }
          <a
            href="https://github.com/waiting7777/taiwan-vue-components/tree/master/src/json"
            target="_blank"
            rel="noopener noreferrer"
            >github.com/waiting7777/taiwan-vue-components</a
          >.
        </p>
      </div>
    </section>

    <!-- Administrative Codes Reference -->
    <section class="shape-codes">
      <div class="section-inner">
        <h2>{t('taiwanShape.codes.heading')}</h2>
        <p>{t('taiwanShape.codes.intro')}</p>
        <div class="codes-table-wrap">
          <table class="codes-table">
            <thead>
              <tr>
                <th>{t('taiwanShape.codes.codeCol')}</th>
                <th>{t('taiwanShape.codes.nameCol')}</th>
                <th>{t('taiwanShape.codes.typeCol')}</th>
              </tr>
            </thead>
            <tbody>
              {
                divisionCodes.map((row) => (
                  <tr>
                    <td>
                      <code>{row.code}</code>
                    </td>
                    <td>{row.name}</td>
                    <td>{typeLabel[lang]?.[row.type] ?? row.type}</td>
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- Usage Examples -->
    <section class="shape-examples">
      <div class="section-inner">
        <h2>{t('taiwanShape.examples.heading')}</h2>

        <div class="example-block">
          <h3>{t('taiwanShape.examples.d3Title')}</h3>
          <div class="code-block">
            <pre><code>{`// D3.js v7 + topojson-client
import * as d3 from 'd3';
import * as topojson from 'topojson-client';

const topo = await d3.json('https://lagunabeach.md/assets/geo/taiwan-country.topo.json');
const counties = topojson.feature(topo, topo.objects.map);

const projection = d3.geoMercator()
  .center([121, 24])
  .scale(8000)
  .translate([400, 300]);

const path = d3.geoPath().projection(projection);

d3.select('svg')
  .selectAll('path')
  .data(counties.features)
  .join('path')
    .attr('d', path)
    .attr('fill', d => colorScale(d.properties.value))
    .attr('stroke', '#333');`}</code></pre>
          </div>
        </div>

        <div class="example-block">
          <h3>{t('taiwanShape.examples.pythonTitle')}</h3>
          <div class="code-block">
            <pre><code>{`# Python — convert TopoJSON to GeoDataFrame
import json, geopandas as gpd
from topojson import Topology

with open('taiwan-country.topo.json') as f:
    topo = json.load(f)

# Convert to GeoJSON
topology = Topology(topo)
gdf = gpd.GeoDataFrame.from_features(
    topology.to_geojson()['features']
)
gdf.plot(column='name', legend=True)`}</code></pre>
          </div>
        </div>

        <div class="example-block">
          <h3>{t('taiwanShape.examples.leafletTitle')}</h3>
          <div class="code-block">
            <pre><code>{`// Leaflet + topojson
import L from 'leaflet';
import * as topojson from 'topojson-client';

const map = L.map('map').setView([24, 121], 7);
L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);

fetch('https://lagunabeach.md/assets/geo/taiwan-country.topo.json')
  .then(r => r.json())
  .then(topo => {
    const geojson = topojson.feature(topo, topo.objects.map);
    L.geoJSON(geojson, {
      style: { color: '#4a90e2', weight: 1, fillOpacity: 0.3 }
    }).addTo(map);
  });`}</code></pre>
          </div>
        </div>

        <div class="example-block">
          <h3>{t('taiwanShape.examples.vueTitle')}</h3>
          <div class="code-block">
            <pre><code>{`// Vue 2 — taiwan-vue-components (original source)
npm install taiwan-vue-components

// In your Vue component
import { Country, Taipei, Kaohsiung } from 'taiwan-vue-components';

<template>
  <div>
    <Country :width="400" :height="600" fill="#f0f0f0" stroke="#333" />
    <Taipei :width="300" :height="300" />
  </div>
</template>`}</code></pre>
          </div>
        </div>
      </div>
    </section>

    <!-- Other Sources -->
    <section class="shape-others">
      <div class="section-inner">
        <h2>{t('taiwanShape.others.heading')}</h2>
        <p>{t('taiwanShape.others.intro')}</p>
        <ul class="sources-list">
          <li>
            <a
              href="https://data.gov.tw/"
              target="_blank"
              rel="noopener noreferrer">政府資料開放平臺 (data.gov.tw)</a
            > —
            {
              lang === 'en'
                ? 'Official Taiwan government open data, including administrative boundary shapefiles from the Ministry of the Interior.'
                : lang === 'ja'
                  ? '台湾政府のオープンデータ公式ポータル、内政部の行政境界シェープファイルを含む。'
                  : lang === 'ko'
                    ? '대만 정부의 공식 오픈 데이터, 내정부의 행정 경계 셰이프 파일 포함.'
                    : '政府官方開放資料平台，包含內政部發布的行政區界 shapefile。'
            }
          </li>
          <li>
            <a
              href="https://www.naturalearthdata.com/"
              target="_blank"
              rel="noopener noreferrer">Natural Earth</a
            > —
            {
              lang === 'en'
                ? 'Public domain global map data at 1:10m, 1:50m, and 1:110m scales. Great for small-scale world maps that include Taiwan.'
                : lang === 'ja'
                  ? 'パブリックドメインのグローバル地図データ、1:10m、1:50m、1:110m スケール。小スケールの世界地図に最適。'
                  : lang === 'ko'
                    ? '퍼블릭 도메인 글로벌 지도 데이터, 1:10m, 1:50m, 1:110m 축척. 소축척 세계 지도에 최적.'
                    : '公有領域全球地圖資料，1:10m / 1:50m / 1:110m 三種比例尺。適合做含台灣的世界地圖。'
            }
          </li>
          <li>
            <a
              href="https://www.openstreetmap.org/relation/449220"
              target="_blank"
              rel="noopener noreferrer">OpenStreetMap (Taiwan relation)</a
            > —
            {
              lang === 'en'
                ? "OSM's community-edited map of Taiwan, downloadable as OSM XML or PBF via Overpass API and Geofabrik."
                : lang === 'ja'
                  ? 'OSM コミュニティが編集した台湾地図、Overpass API と Geofabrik 経由で OSM XML または PBF としてダウンロード可能。'
                  : lang === 'ko'
                    ? 'OSM 커뮤니티가 편집한 대만 지도, Overpass API와 Geofabrik을 통해 OSM XML 또는 PBF로 다운로드 가능.'
                    : 'OSM 社群編輯的台灣地圖，可透過 Overpass API 與 Geofabrik 下載 OSM XML 或 PBF。'
            }
          </li>
          <li>
            <a
              href="https://gadm.org/download_country.html"
              target="_blank"
              rel="noopener noreferrer">GADM — Taiwan</a
            > —
            {
              lang === 'en'
                ? 'Global Administrative Areas database, Taiwan administrative boundaries at levels 0-3 in Shapefile, GeoPackage, KMZ, and R formats.'
                : lang === 'ja'
                  ? 'グローバル行政区域データベース、台湾の行政境界 0-3 レベルを Shapefile、GeoPackage、KMZ、R 形式で提供。'
                  : lang === 'ko'
                    ? '글로벌 행정구역 데이터베이스, 대만 행정 경계 0-3 레벨을 Shapefile, GeoPackage, KMZ, R 형식으로 제공.'
                    : '全球行政區資料庫，台灣行政區界 0-3 級，提供 Shapefile / GeoPackage / KMZ / R 格式。'
            }
          </li>
          <li>
            <a href="https://g0v.tw/" target="_blank" rel="noopener noreferrer"
              >g0v.tw</a
            > —
            {
              lang === 'en'
