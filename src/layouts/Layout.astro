---
import '../styles/global.css';
import '../styles/shot-mode.css';
import '../styles/dark-polish.css';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BrandMark from '../components/BrandMark.astro';
import ReaderSettings from '../components/ReaderSettings.astro';
import HeadInlineScripts from '../components/HeadInlineScripts.astro';

import type { Lang } from '../config/languages';

interface Props {
  title: string;
  description?: string;
  lang?: Lang;
  image?: string;
  type?: 'website' | 'article';
  datePublished?: string;
  dateModified?: string;
  content?: string;
  tags?: string[];
  category?: string;
  slug?: string;
  categorySlug?: string;
  noindex?: boolean;
}

const { lang = 'zh-TW' } = Astro.props;
const {
  title,
  description = lang === 'en'
    ? 'Open-source knowledge base about Taiwan'
    : '讓全世界完整認識台灣',
  image,
  type,
  datePublished,
  dateModified,
  content,
  tags,
  category,
  slug,
  categorySlug: propCategorySlug,
  noindex,
} = Astro.props;

// Search index now loaded via /api/search-index.json (fetch API)
const isEn = lang === 'en';
// categorySlug: prefer the English URL slug passed explicitly (e.g. 'food',
// 'history') so the body's `jf-{slug}` class matches the English selectors
// the justfont SDK config below uses (`.jf-food h1`, `.jf-history h1`).
// Pre-2026-05-04 this took `category?.toLowerCase()` which ALSO captured the
// localized display name (`自然`, `美食`) and produced classes like `jf-自然`
// that no SDK selector matched — the category-specific font rules were dead
// in production. Falling back to the old behavior for callers that don't
// pass categorySlug (utility pages still get `jf-${category}` like before).
const categorySlug =
  propCategorySlug?.toLowerCase() || category?.toLowerCase() || '';
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const isHome = currentPath === '/' || currentPath === '/en';

// Reader options (dark mode + ReaderSettings panel) only run on standard
// category article pages — those are the only routes whose prose CSS is
// dark-ready. Dashboard / home / bench / hub pages still have white-island
// component layouts that look broken on a dark body, so we keep them
// light until a dedicated dark-mode pass per surface lands.
// Detection: only [category]/[slug].astro pages pass BOTH props.
// (Hub pages pass category only; lifetree passes slug only; landings pass neither.)
const isArticlePage = Boolean(category && slug);
// justfont: only put the body font class on <body> to avoid rate-limit.
// Other font classes go on specific elements (h1-h6, blockquote, nav, etc.)
const jfClass = [
  'jf-jinxuanlatte-regular',
  isHome ? 'page-home' : 'page-default',
  categorySlug ? `jf-${categorySlug}` : '',
]
  .filter(Boolean)
  .join(' ');
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <!-- Apple touch icons: 2026-04-11 fix. Cloudflare logs showed 130 req/day
         404 on /apple-touch-icon.png + /apple-touch-icon-precomposed.png.
         iOS/macOS Safari auto-probes these paths. -->
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link
      rel="apple-touch-icon-precomposed"
      href="/apple-touch-icon-precomposed.png"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Taiwan Typography System -->
    <!-- Google Fonts: Noto Sans/Serif TC for fallback -->
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@300;400;500;600;700;800;900&family=Noto+Serif+TC:wght@400;600;700;900&display=swap"
      rel="preload"
      as="style"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <!-- justfont 蘭陽明體 已透過 justfont SDK 載入，無需額外 import -->
    <!-- Fallback for critical text -->
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@300;400;500;600;700;800;900&family=Noto+Serif+TC:wght@400;600;700;900&display=swap"
        rel="stylesheet"
      />
    </noscript>
    <title>{title} | Taiwan.md</title>
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Taiwan.md RSS"
      href="/rss.xml"
    />
    <SEO
      title={title}
      description={description}
      lang={lang}
      image={image}
      type={type}
      datePublished={datePublished}
      dateModified={dateModified}
      content={content}
      tags={tags}
      category={category}
      slug={slug}
      categorySlug={propCategorySlug}
    />
    <!-- Pre-paint inline scripts: shot-mode + reader-settings FOUC init.
         2026-05-03 sleepy-colden Tier 2.6: 抽到 src/components/HeadInlineScripts.astro
         讓 Layout 主結構乾淨。原本 ~150 行 inline 邏輯都在這裡。 -->
    <HeadInlineScripts isArticlePage={isArticlePage} />
    <script
      is:inline
      async
      src="https://www.googletagmanager.com/gtag/js?id=G-JGC5W00N7T"></script>
