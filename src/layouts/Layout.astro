---
import '../styles/global.css';
import '../styles/shot-mode.css';
import '../styles/dark-polish.css';
import '../styles/article-modules.css';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BrandMark from '../components/BrandMark.astro';
import ReaderSettings from '../components/ReaderSettings.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import HeadInlineScripts from '../components/HeadInlineScripts.astro';
import EventTracker from '../components/EventTracker.astro';

import type { Lang } from '../config/languages';

interface Props {
  title: string;
  description?: string;
  lang?: Lang;
  image?: string;
  type?: 'website' | 'article';
  datePublished?: string;
  dateModified?: string;
  content?: string;
  tags?: string[];
  category?: string;
  slug?: string;
  categorySlug?: string;
  noindex?: boolean;
  /**
   * Opt this surface into the floating ReaderSettings panel
   * (light/auto/dark theme + text-size + plain-text link) and
   * the FOUC-safe pre-paint theme init script.
   *
   * Contract for opting in: the surface MUST be dark-mode tested.
   * Per-surface dark polish lives in `src/styles/dark-polish.css`
   * scoped under the surface's <main class="..."> hook (e.g.
   * `main.article-page`, `main.category-page`). Don't enable
   * this on a surface that hasn't been visually audited dark —
   * the panel will toggle data-theme on <html> globally and a
   * surface without dark coverage will look broken.
   *
   * Default: false. Article + category-hub templates opt in.
   */
  readerSettings?: boolean;
  /**
   * Opt this surface into the floating reader FeedbackWidget
   * (correction / bug / new-topic → managed backend → cron → GitHub issue).
   * Self-gates on PUBLIC_FEEDBACK_MODE (off/github-only/mock/supabase); when
   * unconfigured it degrades to a static "report on GitHub" button, so it is
   * always safe to leave on. Default: true (every surface that uses Layout).
   * Pass feedback={false} to opt a surface out (e.g. embed/raw views).
   */
  feedback?: boolean;
  /**
   * GA4 page_type dimension for the engagement tracker (EventTracker is mounted
   * once here for EVERY page). Optional — when omitted it's derived from the
   * URL + category/slug props, so every surface gets a sensible page_type with
   * zero per-page wiring. Pass explicitly to override (e.g. pageType="home").
   */
  pageType?: string;
}

const { lang = 'en' } = Astro.props;
const {
  title,
  description = lang === 'zh-TW'
    ? '關於拉古納海灘的開源知識庫'
    : 'Open-source knowledge base about Laguna Beach',
  image,
  type,
  datePublished,
  dateModified,
  content,
  tags,
  category,
  slug,
  categorySlug: propCategorySlug,
  noindex,
  readerSettings = false,
  feedback = true,
  pageType: pageTypeProp,
} = Astro.props;

// Search index now loaded via /api/search-index.json (fetch API)
const isEn = lang === 'en';
const categorySlug =
  propCategorySlug?.toLowerCase() || category?.toLowerCase() || '';
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';

// ── page_type for the engagement tracker (EventTracker, mounted once below) ──
// Explicit prop wins; else derived: an article sets `slug`, a category hub sets
// `category` (no slug); everything else maps to its first URL segment (lang
// prefix stripped) so /about → about, /dashboard → dashboard, / → home.
const pageType =
  pageTypeProp ||
  (slug
    ? 'article'
    : category
      ? 'category'
      : currentPath
          .replace(/^\/(en|ja|ko|es|fr)(?=\/|$)/, '')
          .split('/')
          .filter(Boolean)[0] || 'home');
const isHome = currentPath === '/' || currentPath === '/en';
// Feedback widget page-kind (v2): drives context-aware category set + inline
// text-selection annotation on articles. Derived from page type + path.
const fbPageKind =
  type === 'article'
    ? 'article'
    : currentPath.includes('/dashboard')
      ? 'dashboard'
      : currentPath.includes('/semiont')
        ? 'semiont'
        : isHome
          ? 'home'
          : propCategorySlug
            ? 'category'
            : 'other';
const bodyClass = isHome ? 'page-home' : 'page-default';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <!-- Apple touch icons: 2026-04-11 fix. Cloudflare logs showed 130 req/day
         404 on /apple-touch-icon.png + /apple-touch-icon-precomposed.png.
         iOS/macOS Safari auto-probes these paths. -->
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link
      rel="apple-touch-icon-precomposed"
      href="/apple-touch-icon-precomposed.png"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Typography System -->
    <!-- Google Fonts: Inter (body) + Noto Sans/Serif TC (zh-TW fallback) -->
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Noto+Sans+TC:wght@300;400;500;600;700;800;900&family=Noto+Serif+TC:wght@400;600;700;900&display=swap"
      rel="preload"
      as="style"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <!-- justfont 蘭陽明體 已透過 justfont SDK 載入，無需額外 import -->
    <!-- Fallback for critical text -->
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Noto+Sans+TC:wght@300;400;500;600;700;800;900&family=Noto+Serif+TC:wght@400;600;700;900&display=swap"
        rel="stylesheet"
      />
    </noscript>
    <title>{title} | LagunaBeach.md</title>
    <link
      rel="alternate"
      type="application/rss+xml"
      title="LagunaBeach.md RSS"
      href="/rss.xml"
    />
    <SEO
      title={title}
      description={description}
      lang={lang}
      image={image}
      type={type}
      datePublished={datePublished}
      dateModified={dateModified}
      content={content}
      tags={tags}
      category={category}
      slug={slug}
      categorySlug={propCategorySlug}
    />
    <!-- FOUC fix: hide <html> until fonts loaded (2026-05-11 picked up from
         tboydar-agent PR #1012 / fixes #401). Combined with shot-mode +
         reader-settings init below for complete pre-paint FOUC prevention. -->
    <style>
      html {
        visibility: hidden;
      }
      html.fonts-loaded {
        visibility: visible;
      }
    </style>
    <script is:inline>
      (function () {
        if (document.fonts) {
          document.fonts.ready.then(function () {
            document.documentElement.classList.add('fonts-loaded');
          });
        } else {
          // fallback for older browsers
          document.documentElement.classList.add('fonts-loaded');
        }
      })();
    </script>
    <!-- Pre-paint inline scripts: shot-mode + reader-settings FOUC init.
         2026-05-03 sleepy-colden Tier 2.6: 抽到 src/components/HeadInlineScripts.astro
         讓 Layout 主結構乾淨。原本 ~150 行 inline 邏輯都在這裡。 -->
    <HeadInlineScripts readerSettings={readerSettings} />
    <script
      is:inline
      async
      src="https://www.googletagmanager.com/gtag/js?id=G-GP9LN8026H"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag('js', new Date());
      gtag('config', 'G-GP9LN8026H');
    </script>
  </head>
  <body class={bodyClass}>
    <Header />

    <script is:inline>
      // ── CJK bigram query tokenizer ──
      var _STOP_BIGRAMS = new Set([
        '不是',
        '不用',
        '不會',
        '也不',
        '也有',
        '也是',
        '他的',
        '他們',
        '但是',
        '你的',
        '到了',
        '到的',
        '到這',
        '們的',
        '在這',
        '她的',
        '就是',
        '我的',
        '我們',
        '是不',
        '是我',
        '是有',
        '是在',
        '是這',
        '有的',
        '的不',
        '的是',
        '用的',
        '而是',
        '都不',
        '都有',
        '都是',
        '這是',
        '為了',
        '這個',
        '那個',
        '這些',
        '這樣',
        '這麼',
        '那麼',
        '這裡',
        '這次',
        '這篇',
        '什麼',
        '自己',
        '己的',
        '其他',
        '其中',
        '可以',
        '因為',
        '所以',
        '因此',
        '沒有',
        '不過',
        '還是',
        '如果',
        '雖然',
        '而且',
        '或是',
        '或許',
        '除了',
        '對於',
        '已經',
        '可能',
        '應該',
        '需要',
        '比較',
        '目前',
        '真的',
        '還有',
        '只是',
        '一個',
        '一些',
        '一下',
        '有一',
        '了一',
        '是一',
        '的一',
        '覺得',
        '起來',
        '出來',
        '就可',
        '也可',
        '是可',
        '是很',
        '算是',
        '上的',
        '中的',
        '來的',
        '面的',
        '樣的',
        '關的',
        '趣的',
        '多的',
        '大的',
        '好的',
        '單的',
        '類的',
        '子的',
        '人的',
        '本的',
        '要的',
      ]);

      function _isCJK(ch) {
        var cp = ch.codePointAt(0);
        // 範圍必須跟 scripts/core/build-search-index.mjs 的 isCJK 同步 —
        // 2026-06-13 Phase 0 補假名 + 諺文（query 端打不中 index 端的洞）
        return (
          (cp >= 0x4e00 && cp <= 0x9fff) ||
          (cp >= 0x3400 && cp <= 0x4dbf) ||
          (cp >= 0x3040 && cp <= 0x30ff) ||
          (cp >= 0x31f0 && cp <= 0x31ff) ||
          (cp >= 0xac00 && cp <= 0xd7a3)
        );
      }

      function _queryBigrams(text) {
        var normalized = text.toLowerCase().normalize('NFKC').trim();
        var segments = normalized.split(/\s+/).filter(Boolean);
        var allTokens = [];
        var filtered = [];
        for (var s = 0; s < segments.length; s++) {
          var seg = segments[s];
          var chars = Array.from(seg);
          var hasCJK = chars.some(function (ch) {
            return _isCJK(ch);
          });
          if (!hasCJK) {
            allTokens.push(seg);
            filtered.push(seg);
            continue;
          }
          if (chars.length === 1) {
            allTokens.push(chars[0]);
            filtered.push(chars[0]);
          } else {
            for (var i = 0; i < chars.length - 1; i++) {
              var bigram = chars[i] + chars[i + 1];
              allTokens.push(bigram);
              if (!_STOP_BIGRAMS.has(bigram)) filtered.push(bigram);
            }
          }
        }
        return filtered.length > 0 ? filtered : allTokens;
      }

      // ── Search engine (MiniSearch with fallback) ──
      var _searchEngine = null;
      var _searchMode = 'loading';
      var _fallbackIdx = null;

      async function _initSearchEngine() {
        try {
          // 2026-06-13 RAG Phase 0：先抓本頁語言的 per-lang shard（六語各一份，
          // ja/ko/es/fr 讀者從零母語結果 → 全母語語料）；shard 404 時退回
          // legacy combined zh+en（舊部署 / 快取相容）。
          var _docLang =
            document.documentElement.getAttribute('lang') || 'zh-TW';
          var res = await fetch('/api/search-minisearch-' + _docLang + '.json');
          if (!res.ok) res = await fetch('/api/search-minisearch.json');
          if (!res.ok) throw new Error('HTTP ' + res.status);
          var data = await res.json();
          var MiniSearch = (
            await import('https://cdn.jsdelivr.net/npm/minisearch@7/dist/es/index.min.js')
          ).default;
          _searchEngine = MiniSearch.loadJSON(JSON.stringify(data), {
            idField: 'id',
            fields: ['title_bigram', 'desc_bigram', 'tags_bigram'],
            storeFields: ['t', 'd', 'u', 'tags', 'lang'],
            tokenize: function (text) {
              return text.split(/\s+/).filter(Boolean);
            },
            searchOptions: {
              boost: { title_bigram: 6, tags_bigram: 4, desc_bigram: 2 },
              prefix: true,
            },
          });
          _searchMode = 'minisearch';
        } catch (e) {
          console.warn(
            '[search] MiniSearch failed, falling back to indexOf:',
            e,
          );
          try {
            var res2 = await fetch('/api/search-index.json');
            if (res2.ok) _fallbackIdx = await res2.json();
            else _fallbackIdx = [];
          } catch (e2) {
            _fallbackIdx = [];
          }
          _searchMode = 'fallback';
        }
      }

      function _doSearch(q, lang) {
        if (_searchMode === 'minisearch' && _searchEngine) {
          var bigrams = _queryBigrams(q);
          var raw = _searchEngine.search(bigrams.join(' '), {
            prefix: true,
            limit: 200,
          });
          var topScore = raw.length > 0 ? raw[0].score : 0;
          var cutoff = topScore * 0.02;
          var matches = raw
            .filter(function (r) {
              return r.score >= cutoff;
            })
            .slice(0, 30);
          // Sort: current language first
          matches.sort(function (a, b) {
            var aLang = a.lang === lang ? 0 : 1;
            var bLang = b.lang === lang ? 0 : 1;
            return aLang - bLang;
          });
          return matches;
        }
        // Fallback: indexOf
        var idx = _fallbackIdx || [];
        var lq = q.toLowerCase();
        var matches = idx.filter(function (item) {
          return (
            item.t.toLowerCase().indexOf(lq) !== -1 ||
            item.d.toLowerCase().indexOf(lq) !== -1 ||
            item.tags.some(function (tag) {
              return String(tag).toLowerCase().indexOf(lq) !== -1;
            })
          );
        });
        matches.sort(function (a, b) {
          return (a.lang === lang ? 0 : 1) - (b.lang === lang ? 0 : 1);
        });
        return matches;
      }

      function _renderResult(item) {
        var langBadge = item.lang === 'en' ? 'EN' : '中';
        var title = item.t || '';
        var desc = item.d || '';
        return (
          '<a class="search-item" href="' +
          item.u +
          '">' +
          '<span class="search-item-lang">' +
          langBadge +
          '</span>' +
          '<div class="search-item-text">' +
          '<span class="search-item-title">' +
          title +
          '</span>' +
          (desc ? '<span class="search-item-desc">' + desc + '</span>' : '') +
          '</div></a>'
        );
      }

      function initSearch() {
        var isEn = document.documentElement.lang === 'en';
        var lang = isEn ? 'en' : 'zh-TW';
        var input = document.getElementById('search-input');
        if (!input) return;
        var results = document.getElementById('search-results');
        var modal = document.getElementById('search-modal');
        var hintEmpty = isEn
          ? 'Type to search across all articles'
          : '輸入關鍵字搜尋所有文章';
        var hintNone = isEn ? 'No results found' : '找不到相關文章';

        // GA4 search tracking (debounced)
        var _gaDebounceTimer = null;
        var _lastTrackedQuery = '';
        var _lastMatchCount = 0;
        var _currentQuery = '';

        function _trackSearchQuery(query, count) {
          if (query.length < 2) return;
          if (query === _lastTrackedQuery) return;
          _lastTrackedQuery = query;
          if (typeof gtag === 'function') {
            gtag('event', 'search_query', {
              search_term: query,
              results_count: count,
              search_lang: lang,
              search_mode: _searchMode,
            });
          }
        }

        function _trackSearchClick(query, title, url, position) {
          if (typeof gtag === 'function') {
            gtag('event', 'search_result_click', {
              search_term: query,
              click_title: title,
              click_url: url,
              click_position: position,
            });
          }
        }

        _initSearchEngine();

        input.addEventListener('input', function () {
          var q = this.value.trim();
          _currentQuery = q;
          if (!q) {
            results.innerHTML =
              '<div class="search-hint">' + hintEmpty + '</div>';
            clearTimeout(_gaDebounceTimer);
            return;
          }
          // Single-char queries are handled by prefix match
          if (_searchMode === 'loading') {
            results.innerHTML =
              '<div class="search-hint">' +
              (isEn ? 'Loading...' : '載入中...') +
              '</div>';
            return;
          }
          var matches = _doSearch(q, lang);
          _lastMatchCount = matches.length;
          if (matches.length === 0) {
            results.innerHTML =
              '<div class="search-hint">' + hintNone + '</div>';
          } else {
            var html = matches.slice(0, 12).map(_renderResult).join('');
            if (matches.length > 12) {
              html +=
                '<div class="search-hint">' +
                (isEn
                  ? '...and ' + (matches.length - 12) + ' more'
                  : '...還有 ' + (matches.length - 12) + ' 篇') +
                '</div>';
            }
            results.innerHTML = html;
          }

          // Debounce GA4 tracking: fire after 800ms of inactivity
          clearTimeout(_gaDebounceTimer);
          _gaDebounceTimer = setTimeout(function () {
            _trackSearchQuery(q, _lastMatchCount);
          }, 800);
        });

        // Track search result clicks via event delegation
        results.addEventListener('click', function (e) {
          var link = e.target.closest('.search-item');
          if (!link) return;
          var allLinks = results.querySelectorAll('.search-item');
          var position = 1;
          for (var i = 0; i < allLinks.length; i++) {
            if (allLinks[i] === link) {
              position = i + 1;
              break;
            }
          }
          var title =
            link.querySelector('.search-item-title')?.textContent || '';
          _trackSearchClick(
            _currentQuery,
            title,
            link.getAttribute('href'),
            position,
          );
        });

        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape' && modal.classList.contains('open')) {
            modal.classList.remove('open');
          }
          if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
            e.preventDefault();
            modal.classList.toggle('open');
            if (modal.classList.contains('open')) {
              setTimeout(function () {
                input.focus();
              }, 100);
            }
          }
          // Restore `/` shortcut (was removed during MiniSearch rewrite, issue #110)
          if (
            e.key === '/' &&
            !modal.classList.contains('open') &&
            !['INPUT', 'TEXTAREA', 'SELECT'].includes(
              (document.activeElement || document.body).tagName,
            ) &&
            !(document.activeElement || document.body).isContentEditable
          ) {
            e.preventDefault();
            modal.classList.add('open');
            setTimeout(function () {
              input.focus();
            }, 100);
          }
        });
      }

      function _tryInit() {
        if (document.getElementById('search-input')) {
          initSearch();
        } else {
          setTimeout(_tryInit, 50);
        }
      }
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', _tryInit);
      } else {
        _tryInit();
      }
    </script>

    <!-- Screenshot mode (?shot=1) watermark — BrandMark (light variant) 固定右下角。
         display: none 由 shot-mode.css 控制，只在 ?shot=1 時顯示。
         必須在 <main> 之外，避免被「hide everything inside main except hero section」
         規則吞掉。2026-04-22 β 從 zh-TW [slug].astro 搬來 Layout，四語言共用。 -->
    <div class="shot-watermark" aria-hidden="true">
      <BrandMark variant="light" size={1.8} />
    </div>

    <main role="main">
      <slot />
    </main>

    <Footer />

    <!-- Floating .md button -->
    <a
      id="md-btn"
      class="floating-md"
      title="查看 Raw Markdown 版本"
      target="_blank"
    >
      .md
    </a>

    <!-- Reader settings: theme + size + plain-text link
         (Issue #615 / idlccp1984 reader options, 2026-05-01 γ-late)
         v1.2 (2026-05-04 zen-mendeleev): gated by explicit `readerSettings`
         prop on Layout. Surfaces opt in by passing readerSettings={true}
         (and audit dark CSS in dark-polish.css before doing so). -->
    {readerSettings && <ReaderSettings lang={lang} />}

    <!-- Reader feedback widget: correction / bug / new-topic → backend → cron → issue.
         Self-gates on PUBLIC_FEEDBACK_MODE; safe to leave on (degrades to a static
         GitHub-issue button when unconfigured). 2026-06-01 feedback-login-system. -->
    {
      feedback && (
        <FeedbackWidget
          lang={lang}
          slug={slug}
          category={categorySlug}
          title={title}
          pageKind={fbPageKind}
        />
      )
    }

    <script is:inline>
      // Set .md button href based on current path
      const btn = document.getElementById('md-btn');
      const pathname = window.location.pathname;
      const ghBase = 'https://github.com/wilsonkichoi/lagunabeach-md/blob/main';

      let target = '/README.md'; // Default fallback

      // Handle special pages
      if (
        pathname === '/' ||
        pathname === '/en' ||
        pathname === '/en/' ||
        pathname === '/index.html'
      ) {
        target = '/README.md';
      } else if (pathname.includes('/contribute')) {
        target = '/CONTRIBUTING.md';
      } else if (pathname.includes('/graph')) {
        target = '/src/pages/graph.astro';
      } else if (pathname.includes('/map')) {
        target = pathname.startsWith('/en')
          ? '/src/pages/en/map.astro'
          : '/src/pages/map.astro';
      } else if (pathname.includes('/about')) {
        target = '/src/pages/about.astro';
      } else {
        // Content pages (Categories or Articles)
        const isEn = pathname.startsWith('/en/');
        // Remove /en/ prefix and leading/trailing slashes
        const cleanPath = pathname
          .replace(/^\/en/, '')
          .replace(/^\//, '')
          .replace(/\/$/, '')
          .replace('index.html', '');
        const parts = cleanPath.split('/');

        if (parts.length > 0 && parts[0]) {
          const cat = parts[0];
          // Capitalize first letter of category (history -> History)
          const catFolder = cat.charAt(0).toUpperCase() + cat.slice(1);

          // ZH source is in knowledge/Category, EN source is in knowledge/en/Category
          const prefix = isEn ? '/knowledge/en' : '/knowledge';

          if (parts.length === 1) {
            // Category Hub: knowledge/History/_History Hub.md
            target = `${prefix}/${catFolder}/_${catFolder} Hub.md`;
          } else {
            // Article: knowledge/History/article-name.md
            const slug = decodeURIComponent(parts.slice(1).join('/'));
            target = `${prefix}/${catFolder}/${slug}.md`;
          }
        }
      }

      btn.href = ghBase + target;

      // Hash-based active state can only be detected client-side
      if (window.location.hash === '#categories') {
        document
          .querySelectorAll('.nav-link[href$="/#categories"]')
          .forEach((l) => l.classList.add('active'));
      }
    </script>

    <!--
      2026-04-27 全站 hash anchor 平滑捲動 + navbar offset
      ──────────────────────────────────────────────────
      改用純 CSS 解（見 global.css §scroll-padding-top）：
        - html { scroll-padding-top: 92px; scroll-behavior: smooth; }
        - prefers-reduced-motion: scroll-behavior: auto
      （刻意不疊 scroll-margin-top on heading，會 additive 變雙倍 offset）

      原本寫過 rAF 自寫動畫繞 Chrome「smooth scroll 被 cancel」的疑似 bug，
      實情是 hidden tab 的 rAF 被 throttle 到 ~1Hz（凍結）造成的測試假象，
      回到 visible tab 後 native smooth scroll 完全正常。教訓 commit 在
      global.css 的 comment 裡，避免下次 contributor 重蹈覆轍。
    -->

    <!-- Site-wide GA4 engagement tracker (scroll_depth / section_view /
         content_click / time_milestone, all carrying page_type) — mounted once
         here so EVERY page is covered. Landmarks via data-ga-view, CTAs via
         data-ga-section. 2026-06-14 cross-page rollout. -->
    <EventTracker pageType={pageType} />
  </body>
</html>

