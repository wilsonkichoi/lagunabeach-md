---
import { getLangSwitchPath } from '../utils/getLangSwitchPath';

const currentPath = Astro.url.pathname;

const { enLink, hasEn } = await getLangSwitchPath(currentPath);
---

<!--
  Phase 4 leaf migration #1: Banner.astro
  ─────────────────────────────────────────
  - Converted to Tailwind atomic utilities in HTML
  - Removed scoped <style> block entirely
  - Teal brand colors (#0284c7, #38bdf8, #7dd3fc) are component-local
    one-offs, kept as arbitrary values: bg-[#0284c7] / text-[#38bdf8]
  - Later phase may promote these to tokens if the color system picks
    up a "lang-banner teal" brand identity
-->
<div
  id="lang-banner"
  class="relative z-50 hidden items-center justify-center gap-4 bg-[#0284c7] px-4 py-[0.6rem] text-center text-[0.85rem] leading-snug text-white [&_a]:font-semibold [&_a]:text-[#38bdf8] [&_a]:underline [&_a:hover]:text-[#7dd3fc]"
>
  {
    hasEn && (
      <span>
        🌐 English version available → <a href={enLink}>Switch to English</a>
      </span>
    )
  }
  <button
    class="cursor-pointer border-none bg-transparent px-[0.3rem] text-base text-white/70 hover:text-white"
    onclick="document.getElementById('lang-banner').style.display='none';localStorage.setItem('lang-banner-dismissed','1');var h=document.getElementById('main-header');if(h)h.style.top='0px';"
    aria-label="Close">✕</button
  >
</div>
<script is:inline>
  (function () {
    if (localStorage.getItem('lang-banner-dismissed')) return;
    // Show banner only on non-default-language paths (e.g. /zh-TW/*)
    // Default language (English) has no prefix, so root / never shows banner
    var path = window.location.pathname;
    var isNonDefault = path.startsWith('/zh-TW') || path.startsWith('/ja') || path.startsWith('/ko') || path.startsWith('/fr') || path.startsWith('/es');
    if (!isNonDefault) return;
    var b = document.getElementById('lang-banner');
    if (b) b.style.display = 'flex';
  })();
</script>
