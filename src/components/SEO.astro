---
import { existsSync } from 'node:fs';
import { resolve } from 'node:path';
import {
  LANGUAGES,
  ENABLED_LANGUAGE_CODES,
  DEFAULT_LANGUAGE,
  getLanguage,
  type Lang,
} from '../config/languages';
import { getLiveArticleCount } from '../utils/liveStats';

// Live article count from prebuilt vitals so SEO meta tracks reality.
// 2026-06-10 audit #5: hoisted to module-level cache (was a per-render
// readFileSync = 8,400+ syscalls/build). Fallback 752 preserved.
const _liveArticleCount = getLiveArticleCount(752);

interface Props {
  title: string;
  description?: string;
  image?: string;
  url?: string;
  lang?: Lang;
  type?: 'website' | 'article';
  datePublished?: string;
  dateModified?: string;
  content?: string;
  tags?: string[];
  category?: string;
  slug?: string;
  categorySlug?: string;
}

const { lang = 'en' } = Astro.props;
const {
  title,
  description = lang === 'zh-TW'
    ? `開源、AI-friendly 的拉古納海灘知識庫。${_liveArticleCount}+ 頁深度內容涵蓋歷史、藝術、美食、海灘、步道等 8 大主題。`
    : `The open-source, AI-friendly knowledge base about Laguna Beach, California. ${_liveArticleCount}+ articles covering history, art, nature, food, beaches, trails, events and neighborhoods.`,
  image = '/images/laguna-social.jpg',
  url = Astro.url.href,
  type = 'website',
  datePublished,
  dateModified,
  content,
  tags,
  category,
  slug,
  categorySlug,
} = Astro.props;

const fullTitle = `${title} | LagunaBeach.md`;
const siteUrl = 'https://lagunabeach.md';

// OG image strategy (2026-04-22 β):
//   - Article pages: per-article OG at /og-images/[lang]/[cat]/[slug].jpg
//   - Generated by `scripts/core/generate-og-images.mjs` via article `?shot=1`
//     mode (unified with spore-image pipeline — single rendering source)
//   - JPG 85 only（vs PNG -70% 體積，1200×630 社交圖視覺無差）
//   - 用 existsSync 在 build time 檢查檔案，若不存在退回預設 social card
//     （避免 og:image URL 404 被社群平台抓空）
let finalImage = image;
if (
  type === 'article' &&
  categorySlug &&
  slug &&
  image === '/images/laguna-social.jpg'
) {
  const isDefaultLang = lang === 'zh-TW';
  const pathPrefix = isDefaultLang
    ? `/og-images/${categorySlug}`
    : `/og-images/${lang}/${categorySlug}`;
  // URL 用 percent-encoded（瀏覽器/社群平台最穩）；
  // 檔案系統檢查用原始 UTF-8（與 og:generate 腳本實際寫入的檔名一致）
  const urlBase = `${pathPrefix}/${encodeURIComponent(slug)}`;
  const diskBase = `${pathPrefix}/${slug}`;

  const jpgFull = resolve(
    process.cwd(),
    'public',
    diskBase.replace(/^\//, '') + '.jpg',
  );

  if (existsSync(jpgFull)) {
    finalImage = `${urlBase}.jpg`;
  }
  // else: finalImage 維持 /images/laguna-social.jpg 預設值
}

const fullImageUrl = new URL(finalImage, siteUrl).href;

// Generate AI-friendly summary from description or content
const aiSummary =
  description ||
  (content
    ? content
        .substring(0, 200)
        .replace(/[\n\r]/g, ' ')
        .replace(/[#*]/g, '')
        .trim() + '...'
    : '');

// Generate JSON-LD structured data
const generateJSONLD = () => {
  // Person pages (people category)
  if (category === 'people' || category === 'People') {
    return {
      '@context': 'https://schema.org',
      '@type': 'Person',
      name: title,
      description: description,
      url: url,
      mainEntityOfPage: {
        '@type': 'WebPage',
        '@id': url,
      },
      ...(datePublished && { birthDate: datePublished }),
    };
  }

  // Article pages
  if (type === 'article' && datePublished) {
    return {
      '@context': 'https://schema.org',
      '@type': 'Article',
      headline: title,
      description: description,
      author: {
        '@type': 'Organization',
        name: 'LagunaBeach.md',
        url: siteUrl,
      },
      publisher: {
        '@type': 'Organization',
        name: 'LagunaBeach.md',
        url: siteUrl,
        logo: {
          '@type': 'ImageObject',
          url: `${siteUrl}/images/laguna-social.jpg`,
          width: 1200,
          height: 630,
        },
      },
      datePublished: datePublished,
      dateModified: dateModified || datePublished,
      inLanguage: lang,
      url: url,
      image: {
        '@type': 'ImageObject',
        url: fullImageUrl,
        width: 1200,
        height: 630,
      },
      mainEntityOfPage: {
        '@type': 'WebPage',
        '@id': url,
      },
      ...(tags && tags.length > 0 && { keywords: tags.join(', ') }),
      ...(category && { articleSection: category }),
    };
  }

  // Website root
  return {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name:
      lang === 'zh-TW'
        ? 'LagunaBeach.md - 拉古納海灘知識庫'
        : 'LagunaBeach.md — Knowledge Base',
    description:
      lang === 'zh-TW'
        ? '開源拉古納海灘知識庫，涵蓋歷史、藝術、自然、美食、海灘、步道、節慶、社區等各方面知識。'
        : 'Open-source, AI-friendly knowledge base about Laguna Beach, California — history, art, nature, food, beaches, trails, events, and neighborhoods.',
    url: siteUrl,
    inLanguage: lang,
    publisher: {
      '@type': 'Organization',
      name: 'LagunaBeach.md',
      url: siteUrl,
      logo: {
        '@type': 'ImageObject',
        url: `${siteUrl}/images/laguna-social.jpg`,
        width: 1200,
        height: 630,
      },
    },
    // 2026-05-27: point SearchAction at /explore (the actual search-first
    // UX, shipped 2026-05-10) instead of the non-existent /search route.
    potentialAction: {
      '@type': 'SearchAction',
      target: {
        '@type': 'EntryPoint',
        urlTemplate: `${siteUrl}/explore?q={search_term_string}`,
      },
      'query-input': 'required name=search_term_string',
    },
    sameAs: [
      'https://github.com/wilsonkichoi/lagunabeach-md',
      'https://x.com/lagunabeachmd',
      'https://www.instagram.com/lagunabeachmd',
    ],
  };
};

const jsonLD = generateJSONLD();

// Organization Schema for all pages.
// 2026-05-27 Wave 2 / Phase 7: expanded for AI reader SEO (PerplexityBot /
// OAI-SearchBot / GPTBot / Googlebot) per LONGINGS §擴散渴望 #4. Added:
//   - `knowsAbout` topical authority signals (12 category domains)
//   - `inLanguage` explicit list of all 6 enabled locales
//   - `slogan` for cite-able tagline
// See reports/homepage-evolution-2026-05-26.md §Gap 5.
const organizationLD = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'LagunaBeach.md',
  alternateName: ['Laguna Beach MD', 'lagunabeach.md'],
  url: siteUrl,
  logo: `${siteUrl}/images/laguna-social.jpg`,
  description:
    lang === 'zh-TW'
      ? '開源、AI-friendly 的拉古納海灘知識庫，涵蓋歷史、藝術、自然、海灘等 8 大主題。'
      : 'Open-source, AI-friendly knowledge base about Laguna Beach, California — curated articles covering history, art, nature, food, beaches, trails, events, and neighborhoods.',
  slogan:
    lang === 'zh-TW'
      ? '策展海灘城市的深度敘事'
      : 'Curating the deep narratives of a coastal city',
  foundingDate: '2026-06-19',
  inLanguage: ENABLED_LANGUAGE_CODES,
  knowsAbout: [
    'Laguna Beach history',
    'Laguna Beach art',
    'Laguna Beach nature',
    'Laguna Beach food',
    'Laguna Beach beaches',
    'Laguna Beach trails',
    'Laguna Beach events',
    'Laguna Beach neighborhoods',
    'Plein air painting',
    'Pageant of the Masters',
    'Orange County California',
    'Southern California coastal ecology',
  ],
  sameAs: [
    'https://github.com/wilsonkichoi/lagunabeach-md',
    'https://x.com/lagunabeachmd',
    'https://www.instagram.com/lagunabeachmd',
    'https://www.threads.com/@lagunabeachmd',
  ],
  contactPoint: {
    '@type': 'ContactPoint',
    email: 'hello@lagunabeach.md',
    contactType: 'Customer Support',
  },
};

// WebSite schema with SearchAction — registers internal search with crawlers.
// Helps Google Sitelinks Search Box + LLM crawlers know we have a queryable
// knowledge base (not just a static blog).
const websiteLD = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'LagunaBeach.md',
  url: siteUrl,
  inLanguage: ENABLED_LANGUAGE_CODES,
  potentialAction: {
    '@type': 'SearchAction',
    target: {
      '@type': 'EntryPoint',
      urlTemplate: `${siteUrl}/explore?q={search_term_string}`,
    },
    'query-input': 'required name=search_term_string',
  },
  publisher: {
    '@type': 'Organization',
    name: 'LagunaBeach.md',
    url: siteUrl,
  },
};

// CollectionPage schema — only emitted for the homepage. Tells AI crawlers
// that `/` is the index of a structured knowledge collection across the 12
// category hubs (not just a marketing landing). Each hub is a `hasPart`.
const isHomepage = (() => {
  try {
    const p = new URL(url).pathname.replace(/\/+$/, '/');
    if (p === '/') return true;
    // Non-default lang homepages: /en/ /ja/ /ko/ /fr/ /es/
    return /^\/(en|ja|ko|fr|es)\/?$/.test(p);
  } catch {
    return false;
  }
})();

const HOMEPAGE_CATEGORY_HUBS = [
  'history',
  'geography',
  'culture',
  'food',
  'art',
  'music',
  'technology',
  'nature',
  'people',
  'society',
  'economy',
  'lifestyle',
];

const homepageCollectionLD = isHomepage
  ? {
      '@context': 'https://schema.org',
      '@type': 'CollectionPage',
      '@id': url,
      url: url,
      name: title,
      description: description,
      inLanguage: lang,
      isPartOf: {
        '@type': 'WebSite',
        '@id': siteUrl,
        name: 'LagunaBeach.md',
      },
      mainEntity: {
        '@type': 'ItemList',
        name:
          lang === 'zh-TW'
            ? 'LagunaBeach.md 知識策展 8 大主題'
            : 'LagunaBeach.md 8 curated knowledge domains',
        numberOfItems: HOMEPAGE_CATEGORY_HUBS.length,
        itemListElement: HOMEPAGE_CATEGORY_HUBS.map((slug, i) => {
          // For non-default langs, hub URL has lang prefix
          const langPrefix = lang === DEFAULT_LANGUAGE.code ? '' : `/${lang}`;
          return {
            '@type': 'ListItem',
            position: i + 1,
            item: {
              '@type': 'CollectionPage',
              '@id': `${siteUrl}${langPrefix}/${slug}`,
              url: `${siteUrl}${langPrefix}/${slug}`,
              name: slug,
            },
          };
        }),
      },
    }
  : null;

// Dynamic keywords (zh-TW gets Chinese keywords; all other langs get English)
const baseKeywords =
  lang === 'zh-TW'
    ? '拉古納海灘, Laguna Beach, 知識庫, 歷史, 藝術, 自然, 海灘'
    : 'Laguna Beach, knowledge base, Laguna Beach history, Laguna Beach art, Laguna Beach beaches, Orange County';

const categoryKeywords = category
  ? lang === 'zh-TW'
    ? [`拉古納海灘${category}`, `${category}拉古納海灘`]
    : [`Laguna Beach ${category}`, `${category} Laguna Beach`]
  : [];

const dynamicKeywords = [
  baseKeywords,
  ...categoryKeywords,
  ...(tags && tags.length > 0 ? tags : []),
].join(', ');

// BreadcrumbList JSON-LD for content pages
const generateBreadcrumbLD = () => {
  const currentPath = new URL(url).pathname;
  // Non-default locales from the registry
  const nonDefaultLocales = ENABLED_LANGUAGE_CODES.filter(
    (c) => c !== DEFAULT_LANGUAGE.code,
  );

  // Determine locale prefix for URLs
  let localePrefix = '';
  for (const p of nonDefaultLocales) {
    if (lang === p) {
      localePrefix = `/${p}`;
      break;
    }
  }

  // Homepage - no breadcrumb needed
  const homePaths = [
    '/',
    ...nonDefaultLocales.flatMap((l) => [`/${l}`, `/${l}/`]),
  ];
  if (homePaths.includes(currentPath)) {
    return null;
  }

  const baseItems = [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'LagunaBeach.md',
      item: `${siteUrl}${localePrefix || ''}`,
    },
  ];

  // Category page (e.g., /history, /en/culture, /ja/food)
  if (
    category &&
    (currentPath.endsWith(`/${category}`) ||
      currentPath.endsWith(`/${category}/`))
  ) {
    return {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [
        ...baseItems,
        {
          '@type': 'ListItem',
          position: 2,
          name: category,
          item: url,
        },
      ],
    };
  }

  // Article page
  if (category && type === 'article') {
    const categoryUrl = `${siteUrl}${localePrefix}/${category}`;
    return {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [
        ...baseItems,
        {
          '@type': 'ListItem',
          position: 2,
          name: category,
          item: categoryUrl,
        },
        {
          '@type': 'ListItem',
          position: 3,
          name: title,
          item: url,
        },
      ],
    };
  }

  // Other pages (about, contribute, etc.)
  return {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      ...baseItems,
      {
        '@type': 'ListItem',
        position: 2,
        name: title,
        item: url,
      },
    ],
  };
};

const breadcrumbLD = generateBreadcrumbLD();
---

<!-- Basic Meta Tags -->
<meta name="description" content={description} />
<meta name="keywords" content={dynamicKeywords} />
<meta name="author" content="LagunaBeach.md" />
<meta name="generator" content="Astro" />
<meta name="theme-color" content="#004d40" />
<meta name="format-detection" content="telephone=no" />

<!-- Additional SEO Meta Tags -->
<meta name="revisit-after" content="7 days" />
<meta name="distribution" content="global" />
<meta name="rating" content="general" />

<!-- AI-friendly summary meta tag -->
<meta name="ai-summary" content={aiSummary} />

<!-- Canonical URL -->
<link rel="canonical" href={url} />

<!-- RSS Feed -->
<link
  rel="alternate"
  type="application/rss+xml"
  title={lang === 'en'
    ? 'LagunaBeach.md RSS Feed (English)'
    : 'LagunaBeach.md RSS 動態消息'}
  href={`${siteUrl}/feed.xml`}
/>

<!-- Preconnect to external resources -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

<!-- DNS prefetch -->
<link rel="dns-prefetch" href="//github.com" />
<link rel="dns-prefetch" href="//x.com" />

<!-- Dynamic Language Tags — driven by LANGUAGES registry -->
{
  (() => {
    const currentPath = new URL(url).pathname;
    // Non-default locale prefixes (everything except zh-TW which has no prefix)
    const nonDefaultCodes = ENABLED_LANGUAGE_CODES.filter(
      (c) => c !== DEFAULT_LANGUAGE.code,
    );

    // Strip any locale prefix to get the base path
    let basePath = currentPath;
    for (const p of nonDefaultCodes) {
      if (currentPath.startsWith(`/${p}/`) || currentPath === `/${p}`) {
        basePath = currentPath.slice(`/${p}`.length) || '/';
        break;
      }
    }

    const buildHref = (code: string) =>
      code === DEFAULT_LANGUAGE.code
        ? `${siteUrl}${basePath}`
        : `${siteUrl}/${code}${basePath === '/' ? '' : basePath}`;

    const defaultHref = buildHref(DEFAULT_LANGUAGE.code);

    return (
      <>
        {ENABLED_LANGUAGE_CODES.map((code) => {
          const entry = getLanguage(code);
          return (
            <link
              rel="alternate"
              hreflang={entry?.hreflang || code}
              href={buildHref(code)}
            />
          );
        })}
        <link rel="alternate" hreflang="x-default" href={defaultHref} />
      </>
    );
  })()
}

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type} />
<meta property="og:url" content={url} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={fullImageUrl} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:type" content="image/jpeg" />
<meta
  property="og:image:alt"
  content={`${title} - ${lang === 'zh-TW' ? 'LagunaBeach.md 拉古納海灘知識庫' : 'LagunaBeach.md — Knowledge Base'}`}
/>
<meta
  property="og:site_name"
  content={lang === 'zh-TW'
    ? 'LagunaBeach.md — 拉古納海灘知識庫'
    : 'LagunaBeach.md — Knowledge Base'}
/>
<meta
  property="og:locale"
  content={(() => {
    // Map registry hreflang → og:locale format (e.g., 'en' → 'en_US', 'ja' → 'ja_JP')
    const ogLocaleMap: Record<string, string> = {
      'zh-Hant': 'zh_TW',
      en: 'en_US',
      ja: 'ja_JP',
      ko: 'ko_KR',
      es: 'es_ES',
      fr: 'fr_FR',
    };
    const entry = getLanguage(lang);
    return ogLocaleMap[entry?.hreflang || ''] || 'zh_TW';
  })()}
/>
{
  datePublished && (
    <meta property="article:published_time" content={datePublished} />
  )
}
{
  dateModified && (
    <meta property="article:modified_time" content={dateModified} />
  )
}
{
  tags &&
    tags.map((tag: string) => <meta property="article:tag" content={tag} />)
}

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content="@lagunabeachmd" />
<meta name="twitter:creator" content="@lagunabeachmd" />
<meta name="twitter:url" content={url} />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={fullImageUrl} />
<meta
  name="twitter:image:alt"
  content={`${title} - ${lang === 'zh-TW' ? 'LagunaBeach.md 拉古納海灘知識庫' : 'LagunaBeach.md — Knowledge Base'}`}
/>

<!-- Additional SEO -->
<meta name="robots" content="index, follow" />
<meta name="googlebot" content="index, follow" />

<!-- JSON-LD Structured Data -->
<script type="application/ld+json" set:html={JSON.stringify(jsonLD, null, 2)} />
<script
  type="application/ld+json"
  set:html={JSON.stringify(organizationLD, null, 2)}
/>
<script
  type="application/ld+json"
  set:html={JSON.stringify(websiteLD, null, 2)}
/>
{
  homepageCollectionLD && (
    <script
      type="application/ld+json"
      set:html={JSON.stringify(homepageCollectionLD, null, 2)}
    />
  )
}
{
  breadcrumbLD && (
    <script
      type="application/ld+json"
      set:html={JSON.stringify(breadcrumbLD, null, 2)}
    />
  )
}
