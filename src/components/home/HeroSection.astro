---
import { useTranslations, getLangFromUrl } from '../../i18n/utils';
import HeroStats from '../HeroStats.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<!--
  Phase 4 leaf migration #10: home/HeroSection.astro
  ──────────────────────────────────────────────────
  - Scoped <style> block removed entirely
  - All classes → Tailwind atomic utilities
  - The 6-radial-gradient "taiwan-mountains" background is preserved
    verbatim as an arbitrary [background:...] value
  - Responsive text sizes use md/lg/max-[...] arbitrary breakpoints to
    match the original 4-tier responsive ladder (default / 1024px /
    768px / 480px)
-->
<section
  class="relative -mt-8 flex w-full max-w-[100vw] items-center overflow-hidden bg-[linear-gradient(to_bottom,#0e2018_0%,#1a3c34_100%)] px-0 pb-20 pt-[calc(8rem+56px)] text-center text-white max-[768px]:min-h-0 max-[768px]:px-4 max-[768px]:pb-16 max-[768px]:pt-[calc(7rem+56px)] max-[480px]:px-2 max-[480px]:pb-12 max-[480px]:pt-[calc(6rem+56px)]"
>
  <div class="absolute inset-0 z-[1]">
    <div
      class="absolute bottom-0 left-0 right-0 h-2/5 [background:radial-gradient(ellipse_1000px_100px_at_5%_100%,rgba(0,77,64,0.15)_0%,transparent_80%),radial-gradient(ellipse_800px_120px_at_15%_100%,rgba(0,77,64,0.2)_0%,transparent_75%),radial-gradient(ellipse_700px_160px_at_35%_100%,rgba(0,99,82,0.25)_0%,transparent_70%),radial-gradient(ellipse_600px_180px_at_55%_100%,rgba(0,99,82,0.3)_0%,transparent_65%),radial-gradient(ellipse_500px_200px_at_70%_100%,rgba(79,209,176,0.2)_0%,transparent_60%),radial-gradient(ellipse_400px_220px_at_85%_100%,rgba(79,209,176,0.25)_0%,transparent_55%)] max-[768px]:h-[35%]"
    >
    </div>
    <svg
      class="absolute right-[8%] top-[15%] h-[180px] w-[180px] opacity-[0.15] [filter:drop-shadow(0_0_10px_rgba(79,209,176,0.2))] max-lg:h-40 max-lg:w-40 max-[768px]:right-[5%] max-[768px]:top-[10%] max-[768px]:h-[120px] max-[768px]:w-[120px] max-[768px]:opacity-20 max-[480px]:h-[100px] max-[480px]:w-[100px] max-[480px]:opacity-[0.15]"
      viewBox="0 0 100 100"
      aria-hidden="true"
    >
      <path
        d="M30 20 C 35 18 40 20 42 25 C 44 30 46 35 48 40 C 50 45 52 50 50 55 C 48 60 46 65 44 70 C 42 75 40 80 35 82 C 30 84 25 82 22 78 C 19 74 20 69 21 64 C 22 59 24 54 26 49 C 28 44 29 39 30 34 C 31 29 30 24 30 20 Z"
        fill="rgba(79, 209, 176, 0.08)"
        stroke="rgba(79, 209, 176, 0.15)"
        stroke-width="0.5"></path>
    </svg>
  </div>
  <div
    class="relative z-10 mx-auto w-full max-w-[1200px] px-8 max-[768px]:px-4"
  >
    <h1
      class="relative mb-6 max-w-full text-[clamp(2rem,11vw,6rem)] font-bold leading-none tracking-tight text-white !font-['jf-kamabit','Noto_Sans_TC','Source_Han_Sans_TC',sans-serif] max-[768px]:mb-[1.2rem]"
    >
      <span
        class="relative z-[2] block text-white [text-shadow:0_2px_8px_rgba(0,0,0,0.3)] !font-[inherit]"
        >LagunaBeach<span class="text-[#4fd1b0]">.md</span></span
      >
    </h1>
    <h2
      class="mb-8 font-['jf-lanyangming','Noto_Serif_TC','Source_Han_Serif_TC',serif] text-[2.8rem] font-light leading-[1.2] tracking-normal text-white/90 [text-shadow:0_1px_4px_rgba(0,0,0,0.3)] max-lg:text-[2.4rem] max-[768px]:mb-8 max-[768px]:text-[2rem] max-[768px]:leading-[1.3] max-[480px]:text-[1.6rem]"
    >
      {t('home.hero.subtitle')}
    </h2>
    <p
      class="mx-auto mb-14 max-w-[700px] text-[1.3rem] font-light leading-[1.8] text-white/85 [text-shadow:0_1px_3px_rgba(0,0,0,0.3)] max-[768px]:mb-14 max-[768px]:max-w-full max-[768px]:px-0 max-[768px]:text-[1.1rem] max-[480px]:text-base"
    >
      {t('home.hero.description')}<br />
      <span class="font-medium tracking-[0.02em] text-white/95">
        {t('home.hero.highlight')}
      </span>
    </p>
    <div
      class="mb-20 flex flex-wrap justify-center gap-8 px-4 max-[768px]:mb-10 max-[768px]:flex-col max-[768px]:items-center max-[768px]:gap-3"
    >
      <a
        href="#categories"
        data-ga-section="hero_cta"
        data-ga-label="explore"
        class="group inline-flex items-center gap-2 rounded-md bg-white/95 px-8 py-[0.8rem] text-[0.95rem] font-semibold tracking-[0.02em] text-[#004d40] no-underline transition-all duration-300 hover:-translate-y-px hover:bg-white hover:shadow-[0_4px_12px_rgba(0,0,0,0.15)] max-[768px]:w-full max-[768px]:max-w-[300px] max-[768px]:justify-center max-[768px]:px-6 max-[768px]:py-[0.6rem] max-[480px]:px-8 max-[480px]:py-5 max-[480px]:text-base"
      >
        <span>{t('home.hero.cta.explore')}</span>
        <svg
          class="transition-all duration-300 group-hover:translate-x-[3px]"
          width="20"
          height="20"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
        </svg>
      </a>
      <a
        href="https://github.com/wilsonkichoi/lagunabeach-md"
        target="_blank"
        data-ga-section="hero_cta"
        data-ga-label="github_star"
        class="group inline-flex items-center gap-2 rounded-md border-[1.5px] border-white/50 bg-transparent px-8 py-[0.8rem] text-[0.95rem] font-semibold tracking-[0.02em] text-white no-underline transition-all duration-300 hover:-translate-y-px hover:border-white/80 hover:bg-white/10 max-[768px]:w-full max-[768px]:max-w-[300px] max-[768px]:justify-center max-[768px]:px-6 max-[768px]:py-[0.6rem] max-[480px]:px-8 max-[480px]:py-5 max-[480px]:text-base"
      >
        <svg
          class="transition-transform duration-300 group-hover:scale-105"
          width="20"
          height="20"
          fill="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            d="M12 0C5.374 0 0 5.373 0 12 0 17.302 3.438 21.8 8.207 23.387c.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"
          ></path>
        </svg>
        <span>⭐ Star on GitHub</span>
      </a>
    </div>
    {
      lang === 'zh-TW' && (
        <div class="mt-8 text-center">
          <p class="m-0 text-[0.8rem] text-white/60">
            {t('home.hero.transparency')}
            <a
              href="https://github.com/wilsonkichoi/lagunabeach-md/issues"
              target="_blank"
              class="text-[rgba(79,209,176,0.8)] underline"
            >
              {t('home.hero.transparency.link')}
            </a>
          </p>
        </div>
      )
    }
    <HeroStats />
  </div>
</section>
