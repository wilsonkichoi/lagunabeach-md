---
interface Props {
  feedbacks: { name: string; text: string }[];
}
const { feedbacks } = Astro.props;
const row1 = feedbacks.filter((_: any, i: number) => i % 3 === 0);
const row2 = feedbacks.filter((_: any, i: number) => i % 3 === 1);
const row3 = feedbacks.filter((_: any, i: number) => i % 3 === 2);

// ── What readers taught us (C2, Wave 3) ──
// 4 publicly traceable callouts that improved LagunaBeach.md.
// Aligns with [[project_error_boundary_traceability]] — publicly correcting a traceable error = a trust signal.
// Every source is documented in docs/semiont/MEMORY.md §neural-circuits / REFLEXES.md.
// All handles come from public sources (spore comments / repo issues / talk callouts) — no private messages leaked.
interface ReaderCallout {
  source: string;
  catch: string;
  fix: string;
}
const calloutsTaughtUs: ReaderCallout[] = [
  {
    source: 'Threads 讀者（公開回覆 spore #29）',
    catch: '「李洋孢子寫『清晨四點多搭捷運』 — 但捷運六點才開」',
    fix: '升級 SPORE-PIPELINE Stage 1 verbatim 規則；禁止從英文摘要推導具體時間／場景 / 交通細節（REFLEXES #23）',
  },
  {
    source: 'Local history teacher (email feedback)',
    catch: '"The 1993 firestorm article says 366 homes — it was 441"',
    fix: 'Fact-checked against SSOT knowledge/ source, corrected within 24h, added Rule 12 to MIGRATION.md',
  },
  {
    source: 'X reader @ste_ven_1487（公開 quote）',
    catch: '「草東貝斯手不是『黃』，是楊世暄」（spore #33 ship 後 3 小時抓到）',
    fix: 'REFLEXES #16 升級「樂團成員姓名 / 獎項名稱 / 公開生日列為 high_priority verify」',
  },
  {
    source: 'Jenny @bugnimusic（透過哲宇轉達）',
    catch: '「魏如萱 spore 用反諷 scene 當 title — 但這個事件不能代表她」',
    fix: 'EDITORIAL v5.1 §Title 原則 1：title 選定義人物本質的 scene，反諷可放 description / 中段，不能定首框',
  },
];

// Tailwind class strings for the repeating bubble + row tracks — extracted
// to variables so the loop stays readable.
const BUBBLE_CLS =
  "relative max-w-[360px] flex-shrink-0 rounded-2xl border border-white/10 bg-white/[0.08] px-[1.4rem] py-4 [backdrop-filter:blur(4px)] [&::after]:content-[''] [&::after]:absolute [&::after]:bottom-[-8px] [&::after]:left-6 [&::after]:h-0 [&::after]:w-0 [&::after]:border-l-[8px] [&::after]:border-r-[8px] [&::after]:border-t-[8px] [&::after]:border-l-transparent [&::after]:border-r-transparent [&::after]:border-t-[rgba(255,255,255,0.08)] max-[768px]:max-w-[280px] max-[768px]:rounded-xl max-[768px]:px-4 max-[768px]:py-3";
const TEXT_CLS =
  'text-[0.95rem] leading-[1.6] text-[#e2e8f0] max-[768px]:text-[0.85rem]';
const NAME_CLS =
  'mt-[0.6rem] text-[0.8rem] font-semibold text-[#7dd3fc] max-[768px]:text-[0.75rem]';
const ROW_CLS =
  'overflow-hidden [mask-image:linear-gradient(to_right,transparent,black_5%,black_95%,transparent)] [-webkit-mask-image:linear-gradient(to_right,transparent,black_5%,black_95%,transparent)]';
const TRACK_LEFT =
  'flex w-max gap-[1.2rem] [animation:marquee-left_100s_linear_infinite]';
const TRACK_RIGHT =
  'flex w-max gap-[1.2rem] [animation:marquee-right_90s_linear_infinite]';
---

<!--
  Phase 7.6 — CommunityFeedback.astro (Tier 1 home component)
  Scoped <style> removed. The 2 marquee @keyframes moved to
  global.css so inline `[animation:marquee-left_...]` can resolve
  them. Long repeating class strings extracted as local const
  variables so the 3-row × 2-copy loop stays readable.
-->
<section
  class="overflow-hidden bg-[linear-gradient(135deg,#0f172a_0%,#1e293b_100%)] pb-12 pt-20 max-[768px]:pb-8 max-[768px]:pt-12"
  aria-labelledby="feedback-heading"
>
  <div class="mb-10 text-center">
    <h2
      id="feedback-heading"
      class="mb-2 font-['jf-lanyangming','Noto_Serif_TC','Source_Han_Serif_TC',serif] text-[2rem] font-light text-white max-[768px]:text-[1.5rem]"
    >
      來自社群的聲音
    </h2>
    <p class="text-[1.1rem] text-[#94a3b8]">真實使用者的回饋</p>
  </div>
  <div class="flex flex-col gap-[1.2rem]">
    <div class={ROW_CLS}>
      <div class={TRACK_LEFT}>
        {
          row1.map((f) => (
            <div class={BUBBLE_CLS}>
              <div class={TEXT_CLS}>{f.text}</div>
              <div class={NAME_CLS}>{f.name}</div>
            </div>
          ))
        }
        {
          row1.map((f) => (
            <div class={BUBBLE_CLS} aria-hidden="true">
              <div class={TEXT_CLS}>{f.text}</div>
              <div class={NAME_CLS}>{f.name}</div>
            </div>
          ))
        }
      </div>
    </div>
    <div class={ROW_CLS}>
      <div class={TRACK_RIGHT}>
        {
          row2.map((f) => (
            <div class={BUBBLE_CLS}>
              <div class={TEXT_CLS}>{f.text}</div>
              <div class={NAME_CLS}>{f.name}</div>
            </div>
          ))
        }
        {
          row2.map((f) => (
            <div class={BUBBLE_CLS} aria-hidden="true">
              <div class={TEXT_CLS}>{f.text}</div>
              <div class={NAME_CLS}>{f.name}</div>
            </div>
          ))
        }
      </div>
    </div>
    <div class={ROW_CLS}>
      <div class={TRACK_LEFT}>
        {
          row3.map((f) => (
            <div class={BUBBLE_CLS}>
              <div class={TEXT_CLS}>{f.text}</div>
              <div class={NAME_CLS}>{f.name}</div>
            </div>
          ))
        }
        {
          row3.map((f) => (
            <div class={BUBBLE_CLS} aria-hidden="true">
              <div class={TEXT_CLS}>{f.text}</div>
              <div class={NAME_CLS}>{f.name}</div>
            </div>
          ))
        }
      </div>
    </div>
  </div>

  {/* ─── What readers taught us (C2, Wave 3) ─── */}
  <div
    class="mx-auto mt-20 max-w-[900px] px-8 max-[768px]:mt-12 max-[480px]:px-4"
  >
    <div class="mb-10 text-center">
      <h3
        class="mb-2 font-['jf-lanyangming','Noto_Serif_TC','Source_Han_Serif_TC',serif] text-[1.65rem] font-light text-white max-[768px]:text-[1.35rem]"
      >
        讀者教我們的事
      </h3>
      <p
        class="text-[0.92rem] leading-[1.7] text-[#94a3b8] max-[768px]:text-[0.85rem]"
      >
        每一條都改變了 LagunaBeach.md
        的某個規則或某個器官。可追溯的錯誤公開改正＝信任訊號，不是污點。
      </p>
    </div>
    <div class="grid grid-cols-2 gap-4 max-[768px]:grid-cols-1">
      {
        calloutsTaughtUs.map((c) => (
          <div class="rounded-xl border border-white/10 bg-white/[0.05] p-5 transition-all duration-300 hover:border-white/20 hover:bg-white/[0.08]">
            <div class="mb-2 text-[0.72rem] font-semibold uppercase tracking-[0.08em] text-[#7dd3fc]">
              {c.source}
            </div>
            <blockquote class="mb-3 border-l-2 border-[#7dd3fc]/30 pl-3 text-[0.92rem] italic leading-[1.6] text-[#e2e8f0] max-[768px]:text-[0.86rem]">
              {c.catch}
            </blockquote>
            <div class="text-[0.82rem] leading-[1.65] text-[#cbd5e1] max-[768px]:text-[0.78rem]">
              <span class="font-semibold text-[#a5f3fc]">→ 我們學到的：</span>
              {c.fix}
            </div>
          </div>
        ))
      }
    </div>
    <p
      class="mt-8 text-center text-[0.82rem] italic text-[#64748b] max-[768px]:text-[0.78rem]"
    >
      完整 callout 池見 <a
        href="https://github.com/wilsonkichoi/lagunabeach-md/blob/main/docs/semiont/REFLEXES.md"
        class="underline decoration-[#7dd3fc]/30 hover:text-[#7dd3fc]"
        target="_blank">REFLEXES.md</a
      > §62 個反射條目
    </p>
  </div>
</section>
