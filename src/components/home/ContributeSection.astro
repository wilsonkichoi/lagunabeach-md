---
import {
  getLangFromUrl,
  useTranslations,
  useTranslatedPath,
} from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
---

<!--
  Phase 7.6 — ContributeSection.astro (Tier 1 home component)
  All scoped CSS inlined. The ::before dot-pattern overlay is
  now an absolute inset-0 div with inline background-image.
  Two buttons (.btn-primary / .btn-secondary) inlined directly
  since each appears exactly once.
-->
<section
  class="relative m-0 overflow-hidden rounded-2xl bg-[linear-gradient(135deg,#f8fafc_0%,#e2e8f0_100%)] px-8 py-20 text-center"
  aria-labelledby="contribute-heading"
>
  <div
    class="pointer-events-none absolute inset-0 opacity-50"
    style="background-image: url(&quot;data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%2394a3b8' fill-opacity='0.05' fill-rule='nonzero'%3E%3Ccircle cx='30' cy='30' r='2'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E&quot;);"
    aria-hidden="true"
  >
  </div>
  <div class="relative z-[2]">
    <h2
      id="contribute-heading"
      class="mb-6 text-[2.25rem] font-bold text-[#1f2937]"
    >
      {t('home.contribute.heading')}
    </h2>
    <p
      class="mx-auto mb-10 max-w-[700px] text-[1.2rem] leading-[1.7] text-[#6b7280]"
    >
      {t('home.contribute.description')}
    </p>
    <div
      class="flex flex-wrap justify-center gap-6 max-[768px]:flex-col max-[768px]:items-center"
    >
      <a
        href={translatePath('/contribute')}
        data-ga-section="contribute"
        data-ga-label="guide"
        class="rounded-lg bg-[#1e40af] px-10 py-4 text-[1.1rem] font-semibold text-white no-underline shadow-[0_4px_12px_rgba(30,64,175,0.3)] transition-all duration-300 hover:-translate-y-0.5 hover:bg-[#1d4ed8] hover:shadow-[0_6px_16px_rgba(30,64,175,0.4)]"
        >{t('home.contribute.guide')}</a
      >
      <a
        href="https://github.com/frank890417/taiwan-md"
        data-ga-section="contribute"
        data-ga-label="github"
        class="rounded-lg border-2 border-[#1e40af] bg-white px-10 py-4 text-[1.1rem] font-semibold text-[#1e40af] no-underline transition-all duration-300 hover:-translate-y-0.5 hover:bg-[#1e40af] hover:text-white"
        target="_blank">{t('home.contribute.github')}</a
      >
    </div>
  </div>
</section>
