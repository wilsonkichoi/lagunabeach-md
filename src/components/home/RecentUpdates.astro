---
import CommitLog from '../commits/CommitLog.astro';
import {
  getLangFromUrl,
  useTranslations,
  useTranslatedPath,
} from '../../i18n/utils';
import type { Commit } from '../../lib/commits';
import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';

interface Props {
  commits: Commit[];
}

const { commits } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

// ── Heartbeat strip (C1, 2026-05-26): organ scores + vitals row above commits.
// Read prebuilt JSON synchronously at build time; safe fallback if missing.
// See reports/homepage-evolution-2026-05-26.md §C1.
interface OrganRow {
  id: string;
  emoji: string;
  nameZh: string;
  name: string;
  score: number;
  trend?: 'up' | 'down' | 'stable';
}

let organs: OrganRow[] = [];
let vitals: {
  totalArticles?: number;
  contributors?: number;
  articlesLast7Days?: number;
  humanReviewedPercent?: number;
} = {};

try {
  const organPath = resolve(
    process.cwd(),
    'public/api/dashboard-organism.json',
  );
  const o = JSON.parse(readFileSync(organPath, 'utf-8'));
  if (Array.isArray(o.organs)) {
    organs = o.organs.map((x: any) => ({
      id: x.id,
      emoji: x.emoji,
      nameZh: x.nameZh,
      name: x.name,
      score: x.score,
      trend: x.trend,
    }));
  }
} catch {}

try {
  const vitalsPath = resolve(process.cwd(), 'public/api/dashboard-vitals.json');
  vitals = JSON.parse(readFileSync(vitalsPath, 'utf-8'));
} catch {}

// Trend arrow + tone (subtle — we don't want this to read like a stock ticker)
function trendGlyph(t?: 'up' | 'down' | 'stable'): string {
  if (t === 'up') return '↑';
  if (t === 'down') return '↓';
  return '→';
}
function trendColor(t?: 'up' | 'down' | 'stable'): string {
  if (t === 'up') return 'text-[#16a34a]';
  if (t === 'down') return 'text-[#dc2626]';
  return 'text-[#94a3b8]';
}

// Score color band: <50 amber, ≥50 mint. Reflects "transparent flaws" principle
// — current immune=28 publicly visible is a signal, not a hidden weakness
// (per [[project_error_boundary_traceability]] + report §6.1 R3).
function scoreColor(score: number): string {
  if (score < 50) return 'text-[#d97706]';
  return 'text-[#0d9488]';
}

const isZh = lang === 'zh-TW';
const showStrip = organs.length > 0 || vitals.totalArticles !== undefined;
---

<!--
  RecentUpdates.astro — Tier 1 home component.

  2026-05-26 Wave 1 / C1 upgrade: prepend organ-score + vitals strip
  before the commit list, so the homepage exposes the same heartbeat
  signal that drives /dashboard 172.3s engagement (per report §C1).
  Click on either strip → /dashboard for full analytics. Current
  immune=28 is intentionally visible — "transparent flaws are a trust
  signal" per [[project_error_boundary_traceability]] + report §6.1.
-->{
  commits.length > 0 && (
    <section class="mx-auto my-16 max-w-[980px] px-8 max-[768px]:my-12 max-[768px]:px-4">
      <div class="relative overflow-hidden rounded-[20px] border border-[#e0f2fe] bg-[linear-gradient(135deg,#f8fafc_0%,#f0f9ff_100%)] p-10 max-[768px]:p-6">
        <div class="pointer-events-none absolute right-0 top-0 h-[200px] w-[200px] bg-[radial-gradient(circle,rgba(59,130,246,0.05)_0%,transparent_70%)]" />
        <div class="relative z-[2] mb-8 text-center">
          <h2 class="mb-2 font-['jf-lanyanghei','Noto_Sans_TC','Source_Han_Sans_TC',sans-serif] text-[1.8rem] font-extrabold text-[#1e3a5f] max-[768px]:text-[1.5rem]">
            {t('home.updates.heading')}
          </h2>
          <p class="text-base font-medium text-[#64748b]">
            {t('home.updates.subtitle')}
          </p>
        </div>

        {/* ─── Heartbeat strip (organ scores + vitals) ─── */}
        {showStrip && (
          <a
            href={translatePath('/dashboard')}
            data-ga-section="recent_updates"
            data-ga-label="heartbeat_strip"
            class="relative z-[2] mb-6 block rounded-[14px] border border-[#dbe9f3] bg-white/70 px-5 py-4 text-inherit no-underline transition-all duration-300 hover:-translate-y-px hover:border-[#7aa8d4]/60 hover:bg-white hover:shadow-[0_4px_12px_rgba(59,130,246,0.08)]"
          >
            {/* Row 1: 8 organs */}
            {organs.length > 0 && (
              <>
                <div class="mb-1 text-[0.7rem] font-semibold uppercase tracking-[0.08em] text-[#94a3b8] max-[480px]:text-[0.65rem]">
                  {t('home.heartbeat.organsLabel')}
                </div>
                <div class="mb-4 flex flex-wrap gap-x-3 gap-y-2 max-[480px]:gap-x-2 max-[480px]:gap-y-1.5">
                  {organs.map((o) => (
                    <span class="inline-flex items-baseline gap-[0.25rem] text-[0.85rem] max-[480px]:text-[0.78rem]">
                      <span aria-hidden="true">{o.emoji}</span>
                      <span class="text-[#475569]">
                        {isZh ? o.nameZh : o.name}
                      </span>
                      <span
                        class:list={[
                          'font-mono font-bold tabular-nums',
                          scoreColor(o.score),
                        ]}
                      >
                        {o.score}
                      </span>
                      <span
                        class:list={[
                          'text-[0.7rem] font-semibold',
                          trendColor(o.trend),
                        ]}
                        aria-hidden="true"
                      >
                        {trendGlyph(o.trend)}
                      </span>
                    </span>
                  ))}
                </div>
              </>
            )}

            {/* Row 2: vitals */}
            {vitals.totalArticles !== undefined && (
              <>
                <div class="mb-1 text-[0.7rem] font-semibold uppercase tracking-[0.08em] text-[#94a3b8] max-[480px]:text-[0.65rem]">
                  {t('home.heartbeat.vitalsLabel')}
                </div>
                <div class="flex flex-wrap gap-x-4 gap-y-1 text-[0.85rem] text-[#475569] max-[480px]:text-[0.78rem]">
                  <span>
                    <span class="font-mono font-bold tabular-nums text-[#1e3a5f]">
                      {vitals.totalArticles}
                    </span>
                    <span class="ml-0.5">{isZh ? '篇文章' : 'articles'}</span>
                  </span>
                  {vitals.contributors !== undefined && (
                    <span>
                      <span class="font-mono font-bold tabular-nums text-[#1e3a5f]">
                        {vitals.contributors}
                      </span>
                      <span class="ml-0.5">
                        {isZh ? '位 contributor' : 'contributors'}
                      </span>
                    </span>
                  )}
                  {vitals.articlesLast7Days !== undefined && (
                    <span>
                      <span class="font-mono font-bold tabular-nums text-[#16a34a]">
                        +{vitals.articlesLast7Days}
                      </span>
                      <span class="ml-0.5">
                        {isZh ? '過去 7 天' : 'past 7 days'}
                      </span>
                    </span>
                  )}
                  {vitals.humanReviewedPercent !== undefined && (
                    <span>
                      <span class="font-mono font-bold tabular-nums text-[#0d9488]">
                        {vitals.humanReviewedPercent}%
                      </span>
                      <span class="ml-0.5">
                        {isZh ? '人類審核覆蓋' : 'human-reviewed'}
                      </span>
                    </span>
                  )}
                  <span class="ml-auto inline-flex items-center gap-1 font-semibold text-[#1e3a5f]">
                    {t('home.heartbeat.viewMore')}
                  </span>
                </div>
              </>
            )}
          </a>
        )}

        <div class="relative z-[2] mx-auto max-w-[860px]">
          <CommitLog commits={commits} lang={lang} variant="cards" />
        </div>
        <div class="relative z-[2] mt-6 flex flex-wrap items-center justify-center gap-3">
          <a
            href={translatePath('/latest')}
            data-ga-section="recent_updates"
            data-ga-label="latest_articles"
            class="inline-flex items-center gap-[0.3rem] rounded-full bg-[#10b981] px-6 py-[0.6rem] text-[0.9rem] font-semibold text-white no-underline transition-all duration-200 hover:-translate-y-0.5 hover:bg-[#059669] hover:shadow-[0_4px_12px_rgba(16,185,129,0.3)]"
          >
            🆕 {t('nav.latest')}
          </a>
          <a
            href={translatePath('/changelog')}
            data-ga-section="recent_updates"
            data-ga-label="view_all"
            class="inline-flex items-center gap-[0.3rem] rounded-full bg-[#1e3a5f] px-6 py-[0.6rem] text-[0.9rem] font-semibold text-white no-underline transition-all duration-200 hover:-translate-y-0.5 hover:bg-[#1e40af] hover:shadow-[0_4px_12px_rgba(30,64,175,0.3)]"
          >
            {t('home.updates.viewAll')}
          </a>
        </div>
      </div>
    </section>
  )
}
