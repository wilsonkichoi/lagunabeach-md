-8 0.5-0.1-8.1 4.2-4.8-0.2-15.2 0.7-11.4 2.6-9.1 4-7.1 1.2-9.3 2.1-8.2 1.2-2.7 5.7-7.6 1-2.5 0.7-1.4 5.2-4 1.4-2.8 1.6-6.6 1.1-2.8 6.5-6.3 1.9-2.6 2.5-7.2 3.9-7.2 5.3-15 2.5-4.3 2.8-2.8 2.3-1.6 2.1-0.9 1.4-1.4 0.6-2.7 1.1-2.6 4.7-3.7 1.1-2.9 0.6-9.3 0.8-2.6 2.5-2.4 10.5-12.3 0.6-0.7 0.7-3 3.1-2.6 2-5.9 2.6-11.5 8.6-15 2.6-9.2 3.1-5.1 12.3-13.7 6.8-7.4 1.7-3.8 0.8-6.1 2.1-5.2 5.4-9.7 1.5-5.8 1.5-2.4 6.2-1.9 1.8-2 1.1-2.4 1.2-2.3 3.9-4.1 4.3-3.1 5.2-1.4 6.6 1.3-0.8-5.1 2.5-3.4 3.4-3.5 1.7-5.4 0.8-1.7 3.3-1.6 1.4-5 5.2-10.6 2-2.8 0.7-1.4-0.1-1.6-0.6-1.7-1-2.1 1.4-2.7 1.6-1.7 0.1-0.1 1.4-2.1 0.5-3.6 0.8-2.7 1.9-2.6 2.5-2 2.3-0.8-0.2-1.2 0.6-2.7 2.1-5.6 1.9-3.1 8.3-13.2 6.4-7.7 6.7-5.6 17.1-5.6 4-2.5 3.4-3.1 4.2-2.2 8.3-3 18.7-3.4 10.4-1.9 4.4-1.7 5.7-4.8 1.8-0.8 2.1-0.4 2.8-0.1 3.2 1.1 1.8 2.5 1.1 2.5 1.5 1.5 3.2-1.3-3.4-5.3-5.4-5.5-2.8-1.7 0.8-2.5 1.7-1.5 1.8-0.8 0.7-0.8 1.9-4.8 3-5.5 6.1-5.5 8.9-4.5 10.2-2.4 10.1 1.2 4.1 3.2 9.3 13.1 3.4 6.9 1-0.4 2.5-0.7 2.9-0.4 2 0.6-0.1 0.8-1 1.2-0.9 1.7 0.1 2 1 1.2 3.4 2.4 0.7 0.9 1.6 1.6 3.6 1.3 42.5 10.3 3 1.9-1.5 3.4-0.4 2.7 0.6 4.8 2.3 8.1 2.4 3.8 2 0.9 6.5-1 3.3 0.3 3.9 1.1 3.5 1.7 1.8 2.4-19.1 9.5-5.2 4.4z';

// Position 8 organs in a circle around Taiwan center (cx 300, cy 200), r 130.
// Start angle -90° (top), 45° apart, clockwise.
const cx = 300;
const cy = 200;
const r = 130;
const organPositions = organs.slice(0, 8).map((o, i) => {
  const angle = -Math.PI / 2 + (i * Math.PI) / 4;
  return {
    ...o,
    x: cx + r * Math.cos(angle),
    y: cy + r * Math.sin(angle),
  };
});

// 4 flow line endpoints — pick 4 organ slots, one per color.
// mint (write) = top (heart), terracotta (DNA evolution) = right (dna),
// periwinkle (multilingual diffusion) = bottom (language),
// gold (sovereignty) = left (immune).
// Maps positionally: top=0, right=2, bottom=4, left=6 (clockwise from top).
const flowTargets = [
  { idx: 0, color: '#4fd1b0', label: t('home.organism.legend.write') }, // top
  { idx: 2, color: '#d4856a', label: t('home.organism.legend.feedback') }, // right
  { idx: 4, color: '#7aa8d4', label: t('home.organism.legend.diffuse') }, // bottom
  { idx: 6, color: '#c9a96a', label: t('home.organism.legend.sovereign') }, // left
];
---

<section
  class="mx-auto mb-16 mt-12 max-w-[820px] px-8 max-[480px]:px-4"
  aria-label="LagunaBeach.md organism preview"
>
  <a
    href={translatePath('/semiont')}
    data-ga-section="organism_preview"
    data-ga-label="open"
    class="group block rounded-2xl border border-[#e2e8f0] bg-[linear-gradient(135deg,#0e2018_0%,#1a3c34_100%)] p-10 no-underline transition-all duration-300 hover:border-[#4fd1b0]/50 hover:shadow-[0_8px_24px_rgba(79,209,176,0.15)] max-[480px]:p-6"
  >
    <div class="mb-6 text-center">
      <h3
        class="mb-3 text-[1.5rem] font-light leading-tight text-[#f4f0ea] max-[480px]:text-[1.2rem]"
        style="font-family: 'jf-lanyangming', 'Noto Serif TC', serif;"
      >
        {t('home.organism.heading')}
      </h3>
      <p
        class="mx-auto max-w-[640px] text-[0.95rem] leading-[1.7] text-[#f4f0ea]/65 max-[480px]:text-[0.88rem]"
        style="font-family: 'jf-lanyangming', 'Noto Serif TC', serif;"
      >
        {body}
      </p>
    </div>

    {/* ─── Compact organism SVG ─── */}
    <div class="relative mx-auto mb-6 aspect-[3/2] w-full max-w-[600px]">
      <svg
        viewBox="0 0 600 400"
        class="h-full w-full"
        role="img"
        aria-label="LagunaBeach.md organism preview diagram"
      >
        {/* Soft glow behind center */}
        <defs>
          <radialGradient id="op-glow" cx="50%" cy="50%" r="50%">
            <stop offset="0%" stop-color="#4fd1b0" stop-opacity="0.4"></stop>
            <stop offset="60%" stop-color="#4fd1b0" stop-opacity="0.1"></stop>
            <stop offset="100%" stop-color="#4fd1b0" stop-opacity="0"></stop>
          </radialGradient>
        </defs>

        <circle cx={cx} cy={cy} r="100" fill="url(#op-glow)"></circle>

        {/* ─── 4 flow arcs (mint/terracotta/periwinkle/gold) ─── */}
        {
          flowTargets.map((f) => {
            const target = organPositions[f.idx];
            if (!target) return null;
            return (
              <line
                x1={cx}
                y1={cy}
                x2={target.x}
                y2={target.y}
                stroke={f.color}
                stroke-width="1.5"
                stroke-opacity="0.55"
                stroke-dasharray={
                  f.color === '#d4856a'
                    ? '5,4'
                    : f.color === '#c9a96a'
                      ? '9,5'
                      : '0'
                }
              />
            );
          })
        }

        {/* ─── 8 organ orbital lines (faint, all) ─── */}
        {
          organPositions.map((o) => (
            <line
              x1={cx}
              y1={cy}
              x2={o.x}
              y2={o.y}
              stroke="#4fd1b0"
              stroke-width="0.6"
              stroke-opacity="0.18"
            />
          ))
        }

        {/* ─── Taiwan island center ─── */}
        <g
          transform={`translate(${cx},${cy}) scale(0.16) translate(-716,-495)`}
        >
          <path
            d={TAIWAN_PATH}
            fill="#4fd1b0"
            fill-opacity="0.32"
            stroke="#4fd1b0"
            stroke-width="3"
            stroke-opacity="0.9"></path>
        </g>

        {/* LagunaBeach.md label */}
        <text
          x={cx}
          y={cy + 75}
          text-anchor="middle"
          fill="#f4f0ea"
          font-size="14"
          font-weight="600"
          letter-spacing="0.05em"
        >
          LagunaBeach.md
        </text>

        {/* ─── 8 organ orbital nodes ─── */}
        {
          organPositions.map((o) => (
            <>
              <circle
                cx={o.x}
                cy={o.y}
                r="22"
                fill="#1a3c34"
                stroke="#4fd1b0"
                stroke-width="1.2"
                stroke-opacity="0.55"
              />
              <text x={o.x} y={o.y + 6} text-anchor="middle" font-size="18">
                {o.emoji}
              </text>
              <text
                x={o.x}
                y={o.y + 42}
                text-anchor="middle"
                fill="#f4f0ea"
                fill-opacity="0.7"
                font-size="10"
                font-weight="500"
              >
                {lang === 'zh-TW' ? o.nameZh : o.name}
              </text>
              <text
                x={o.x}
                y={o.y + 55}
                text-anchor="middle"
                fill="#4fd1b0"
                fill-opacity="0.8"
                font-size="9"
                font-family="monospace"
              >
                {o.score}
              </text>
            </>
          ))
        }
      </svg>
    </div>

    {/* ─── Legend strip (4 colors matching the full diagram) ─── */}
    <ul
      class="mx-auto mb-5 flex max-w-[560px] flex-wrap justify-center gap-x-5 gap-y-2 text-[0.78rem] text-[#f4f0ea]/55 max-[480px]:text-[0.72rem]"
      aria-label="Flow legend"
    >
      {
        flowTargets.map((f) => (
          <li class="flex items-center gap-[0.4rem]">
            <span
              class="inline-block h-[2px] w-5"
              style={`background:${f.color};${
                f.color === '#d4856a'
                  ? 'background-image:linear-gradient(90deg,' +
                    f.color +
                    ' 60%,transparent 60%);background-size:6px 2px;background-repeat:repeat-x;'
                  : f.color === '#c9a96a'
                    ? 'background-image:linear-gradient(90deg,' +
                      f.color +
                      ' 70%,transparent 70%);background-size:11px 2px;background-repeat:repeat-x;'
                    : ''
              }`}
            />
            <span>{f.label}</span>
          </li>
        ))
      }
    </ul>

    {/* CTA */}
    <p class="text-center">
      <span
        class="inline-flex items-center gap-1 text-[0.95rem] font-medium text-[#4fd1b0] transition-all duration-300 group-hover:gap-2"
        style="font-family: 'jf-lanyangming', 'Noto Serif TC', serif;"
      >
        {t('home.organism.cta')}
      </span>
    </p>
  </a>
</section>
