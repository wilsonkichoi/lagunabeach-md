---
/**
 * OrganismPreview.astro — Homepage Evolution Wave 1 / A1 (2026-05-26)
 *
 * Replaces the old MiniGraph d3 12-category force-directed widget. Now shows
 * LagunaBeach.md as an organism: real Laguna Beach municipal-boundary SVG
 * center node (2026-06-22, replacing the inherited Taiwan silhouette), 8
 * organ specimens orbiting, 4-color flow legend matching the full
 * SemiontOrganismDiagram on /semiont.
 *
 * Why this replaces the d3 mini-graph:
 *   - /semiont 5/25 NEW (178.9s engagement, top of site) proves the organism
 *     framing has magnetic pull, but homepage didn't reflect it.
 *   - 12-category force-directed graph is a database visualization. LagunaBeach.md
 *     is a Semiont — the homepage hook should match what LagunaBeach.md actually is.
 *   - The full diagram lives at /semiont; this is the appetizer.
 *
 * Reads dashboard-vitals.json + dashboard-organism.json at build time for live
 * organ scores. Article/lang counts are interpolated into the body prose via
 * the i18n {articles} / {langs} placeholders.
 *
 * See reports/homepage-evolution-2026-05-26.md §A1 + SemiontOrganismDiagram.astro
 * for the full version.
 */
import {
  useTranslations,
  getLangFromUrl,
  useTranslatedPath,
} from '../../i18n/utils';
import { ENABLED_LANGUAGE_CODES } from '../../config/languages';
import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

// ── Read live vitals + organs (prebuilt; falls back to safe defaults) ──
let articleCount = 752;
let langCount = ENABLED_LANGUAGE_CODES.length;
let organs: Array<{
  id: string;
  emoji: string;
  nameZh: string;
  name: string;
  score: number;
}> = [];

try {
  const vitalsPath = resolve(process.cwd(), 'public/api/dashboard-vitals.json');
  const v = JSON.parse(readFileSync(vitalsPath, 'utf-8'));
  if (typeof v.totalArticles === 'number') articleCount = v.totalArticles;
} catch {}

try {
  const orgPath = resolve(process.cwd(), 'public/api/dashboard-organism.json');
  const o = JSON.parse(readFileSync(orgPath, 'utf-8'));
  if (Array.isArray(o.organs)) {
    organs = o.organs.map((x: any) => ({
      id: x.id,
      emoji: x.emoji,
      nameZh: x.nameZh,
      name: x.name,
      score: x.score,
    }));
  }
} catch {}

// Body prose with token interpolation
const body = t('home.organism.body')
  .replace('{articles}', String(articleCount))
  .replace('{langs}', String(langCount));

// Laguna Beach municipal-boundary path (City of Laguna Beach, Orange County,
// CA — OSM relation via Nominatim, simplified). Same SSOT bbox convention as
// the old Taiwan path it replaces: x 478-955, y 45-946, so the existing
// scale/translate below needed no changes — only the path data swapped.
const LAGUNA_PATH =
  'M478.0,545.0 L580.0,609.2 L613.8,622.2 L650.4,648.5 L668.6,686.4 L733.0,738.9 L742.9,775.6 L801.2,855.0 L951.0,674.1 L951.1,634.6 L955.0,630.8 L951.1,628.5 L951.1,617.3 L941.9,614.3 L942.9,597.2 L947.2,597.2 L937.5,585.5 L931.2,585.5 L927.6,577.5 L929.8,574.2 L939.1,578.7 L943.7,566.7 L936.2,567.5 L935.9,560.7 L926.3,563.1 L922.8,561.2 L926.4,554.3 L920.0,554.3 L920.1,500.9 L889.7,501.0 L889.7,492.7 L877.5,492.8 L877.3,478.3 L872.9,478.4 L872.4,430.4 L889.8,430.8 L890.0,257.7 L847.7,258.2 L847.4,254.1 L870.6,234.0 L891.0,202.5 L894.4,189.9 L882.0,185.2 L881.5,151.7 L865.0,136.0 L853.7,151.6 L848.9,167.3 L846.4,181.1 L851.5,204.1 L850.4,227.7 L837.6,290.5 L835.1,334.0 L814.3,335.7 L804.3,346.1 L802.1,358.2 L791.4,355.3 L800.4,368.2 L774.8,399.5 L769.2,398.7 L767.5,383.4 L761.8,385.5 L765.6,391.4 L757.0,400.2 L738.1,386.4 L727.9,398.0 L702.8,377.0 L691.0,391.2 L684.9,383.0 L664.5,373.7 L669.7,367.4 L652.8,357.3 L648.5,365.7 L637.6,366.6 L478.0,545.0 Z';

// Position 8 organs in a circle around the Laguna center (cx 300, cy 200), r 130.
// Start angle -90° (top), 45° apart, clockwise.
const cx = 300;
const cy = 200;
const r = 130;
const organPositions = organs.slice(0, 8).map((o, i) => {
  const angle = -Math.PI / 2 + (i * Math.PI) / 4;
  return {
    ...o,
    x: cx + r * Math.cos(angle),
    y: cy + r * Math.sin(angle),
  };
});

// 4 flow line endpoints — pick 4 organ slots, one per color.
// mint (write) = top (heart), terracotta (DNA evolution) = right (dna),
// periwinkle (multilingual diffusion) = bottom (language),
// gold (sovereignty) = left (immune).
// Maps positionally: top=0, right=2, bottom=4, left=6 (clockwise from top).
const flowTargets = [
  { idx: 0, color: '#38bdf8', label: t('home.organism.legend.write') }, // top
  { idx: 2, color: '#d4856a', label: t('home.organism.legend.feedback') }, // right
  { idx: 4, color: '#7aa8d4', label: t('home.organism.legend.diffuse') }, // bottom
  { idx: 6, color: '#c9a96a', label: t('home.organism.legend.sovereign') }, // left
];
---

<section
  class="mx-auto mb-16 mt-12 max-w-[820px] px-8 max-[480px]:px-4"
  aria-label="LagunaBeach.md organism preview"
>
  <a
    href={translatePath('/semiont')}
    data-ga-section="organism_preview"
    data-ga-label="open"
    class="group block rounded-2xl border border-[#e2e8f0] bg-[linear-gradient(135deg,#082f49_0%,#0e3a5c_100%)] p-10 no-underline transition-all duration-300 hover:border-[#38bdf8]/50 hover:shadow-[0_8px_24px_rgba(56,189,248,0.15)] max-[480px]:p-6"
  >
    <div class="mb-6 text-center">
      <h3
        class="mb-3 text-[1.5rem] font-light leading-tight text-[#f4f0ea] max-[480px]:text-[1.2rem]"
        style="font-family: 'jf-lanyangming', 'Noto Serif TC', serif;"
      >
        {t('home.organism.heading')}
      </h3>
      <p
        class="mx-auto max-w-[640px] text-[0.95rem] leading-[1.7] text-[#f4f0ea]/65 max-[480px]:text-[0.88rem]"
        style="font-family: 'jf-lanyangming', 'Noto Serif TC', serif;"
      >
        {body}
      </p>
    </div>

    {/* ─── Compact organism SVG ─── */}
    <div class="relative mx-auto mb-6 aspect-[3/2] w-full max-w-[600px]">
      <svg
        viewBox="0 0 600 400"
        class="h-full w-full"
        role="img"
        aria-label="LagunaBeach.md organism preview diagram"
      >
        {/* Soft glow behind center */}
        <defs>
          <radialGradient id="op-glow" cx="50%" cy="50%" r="50%">
            <stop offset="0%" stop-color="#38bdf8" stop-opacity="0.4"></stop>
            <stop offset="60%" stop-color="#38bdf8" stop-opacity="0.1"></stop>
            <stop offset="100%" stop-color="#38bdf8" stop-opacity="0"></stop>
          </radialGradient>
        </defs>

        <circle cx={cx} cy={cy} r="100" fill="url(#op-glow)"></circle>

        {/* ─── 4 flow arcs (mint/terracotta/periwinkle/gold) ─── */}
        {
          flowTargets.map((f) => {
            const target = organPositions[f.idx];
            if (!target) return null;
            return (
              <line
                x1={cx}
                y1={cy}
                x2={target.x}
                y2={target.y}
                stroke={f.color}
                stroke-width="1.5"
                stroke-opacity="0.55"
                stroke-dasharray={
                  f.color === '#d4856a'
                    ? '5,4'
                    : f.color === '#c9a96a'
                      ? '9,5'
                      : '0'
                }
              />
            );
          })
        }

        {/* ─── 8 organ orbital lines (faint, all) ─── */}
        {
          organPositions.map((o) => (
            <line
              x1={cx}
              y1={cy}
              x2={o.x}
              y2={o.y}
              stroke="#38bdf8"
              stroke-width="0.6"
              stroke-opacity="0.18"
            />
          ))
        }

        {/* ─── Laguna Beach center ─── */}
        <g
          transform={`translate(${cx},${cy}) scale(0.16) translate(-716,-495)`}
        >
          <path
            d={LAGUNA_PATH}
            fill="#38bdf8"
            fill-opacity="0.32"
            stroke="#38bdf8"
            stroke-width="3"
            stroke-opacity="0.9"></path>
        </g>

        {/* LagunaBeach.md label */}
        <text
          x={cx}
          y={cy + 75}
          text-anchor="middle"
          fill="#f4f0ea"
          font-size="14"
          font-weight="600"
          letter-spacing="0.05em"
        >
          LagunaBeach.md
        </text>

        {/* ─── 8 organ orbital nodes ─── */}
        {
          organPositions.map((o) => (
            <>
              <circle
                cx={o.x}
                cy={o.y}
                r="22"
                fill="#0e3a5c"
                stroke="#38bdf8"
                stroke-width="1.2"
                stroke-opacity="0.55"
              />
              <text x={o.x} y={o.y + 6} text-anchor="middle" font-size="18">
                {o.emoji}
              </text>
              <text
                x={o.x}
                y={o.y + 42}
                text-anchor="middle"
                fill="#f4f0ea"
                fill-opacity="0.7"
                font-size="10"
                font-weight="500"
              >
                {lang === 'zh-TW' ? o.nameZh : o.name}
              </text>
              <text
                x={o.x}
                y={o.y + 55}
                text-anchor="middle"
                fill="#38bdf8"
                fill-opacity="0.8"
                font-size="9"
                font-family="monospace"
              >
                {o.score}
              </text>
            </>
          ))
        }
      </svg>
    </div>

    {/* ─── Legend strip (4 colors matching the full diagram) ─── */}
    <ul
      class="mx-auto mb-5 flex max-w-[560px] flex-wrap justify-center gap-x-5 gap-y-2 text-[0.78rem] text-[#f4f0ea]/55 max-[480px]:text-[0.72rem]"
      aria-label="Flow legend"
    >
      {
        flowTargets.map((f) => (
          <li class="flex items-center gap-[0.4rem]">
            <span
              class="inline-block h-[2px] w-5"
              style={`background:${f.color};${
                f.color === '#d4856a'
                  ? 'background-image:linear-gradient(90deg,' +
                    f.color +
                    ' 60%,transparent 60%);background-size:6px 2px;background-repeat:repeat-x;'
                  : f.color === '#c9a96a'
                    ? 'background-image:linear-gradient(90deg,' +
                      f.color +
                      ' 70%,transparent 70%);background-size:11px 2px;background-repeat:repeat-x;'
                    : ''
              }`}
            />
            <span>{f.label}</span>
          </li>
        ))
      }
    </ul>

    {/* CTA */}
    <p class="text-center">
      <span
        class="inline-flex items-center gap-1 text-[0.95rem] font-medium text-[#38bdf8] transition-all duration-300 group-hover:gap-2"
        style="font-family: 'jf-lanyangming', 'Noto Serif TC', serif;"
      >
        {t('home.organism.cta')}
      </span>
    </p>
  </a>
</section>
