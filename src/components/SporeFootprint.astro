---
/**
 * SporeFootprint — 社群足跡（溫暖紀實風格）
 *
 * v2 (2026-06-10, reports/spore-data-architecture-2026-06-10.md):
 * frontmatter sporeLinks 只帶 identity（id/platform/date/url），engagement
 * 數字 build-time join src/data/spores.json（孢子自己的記錄層）。文章檔案
 * 不再因 harvest 回填而變動。Inline metric 欄位仍接受作 fallback（過渡期
 * 譯文 / fork 沒帶 spores.json 時 markdown 仍自我完整）。
 */
import type { Lang } from '../config/languages';
import sporesData from '../data/spores.json';

interface SporeLink {
  id?: number;
  platform: string;
  date: string;
  url: string;
  views?: number;
  likes?: number;
  reposts?: number;
  comments?: number;
  shares?: number;
}

interface Props {
  sporeLinks: SporeLink[];
  lang?: Lang;
}

const { sporeLinks, lang = 'zh-TW' } = Astro.props;

if (!sporeLinks || sporeLinks.length === 0) return;

// Module-scope record maps — built once per build process.
type SporeRecord = {
  id: number;
  url: string | null;
  metrics: Record<string, number | null>;
};
const records = (sporesData as any).spores as SporeRecord[];
const byId = new Map<number, SporeRecord>(records.map((r) => [r.id, r]));
const byUrl = new Map<string, SporeRecord>(
  records.filter((r) => r.url).map((r) => [r.url as string, r]),
);

// Join: spores.json record (by id, then url) wins; inline frontmatter values
// are the fallback so the component degrades gracefully without the data file.
const enriched = sporeLinks.map((s) => {
  const rec = (s.id != null ? byId.get(s.id) : undefined) ?? byUrl.get(s.url);
  const m = rec?.metrics ?? {};
  return {
    ...s,
    views: m.views ?? s.views,
    likes: m.likes ?? s.likes,
  };
});

const title =
  lang === 'zh-TW' ? '這篇文章去過的地方' : 'Where this story traveled';
const platformName = (p: string) =>
  p === 'threads' ? 'Threads' : p === 'x' ? 'X' : p;
---

<div class="my-10">
  <p
    class="mb-4 border-b border-[#c4b8a4] pb-2 font-['Georgia','Noto_Serif_TC',serif] text-[0.9rem] text-[#6b6358]"
  >
    {title}
  </p>
  <div class="flex flex-col gap-2">
    {
      enriched.map((s) => (
        <a
          href={s.url}
          target="_blank"
          rel="noopener noreferrer"
          class="group flex items-baseline gap-3 py-1.5 text-inherit no-underline transition-colors hover:text-[#0e3a5c]"
        >
          <span class="font-['Georgia','Noto_Serif_TC',serif] text-[0.95rem] font-semibold text-[#3d3530]">
            {platformName(s.platform)}
          </span>
          <span class="text-[0.85rem] text-[#8a7e70]">{s.date}</span>
          <span class="flex-1 border-b border-dotted border-[#ddd5c8]" />
          <span class="text-[0.88rem] text-[#5a4f44]">
            {s.views != null ? `${s.views.toLocaleString()} 次閱讀` : ''}
            {s.likes ? `${s.views != null ? ' · ' : ''}${s.likes} 個共鳴` : ''}
          </span>
          <span class="text-[0.7rem] text-[#c4b8a8] transition-colors group-hover:text-[#0e3a5c]">
            ↗
          </span>
        </a>
      ))
    }
  </div>
</div>
