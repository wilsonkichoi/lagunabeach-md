---
// LifeTree.astro — life decision tree visualization
// Primary axis: time (top-down) / secondary axis: choices (left-right alternatives)
// Design: reports/life-decision-tree-design-2026-04-26.md
//
// Props:
//   tree: lifeTree frontmatter object
//   collapsed: whether to collapse by default (true for inline embed, false for standalone)

interface Theme {
  id: string;
  label: string;
  color: string;
}

interface Alternative {
  label: string;
  plausibility:
    | 'actual-chose'
    | 'actual-attempted'
    | 'structural'
    | 'speculative';
  note?: string;
}

interface Choice {
  label: string;
  consequence?: string;
}

interface Node {
  id: string;
  year: number;
  month?: number;
  day?: number;
  age?: number;
  type: 'given' | 'choice' | 'event';
  theme: string;
  label?: string;
  scene?: string;
  chose?: Choice;
  alternatives?: Alternative[];
  sources?: string[];
}

interface SourceProvenance {
  article: string; // e.g. 'knowledge/History/some-article.md'
  commit?: string; // 'a1b2c3d' git SHA at extraction time
  commitDate?: string; // '2026-04-26' YYYY-MM-DD
  extractedBy?: string; // 'LagunaBeach.md (Semiont) β-r5'
  extractedAt?: string; // '2026-04-26 11:30 +0800'
  note?: string; // additional notes
}

interface LifeTree {
  protagonist: string;
  birthYear: number;
  span: string;
  intro?: string;
  source?: SourceProvenance;
  themes: Theme[];
  nodes: Node[];
}

interface Props {
  tree: LifeTree;
  collapsed?: boolean;
}

const { tree, collapsed = false } = Astro.props;

// Build theme color lookup
const themeMap = new Map(tree.themes.map((t) => [t.id, t]));

const plausibilityLabel: Record<string, string> = {
  'actual-chose': 'Chosen',
  'actual-attempted': 'Attempted',
  structural: 'Structural alternative',
  speculative: 'Speculative',
};

const plausibilityIcon: Record<string, string> = {
  'actual-chose': '●',
  'actual-attempted': '◐',
  structural: '○',
  speculative: '◌',
};

function formatDate(node: Node): string {
  const parts = [String(node.year)];
  if (node.month) {
    parts.push(`/${String(node.month).padStart(2, '0')}`);
    if (node.day) parts.push(`/${String(node.day).padStart(2, '0')}`);
  }
  return parts.join('');
}
---

<section
  class={`life-tree ${collapsed ? 'life-tree--collapsed' : ''}`}
  aria-labelledby="life-tree-title"
>
  <header class="life-tree__header">
    <h2 id="life-tree-title">
      <span class="life-tree__icon" aria-hidden="true">🌳</span>
      {tree.protagonist}'s Life Decision Tree
    </h2>
    <p class="life-tree__meta">
      <span>{tree.span}</span>
      <span class="life-tree__sep">·</span>
      <span>{tree.nodes.length} turning points</span>
    </p>
    {tree.intro && <p class="life-tree__intro">{tree.intro}</p>}
    <ul class="life-tree__legend" role="list">
      {
        tree.themes.map((theme) => (
          <li>
            <span
              class="life-tree__theme-dot"
              style={`--theme-color: ${theme.color}`}
              aria-hidden="true"
            />
            {theme.label}
          </li>
        ))
      }
    </ul>
    <details class="life-tree__plausibility-key">
      <summary>Legend: alternative plausibility levels</summary>
      <ul role="list">
        <li>
          <span aria-hidden="true">●</span> Chosen — the path actually taken
        </li>
        <li>
          <span aria-hidden="true">◐</span> Attempted — started but turned back
        </li>
        <li>
          <span aria-hidden="true">○</span> Structural alternative — path taken by
          peers in similar circumstances
        </li>
        <li>
          <span aria-hidden="true">◌</span> Speculative — no concrete source, reasonable
          inference only
        </li>
      </ul>
    </details>
  </header>

  <ol class="life-tree__timeline" role="list">
    {
      tree.nodes.map((node) => {
        const theme = themeMap.get(node.theme);
        const themeColor = theme?.color || '#666';
        return (
          <li
            class={`life-tree__node life-tree__node--${node.type}`}
            data-theme={node.theme}
            id={`lt-${node.id}`}
          >
            <div class="life-tree__date" aria-hidden="true">
              <span class="life-tree__date-year">{formatDate(node)}</span>
              {typeof node.age === 'number' && (
                <span class="life-tree__date-age">age {node.age}</span>
              )}
            </div>

            <div
              class="life-tree__marker"
              style={`--theme-color: ${themeColor}`}
              aria-hidden="true"
            >
              {node.type === 'given' ? '◇' : node.type === 'event' ? '▣' : '●'}
            </div>

            <div class="life-tree__content">
              <h3 class="life-tree__node-title">
                <span
                  class="life-tree__node-theme-tag"
                  style={`--theme-color: ${themeColor}`}
                >
                  {theme?.label}
                </span>
                {node.scene || node.label}
              </h3>

              {node.chose && (
                <div class="life-tree__chose">
                  <p class="life-tree__chose-label">
                    <span class="life-tree__chose-icon" aria-hidden="true">
                      ●
                    </span>
                    <strong>Path chosen:</strong>
                    {node.chose.label}
                  </p>
                  {node.chose.consequence && (
                    <p class="life-tree__chose-consequence">
                      → {node.chose.consequence}
                    </p>
                  )}
                </div>
              )}

              {node.alternatives && node.alternatives.length > 0 && (
                <details class="life-tree__alternatives">
                  <summary>
                    Paths not taken ({node.alternatives.length} alternatives)
                  </summary>
                  <ul role="list">
                    {node.alternatives.map((alt) => (
                      <li
                        class={`life-tree__alt life-tree__alt--${alt.plausibility}`}
                      >
                        <p class="life-tree__alt-label">
                          <span
                            class="life-tree__alt-icon"
                            aria-hidden="true"
                            title={plausibilityLabel[alt.plausibility]}
                          >
                            {plausibilityIcon[alt.plausibility]}
                          </span>
                          <span class="life-tree__alt-tag">
                            [{plausibilityLabel[alt.plausibility]}]
                          </span>
                          {alt.label}
                        </p>
                        {alt.note && (
                          <p class="life-tree__alt-note">{alt.note}</p>
                        )}
                      </li>
                    ))}
                  </ul>
                </details>
              )}

              {node.sources && node.sources.length > 0 && (
                <p class="life-tree__sources">
                  source: {node.sources.map((s) => `[${s}]`).join(' ')}
                </p>
              )}
            </div>
          </li>
        );
      })
    }
  </ol>

  <footer class="life-tree__footer">
    <p>
      <strong>About this tree</strong>: every alternative comes from sources
      cited in the article or structural inference from peers. <strong
        >Speculative</strong
      >
      entries are explicitly labeled; they never masquerade as fact.
    </p>
    <p>
      <strong>How to read</strong>: time flows top to bottom; each node is a
      turning point. ● is the chosen path, ○ ◐ ◌ are paths not taken — expand to
      see why they were plausible.
    </p>

    {
      tree.source && (
        <aside class="life-tree__provenance" aria-label="Source and version">
          <p class="life-tree__provenance-title">
            📍 Source and version snapshot
          </p>
          <ul role="list">
            <li>
              <strong>Article</strong>:{' '}
              <a
                href={`https://github.com/wilsonkichoi/lagunabeach-md/blob/main/${tree.source.article}`}
                target="_blank"
                rel="noopener"
              >
                <code>{tree.source.article}</code>
              </a>
            </li>
            {tree.source.commit && (
              <li>
                <strong>Based on commit</strong>:{' '}
                <a
                  href={`https://github.com/wilsonkichoi/lagunabeach-md/commit/${tree.source.commit}`}
                  target="_blank"
                  rel="noopener"
                >
                  <code>{tree.source.commit}</code>
                </a>
                {tree.source.commitDate && (
                  <span class="life-tree__provenance-date">
                    ({tree.source.commitDate})
                  </span>
                )}
              </li>
            )}
            {tree.source.extractedBy && (
              <li>
                <strong>Extracted by</strong>: {tree.source.extractedBy}
                {tree.source.extractedAt && (
                  <span class="life-tree__provenance-date">
                    {' '}
                    @ {tree.source.extractedAt}
                  </span>
                )}
              </li>
            )}
            {tree.source.note && (
              <li>
                <strong>Note</strong>: {tree.source.note}
              </li>
            )}
          </ul>
          <p class="life-tree__provenance-caveat">
            This tree is a snapshot extension of the article at the above
            commit. The article may evolve or be corrected later; if the tree
            diverges from the article, the article is authoritative. Please
            report inconsistencies for re-extraction.
          </p>
        </aside>
      )
    }
  </footer>
</section>

<style>
  .life-tree {
    margin: 3rem 0;
    padding: 1.5rem;
    background: var(--color-bg-soft, #fafaf7);
    border: 1px solid var(--color-border, #e5e5e0);
    border-radius: 12px;
    font-family: var(--font-sans, system-ui, sans-serif);
    line-height: 1.6;
  }

  .life-tree__header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 2px dashed var(--color-border, #e5e5e0);
  }

  .life-tree__header h2 {
    font-size: 1.5rem;
    margin: 0 0 0.5rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .life-tree__icon {
    font-size: 1.4em;
  }

  .life-tree__meta {
    color: var(--color-text-soft, #666);
    font-size: 0.9rem;
    margin: 0 0 1rem;
  }

  .life-tree__sep {
    margin: 0 0.5rem;
    color: var(--color-border, #ccc);
  }

  .life-tree__intro {
    font-size: 0.95rem;
    color: var(--color-text, #333);
    margin: 1rem 0;
    padding: 0.75rem 1rem;
    background: var(--color-bg, #fff);
    border-left: 3px solid var(--color-border, #ccc);
    border-radius: 4px;
  }

  .life-tree__legend {
    list-style: none;
    padding: 0;
    margin: 1rem 0 0.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    font-size: 0.85rem;
    color: var(--color-text-soft, #555);
  }

  .life-tree__legend li {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .life-tree__theme-dot {
    width: 0.8em;
    height: 0.8em;
    border-radius: 50%;
    background: var(--theme-color);
    display: inline-block;
  }

  .life-tree__plausibility-key {
    font-size: 0.85rem;
    color: var(--color-text-soft, #555);
    margin-top: 0.5rem;
  }

  .life-tree__plausibility-key summary {
    cursor: pointer;
    user-select: none;
  }

  .life-tree__plausibility-key ul {
    list-style: none;
    padding: 0.5rem 0 0 1rem;
    margin: 0;
  }

  .life-tree__plausibility-key li {
    margin: 0.25rem 0;
  }

  .life-tree__timeline {
    list-style: none;
    padding: 0;
    margin: 0;
    position: relative;
  }

  /* Vertical timeline line */
  .life-tree__timeline::before {
    content: '';
    position: absolute;
    left: 5.5rem;
    top: 0.5rem;
    bottom: 0.5rem;
    width: 2px;
    background: linear-gradient(
      to bottom,
      var(--color-border, #ddd) 0%,
      var(--color-border, #ddd) 95%,
      transparent 100%
    );
  }

  .life-tree__node {
    position: relative;
    padding-left: 7.5rem;
    margin-bottom: 2.5rem;
    min-height: 3rem;
  }

  .life-tree__node:last-child {
    margin-bottom: 0;
  }

  .life-tree__date {
    position: absolute;
    left: 0;
    top: 0.25rem;
    width: 4.5rem;
    text-align: right;
    font-variant-numeric: tabular-nums;
  }

  .life-tree__date-year {
    display: block;
    font-weight: 600;
    color: var(--color-text, #333);
    font-size: 0.95rem;
  }

  .life-tree__date-age {
    display: block;
    font-size: 0.75rem;
    color: var(--color-text-soft, #888);
    margin-top: 0.1rem;
  }

  .life-tree__marker {
    position: absolute;
    left: 4.75rem;
    top: 0.25rem;
    width: 1.5rem;
    height: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg-soft, #fafaf7);
    color: var(--theme-color);
    font-size: 1.2rem;
    border-radius: 50%;
    z-index: 1;
  }

  .life-tree__content {
    background: var(--color-bg, #fff);
    padding: 0.75rem 1rem;
    border-radius: 8px;
    border-left: 3px solid var(--theme-color, #ccc);
  }

  .life-tree__node-title {
    font-size: 1rem;
    font-weight: 500;
    margin: 0 0 0.5rem;
    line-height: 1.5;
    color: var(--color-text, #222);
  }

  .life-tree__node-theme-tag {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.15rem 0.5rem;
    margin-right: 0.5rem;
    border-radius: 999px;
    background: var(--theme-color);
    color: #fff;
    vertical-align: middle;
    letter-spacing: 0.02em;
  }

  .life-tree__chose {
    margin: 0.5rem 0;
    padding: 0.6rem 0.8rem;
    background: rgba(139, 92, 246, 0.04);
    border-radius: 6px;
  }

  .life-tree__chose-label {
    margin: 0;
    font-size: 0.95rem;
  }

  .life-tree__chose-icon {
    color: #16a34a;
    margin-right: 0.4rem;
    font-size: 0.9em;
  }

  .life-tree__chose-consequence {
    margin: 0.4rem 0 0;
    font-size: 0.88rem;
    color: var(--color-text-soft, #555);
    padding-left: 1.2rem;
  }

  .life-tree__alternatives {
    margin-top: 0.5rem;
  }

  .life-tree__alternatives summary {
    cursor: pointer;
    user-select: none;
    font-size: 0.85rem;
    color: var(--color-text-soft, #666);
    padding: 0.4rem 0;
    list-style: none;
  }

  .life-tree__alternatives summary::before {
    content: '▸ ';
    display: inline-block;
    transition: transform 0.15s ease;
  }

  .life-tree__alternatives[open] summary::before {
    transform: rotate(90deg);
  }

  .life-tree__alternatives summary::-webkit-details-marker {
    display: none;
  }

  .life-tree__alternatives ul {
    list-style: none;
    padding: 0;
    margin: 0.4rem 0 0;
  }

  .life-tree__alt {
    padding: 0.5rem 0.75rem;
    margin: 0.4rem 0;
    background: var(--color-bg-soft, #f7f7f3);
    border-radius: 6px;
    border-left: 2px dashed var(--color-border, #ccc);
  }

  .life-tree__alt-label {
    margin: 0;
    font-size: 0.9rem;
  }

  .life-tree__alt-icon {
    margin-right: 0.4rem;
    font-size: 0.95em;
    color: var(--color-text-soft, #888);
  }

  .life-tree__alt-tag {
    font-size: 0.7rem;
    color: var(--color-text-soft, #888);
    margin-right: 0.3rem;
    text-transform: lowercase;
  }

  .life-tree__alt-note {
    margin: 0.3rem 0 0;
    font-size: 0.82rem;
    color: var(--color-text-soft, #666);
    padding-left: 1.2rem;
    line-height: 1.5;
  }

  .life-tree__alt--speculative {
    border-left-style: dotted;
  }

  .life-tree__alt--actual-attempted {
    border-left-style: solid;
    border-left-color: rgba(245, 158, 11, 0.5);
  }

  .life-tree__sources {
    font-size: 0.75rem;
    color: var(--color-text-soft, #888);
    margin: 0.5rem 0 0;
    font-family: var(--font-mono, ui-monospace, monospace);
  }

  .life-tree__footer {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px dashed var(--color-border, #e5e5e0);
    font-size: 0.82rem;
    color: var(--color-text-soft, #666);
  }

  .life-tree__footer p {
    margin: 0.4rem 0;
  }

  .life-tree__provenance {
    margin-top: 1.25rem;
    padding: 0.9rem 1rem;
    background: #fff;
    border: 1px dashed rgba(139, 92, 246, 0.3);
    border-radius: 8px;
    font-size: 0.8rem;
    color: var(--color-text, #2c3a36);
    line-height: 1.7;
  }

  .life-tree__provenance-title {
    margin: 0 0 0.4rem !important;
    font-weight: 600;
    color: #8b5cf6;
    font-size: 0.85rem;
  }

  .life-tree__provenance ul {
    list-style: none;
    padding: 0;
    margin: 0.3rem 0 0.5rem;
  }

  .life-tree__provenance li {
    margin: 0.2rem 0;
  }

  .life-tree__provenance code {
    background: rgba(139, 92, 246, 0.08);
    padding: 0.1rem 0.4rem;
    border-radius: 4px;
    font-size: 0.85em;
    font-family: var(--font-mono, ui-monospace, monospace);
  }

  .life-tree__provenance a {
    color: #8b5cf6;
    text-decoration: none;
  }

  .life-tree__provenance a:hover {
    text-decoration: underline;
  }

  .life-tree__provenance-date {
    color: var(--color-text-soft, #888);
    font-size: 0.85em;
    font-variant-numeric: tabular-nums;
  }

  .life-tree__provenance-caveat {
    margin: 0.5rem 0 0 !important;
    padding-top: 0.5rem;
    border-top: 1px dashed rgba(139, 92, 246, 0.15);
    font-size: 0.78rem;
    color: var(--color-text-soft, #5a6f6a);
  }

  /* Different node type icons */
  .life-tree__node--given .life-tree__chose-icon {
    color: var(--color-text-soft, #888);
  }

  /* Mobile */
  @media (max-width: 640px) {
    .life-tree {
      padding: 1rem 0.75rem;
      margin: 2rem -0.5rem;
      border-radius: 8px;
    }

    .life-tree__node {
      padding-left: 5rem;
    }

    .life-tree__date {
      width: 3rem;
    }

    .life-tree__date-year {
      font-size: 0.8rem;
    }

    .life-tree__date-age {
      font-size: 0.7rem;
    }

    .life-tree__timeline::before {
      left: 3.75rem;
    }

    .life-tree__marker {
      left: 3.25rem;
      width: 1rem;
      height: 1rem;
      font-size: 0.85rem;
    }

    .life-tree__legend {
      gap: 0.5rem;
      font-size: 0.78rem;
    }

    .life-tree__node-title {
      font-size: 0.92rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .life-tree__alternatives summary::before {
      transition: none;
    }
  }
</style>
