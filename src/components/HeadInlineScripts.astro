---
/**
 * HeadInlineScripts — pre-paint <head> inline-script collection (shot-mode + reader-settings)
 *
 * Why extracted: Layout.astro was 977 lines; these two inline scripts are ~50 lines each,
 * logically cohesive (both apply attributes before first paint), extracting them keeps
 * Layout's main structure clean.
 *
 * Not extracted: GA — coupled to Layout, separating it would add mental overhead instead.
 *
 * Contents:
 *   1. shot-mode init (?shot=1 → data-shot attr, used by generate-og-images.mjs)
 *   2. reader settings FOUC-safe early init (reads localStorage, applies data-theme)
 *
 * 2026-05-03 sleepy-colden Tier 2.6 build-perf split.
 */

interface Props {
  /**
   * Whether this surface opts into the ReaderSettings panel +
   * FOUC-safe theme init. Mirrors the same-named prop on Layout.
   * Renamed from `isArticlePage` 2026-05-04 (zen-mendeleev) so the
   * gate describes its rendered effect rather than the surface type.
   */
  readerSettings: boolean;
}
const { readerSettings } = Astro.props;
---

<!-- shot-mode init: ?shot=1 activates OG/Spore image-generation mode
     mainly used by scripts/core/generate-og-images.mjs + generate-spore-image.mjs -->
<script is:inline>
  (function () {
    try {
      var qs = new URLSearchParams(location.search);
      if (qs.get('shot') !== '1') return;
      document.documentElement.setAttribute('data-shot', '1');
      if (qs.get('og') === '1') {
        document.documentElement.setAttribute('data-og', '1');
      }
      if (location.pathname.indexOf('/semiont/diary/') !== -1) {
        document.documentElement.setAttribute('data-diary', '1');
      }
      var apply = function () {
        var m = document.querySelector('main.article-page');
        if (m) m.setAttribute('data-shot', '1');
        var titleOverride = qs.get('title');
        if (titleOverride) {
          var h1 = document.querySelector('.hero-title');
          if (h1) h1.textContent = titleOverride;
        }
        var descOverride = qs.get('desc');
        if (descOverride) {
          var p = document.querySelector(
            'main.article-page > section > div:nth-child(2) > p',
          );
          if (p) {
            p.textContent = descOverride;
          } else {
            var inner = document.querySelector(
              'main.article-page > section > div:nth-child(2)',
            );
            var hero = inner && inner.querySelector('.hero-title');
            if (inner && hero) {
              var np = document.createElement('p');
              np.textContent = descOverride;
              hero.insertAdjacentElement('afterend', np);
            }
          }
        }
      };
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', apply);
      } else {
        apply();
      }
    } catch (_) {}
  })();
</script>

<!-- Reader settings FOUC-safe early init.
     reads localStorage settings and applies data-theme / data-text-size before first
     paint, avoiding a toggling flash. ?shot=1 short-circuits (OG images are always light).
     window.__TW_MD_READER_SETTINGS gate: only apply dark theme on opt-in surfaces.
     Non-opt-in surfaces (dashboard / home / etc) stay light, because component
     layouts assume a light bg.
     2026-05-01 γ-late issue #615 / idlccp1984 reader options;
     v1.1 fix 2026-05-02 γ-late after dark-on-dashboard regression;
     v1.2 2026-05-04 zen-mendeleev: rename gate to `readerSettings` prop
     so any surface can opt in (hub pages added). -->
<script is:inline define:vars={{ readerSettings }}>
  window.__TW_MD_READER_SETTINGS = !!readerSettings;
</script>
<script is:inline>
  (function () {
    try {
      if (!window.__TW_MD_READER_SETTINGS) return;
      var qs = new URLSearchParams(location.search);
      if (qs.get('shot') === '1') return;
      var html = document.documentElement;
      var saved = null;
      try {
        saved = localStorage.getItem('tw-md-theme');
      } catch (_) {}
      // Default = light (explicit directive: the whole site defaults to light mode unless dark mode is specifically toggled)
      var prefersDark =
        window.matchMedia &&
        window.matchMedia('(prefers-color-scheme: dark)').matches;
      var effective =
        saved === 'dark'
          ? 'dark'
          : saved === 'auto'
            ? prefersDark
              ? 'dark'
              : 'light'
            : 'light';
      if (effective === 'dark') html.setAttribute('data-theme', 'dark');
      var size = null;
      try {
        size = localStorage.getItem('tw-md-text-size');
      } catch (_) {}
      if (size === 'large' || size === 'xlarge') {
        html.setAttribute('data-text-size', size);
      }
    } catch (_) {}
  })();
</script>
