---
/**
 * ArticleCard — shared article card component.
 *
 * 跨站共用的「文章卡」元件，三種 density mode：
 * - `premium` (~RelatedArticleCard 替代品) — cover image + category badge + title + desc + CTA arrow
 * - `compact` (default) — 緊湊 sidebar list 用：dot + title + 1-2 line desc + meta
 * - `row`              — ultra-compact 一行：只 dot + title + small meta
 *
 * 設計目標：
 * 1. Astro 靜態 render 用（其他頁面文章列表）
 * 2. 同時 expose `:global()` CSS classes 讓 dynamic innerHTML 也能用同樣樣式
 *    （map.template.astro 場景：JS 動態生成 marker article 卡片）
 *
 * CSS classes exposed for dynamic use:
 * - `.article-card`              — base card container
 * - `.article-card-body`         — content column
 * - `.article-card-title`        — h4 title
 * - `.article-card-desc`         — p description
 * - `.article-card-meta`         — small meta line
 * - `.article-card-dot`          — category color dot
 * - `.article-card-cta`          — "閱讀全文 →" link text
 * - `.article-card.is-premium`   — premium variant
 * - `.article-card.is-compact`   — compact variant (default)
 * - `.article-card.is-row`       — row variant
 *
 * Map page 客製化延伸：
 * - `.article-card.route-stop-card` 在卡片左側加 numbered badge（透過 .stop-number）
 *   route 站點繼承本元件 base + 附加 stop-number 視覺
 */

export interface Props {
  /** Article URL — wraps card in <a> when present. */
  href?: string;
  /** 主標題（必填）*/
  title: string;
  /** 副描述（選用）*/
  description?: string;
  /** 分類標籤（顯示在 meta 區）*/
  categoryLabel?: string;
  /** 分類顏色（用在左側 dot 或 premium badge 背景）*/
  categoryColor?: string;
  /** 閱讀時間（meta 的 · 後面）*/
  readingTime?: string;
  /** 封面圖 URL（premium mode 才用）*/
  coverImage?: string;
  /** 卡片密度 */
  density?: 'premium' | 'compact' | 'row';
  /** Click 行為：'new-tab' 預設另開分頁 / 'same-tab' 同分頁 */
  openIn?: 'new-tab' | 'same-tab';
  /** 額外 class（給特定 mode 客製化用，e.g. route-stop-card）*/
  extraClass?: string;
}

const {
  href,
  title,
  description,
  categoryLabel,
  categoryColor = '#16a34a',
  readingTime,
  coverImage,
  density = 'compact',
  openIn = 'new-tab',
  extraClass = '',
} = Astro.props;

const target = openIn === 'new-tab' ? '_blank' : '_self';
const rel = openIn === 'new-tab' ? 'noopener noreferrer' : undefined;
const Tag = href ? 'a' : 'div';
const densityClass = `is-${density}`;
const classes = ['article-card', densityClass, extraClass]
  .filter(Boolean)
  .join(' ');
---

<Tag
  class={classes}
  href={href}
  target={href ? target : undefined}
  rel={rel}
>
  {
    density === 'premium' && coverImage && (
      <div
        class="article-card-hero"
        style={`background-image: url('${coverImage}'); background-color: ${categoryColor};`}
        aria-hidden="true"
      />
    )
  }
  {
    density !== 'premium' && categoryColor && (
      <span
        class="article-card-dot"
        style={`background: ${categoryColor};`}
        aria-hidden="true"
      />
    )
  }

  <div class="article-card-body">
    {
      density === 'premium' && categoryLabel && (
        <span
          class="article-card-badge"
          style={`color: ${categoryColor}; background: ${categoryColor}14; border-color: ${categoryColor}28;`}
        >
          {categoryLabel}
        </span>
      )
    }

    <h4 class="article-card-title">{title}</h4>

    {description && <p class="article-card-desc">{description}</p>}

    {
      (categoryLabel || readingTime) && density !== 'premium' && (
        <span class="article-card-meta">
          {categoryLabel}
          {categoryLabel && readingTime && ' · '}
          {readingTime}
        </span>
      )
    }

    {
      density === 'premium' && (
        <span class="article-card-cta" style={`color: ${categoryColor};`}>
          閱讀全文 →
        </span>
      )
    }
  </div>
</Tag>

<style is:global>
  /* === Article Card — base (compact mode default) === */
  .article-card {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 12px 14px;
    margin: 6px 0;
    border: 1px solid #e5e7eb;
    border-radius: 10px;
    background: white;
    cursor: pointer;
    transition:
      transform 0.16s,
      border-color 0.16s,
      box-shadow 0.16s,
      background 0.16s;
    text-decoration: none;
    color: inherit;
    text-align: left;
    font-family: inherit;
    width: 100%;
    box-sizing: border-box;
  }
  .article-card:hover {
    border-color: #16a34a;
    background: #fafdf6;
    transform: translateY(-1px);
    box-shadow: 0 4px 10px rgba(22, 163, 74, 0.08);
  }
  .article-card-body {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .article-card-title {
    font-size: 0.9rem;
    font-weight: 700;
    color: #14532d;
    margin: 0;
    line-height: 1.35;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }
  .article-card-desc {
    font-size: 0.78rem;
    color: #6b7280;
    line-height: 1.45;
    margin: 0;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }
  .article-card-meta {
    font-size: 0.7rem;
    color: #9ca3af;
    margin-top: 2px;
    font-weight: 500;
  }
  .article-card-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 6px;
  }
  .article-card-cta {
    font-size: 0.78rem;
    font-weight: 600;
    margin-top: 4px;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    color: #16a34a;
  }

  /* === Premium variant — with cover image hero === */
  .article-card.is-premium {
    flex-direction: column;
    padding: 0;
    overflow: hidden;
    gap: 0;
  }
  .article-card.is-premium .article-card-hero {
    height: 140px;
    background-size: cover;
    background-position: center;
  }
  .article-card.is-premium .article-card-body {
    padding: 14px 16px 16px;
  }
  .article-card.is-premium .article-card-title {
    font-size: 1rem;
    -webkit-line-clamp: 2;
  }
  .article-card.is-premium .article-card-desc {
    font-size: 0.82rem;
    -webkit-line-clamp: 3;
  }
  .article-card-badge {
    display: inline-block;
    align-self: flex-start;
    padding: 2px 10px;
    border-radius: 12px;
    font-size: 0.7rem;
    font-weight: 600;
    border: 1px solid transparent;
    margin-bottom: 6px;
  }

  /* === Row variant — ultra-compact === */
  .article-card.is-row {
    padding: 8px 12px;
    gap: 8px;
    align-items: center;
  }
  .article-card.is-row .article-card-title {
    font-size: 0.85rem;
    -webkit-line-clamp: 1;
  }
  .article-card.is-row .article-card-desc {
    display: none;
  }
  .article-card.is-row .article-card-meta {
    font-size: 0.68rem;
  }

  /* === Map-page 客製化延伸：route-stop-card === */
  .article-card.route-stop-card .stop-number {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.85rem;
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 2px;
  }
</style>
