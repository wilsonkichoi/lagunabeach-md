---
/**
 * SemiontBreadcrumb — Path-style breadcrumb for /semiont pages.
 * Styled as a file path in monospace, warm amber tones.
 */
export interface Props {
  segments: { label: string; href?: string }[];
}

const { segments } = Astro.props;
---

<nav class="mb-8 font-mono text-xs text-[#38bdf8]/70" aria-label="breadcrumb">
  <ol class="flex flex-wrap items-center gap-1">
    {
      segments.map((seg, i) => (
        <li class="flex items-center gap-1">
          {i > 0 && <span class="select-none">/</span>}
          {seg.href ? (
            <a
              href={seg.href}
              class="underline decoration-[#38bdf8]/35 underline-offset-2 transition-colors hover:text-[#38bdf8]"
            >
              {seg.label}
            </a>
          ) : (
            <span class="text-[#f4f0ea]/55">{seg.label}</span>
          )}
        </li>
      ))
    }
  </ol>
</nav>
