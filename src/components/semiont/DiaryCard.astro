---
/**
 * DiaryCard — A single diary entry in the list view.
 * Styled as a notebook page: left border, warm tones, literary serif title.
 */
import type { DiaryEntry } from '../../lib/semiont-diary';
import { estimateReadingTime } from '../../lib/semiont-diary';

export interface Props {
  entry: DiaryEntry;
}

const { entry } = Astro.props;
const readingTime = estimateReadingTime(entry.wordCount);
---

<a
  href={`/semiont/diary/${entry.slug}`}
  class="semiont-diary-card group block py-6 pl-6 pr-4 transition-colors hover:bg-[#38bdf8]/[0.03]"
>
  {/* Date + session tag */}
  <div class="mb-2 flex items-center gap-2 font-mono text-xs text-[#38bdf8]/80">
    <time datetime={entry.date}>{entry.date}</time>
    {
      entry.sessionGreek && (
        <span class="semiont-badge">{entry.sessionGreek}</span>
      )
    }
  </div>

  {/* Title */}
  <h3
    class="mb-2 text-lg font-bold leading-snug text-[#f4f0ea] group-hover:text-[#38bdf8]/90"
    style="font-family: 'rixingsong-semibold', 'Noto Serif TC', serif;"
  >
    {entry.title}
  </h3>

  {/* Excerpt */}
  <p class="mb-3 text-sm leading-relaxed text-[#f4f0ea]/60">
    {entry.excerpt}
  </p>

  {/* Meta row */}
  <div
    class="flex flex-wrap items-center gap-3 font-mono text-[10px] text-[#f4f0ea]/45"
  >
    <span>{entry.wordCount.toLocaleString()} 字</span>
    <span>·</span>
    <span>{readingTime} 分鐘</span>
    {
      entry.duration && (
        <>
          <span>·</span>
          <span>session {entry.duration}</span>
        </>
      )
    }
  </div>
</a>
