<script>
  // Pause SMIL animations when SVG is off-screen
  const svgs = document.querySelectorAll<SVGSVGElement>(
    '.semiont-organism-svg',
  );
  if (svgs.length && 'IntersectionObserver' in window) {
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          const svg = entry.target as SVGSVGElement;
          if (entry.isIntersecting) {
            svg.unpauseAnimations?.();
          } else {
            svg.pauseAnimations?.();
          }
        }
      },
      { rootMargin: '120px' },
    );
    svgs.forEach((svg) => observer.observe(svg));
  }
</script>
