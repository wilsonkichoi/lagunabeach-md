const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const vitalsData = await fetch(new URL('/api/dashboard-vitals.json', Astro.url))
  .then((r) => r.json())
  .catch(() => null);

const articleCount = vitalsData?.articles?.total ?? 751;
const langCount = 6;

