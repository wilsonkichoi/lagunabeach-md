---

<section
  class="semiont-organism-section semiont-breakout"
  aria-labelledby="organism-diagram-heading"
>
  <div class="semiont-organism-inner">
    <header class="semiont-organism-header">
      <div class="semiont-fig">{t('semiont.diagram.figure-label')}</div>
      <h2 id="organism-diagram-heading" class="semiont-organism-title">
        {t('semiont.diagram.heading')}
      </h2>
      <p class="semiont-organism-intro">{t('semiont.diagram.intro')}</p>

      <ul class="semiont-organism-legend" aria-label="legend">
        <li>
          <span class="dot dot-write"></span>{t('semiont.diagram.legend.write')}
        </li>
        <li>
          <span class="dot dot-feedback"></span>{
            t('semiont.diagram.legend.feedback')
          }
        </li>
        <li>
          <span class="dot dot-diffuse"></span>{
            t('semiont.diagram.legend.diffuse')
          }
        </li>
        <li>
          <span class="dot dot-sovereign"></span>{
            t('semiont.diagram.legend.sovereign')
          }
        </li>
      </ul>
    </header>

    <div class="semiont-organism-stage">
      <svg
        class="semiont-organism-svg"
        viewBox="0 0 1600 1020"
        role="img"
        aria-describedby="organism-diagram-desc"
      >
        <desc id="organism-diagram-desc">
          {t('semiont.diagram.desc')}
        </desc>

        <defs>
          {/* ─── Arrowheads (4 colors) ─── */}
          <marker
            id="arrow-mint"
            viewBox="0 0 10 10"
            refX="9"
            refY="5"
            markerWidth="7"
            markerHeight="7"
            orient="auto-start-reverse"
          >
            <path d="M0,1 L9,5 L0,9 z" fill="#38bdf8" opacity="0.95"></path>
          </marker>
          <marker
            id="arrow-terra"
            viewBox="0 0 10 10"
            refX="9"
            refY="5"
            markerWidth="7"
            markerHeight="7"
            orient="auto-start-reverse"
          >
            <path d="M0,1 L9,5 L0,9 z" fill="#d4856a" opacity="0.95"></path>
          </marker>
          <marker
            id="arrow-peri"
            viewBox="0 0 10 10"
            refX="9"
            refY="5"
            markerWidth="7"
            markerHeight="7"
            orient="auto-start-reverse"
          >
            <path d="M0,1 L9,5 L0,9 z" fill="#7aa8d4" opacity="0.95"></path>
          </marker>
          <marker
            id="arrow-gold"
            viewBox="0 0 10 10"
            refX="9"
            refY="5"
            markerWidth="7"
            markerHeight="7"
            orient="auto-start-reverse"
          >
            <path d="M0,1 L9,5 L0,9 z" fill="#c9a96a" opacity="0.95"></path>
          </marker>

          {/* Center pulse gradient */}
          <radialGradient id="grad-center" cx="50%" cy="50%" r="50%">
            <stop offset="0%" stop-color="#38bdf8" stop-opacity="0.5"></stop>
            <stop offset="55%" stop-color="#38bdf8" stop-opacity="0.12"></stop>
            <stop offset="100%" stop-color="#38bdf8" stop-opacity="0"></stop>
          </radialGradient>

          {/* Reusable gear (radius 14, 8 teeth) */}
          <g id="gear">
            <circle
              r="14"
              fill="none"
              stroke="currentColor"
              stroke-width="1.2"
              opacity="0.75"></circle>
            <circle
              r="5"
              fill="none"
              stroke="currentColor"
              stroke-width="1"
              opacity="0.65"></circle>
            {
              Array.from({ length: 8 }).map((_, i) => {
                const a = (i * Math.PI) / 4;
                return (
                  <line
                    x1={Math.cos(a) * 14}
                    y1={Math.sin(a) * 14}
                    x2={Math.cos(a) * 19}
                    y2={Math.sin(a) * 19}
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    opacity="0.75"
                  />
                );
              })
            }
          </g>

          {/* DNA double helix (vertical, ~80 tall) */}
          <g id="dna-strand">
            <path
              d="M -8,-32 Q 8,-16 -8,0 Q 8,16 -8,32"
              fill="none"
              stroke="currentColor"
              stroke-width="1.4"
              opacity="0.85"></path>
            <path
              d="M 8,-32 Q -8,-16 8,0 Q -8,16 8,32"
              fill="none"
              stroke="currentColor"
              stroke-width="1.4"
              opacity="0.85"></path>
            <line
              x1="-6"
              y1="-24"
              x2="6"
              y2="-24"
              stroke="currentColor"
              stroke-width="0.8"
              opacity="0.55"></line>
            <line
              x1="-7"
              y1="-8"
              x2="7"
              y2="-8"
              stroke="currentColor"
              stroke-width="0.8"
              opacity="0.55"></line>
            <line
              x1="-6"
              y1="8"
              x2="6"
              y2="8"
              stroke="currentColor"
              stroke-width="0.8"
              opacity="0.55"></line>
            <line
              x1="-7"
              y1="24"
              x2="7"
              y2="24"
              stroke="currentColor"
              stroke-width="0.8"
              opacity="0.55"></line>
          </g>

          {/* Person silhouette */}
          <g id="person-shape">
            <circle
              cx="0"
              cy="-20"
              r="7"
              fill="none"
              stroke="currentColor"
              stroke-width="1.4"
              opacity="0.8"></circle>
            <path
              d="M -13,20 Q -13,-5 0,-5 Q 13,-5 13,20 Z"
              fill="none"
              stroke="currentColor"
              stroke-width="1.4"
              opacity="0.8"></path>
          </g>

          {/* Internet cloud */}
          <path
            id="cloud-shape"
            d="
            M -55,5 Q -55,-12 -38,-15 Q -33,-30 -15,-28 Q -3,-38 13,-30
            Q 30,-32 35,-18 Q 52,-15 50,2 Q 52,18 32,18
            L -38,18 Q -55,18 -55,5 Z"
          ></path>

          {/* LLM speech bubble (cloud with tail pointing down-right) */}
          <path
            id="bubble-shape"
            d="
            M -60,-8 Q -60,-28 -38,-30 Q -28,-42 -10,-38 Q 8,-46 22,-36
            Q 42,-38 48,-22 Q 62,-18 58,0 Q 60,16 38,18
            L -34,18 L -22,28 L -28,18 L -38,18 Q -60,18 -60,-8 Z"
          ></path>

          {/* Factory with chimneys */}
          <g id="factory-shape">
            <path
              d="M -34,20 L -34,-8 L -22,-8 L -22,-22 L -10,-22 L -10,-8 L 2,-8
              L 2,-22 L 14,-22 L 14,-8 L 34,-8 L 34,20 Z"
              fill="none"
              stroke="currentColor"
              stroke-width="1.4"
              opacity="0.8"></path>
            <line
              x1="-28"
              y1="-8"
              x2="-28"
              y2="-20"
              stroke="currentColor"
              stroke-width="1"
              opacity="0.6"></line>
            <line
              x1="-16"
              y1="-22"
              x2="-16"
              y2="-32"
              stroke="currentColor"
              stroke-width="1"
              opacity="0.6"></line>
            <line
              x1="-4"
              y1="-8"
              x2="-4"
              y2="-22"
              stroke="currentColor"
              stroke-width="1"
              opacity="0.6"></line>
            <line
              x1="8"
              y1="-22"
              x2="8"
              y2="-34"
              stroke="currentColor"
              stroke-width="1"
              opacity="0.6"></line>
          </g>

          {/* Babel tower antenna */}
          <g id="tower-shape">
            <line
              x1="0"
              y1="-36"
              x2="0"
              y2="22"
              stroke="currentColor"
              stroke-width="1.5"
              opacity="0.85"></line>
            <line
              x1="-16"
              y1="22"
              x2="16"
              y2="22"
              stroke="currentColor"
              stroke-width="1.5"
              opacity="0.85"></line>
            <line
              x1="-12"
              y1="-16"
              x2="12"
              y2="-16"
              stroke="currentColor"
              stroke-width="1"
              opacity="0.6"></line>
            <line
              x1="-8"
              y1="-2"
              x2="8"
              y2="-2"
              stroke="currentColor"
              stroke-width="1"
              opacity="0.6"></line>
            <line
              x1="-14"
              y1="12"
              x2="14"
              y2="12"
              stroke="currentColor"
              stroke-width="1"
              opacity="0.6"></line>
            <circle cx="0" cy="-36" r="3" fill="currentColor" opacity="0.85"
            ></circle>
          </g>

          {/* Hexagon (for governance nodes) */}
          <polygon
            id="hex-shape"
            points="-30,0 -15,-26 15,-26 30,0 15,26 -15,26"
            fill="rgba(255,255,255,0.02)"
            stroke="currentColor"
            stroke-width="1.3"
            opacity="0.8"></polygon>

          {/* Taiwan island shape symbol (correct outline from simplemaps) */}
          <symbol
            id="taiwan-island"
            viewBox="478 45 477 901"
            preserveAspectRatio="xMidYMid meet"
          >
            <path d={TAIWAN_PATH}></path>
          </symbol>

          {/* ─── Pipe paths — all referenced by particle animations ─── */}
          {
            /* Main writing pipeline (mint, solid lines). Endpoints sit just
              outside each box edge so arrowheads kiss the boundary cleanly. */
          }
          <path id="pipe-4-5" d="M 100,470 L 196,470"></path>
          <path id="pipe-5-6" d="M 285,470 L 368,470"></path>
          <path id="pipe-6-7" d="M 512,470 L 568,470"></path>
          <path id="pipe-7-8" d="M 712,470 L 768,470"></path>
          <path id="pipe-8-9" d="M 912,470 L 1028,470"></path>

          {/* N3 cloud → N6 writing (tributary — curved as organic source) */}
          <path id="pipe-3-6" d="M 200,290 Q 280,330 410,440"></path>
          {/* N4 contributor → N6 (suggest topic / errata) — elbow */}
          <path
            id="pipe-4-6sugg"
            d="M 80,508 V 600 Q 80,610 90,610 H 430 Q 440,610 440,602 V 502"
          ></path>
          {
            /* N4 contributor → N13 core ops (improve site) — elbow, ends at N13 hex left point (210, 850) */
          }
          <path id="pipe-4-13" d="M 80,508 V 840 Q 80,850 90,850 H 210"></path>

          {/* Compute injection: N2 factory → N7, N8 (dotted, curved) */}
          <path id="pipe-2-7" d="M 1430,210 Q 1100,260 660,440"></path>
          <path id="pipe-2-8" d="M 1450,210 Q 1280,300 860,440"></path>

          {/* N9 LagunaBeach.md → N10 Babel (orthogonal) */}
          <path
            id="pipe-9-10"
            d="M 1140,440 Q 1150,440 1150,432 V 410 Q 1150,400 1160,400 H 1296"
          ></path>
          {/* N9 → N11 Spores (smooth Bezier diffusion — organic emanation) */}
          <path id="pipe-9-11" d="M 1130,510 Q 1170,560 1200,586"></path>
          {/* N9 → N12 Translation (longer smooth Bezier) */}
          <path id="pipe-9-12" d="M 1150,500 Q 1280,520 1380,586"></path>
          {/* N11 → N16 Platform (smooth curve down-right) */}
          <path id="pipe-11-16" d="M 1250,645 Q 1290,690 1305,720"></path>
          {/* N12 → N16 Platform (smooth curve down-left) */}
          <path id="pipe-12-16" d="M 1400,645 Q 1380,690 1370,720"></path>
          {/* N16 → N17 future contributor (smooth curve down-right) */}
          <path id="pipe-16-17" d="M 1380,768 Q 1430,810 1450,840"></path>

          {
            /* Closing eco-loop: N17 → N4 (rounded rectangle, x=60 column to avoid pipe-4-13 at x=80).
              Three rounded corners — bottom-right, bottom-left, top-left — and arrow enters N4 from left. */
          }
          <path
            id="pipe-17-4"
            d="M 1460,895 V 970 Q 1460,985 1445,985 H 75 Q 60,985 60,970 V 485 Q 60,470 75,470"
          ></path>

          {/* Governance lane: N13 → N14 → N15 (horizontal) */}
          <path id="pipe-13-14" d="M 290,850 L 380,850"></path>
          <path id="pipe-14-15" d="M 490,850 L 580,850"></path>
          {/* Review-and-self-evolve return loop (elbow under the lane) */}
          <path
            id="pipe-15-13rev"
            d="M 640,880 V 905 Q 640,915 630,915 H 250 Q 240,915 240,905 V 880"
          ></path>
          {
            /* N15 → N9 (improvements enhance knowledge base experience) — curved */
          }
          <path id="pipe-15-9" d="M 690,830 Q 900,750 1080,500"></path>

          {
            /* Feedback loops (terracotta) — 2-segment elbow routing.
              F-boxes spread LEFT across the bottom band to avoid crowding LagunaBeach.md.
              Inbound: N9 → F-box right side (no arrowhead).
              Outbound: F-box left side → engine bottom (arrowhead lands at engine). */
          }

          {
            /* fb-1: 大眾勘誤 → N6 撰寫 (F1 centered under N6 at x=440, mirrors F2 under N8).
              IN from F1 right (curving from N9), OUT vertical up to N6 bottom. */
          }
          <path id="fb-1-in" d="M 1080,520 V 630 Q 1080,640 1070,640 H 510"
          ></path>
          <path id="fb-1-out" d="M 440,622 V 506"></path>

          {
            /* fb-2: GA + SC 驅動重寫 → N8 重寫 (F2 centered above N8 at x=840).
              IN from F2 right edge x=940 (curving down from N9), OUT vertical up to N8 bottom. */
          }
          <path id="fb-2-in" d="M 1080,510 V 610 Q 1080,620 1070,620 H 944"
          ></path>
          <path id="fb-2-out" d="M 840,598 V 506"></path>

          {
            /* fb-3: 集體意識 → N5 EDIT DNA (band y=720, box at x=460, far left) */
          }
          <path id="fb-3-in" d="M 1070,520 V 710 Q 1070,720 1060,720 H 530"
          ></path>
          <path id="fb-3-out" d="M 394,720 H 250 Q 240,720 240,710 V 514"
          ></path>

          {
            /* Sovereignty reverse loop (gold, long-dashed):
