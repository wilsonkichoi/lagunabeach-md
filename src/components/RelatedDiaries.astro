---
/**
 * RelatedDiaries Рђћ Semiont reflective diaries written alongside this article (array version, successor to diaryLink)
 *
 * Shows readers at the bottom of an article: "what was the system thinking while writing this?"
 *
 * frontmatter:
 *   relatedDiary:
 *     - 2026-06-19-115522-manual                       # slug only; title / excerpt / date auto-resolve
 *     - { slug: 2026-04-13-alpha2, excerpt: 'custom excerpt...' }  # object form can override excerpt
 *
 * slug = diary filename minus .md (Greek letters transliterated, matches /semiont/diary/{slug} route).
 * Entries with no matching diary gracefully skip; if nothing resolves, the whole block is hidden.
 *
 * Design parallel to SporeFootprint (array frontmatter -> build-time resolve -> warm documentary block),
 * except the enrich source is getAllDiaryEntries() rather than spores.json.
 */
import type { Lang } from '../config/languages';
import { getAllDiaryEntries, type DiaryEntry } from '../lib/semiont-diary';

type DiaryRef = string | { slug: string; excerpt?: string };

interface Props {
  relatedDiary: DiaryRef[];
  lang?: Lang;
}

const { relatedDiary, lang = 'zh-TW' } = Astro.props;

if (!relatedDiary || relatedDiary.length === 0) return;

// Build-once cache: only articles with relatedDiary trigger this; the entire build shares one scan
// (prevents each article from re-scanning docs/semiont/diary/ as this field becomes common).
const g = globalThis as unknown as {
  __twmdDiaryEntries?: Promise<DiaryEntry[]>;
};
const allEntries = await (g.__twmdDiaryEntries ??= getAllDiaryEntries());
const bySlug = new Map(allEntries.map((e) => [e.slug, e]));

const normalize = (d: DiaryRef) => {
  const raw = typeof d === 'string' ? { slug: d } : d;
  // Tolerate authors pasting the full path (/semiont/diary/xxx) Рђћ extract slug segment only
  const slug = raw.slug.replace(/^\/?semiont\/diary\//, '').replace(/^\//, '');
  return { slug, excerpt: typeof d === 'string' ? undefined : d.excerpt };
};

const resolved = relatedDiary
  .map(normalize)
  .map(({ slug, excerpt }) => {
    const entry = bySlug.get(slug);
    if (!entry) return null;
    return {
      slug,
      href: `/semiont/diary/${slug}`,
      title: entry.title,
      date: entry.date,
      excerpt: excerpt ?? entry.excerpt,
    };
  })
  .filter((d): d is NonNullable<typeof d> => d !== null);

if (resolved.length === 0) return;

const heading =
  lang === 'ja'
    ? 'сЂЊсЂ«УеўС║ІсѓњТЏИсЂёсЂЪсЂесЂЇсђЂSemiont сЂїУђЃсЂѕсЂдсЂёсЂЪсЂЊсЂе'
    : lang === 'ko'
      ? 'ВЮ┤ ЖИђВЮё ВЊИ вЋї, Semiontвіћ вг┤ВЌЄВЮё ВЃЮЖ░Ђьќѕвѓў'
      : lang === 'es'
        ? 'Lo que Semiont pensaba al escribir este art├Гculo'
        : lang === 'fr'
          ? 'Ce que Semiont pensait en ├Еcrivant cet article'
          : lang === 'en'
            ? 'What Semiont was thinking while writing this'
            : 'т»ФжђЎу»ЄТќЄуФаТЎѓ№╝їSemiont тюеТЃ│С╗ђж║╝';

const readMore =
  lang === 'ja'
    ? 'ТЌЦУеўсѓњУфГсѓђ Рєњ'
    : lang === 'ko'
      ? 'ВЮ╝ЖИ░ ВЮйЖИ░ Рєњ'
      : lang === 'es'
        ? 'Leer el diario Рєњ'
        : lang === 'fr'
          ? 'Lire le journal Рєњ'
          : lang === 'en'
            ? 'Read the full diary Рєњ'
            : 'жќ▒У«ђт«їТЋ┤ТЌЦУеў Рєњ';
---

<div class="my-10 rounded-none border-y border-[#c4b8a4] py-6">
  <p
    class="m-0 mb-5 font-['Noto_Serif_TC',serif] text-[0.8rem] font-semibold uppercase tracking-[0.15em] text-[#6b6358]"
  >
    ­ЪДг {heading}
  </p>
  <div class="flex flex-col gap-6">
    {
      resolved.map((d) => (
        <a href={d.href} class="group block text-inherit no-underline">
          <p class="m-0 font-['TpRixNixieStd','Noto_Serif_TC','Georgia',serif] text-[1.15rem] leading-[1.7] text-[#3d3530] transition-colors group-hover:text-[#0e3a5c] max-[768px]:text-[1.02rem]">
            {d.title}
          </p>
          <p class="m-0 mt-2 font-['Noto_Serif_TC',serif] text-[0.95rem] leading-[1.85] text-[#6b6358]">
            {d.excerpt}
          </p>
          <p class="m-0 mt-2 text-[0.82rem] text-[#8a7e70] transition-colors group-hover:text-[#0e3a5c]">
            <span class="text-[#a89c8a]">{d.date}</span>сђђ{readMore}
          </p>
        </a>
      ))
    }
  </div>
</div>
