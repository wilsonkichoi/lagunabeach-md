<script is:inline>
  (() => {
    const allowedHosts = new Set(['lagunabeach.md', 'www.lagunabeach.md']);
    if (!allowedHosts.has(window.location.hostname)) return;

    // Protico chat widget - disabled until configured for LagunaBeach.md
    // Original: https://main.protico.io/api/v1/taiwan.md/protico-frame.js
    return;
    const script = document.createElement('script');
    script.src = 'https://main.protico.io/api/v1/lagunabeach.md/protico-frame.js';
    script.async = true;
    document.head.appendChild(script);
  })();
</script>
