---
/**
 * Phase 2.5 — 3-tab horizontal navigation. Sticky below the header.
 * Active route is detected from Astro.url.pathname so SSR + each route
 * renders its own active state without client JS.
 */
const path = Astro.url.pathname.replace(/\/$/, '') || '/';

const TABS = [
  {
    href: '/',
    label: '即時運作',
    emoji: '🏃',
    match: (p: string) => p === '/',
  },
  {
    href: '/vitals',
    label: '生命徵象',
    emoji: '🫀',
    match: (p: string) => p.startsWith('/vitals'),
  },
  {
    href: '/sessions',
    label: 'Session',
    emoji: '👁',
    match: (p: string) => p.startsWith('/sessions'),
  },
];
---

<nav
  class="sticky top-[57px] z-20 bg-bg-base/85 backdrop-blur border-b border-line"
>
  <div class="max-w-7xl mx-auto px-4 flex items-center gap-1 overflow-x-auto">
    {
      TABS.map((tab) => {
        const active = tab.match(path);
        return (
          <a
            href={tab.href}
            class={`relative inline-flex items-center gap-2 px-3 py-2.5 text-sm whitespace-nowrap transition-colors ${
              active
                ? 'text-accent-green-soft font-medium'
                : 'text-text-secondary hover:text-text-primary'
            }`}
          >
            <span>{tab.emoji}</span>
            <span>{tab.label}</span>
            {active && (
              <span class="absolute left-2 right-2 -bottom-px h-0.5 bg-accent-green rounded-full" />
            )}
          </a>
        );
      })
    }
  </div>
</nav>
