---
import Layout from '../layouts/Layout.astro';
import TodayTasks from '../components/TodayTasks.tsx';
import TaskQueue from '../components/TaskQueue.tsx';
import ManualInput from '../components/ManualInput.tsx';
import QuickActionBar from '../components/QuickActionBar.tsx';
import SchedulerControl from '../components/SchedulerControl.tsx';
---

<Layout
  title="🧬 Bridge · Harvest"
  subtitle="Phase 5 · Captain's Bridge · unified auto + manual spawn control"
>
  <main class="px-4 lg:px-6 py-5 space-y-6">
    <!-- (Active sessions live in Today's Tasks column to avoid duplication;
         dedicated deep-dive in /sessions page) -->

    <!-- 3-column captain's bridge -->
    <div class="grid grid-cols-1 xl:grid-cols-12 gap-5">
      <!-- LEFT column: today + queue (~5/12) -->
      <div class="xl:col-span-5 space-y-5">
        <section>
          <div class="flex items-center justify-between mb-2">
            <h2 class="text-base font-semibold">⚡ Today's Tasks</h2>
            <span class="text-xs text-text-muted">active + 24h · 5s</span>
          </div>
          <div class="card">
            <div class="card-body p-3">
              <TodayTasks client:only="solid-js" />
            </div>
          </div>
        </section>

        <section>
          <div class="flex items-center justify-between mb-2">
            <h2 class="text-base font-semibold">📋 Task Queue</h2>
            <span class="text-xs text-text-muted">all · click ▶️ to spawn</span>
          </div>
          <div class="card">
            <div class="card-body p-3">
              <TaskQueue client:only="solid-js" />
            </div>
          </div>
        </section>
      </div>

      <!-- CENTER column: quick actions + manual input (~4/12) -->
      <div class="xl:col-span-4 space-y-5">
        <section>
          <div class="flex items-center justify-between mb-2">
            <h2 class="text-base font-semibold">⚡ Quick Dispatch</h2>
            <span class="text-xs text-text-muted">one-click presets</span>
          </div>
          <div class="card">
            <div class="card-body p-3">
              <QuickActionBar client:only="solid-js" />
            </div>
          </div>
        </section>

        <section>
          <div class="flex items-center justify-between mb-2">
            <h2 class="text-base font-semibold">✍️ Manual Create</h2>
            <span class="text-xs text-text-muted">custom task / topic</span>
          </div>
          <div class="card">
            <div class="card-body p-3">
              <ManualInput client:only="solid-js" />
            </div>
          </div>
        </section>
      </div>

      <!-- RIGHT column: scheduler policy + helper text (~3/12) -->
      <div class="xl:col-span-3 space-y-5">
        <section>
          <div class="flex items-center justify-between mb-2">
            <h2 class="text-base font-semibold">🎛️ Scheduler Control</h2>
            <span class="text-xs text-text-muted">auto-spawn policy</span>
          </div>
          <div class="card">
            <div class="card-body p-3">
              <SchedulerControl client:only="solid-js" />
            </div>
          </div>
        </section>

        <section>
          <div class="flex items-center justify-between mb-2">
            <h2 class="text-base font-semibold">🧭 Usage Guide</h2>
          </div>
          <div class="card">
            <div class="card-body p-3 text-xs text-text-secondary space-y-2">
              <p>
                <strong>Quick Dispatch</strong>: click once to create task and
                enqueue. Then wait for auto-spawn (if priority + scheduler
                allow) or manual ▶️
              </p>
              <p>
                <strong>Scheduler Control</strong>: check = auto-dispatch;
                uncheck = manual only. PR / spore / issue default OFF.
              </p>
              <p>
                <strong>Active session</strong>: top banner shows live
                Read/Edit/Bash stream.
              </p>
              <p>
                <strong>Engines</strong>:
                <code class="text-accent-green-soft">claude</code> (Sonnet) /
                <code class="text-accent-green-soft">codex</code> (ChatGPT) /
                <code class="text-accent-green-soft">ollama</code> (local qwen)
              </p>
            </div>
          </div>
        </section>
      </div>
    </div>

    <footer class="pt-6 pb-3 text-xs text-text-muted text-center">
      🧬 Harvest engine · captain's bridge · Phase 5 (2026-04-29)
    </footer>
  </main>
</Layout>
