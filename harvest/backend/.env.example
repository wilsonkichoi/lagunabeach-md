# Harvest Backend environment variables.
# Copy this file to `.env` and adjust as needed. None of these values are
# secret today, but the file is gitignored anyway so future secrets stay out.

# HTTP port the Hono server listens on. Pure internal tool — never expose.
HARVEST_PORT=4319

# Repository root (absolute path). Used to resolve ARTICLE-INBOX, write
# task folders under .harvest/, and produce reports/ commits.
# Defaults to walking up from the backend folder if unset.
HARVEST_REPO_ROOT=/Users/cheyuwu/Projects/taiwan-md

# SQLite database path (absolute). Defaults to <backend>/harvest.db.
HARVEST_DB_PATH=

# Logger level: trace | debug | info | warn | error | fatal
HARVEST_LOG_LEVEL=info

# Pretty-print logs in dev (true/false). Production should keep raw JSON.
HARVEST_LOG_PRETTY=true

# Path to the `claude` CLI binary used by the spawner. If unset the spawner
# falls back to `claude` on PATH.
HARVEST_CLAUDE_BIN=/Users/cheyuwu/.bun/bin/claude

# Hard timeout per spawned Claude session (minutes).
HARVEST_SESSION_TIMEOUT_MIN=90

# Disable the cron scheduler entirely (useful for tests). true/false.
HARVEST_DISABLE_CRON=false

# Disable the file-watch intake (useful when running short scripts).
HARVEST_DISABLE_WATCH=false

# When true, the daily reporter commits + pushes the report. Defaults false
# in MVP — flip on once cheyu has eyeballed a few reports.
HARVEST_AUTO_COMMIT_REPORT=false
