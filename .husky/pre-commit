npx lint-staged

# Validate frontmatter on staged .md files in knowledge/
node scripts/core/test-frontmatter.mjs --staged 2>/dev/null || true

# Canonical frontmatter format check
if [ -f "scripts/tools/check-canonical-frontmatter.py" ]; then
  python3 scripts/tools/check-canonical-frontmatter.py --staged --quiet || {
    echo ""
    echo "Canonical frontmatter validation failed."
    echo "Run: python3 scripts/tools/check-canonical-frontmatter.py --all"
    exit 1
  }
fi

# translatedFrom enforcement for non-default-language translation files
staged_translations=$(git diff --cached --name-only --diff-filter=AM | grep -E '^knowledge/(zh-TW)/.*\.md$' || true)
if [ -n "$staged_translations" ]; then
  tf_fail=0
  for f in $staged_translations; do
    [[ "$(basename "$f")" == _* ]] && continue
    [ ! -f "$f" ] && continue
    if ! awk '/^---$/{n++; next} n==1{print} n>=2{exit}' "$f" | grep -q '^translatedFrom:'; then
      echo "ERROR: $f missing translatedFrom field"
      echo "  Example: translatedFrom: 'History/founding-and-early-history.md'"
      tf_fail=1
    fi
  done
  if [ "$tf_fail" = "1" ]; then
    echo ""
    echo "Translation files must declare their source article in frontmatter."
    exit 1
  fi
fi

# Frontmatter format auto-fix on staged knowledge/*.md
staged_md=$(git diff --cached --name-only --diff-filter=ACM | grep '^knowledge/.*\.md$' | grep -vE '^knowledge/(zh-TW)/' || true)
if [ -n "$staged_md" ]; then
  if [ -f "scripts/tools/article-health.py" ]; then
    fix_output=$(python3 scripts/tools/article-health.py --staged --check=frontmatter-format --fix 2>&1 || true)
    fixed_count=$(echo "$fix_output" | grep -oE 'Modified [0-9]+ file' | grep -oE '[0-9]+' | head -1 || echo "0")
    if [ -n "$fixed_count" ] && [ "$fixed_count" != "0" ]; then
      echo "Auto-fixed frontmatter format on $fixed_count staged file(s); re-staging..."
      echo "$staged_md" | xargs -I {} git add {}
    fi
  fi
fi

# article-health pre-commit gate
if [ -n "$staged_md" ]; then
  if [ -f "scripts/tools/article-health.py" ]; then
    if ! python3 scripts/tools/article-health.py --staged --profile=pre-commit --quiet 2>/dev/null; then
      echo ""
      echo "Article health check failed."
      echo "  Details: python3 scripts/tools/article-health.py --staged --profile=pre-commit"
      echo "  Bypass (emergency): git commit --no-verify"
      exit 1
    fi
  fi
fi

# Language registry sync check (.ts and .mjs must match)
staged_any=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)
if echo "$staged_any" | grep -qE 'src/config/languages\.(ts|mjs)$'; then
  if [ -f "scripts/tools/check-language-registry-sync.sh" ]; then
    if ! bash scripts/tools/check-language-registry-sync.sh; then
      echo ""
      echo "languages.ts and languages.mjs are out of sync. Edit both."
      exit 1
    fi
  fi
fi

# Hardcoded language array detector
staged_lang_files=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null \
  | grep -E '\.(ts|tsx|mjs|cjs|js|astro|sh)$' \
  | grep -vE '(node_modules|dist|src/config/languages\.|scripts/tools/check-hardcoded-langs)' \
  || true)
if [ -n "$staged_lang_files" ]; then
  if [ -f "scripts/tools/check-hardcoded-langs.sh" ]; then
    if ! bash scripts/tools/check-hardcoded-langs.sh --staged; then
      echo ""
      echo "Hardcoded language arrays detected. Use LANGUAGES registry instead."
      echo "  Bypass (emergency): git commit --no-verify"
      exit 1
    fi
  fi
fi

# Narrative scope pollution detector (warning only, does not block)
staged_for_scope=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)
if [ -n "$staged_for_scope" ]; then
  domains_touched=""
  while IFS= read -r f; do
    [ -z "$f" ] && continue
    case "$f" in
      knowledge/*)                         d="content-ssot" ;;
      src/content/*)                       d="content-mirror" ;;
      docs/semiont/*)                      d="cognitive" ;;
      docs/pipelines/*|docs/editorial/*|docs/prompts/*|docs/factory/*|docs/community/*|docs/taxonomy/*|docs/design/*|docs/refactor/*) d="pipelines" ;;
      scripts/*|.husky/*)                  d="tooling" ;;
      .github/*)                           d="ci" ;;
      data/*)                              d="data" ;;
      public/api/*|src/data/*.json)        d="build-output" ;;
      public/*)                            d="public" ;;
      src/*|astro.config.mjs|package.json|tsconfig.json) d="code" ;;
      *)                                   d="other" ;;
    esac
    case " $domains_touched " in
      *" $d "*) ;;
      *) domains_touched="$domains_touched $d" ;;
    esac
  done <<< "$staged_for_scope"

  non_auto=$(echo "$domains_touched" | tr ' ' '\n' | grep -v '^$' | grep -v '^build-output$' | sort -u)
  domain_count=$(printf '%s\n' "$non_auto" | grep -c . 2>/dev/null || echo 0)

  if [ "$domain_count" -ge 3 ]; then
    echo ""
    echo "WARNING: This commit spans $domain_count narrative domains:"
    for d in $non_auto; do echo "  - $d"; done
    echo "Consider splitting into separate commits if unintentional."
    echo ""
  fi
fi

# Credential leak detection
if [ -n "$staged_any" ]; then
  cred_fail=0
  for f in $staged_any; do
    [ ! -f "$f" ] && continue
    case "$f" in
      *.png|*.jpg|*.jpeg|*.gif|*.webp|*.pdf|*.zip|*.woff*|*.ttf|*.otf|*.ico|*.mp4|*.mp3) continue ;;
    esac
    if grep -l '"type":[[:space:]]*"service_account"' "$f" > /dev/null 2>&1; then
      echo "CREDENTIAL LEAK: $f looks like a Google service account JSON"
      cred_fail=1
    fi
    if grep -lE 'BEGIN (RSA )?PRIVATE KEY' "$f" > /dev/null 2>&1; then
      echo "CREDENTIAL LEAK: $f contains a private key"
      cred_fail=1
    fi
    if grep -lE 'AIza[0-9A-Za-z_-]{35}' "$f" > /dev/null 2>&1; then
      echo "CREDENTIAL LEAK: $f contains a suspected Google API key (AIza...)"
      cred_fail=1
    fi
    if grep -lE '(CF|CLOUDFLARE)_(API_)?TOKEN[[:space:]]*=[[:space:]]*["'"'"']?[A-Za-z0-9_-]{40,}' "$f" > /dev/null 2>&1; then
      echo "CREDENTIAL LEAK: $f contains a suspected Cloudflare API token"
      cred_fail=1
    fi
    if grep -lE '(sk|pk)_(live|test)_[A-Za-z0-9]{24,}' "$f" > /dev/null 2>&1; then
      echo "CREDENTIAL LEAK: $f contains a suspected sk_/pk_ API key"
      cred_fail=1
    fi
  done
  if [ "$cred_fail" = "1" ]; then
    echo ""
    echo "Credential leak detected. Do not commit secrets."
    echo "  Bypass (false positive): git commit --no-verify"
    exit 1
  fi
fi
