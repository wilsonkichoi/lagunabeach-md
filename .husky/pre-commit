# ═══ translatedFrom 強制檢查（2026-04-14 η 新增）═══
# 規則：所有非 zh-TW 翻譯檔的 frontmatter 必須有 translatedFrom 欄位
# 為什麼：file-level SSOT 比中央 _translations.json 更可靠
#   - 即使 _translations.json 漏條目，文件本身仍知道來源
#   - 重命名原文時可以立即偵測哪些翻譯變孤兒
#   - 不需要查中央表 = self-documentation
staged_translations=$(git diff --cached --name-only --diff-filter=AM | grep -E '^knowledge/(en|ja|ko|es|fr)/.*\.md$' || true)
if [ -n "$staged_translations" ]; then
  tf_fail=0
  for f in $staged_translations; do
    [[ "$(basename "$f")" == _* ]] && continue
    [ ! -f "$f" ] && continue
    # Check frontmatter for translatedFrom
    if ! awk '/^---$/{n++; next} n==1{print} n>=2{exit}' "$f" | grep -q '^translatedFrom:'; then
      echo "❌ $f: 缺 translatedFrom 欄位"
      echo "   範例: translatedFrom: 'Music/原中文檔名.md'"
      tf_fail=1
    fi
  done
  if [ "$tf_fail" = "1" ]; then
    echo ""
    echo "💡 翻譯檔必須在 frontmatter 標明來源中文檔，避免成為孤兒"
    echo "   詳見: docs/community/LANGUAGE-STATUS.md §Orphan prevention"
    echo "   跳過此檢查（緊急修復）: git commit --no-verify"
    exit 1
  fi
fi

# ═══ frontmatter-format auto-fix on staged (2026-05-08 #884 root-cause fix) ═══
# Solves the 5/7 #884 conflict storm: when main runs frontmatter formatter
# bulk repair, all in-flight contributor PRs become CONFLICTING because their
# frontmatter style differs (list-mode tags / category-after-tags / quoted
# dates / etc.).
#
# By auto-fixing staged knowledge/*.md frontmatter at commit time, contributor
# branches stay in canonical format from the start — no future bulk repair
# can produce conflicts because everyone's already in the same shape.
#
# Fixes applied (canonical per REWRITE-PIPELINE Stage 4):
# - Reorder fields per CANONICAL_ORDER (title/desc/date/category/tags/...)
# - Convert list-mode tags `tags:\n  - a` → flow `tags: ['a']`
# - Quote unquoted scalars: `category: Society` → `category: 'Society'`
# - Convert double-quoted to single-quoted (no escapes)
# - Unquote dates and bools that have stray quotes
# - Add missing canonical fields with safe defaults
#
# If fix() actually modifies a file, we re-stage it so the commit reflects
# the canonical version. Contributors see one harmless re-staging step
# instead of fighting bulk repair conflicts later.
staged_md=$(git diff --cached --name-only --diff-filter=ACM | grep '^knowledge/.*\.md$' | grep -vE '^knowledge/(en|ja|ko|es|fr)/' || true)
if [ -n "$staged_md" ]; then
  fix_output=$(python3 scripts/tools/article-health.py --staged --check=frontmatter-format --fix 2>&1)
  fixed_count=$(echo "$fix_output" | grep -oE 'Modified [0-9]+ file' | grep -oE '[0-9]+' | head -1 || echo "0")
  if [ -n "$fixed_count" ] && [ "$fixed_count" != "0" ]; then
    echo "🔧 Auto-fixed frontmatter format on $fixed_count staged file(s); re-staging..."
    echo "$staged_md" | xargs -I {} git add {}
  fi
fi

