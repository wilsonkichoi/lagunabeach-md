{
  "name": "lagunabeach-md",
  "type": "module",
  "version": "0.2.0",
  "description": "AI-native open knowledge base about Laguna Beach, California. Built on Taiwan.md.",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "postinstall": "git config merge.ours.driver true || true && bash scripts/core/sync.sh",
    "lb": "node scripts/lb.mjs",
    "dev": "npm run prebuild:sync && npm run prebuild:gitinfo && astro dev",
    "prebuild": "npm run prebuild:sync && npm run prebuild:status && run-p prebuild:api prebuild:map prebuild:search prebuild:dashboard prebuild:changelog prebuild:contributors prebuild:verify-contributors prebuild:spores prebuild:buildperf prebuild:langswitch prebuild:og prebuild:i18n prebuild:content-dates prebuild:gitinfo prebuild:content-stats prebuild:i18n-progress prebuild:llms prebuild:stats prebuild:related && npm run prebuild:latest",
    "prebuild:sync": "bash scripts/core/sync.sh",
    "prebuild:status": "python3 scripts/tools/lang-sync/status.py && python3 scripts/tools/sync-translations-json.py && python3 scripts/tools/sync-spore-links.py --apply",
    "prebuild:api": "node scripts/core/generate-api.js",
    "prebuild:map": "node scripts/core/generate-map-markers.js",
    "prebuild:search": "node scripts/core/build-search-index.mjs",
    "prebuild:dashboard": "python3 scripts/tools/article-health.py --baseline-out scripts/tools/.quality-baseline.json && python3 scripts/core/generate-dashboard-immune.py && node scripts/core/generate-dashboard-data.js && node scripts/core/generate-dashboard-alerts.mjs",
    "prebuild:changelog": "node scripts/core/generate-changelog-data.js",
    "prebuild:contributors": "node scripts/core/generate-contributors-data.js",
    "prebuild:verify-contributors": "node scripts/tools/verify-contributors.mjs",
    "prebuild:spores": "python3 scripts/tools/generate-spore-records.py && python3 scripts/tools/generate-dashboard-spores.py",
    "prebuild:buildperf": "node scripts/core/extract-build-perf.mjs --runs 30",
    "prebuild:langswitch": "node scripts/core/generate-lang-switch-map.mjs",
    "prebuild:og": "node scripts/core/generate-og-images.mjs",
    "prebuild:i18n": "bash scripts/tools/i18n-coverage-audit.sh --json-out public/api/dashboard-i18n.json",
    "prebuild:content-dates": "node scripts/core/build-content-dates.mjs",
    "prebuild:latest": "node scripts/core/build-latest.mjs",
    "prebuild:content-stats": "node scripts/tools/generate-content-stats.js",
    "prebuild:i18n-progress": "python3 scripts/utils/i18n-status.py >/dev/null",
    "prebuild:llms": "python3 scripts/tools/refresh-llms-txt.py",
    "prebuild:stats": "bash scripts/tools/update-stats.sh",
    "prebuild:related": "node scripts/core/build-related-tagoverlap.mjs",
    "build": "astro build",
    "test": "node scripts/core/test-frontmatter.mjs",
    "test:ci": "node scripts/core/test-frontmatter.mjs --ci",
    "postbuild": "run-s postbuild:smoke postbuild:internal-links",
    "postbuild:smoke": "node scripts/core/post-build-check.mjs",
    "postbuild:internal-links": "bash scripts/tools/verify-internal-links.sh",
    "preview": "astro preview",
    "sync": "bash scripts/core/sync.sh",
    "sync:build": "bash scripts/core/sync.sh && astro build",
    "check-images": "node scripts/utils/check-images.mjs",
    "check-links": "bash scripts/utils/check-links.sh",
    "check-internal-links": "bash scripts/tools/verify-internal-links.sh",
    "article-health": "python3 scripts/tools/article-health.py",
    "image-ingest": "node scripts/tools/image-ingest.mjs",
    "article-health:all": "python3 scripts/tools/article-health.py --all --profile=dashboard --output=json",
    "article-health:test": "python3 -m pytest tests/article_health -q",
    "feedback:triage": "node scripts/feedback/triage.mjs",
    "feedback:test": "node --test scripts/feedback/*.test.mjs",
    "feedback:uxtest": "node tests/feedback/widget.uxtest.mjs",
    "feedback:devtest": "PUBLIC_FEEDBACK_MODE=mock astro dev --port 4330",
    "visual:baseline": "node scripts/visual/capture-baseline.mjs --baseline",
    "visual:capture": "node scripts/visual/capture-baseline.mjs",
    "visual:diff": "node scripts/visual/diff.mjs",
    "visual:check": "node scripts/visual/capture-baseline.mjs && node scripts/visual/diff.mjs",
    "astro": "astro",
    "format::check": "prettier --check .",
    "format::write": "prettier --write .",
    "og:generate": "node scripts/core/generate-og-images.mjs",
    "prepare": "husky",
    "prebuild:gitinfo": "node scripts/core/build-git-info.mjs"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.17",
    "@astrojs/sitemap": "^3.7.1",
    "@supabase/supabase-js": "^2.108.2",
    "@tailwindcss/vite": "^4.2.2",
    "astro": "^6.2.1",
    "gray-matter": "^4.0.3",
    "marked": "^17.0.4",
    "minisearch": "^7.2.0",
    "rehype-external-links": "^3.0.0",
    "remark-wiki-link": "^2.0.1",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "npm-run-all2": "^8.0.4",
    "opencc-js": "^1.0.5",
    "pixelmatch": "^6.0.0",
    "playwright": "^1.59.1",
    "pngjs": "^7.0.0",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "0.14.1",
    "sharp": "^0.34.5"
  },
  "bin": {
    "lb": "./scripts/lb.mjs"
  }
}
